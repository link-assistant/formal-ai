# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# See https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Python virtual environments (for scripts)
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Coverage reports
*.lcov
coverage/
tarpaulin-report.html

# Benchmark results
criterion/

# Documentation build output
doc/

# Local development files
.env
.env.local
*.local
node_modules/

# Log files
*.log
logs/
ci-logs/

# Playwright MCP scratch output (browser cache snapshots, etc.)
.playwright-mcp/

# Web demo seed mirror (generated by scripts/sync-seed.sh from data/seed/)
# The canonical source of truth is data/seed/; the web copy is rebuilt at
# CI / dev-server start time so the browser worker can fetch the same files.
src/web/seed/

# Electron desktop packaging output generated by npm run desktop:build.
desktop/bin/
desktop/dist-web/
desktop/release/

# Semantic-identity HTTP cache populated by FORMAL_AI_LIVE_API=1. These
# directories are a local accelerator only; the committed source of
# truth for offline tests is the raw-API-response seed bundle under
# data/seed/api-cache/*.lino, bundled by examples/refresh_translation_cache.rs.
data/wikidata-cache/
data/wiktionary-cache/
data/http-cache/
