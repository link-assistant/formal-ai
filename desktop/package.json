{
  "name": "formal-ai-desktop",
  "version": "0.153.0",
  "private": true,
  "description": "Cross-platform desktop wrapper for formal-ai",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "prebuild": "node scripts/prepare-resources.mjs",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "smoke": "node scripts/smoke.mjs",
    "test": "node --test scripts/tool-router.test.mjs scripts/memory-sync.test.mjs && node scripts/smoke.mjs"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ai.formal.desktop",
    "productName": "formal-ai Desktop",
    "asar": true,
    "files": [
      "main.cjs",
      "preload.cjs",
      "lib/**",
      "package.json",
      "dist-web/**"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Utility",
      "artifactName": "formal-ai-desktop-linux-${arch}-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "artifactName": "formal-ai-desktop-macos-${arch}-${version}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "formal-ai-desktop-windows-installer-${arch}-${version}.${ext}"
    },
    "portable": {
      "artifactName": "formal-ai-desktop-windows-portable-${arch}-${version}.${ext}"
    }
  }
}
