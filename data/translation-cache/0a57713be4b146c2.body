n|myv=[[ков]]\n|eo=[[luno]]\n|et=[[kuu]]\n|jv=\n|sah=\n|ja=[[月]] ([[つき]], tsuki)\n}}\n\n=== Анаграммы ===\n* [[улан]]\n\n<!-- Служебное: -->\n{{improve|ru|переводы}}\n{{Категория|язык=ru|Луна|Прописная и строчная}}\n{{длина слова|4|ru}}\n\n= {{-bg-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg |слоги={{по-слогам|луна}}|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|size=|lang=bg|}}\n\n==== Значение ====\n# {{помета.|bg}} {{as ru}} {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|источник=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|bg|морфо|транскрипция/мн|пример}}\n\n{{Категория|язык=bg|Луна||}}\n{{длина слова|4|bg}}\n\n= {{-uk-}} =\n{{wikipedia|lang=uk}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk f ina 1d\n|основа=лун\n|основа1=лу́н\n|слоги={{слоги|лу/на́}}\n|show-text=1\n}}\n\n{{морфо|прист1=|корень1=лун|суфф1=|оконч=а}}\n\n=== Произношение ===\n{{transcriptions|luˈna|ˈlunɪ|Uk-луна.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[эхо]]; [[отзвук]], [[отголосок]] {{пример|{{выдел|Луна}} особливо підсилюється, якщо перешкоди, від яких відбивається звук, утворюють резонатор.|перевод={{выдел|Эхо}} особенно усиливается, если препятствия, от которых отражается звук, образуют резонатор.|источник=uk.wikipedia.org}}\n# \n\n==== Синонимы ====\n# [[відлуння]]\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# —\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=відлуння, відлунок, відлунювання\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=лунати, відлунювати, відлунати, відлунити, пролунати\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:луна|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|uk|}}\n{{Категория|язык=uk|Эхо||}}\n{{длина слова|4|uk}}\n\n{{multilang|3}}"}}