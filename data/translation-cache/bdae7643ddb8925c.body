уществительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nИз тюркских языков.\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|udm|транскрипция/мн|пример}}\n{{Категория|язык=udm|Тайны|}}\n{{длина слова|3|udm}}\n\n= {{-rom-}} =\n{{Омонимы|rom|2}}\n\n== {{заголовок|I}} ==\nлатиницей: '''sîr'''\n\nвозможные диалектические варианты: '''sir''' |сир|, '''siir''' |сиир|, '''сар'''\n\n=== Морфологические и синтаксические свойства ===\n{{сущ rom f ina|слоги={{по слогам|сыр}}}}\n\n{{падежи rom ina\n|nom-sg=сыр\n|nom-pl=сырья́\n|acc-sg=сыр\n|acc-pl=сырья́\n|dat-sg=сырья́кэ\n|dat-pl=сырье́нгэ\n|lok-sg=сырья́тыр\n|lok-pl=сырье́ндыр\n|ins-sg=сырья́са\n|ins-pl=сырье́нса\n}}\n\n{{морфо||сыр}}\n\n=== Произношение ===\n{{transcriptions|sɨr|sɨˈrʲjæ}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[чеснок]]; головка чеснока {{пример|Чюв {{выдел|сыр}} адро зуми.|перевод=Положи {{выдел|чеснока}} в суп.}}\n# {{диал.|rom}} светлый цыган, белокурый цыган, белокожий цыган {{пример||перевод=}}\n# {{диал.|rom}} сыщик или полицейский, знающий цыганский язык {{пример||перевод=}}\n\n==== Синонимы ====\n# ?\n# ?\n# ?\n\n==== Антонимы ====\n# —\n# ?\n# ?\n\n==== Гиперонимы ====\n# ?\n# ?\n# ?\n\n==== Гипонимы ====\n# —\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=сырори\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|rom}}\n\n<!-- Служебное: -->\n{{improve|rom|примеры|этимология}}\n{{Категория|язык=rom|Луковые|Полицейские|}}\n{{Категория|язык=rom|Чеснок}}\n\n== {{заголовок|II}} ==\nвозможные диалектические варианты: '''sar''' |сар|, '''har''' |хар|, '''hir''' |хир|, '''sir''' |сир|\n\n=== Морфологические и синтаксические свойства ===\n{{conj rom|}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|sɨr}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[как]] {{пример||перевод=}}\n# [[если]] {{пример||перевод=}}\n\n==== Синонимы ====\n# —\n# —\n\n==== Антонимы ====\n# —\n# —\n\n==== Гиперонимы ====\n# —\n# —\n\n==== Гипонимы ====\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|rom}}\n\n<!-- Служебное: -->\n{{improve|rom|морфо|пример|этимология}}\n{{Категория|язык=rom|||}}\n{{длина слова|3|rom}}\n\n= {{-cv-}} =\n{{Омонимы|cv|2}}\n\n== {{з|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ cv\n|основа=сыр\n|слоги={{по-слогам|сыр}}\n}}\n\n{{морфо|корень1=сыр}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{кулин.|cv}} [[сыр#Русский|сыр]] {{пример||перевод=}}\n# {{адъектив.|cv}} [[сырный]] {{пример||перевод=}}\n\n==== Синонимы ====\n# [[чăкăт]]\n# ?\n\n==== Антонимы ====\n# —\n# —\n\n==== Гиперонимы ====\n# ?\n# ?\n\n==== Гипонимы ====\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nИз {{сэ|ru|сыр|и=cv}}.\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|cv|транскрипция/мн|пример}}\n{{Категория|язык=cv|Сыр|Кисломолочные продукты|}}\n\n== {{з|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{гл cv\n|основа=сыр\n|слоги={{по-слогам|сыр}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[окружать]], [[обступать]], [[облеплять]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# [[покрывать]], [[затягивать]], [[заволакивать]]; [[охватывать]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# [[роиться]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# [[обувать]], [[обуваться]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# [[повязывать]], [[повязываться]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# [[надевать]] (''на ноги'') {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n# {{диал.|cv}} [[нанизывать]] {{семантика|2|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример||перевод=}}\n\n{{списки семантических связей|2}}\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|cv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|cv|морфо|транскрипция|пример|синонимы|гиперонимы|этимология}}\n{{Категория|язык=cv|Глаголы одевания||}}\n{{длина слова|3|cv}}\n\n= {{-sah-}} =\n{{Омонимы|sah|3}}\n\n== {{з|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sah\n|основа=сыр\n|слоги={{по-слогам|сыр}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# -\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|sah}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* сыр II // {{книга |заглавие = Якутско-русский словарь. 25 300 слов\n |ссылка = https://sakhatyla.ru/translate?q=сыр\n |место = М. |год = 1972 }}\n\n{{improve|sah|морфо|транскрипция/мн|пример|этимология}}\n{{Категория|язык=sah|Сыр||}}\n\n== {{з|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{onomatop sah\n|основа=сыр\n|слоги={{по-слогам|сыр}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# [[однократный]] [[лёгкий]] [[треск]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|причастия=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|sah}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n* \n\n=== Библиография ===\n* сыр I // {{книга |заглавие = Якутско-русский словарь. 25 300 слов\n |ссылка = https://sakhatyla.ru/translate?q=сыр\n |место = М. |год = 1972 }}\n\n{{improve|sah|морфо|транскрипция|пример|этимология}}\n{{Категория|язык=sah|Звуки||}}\n\n== {{з|III}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{part sah\n|основа=сыр\n|слоги={{по-слогам|сыр}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{помета|часть сочетания}} {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|ун