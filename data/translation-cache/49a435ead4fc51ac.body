\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|ms=<!-- Малайский -->\n|mr=<!-- Маратхи -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|de=<!-- Немецкий -->\n|nl=<!-- Нидерландский -->\n|no=<!-- Норвежский -->\n|pa=<!-- Панджаби -->\n|fa=<!-- Персидский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|ro=<!-- Румынский -->\n|sa=<!-- Санскрит -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|cu-Cyrl=<!-- Старославянский (кир) -->\n|cu-Glag=<!-- Старославянский (лат) -->\n|ta=<!-- Тамильский -->\n|tl=<!-- Тагальский -->\n|th=<!-- Тайский -->\n|tt=<!-- Татарский -->\n|te=<!-- Телугу -->\n|art=<!-- Токипона -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украинский -->\n|ur=<!-- Урду -->\n|fi=<!-- Финский -->\n|fr=<!-- Французский -->\n|hi=<!-- Хинди -->\n|hr=<!-- Хорватский -->\n|cv=<!-- Чувашский -->\n|cs=<!-- Чешский -->\n|sv=<!-- Шведский -->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|ja=<!--Японский-->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n=== Метаграммы ===\n* [[утица]], [[чтица]]\n* [[плица]]\n\n=== Библиография ===\n* * {{книга\n |ответственный  = ред. А. Н. Тихонов\n |заглавие       = Фразеологический словарь современного русского литературного языка\n |место          = М.\n |издательство   = Флинта, Наука\n |год            = 2004\n |страниц        = 832\n |серия          = \n |isbn           = 5-89349-691-4\n}}\n\n<!-- Служебное: -->\n{{improve|ru|переводы}}\n\n{{Категория|язык=ru|Птицы|}}\n{{длина слова|5|ru}}\n\n= {{-bg-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg f 41|птиц|слоги={{по-слогам|пти|ца}}}}\n\n=== Произношение ===\n{{transcription|pti.ʦə}}\n\n=== Семантические свойства ===\n{{илл|HouseSparrow23.jpg|Птица [1]}}\n\n==== Значение ====\n# [[птица]] (аналогично русск. слову в знач. [1.]) {{пример|И когато сееше, едно падна край пътя, и дойдоха {{выдел|птиците}} небесни и озобаха го.||Цариградска Библия|1871|ч=Евангелие от Марка 4:4|||перевод=и, когда сеял, случилось, что иное упало при дороге, и налетели {{выдел|птицы}} и поклевали то.}}\n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n\n==== Гиперонимы ====\n# \n\n==== Гипонимы ====\n# \n\n=== Родственные слова ===\n{{родств-блок\n|имена-собственные=\n|существительные=птичка\n|прилагательные=птичи\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:птица|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|морфо|пример|синонимы|гиперонимы}}\n{{Категория|язык=bg|Птицы|}}\n{{длина слова|5|bg}}\n\n= {{-mk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ mk f|слоги={{по-слогам|пти|ца}}|птиц|}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|Blue Tit aka.jpg|Птица [1]}}\n\n==== Значение ====\n# птица (аналог. русск. птица [1.]) {{пример||перевод=}}\n# птица (аналог. русск. птица [3.]) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:птица|mk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|mk|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=mk|Птицы|}}\n{{длина слова|5|mk}}\n\n= {{-sr-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr f|птиц|слоги={{по-слогам|пти|ца}}}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n{{илл|Passer domesticus3.jpg|Птица [1]}}\n\n==== Значение ====\n# [[птица]] (аналогично русск. слову в знач. [1.]) {{пример||перевод=}}\n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n\n==== Гиперонимы ====\n# \n\n==== Гипонимы ====\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:птица|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|sr|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=sr|Птицы|}}\n{{длина слова|5|sr}}\n{{multilang|4}}\n= {{-chu-ru-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ chu-ru |слоги={{по-слогам|птица}}|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|size=|lang=chu-ru|}}\n\n==== Значение ====\n# {{помета.|chu-ru}} [[птица]] {{пример|lang=chu-ru|и҆ бы́сть є҆гда̀ сѣ́ѧше, ѻ҆́во падѐ при пꙋтѝ, и҆ прїидо́ша {{выдел|пти̑цы}}, и҆ позоба́ша є҆̀:|перевод=и, когда сеял, случилось, что иное упало при дороге, и налетели {{выдел|птицы}} и поклевали то.||Елизаветинская Библия|часть={{Cyrs|Ѿ ма́рка ст҃о́е бл҃говѣствова́нїе д҃:д҃}}||дата издания=1751}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|chu-ru}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|chu-ru|морфо|транскрипция|синонимы|гиперонимы|этимология}}\n\n{{Категория|язык=chu-ru|||}}\n{{длина слова|5|lang=chu-ru}}"}}