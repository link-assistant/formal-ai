n|tyv=[[шай]]\n|tr=[[çay]]\n|tk=[[çaý]]\n|udm={{с|udm|чай}}\n|ug=[[chay]] ({{с|ug|чай}}, [[چاي]])\n|uz=[[choy]]\n|uk={{t|uk|чай|m}}; {{помета|зап.|западноукраинское}} {{t|uk|гербата|alt=герба́та|f}}\n|ur=[[چائے]] (čāʾe)\n|fo=[[te]]\n|fi=[[tee]]\n|fr=[[thé]]\n|fy=[[tee]]\n|fur=[[tè]]\n|kjh={{с|kjh|чай}}; [[чей]]\n|ha=[[shayi]]\n|hi=[[चा]] (čā); [[चाय]] (čāy)\n|hr=[[čaj]] {{m}}\n|rom=[[драб]]\n|ch=[[cha]]\n|ce={{с|ce|чай}}\n|cs=[[čaj]]\n|cv=[[чей]]\n|sv=[[te]]\n|xsr=[[च्य]] (čya)\n|sn=[[tii]]\n|cjs=[[шай]]\n|sco=[[tea]]\n|ewe=\n|evn={{с|evn|чай}}\n|eve={{с|eve|чай}}\n|myv={{с|myv|чай}}\n|eo=[[teo]]\n|et=[[tee]]\n|jv=[[tèh]]\n|sah=[[чэй]]\n|ja=[[茶]] ([[ちゃ]]; cha)\n}}\n\n{{перев-блок|высушенный ''и'' измельчённый чайный лист, предназначенный для приготовления {{выдел|чая}} [2]\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en=<!-- Английский-->\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=<!-- Армянский -->\n|ba=<!-- Башкирский -->\n|be=<!-- Белорусский -->\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийский -->\n|br=<!-- Бретонский -->\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|da=<!-- Датский -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=<!-- Немецкий -->\n|no=<!-- Норвежский -->\n|nl=<!-- Нидерландский -->\n|os=<!-- Осетинский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украинский -->\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский -->\n|fr=<!-- Французский -->\n|hr=<!-- Хорватский -->\n|cs=<!-- Чешский -->\n|sv=<!-- Шведский -->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|ja=<!--Японский-->\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n{{перев-блок|любой растительный настой ''или'' отвар, употребляемый в питьё\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en=<!-- Английский-->\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=<!-- Армянский -->\n|ba=<!-- Башкирский -->\n|be=<!-- Белорусский -->\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийский -->\n|br=<!-- Бретонский -->\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|da=<!-- Датский -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=<!-- Немецкий -->\n|no=<!-- Норвежский -->\n|nl=<!-- Нидерландский -->\n|os=<!-- Осетинский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украинский -->\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский -->\n|fr=<!-- Французский -->\n|hr=<!-- Хорватский -->\n|cs=<!-- Чешский -->\n|sv=<!-- Шведский -->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|ja=<!--Японский-->\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n{{перев-блок|чаепитие\n|ain=\n|sq=\n|en=[[tea]]; [[tea party]], [[five o'clock tea]]\n|hy=\n|ast=\n|af=\n|ba=\n|be={{с|be|чай}}\n|bg={{с|bg|чай}}\n|bs=\n|br=\n|hu=\n|vep=\n|vi=\n|vro=\n|gl=\n|el=[[τεϊοποσία]]; [[τσάι]] {{n}}, [[τέιο|τέιο(ν)]] {{n}}\n|ka=\n|da=\n|io=\n|ia=\n|is=\n|es=\n|it=\n|kk=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|la=\n|lv=\n|lt=\n|mk=\n|mdf=\n|mn=\n|gv=\n|nah=\n|de=\n|nl=\n|no=\n|os=\n|pl=\n|ppol=\n|pt=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|uz=\n|uk=чай\n|fo=\n|fi=\n|fr=\n|hr=\n|cs=\n|sv=[[te]], [[tebjudning]], [[kvällste]], [[teceremoni]]\n|eo=\n|et=\n|ja=\n}}\n\n=== Библиография ===\n* {{Книга:Мельчук|Богданова Е. Ю., Жолковский А. К., Мельчук И. А., Никитина С. Е.|Чай|943–951}}\n* \n\n{{improve|ru|семантика|переводы}}\n\n{{Категория|язык=ru|Чай|Чайные||}}\n\n== {{з|(вводное слово)}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{intro ru|чай|слоги={{по-слогам|чай}}}}\n\n{{слобр|ru|-|и=т3}}\n\n{{морфо-ru|чай|и=т}}\n\n=== Произношение ===\n{{transcription-ru|чай}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{нар.-разг.|ru}} {{помета|выражает вероятность, допущение}}: [[по-видимому]], [[вероятно]] {{пример|Жена, {{выдел|чай}}, теперь с голоду в кулак свистит.|Тургенев|[[:s:Малиновая вода (Тургенев)|Малиновая вода]]|1847}} {{пример|{{выдел|Чай}}, не ждал гостей?|Чехов|[[:s:Последняя могиканша (Чехов)|Последняя могиканша]]|1885}}\n# {{нар.-разг.|ru}} {{помета|используется в качестве усилительной частицы}}: [[ведь]], [[всё-таки]] {{пример|Я {{выдел|чай}}, не нашёл чем пожаловать князь Никиту Романыча!|А. К. Толстой|[[:s:Князь Серебряный (А. К. Толстой)/Глава 19|Князь Серебряный]]|1861}}\n# \n\n==== Синонимы ====\n# [[по-видимому]], [[вероятно]], [[небось]], [[никак]], [[авось]]\n# [[ведь]], [[всё-таки]]\n\n==== Антонимы ====\n# ?\n# ?\n\n==== Гиперонимы ====\n# —\n# —\n\n==== Гипонимы ====\n# —\n# —\n\n=== Этимология ===\nПроисходит от выражения «я чаю», от 1-го лица ед. числа гл. [[чаять]], причём первоначально говорили также «я чай» {{пример|Ведь, {{выдел|я чаю}}, скоро и учители придут.|Фонвизин}} {{пример|Сказала что-то вскользь, а ты, {{выдел|я чай}}, надеждами вознесся.|Грибоедов}} {{пример|{{--}}А вы всё учитесь? Вы уж и так, {{выдел|я чай}}, всё знаете.|Тургенев}}, далее от {{этимология:чаять|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n==== Пословицы и поговорки ====\n{{table-top|ffffff}}\n\n* [[врал много, а чай, больше того осталось]]\n* \n\n{{table-bot}}\n\n=== Перевод ===\n{{перев-блок|\n|de=[[wohl]]\n}}\n\n=== Библиография ===\n* \n\n{{improve|ru|переводы}}\n\n{{Категория|язык=ru|||}}\n\n== {{з|(глагол)}} ==\n{{Форма-гл|чаять|||2|1|п|язык=ru|слоги={{по-слогам|чай}}|МФА={{t-ru|чай}}}} {{пример|}}\n\n{{improve|ru|пример}}\n\n{{длина слова|3|ru}}\n\n= {{-be-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ be m ina|слоги={{по-слогам|чай}}|}}\n\n{{морфо||чай}}\n\n=== Произношение ===\n{{transcriptions|ʈ͡ʂaɪ̯|}}\n\n=== Семантические свойства ===\n{{илл|Tea plants.jpg|Чай [1]}}\n{{илл|Must tee suurelt.jpg|Чай [2]}}\n{{илл|Cup of Earl Gray.jpg|Чай [3]}}\n\n==== Значение ====\n# {{ботан.|be}} {{as ru}} [1] {{пример||перевод=}}\n# {{as ru}} [2] {{пример||перевод=}}\n# {{as ru}} [3] {{пример||перевод=}}\n# [[чаепитие]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:чай|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|be|пример|синонимы|гиперонимы}}\n{{Категория|язык=be|||}}\n{{длина слова|3|be}}\n\n= {{-bg-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg m 28|ча|слоги={{по-слогам|чай}}}}\n\n{{морфо||чай}}\n\n=== Произношение ===\n{{transcription|tʃai}}\n\n=== Семантические свойства ===\n{{илл|Tea plants.jpg|Чай [1]}}\n{{илл|Must tee suurelt.jpg|Чай [2]}}\n{{илл|Cup of Earl Gray.jpg|Чай [3]}}\n\n==== Значение ====\n# {{ботан.|bg}} {{as ru}} [1] {{пример||перевод=}}\n# {{as ru}} [2] {{пример||перевод=}}\n# {{as ru}} [3] {{пример|липов чай|перевод=липовый чай}} {{пример|попарвам чай|перевод=заваривать чай}} {{пример|силен чай|перевод=крепкий чай}}\n# [[чаепитие]] {{пример|Каня на {{выдел|чай}}.|перевод=Пригласить на чай.}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:чай|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|примеры|синонимы|гиперонимы}}\n{{Категория|язык=bg|Чай|Чайные|}}\n{{длина слова|3|bg}}\n= {{-jct-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ jct\n|основа=\n|слоги={{по-слогам|чай}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[река]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|причастия=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|kdr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{unfinished|jct|s=1|p=1|e=1|m=1}}\n{{Категория|язык=jct|||}}\n{{длина слова|3|jct}}\n\n= {{-kim-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ kim\n|основа=чай\n|слоги={{по-слогам|чай}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[лето]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# [[ӄыъш]]\n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|kim}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* {{книга|автор = Рассадин В. И.|часть = |заглавие =Словарь тофаларско-русский и русско-тофаларский: Учеб. пособие для уч-ся ср. шк.|оригинал = |ссылка = |ответственный = |издание = |место = СПб. |издательство = «Издательство „Дрофа“ Санкт-Петербург»| год = 2005|том = |страницы = 111|страниц = 295 |isbn = 5-94745-111-5}}\n\n<!-- Служебное: -->\n{{improve|kim|морфо|транскрипция/мн|пример|синонимы|гиперонимы|этимология}}\n{{Категория|язык=kim|Лето||}}\n{{длина слова|3|kim}}\n\n= {{-tyv-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ tyv |слоги={{по-слогам|чай}}|}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[лето]] {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# [[кыш]]\n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=чайлаг\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:|tyv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|tyv|морфо|транскрипция/мн|пример|синонимы|гиперонимы|этимология}}\n{{Категория|язык=tyv|Лето|}}\n{{длина слова|3|tyv}}\n\n= {{-uk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk m ina 6c|слоги={{по-слогам|чай}}|соотв=ча|ча́|ча}}\n\n{{морфо||чай}}\n\n=== Произношение ===\n{{transcriptions||}} {{медиа|Uk-чай.ogg}}\n\n=== Семантические свойства ===\n{{илл|Tea plants.jpg|Чай [1]}}\n{{илл|Must tee suurelt.jpg|Чай [2]}}\n{{илл|Cup of Earl Gray.jpg|Чай [3]}}\n\n==== Значение ====\n# {{ботан.|uk}} {{as ru}} [1] {{пример|Збирати {{выдел|чай}}.|перевод=Собирать {{выдел|чай}}.}} {{пример|Вирощувати {{выдел|чай}}.|перевод=Выращивать {{выдел|чай}}.}}\n# {{as ru}} [2] {{пример|У зеленому {{выдел|чаї}} багато вітамінів.|перевод=В зелёном {{выдел|чае}} много витаминов.}}\n# {{as ru}} [3] {{пример|{{выдел|Чай}} зі свіжих листків м’яти заспокіює нерви.|перевод={{выдел|Чай}} из свежих листьев мяты успокаивает нервы.}} {{пример|Вранці ми любимо пити міцний {{выдел|чай}} або каву.|перевод=По утрам мы любим пить крепкий {{выдел|чай}} или кофе.}}\n# [[чаепитие]] {{пример|Запрошуємо вас на {{выдел|чай}}.|перевод=Приглашаем вас на {{выдел|чай}}.}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# [[рослина]]\n# [[продукт]]\n# [[напій]]\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=чайок\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=чайник, чайниця, чайничок, чаювання\n|прилагательные=чайний, чайниковий\n|числительные=\n|местоимения=\n|глаголы=чаювати\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:чай|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|uk|транскрипция/мн|синонимы|гиперонимы}}\n{{Категория|язык=uk|||}}\n{{длина слова|3|uk}}\n= {{-ce-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ce |слоги=|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=ce|}}\n\n==== Значение ====\n# {{помета.|ce}} [[чай]] {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|источник=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=чайлелор, чайлелорхо\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|ce}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|ce|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n\n{{Категория|язык=ce|||}}\n{{длина слова|3|ce}}\n= {{-ckt-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ckt |слоги={{по-слогам|}}|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=ckt|}}\n==== Значение ====\n# {{помета.|ckt}} [[чай]] {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|источник=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|ckt}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|ckt|морфо|транскрипция|синонимы|гиперонимы|этимо