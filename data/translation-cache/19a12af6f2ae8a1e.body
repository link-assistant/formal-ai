{"parse":{"title":"кафедра","pageid":174176,"redirects":[],"wikitext":"{{w}}\n\n= {{-ru-}} =\n{{Лексема в Викиданных|L115717}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|ка́федра|ж 1a\n|слоги={{по-слогам|ка́|фед|ра}}\n|дореф=ка́ѳе́дра\n}}\n\n{{тж|тип=s|стиль={{помета|устар.|устаревший}}|формы=кафе́дра}}\n\n{{слобр|ru|-|и=}}\n\n{{морфо-ru|кафедр|+а|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|ка́федра|ка́федры|Ru-кафедра.ogg}}\n\n=== Семантические свойства ===\n{{илл|size=260px|lang=ru|Michael Drewett 03.jpg|Выступление с {{выдел|кафедры}} [1]}}\n\n==== Значение ====\n# специально оборудованное [[возвышение]], с которого читаются лекции, делаются доклады и иные выступления перед аудиторией {{пример|Но я молю тебя, поклонник верный твой, // Будь мне вожатаем. Дерзаю за тобой // Занять кафе́дру ту, с которой в прежни лета // Ты слишком превознёс достоинства сонета…|Пушкин|[[w:Французских рифмачей суровый судия (Пушкин)|Французских рифмачей суровый судия…]]|1833|и=Викитека}} {{пример|Потом он широко расставил локти на {{выдел|кафедре}}, подпёр подбородок ладонями и, запустив ногти в рот, начал нараспев и сквозь зубы:{{--}}Ну-с, орлы заморские… ученички развращённые… Что вы знаете?|А. И. Куприн|На переломе|ч=(«Кадеты»)|1900|и=НКРЯ}} {{пример|И не знает, что ночь, дрожа по всей обшивке // Лесов, озёр, церковных приходов и школ, // Вот-вот срежется, спрягая в разбивку // С {{выдел|кафе́дры}} на ветер брошенный глагол…|Пастернак|Артиллерист стоит у кормила…|1914|и=НКРЯ}}\n# ''в высших учебных заведениях'': [[объединение]] преподавателей учебных дисциплин, относящихся к какой-либо одной отрасли науки, а также должность лица, возглавляющего это объединение {{пример|В Национальном исследовательском ядерном университете будет открыта {{выдел|кафедра}} теологии, возглавит которую митрополит Волоколамский Иларион.}} {{пример|После сессии ВАСХНИЛ Лысенко и его сторонники громят генетику, крупнейших ученых-биологов, которые не желают отрекаться от генетики, лишают лабораторий, {{выдел|кафедр}}, а в это время Зубр в своем никому не ведомом заповеднике преспокойно продолжает генетические работы на дрозофилах.|Даниил Гранин|Зубр|1987|и=НКРЯ}}\n# {{религ.|ru}} [[возвышение]] с [[кресло]]м для [[епископ]]а в христианском [[собор]]е {{пример|}}\n# {{религ.|ru}} [[должность]] епископа, управляющего епархией {{пример|}}\n#\n\n==== Синонимы ====\n# \n# \n# \n# \n\n==== Антонимы ====\n# \n# \n# \n# \n\n==== Гиперонимы ====\n# \n# \n# \n# \n\n==== Гипонимы ====\n# \n# \n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=кафедральный\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\n{{дат|17|ru|ЭСлРЯ}}\nОт {{этимология:кафедра|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|возвышение, с которого читаются лекции, делаются доклады\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ady=<!-- Адыгейский-->\n|az={{t|az|kafedra}}, {{t|az|kürsü}}\n|sq={{t|sq|katedër|f}}\n|am=<!-- Амхарский-->\n|en={{t|en|rostrum}}, {{t|en|podium}}, {{t|en|lectern}}\n|ar={{t|ar|منبر|tr=minbar|m}}, {{t|ar|منصة|tr=minaṣṣa|f}}\n|an=<!-- Арагонский-->\n|ast=<!-- Астурийский-->\n|hy={{t|hy|ամբիոն|tr=ambion}}, {{t|hy|կաֆեդրա|tr=kafedra}}\n|af={{t|af|kateder}}, {{t|af|lesenaar}}\n|eu={{t|eu|katedra}}\n|ba=<!-- Башкирский -->\n|be={{t|be|кафедра|f}}, {{t|be|трыбуна|f}}\n|bn=<!-- Бенгали -->\n|my=<!-- Бирманский-->\n|bg={{t|bg|катедра|f}}\n|bs={{t|bs|katedra|f}}\n|br=<!-- Бретонский-->\n|cy={{t|cy|cadair|f}}, {{t|cy|darllenfa|f}}\n|wa=<!-- Валлонский -->\n|hu={{t|hu|katedra}}, {{t|hu|emelvény}}\n|hsb=<!-- Верхнелужицкий -->\n|vi={{t|vi|bục giảng}}, {{t|vi|toà giảng}}\n|haw=<!-- Гавайский-->\n|ht=<!-- Гаитянский-->\n|gl={{t|gl|cátedra|f}}, {{t|gl|púlpito|m}}\n|kl=<!-- Гренландский-->\n|el={{t|el|έδρα|tr=édra|f}}, {{t|el|βήμα|tr=víma|n}}\n|ka={{t|ka|კათედრა|tr=ḳatedra}}, {{t|ka|ამბიონი|tr=ambioni}}\n|gu=<!-- Гуджарати -->\n|gd=<!-- Гэльский-->\n|da={{t|da|kateder|n}}, {{t|da|talerstol|c}}\n|dv=<!-- Дивехи-->\n|grc=<!-- Древнегреческий-->\n|zu=<!-- Зулу-->\n|he={{t|he|בימה|tr=bimá|f}}, {{t|he|דוכן|tr=dokhán|m}}\n|yi=<!-- Идиш -->\n|io=<!-- Идо -->\n|inh=<!-- Ингушский-->\n|id={{t|id|mimbar}}, {{t|id|podium}}\n|ia=<!-- Интерлингва -->\n|ga={{t|ga|catóir|f}}, {{t|ga|léachtán|m}}\n|is={{t|is|ræðustóll|m}}, {{t|is|kennarapallur|m}}\n|es={{t|es|cátedra|f}}, {{t|es|púlpito|m}}, {{t|es|podio|m}}\n|it={{t|it|cattedra|f}}, {{t|it|podio|m}}\n|yo=<!-- Йоруба-->\n|kk={{t|kk|кафедра}}, {{t|kk|мұнбер}}\n|xal=<!-- Калмыцкий-->\n|kn=<!-- Каннада-->\n|ca={{t|ca|càtedra|f}}, {{t|ca|farcistol|m}}\n|ky={{t|ky|кафедра}}, {{t|ky|трибуна}}\n|zh=<!-- Китайский (общ.) -->\n|zh-tw={{t|zh|講臺|tr=jiǎngtái}}, {{t|zh|講壇|tr=jiǎngtán}}\n|zh-cn={{t|zh|讲台|tr=jiǎngtái}}, {{t|zh|讲坛|tr=jiǎngtán}}\n|ko={{t|ko|교탁|tr=gyotak}}, {{t|ko|연단|tr=yeondan}}\n|xh=<!-- Коса-->\n|ku=<!-- Курдский (курманджи)-->\n|ckb=<!-- Курдский (сорани)-->\n|km=<!-- Кхмерский -->\n|lo=<!-- Лаосский-->\n|la=<!-- Латинский-->\n|lv={{t|lv|katedra|f}}\n|lez=<!-- Лезгинский-->\n|ln=<!-- Лингала-->\n|lt={{t|lt|katedra|f}}\n|lb=<!-- Люксембургский -->\n|mk={{t|mk|катедра|f}}\n|mg=<!-- Малагасийский-->\n|ms=<!-- Малайский -->\n|ml=<!-- Малаялам -->\n|mt=<!-- Мальтийский -->\n|mi=<!-- Маори-->\n|mr=<!-- Маратхи -->\n|mn={{t|mn|индэр}}, {{t|mn|лекцийн суудал}}\n|gv=<!-- Мэнский-->\n|nv=<!-- Навахо-->\n|de={{t|de|Katheder|n}}, {{t|de|Pult|n}}\n|ne=<!-- Непальский-->\n|nl={{t|nl|katheder|m}}, {{t|nl|spreekgestoelte|n}}\n|dsb=<!-- Нижнелужицкий-->\n|no={{t|no|kateter|n}}, {{t|no|talerstol|m}}\n|oc=<!-- Окситанский-->\n|or=<!-- Ория-->\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби -->\n|fa={{t|fa|کرسی|tr=korsi}}, {{t|fa|منبر|tr=membar}}\n|pl={{t|pl|katedra|f}}\n|pt={{t|pt|cátedra|f}}, {{t|pt|púlpito|m}}\n|ps=<!-- Пушту-->\n|ro={{t|ro|catedră|f}}\n|sa=<!-- Санскрит -->\n|ceb=<!-- Себуано-->\n|sr={{t|sr|катедра|f}}\n|sr-l={{t|sr|katedra|f}}\n|si=<!-- Сингальский-->\n|sk={{t|sk|katedra|f}}\n|sl={{t|sl|kateder|m}}\n|sw=<!-- Суахили -->\n|ta=<!-- Тамильский -->\n|tl=<!-- Тагальский -->\n|tg={{t|tg|кафедра}}, {{t|tg|минбар}}\n|th={{t|th|แท่นบรรยาย|tr|tɛ̂n ban-yaai}}\n|tt={{t|tt|кафедра}}, {{t|tt|мөнбәр}}\n|te=<!-- Телугу -->\n|bo=<!-- Тибетский-->\n|tr={{t|tr|kürsü}}\n|tk=<!-- Туркменский -->\n|uz={{t|uz|kafedra}}, {{t|uz|minbar}}\n|ug=<!-- Уйгурский-->\n|uk={{t|uk|кафедра|f}}\n|ur=<!-- Урду -->\n|fo=<!-- Фарерский -->\n|fi={{t|fi|luentokoroke}}, {{t|fi|kateederi}}\n|fr={{t|fr|chaire|f}}, {{t|fr|tribune|f}}\n|ha=<!-- Хауса-->\n|hi={{t|hi|मंच|tr|mañc|m}}, {{t|hi|व्याख्यान पीठ|tr|vyākhyān pīṭh|m}}\n|hr={{t|hr|katedra|f}}\n|chr=<!-- Чероки-->\n|ce=<!-- Чеченский -->\n|cv=<!-- Чувашский -->\n|cs={{t|cs|katedra|f}}\n|sv={{t|sv|kateder|c}}, {{t|sv|talarstol|c}}\n|eo={{t|eo|katedro}}, {{t|eo|podio}}\n|et={{t|et|kateeder}}, {{t|et|kõnepult}}\n|jv=<!-- Яванский-->\n|sah=<!-- Якутский-->\n|ja={{t|ja|講壇|tr=こうだん, kōdan}}, {{t|ja|教壇|tr=きょうだん, kyōdan}}\n}}\n{{перев-блок|объединение преподавателей в учебном заведении\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ady=<!-- Адыгейский-->\n|az={{t|az|kafedra}}\n|sq=<!-- Албанский-->\n|am=<!-- Амхарский-->\n|en={{t|en|department}}, {{t|en|chair}}, {{t|en|faculty}}\n|ar={{t|ar|قسم|tr=qism|m}}, {{t|ar|شعبة|tr=šuʕba|f}}\n|an=<!-- Арагонский-->\n|ast=<!-- Астурийский-->\n|hy={{t|hy|ամբիոն|tr=ambion}}, {{t|hy|կաֆեդրա|tr=kafedra}}\n|af={{t|af|departement}}\n|eu={{t|eu|sail}}, {{t|eu|departamentu}}\n|ba=<!-- Башкирский -->\n|be={{t|be|кафедра|f}}\n|bn=<!-- Бенгали -->\n|my=<!-- Бирманский-->\n|bg={{t|bg|катедра|f}}\n|bs=<!-- Боснийский -->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский -->\n|wa=<!-- Валлонский -->\n|hu={{t|hu|tanszék}}\n|hsb=<!-- Верхнелужицкий -->\n|vi={{t|vi|bộ môn}}, {{t|vi|khoa}}\n|haw=<!-- Гавайский-->\n|ht=<!-- Гаитянский-->\n|gl={{t|gl|departamento|m}}, {{t|gl|cátedra|f}}\n|kl=<!-- Гренландский-->\n|el={{t|el|έδρα|tr=édra|f}}, {{t|el|τμήμα|t