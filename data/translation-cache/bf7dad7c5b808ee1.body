ский-->\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n<!-- Служебное: -->\n{{improve|ru|семантика|переводы}}\n{{Категория|язык=ru|Лук|Части тела|Часы|Покрытия}}\n{{длина слова|8|ru}}"}}