[[בצל]] {{m}} (batzal)\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=[[oinniún]] {{m}}\n|is=\n|es=[[cebolla]]\n|it=[[cipolla]] {{f}}\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co=\n|xh=\n|crh=\n|ku=[[pîvaz]] {{f}}\n|km=\n|lad=\n|lo=\n|la=\n|lv=\n|lez=\n|li=\n|ln=\n|lt=\n|lmo=\n|lb=\n|mk=[[главица]] {{f}}\n|mg=\n|ms=\n|ml=\n|mt=[[basla]] {{f}}\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=[[tł'oh chin]]\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|new=\n|de=[[Zwiebel]] {{f}}\n|yrk=\n|nl=\n|dsb=\n|no=[[løk]] {{m}}\n|nn=[[lauk]] {{m}}\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=[[cebola]]\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=[[ceapă]]\n|rue=\n|ru-old=\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|si=\n|sd=\n|sk=\n|sl=[[čebulica]] {{f}}\n|slovio-c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=[[kitunguu]]\n|tab=\n|tl=[[sibuyas]]\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|bo=\n|art=\n|tpi=[[anian]]\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=[[луковиця]] {{f}}, [[цибулина]] {{f}}\n|ur=\n|fo=\n|fi=[[sipuli]]\n|fr=[[oignon]] {{m}}\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=[[luk]] {{m}}\n|rom=\n|chr=\n|ce=\n|cs=\n|cv=\n|sv={{t|sv|lök|c}}\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo={{t|eo|cepo}}, {{t|eo|bulbo}}\n|et=[[sibul]]\n|ext=\n|jv=\n|sah=\n|ja=\n}}\n\n{{перев-блок|зелёный лук\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=göy soğan\n|ay=\n|sq=\n|als=\n|ale=\n|alt=\n|am=\n|en=[[green onion]]\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|my=\n|bg=\n|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\n|haw=\n|ht=\n|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=[[шиниша жерши]]\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|orv=\n|sgs=\n|zza=\n|zu=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co=\n|xh=\n|crh=\n|ku=\n|km=\n|lad=\n|lo=\n|la=\n|lv=[[loki]]\n|lez=\n|li=\n|ln=\n|lt=\n|lmo=\n|lb=\n|mk=\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|new=\n|de=[[Zwiebel]] {{f}}\n|yrk=\n|nl=\n|dsb=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=\n|rue=\n|ru-old=\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|si=\n|sd=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|bo=\n|art=\n|tpi=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=[[mladi luk]] {{m}}, [[zeleni luk]] {{m}}\n|rom=\n|ce=\n|cs=\n|cv=\n|sv=\n|cjs=\n|sco=\n|myv=\n|eo=\n|et=\n|ext=\n|jv=\n|sah=\n|ja=\n}}\n{{перев-блок|гусиный лук\n|en=\n|de=\n|fr=\n|it=\n|es=\n|uk=\n|kk=\n}}\n{{перев-блок|морской лук\n|en=\n|de=\n|fr=\n|it=\n|es=\n|uk=\n|kk=\n}}\n\n=== Анаграммы ===\n* [[Кул]]\n\n=== Метаграммы ===\n* {{мета:?ук}}\n* [[лак]], [[лик]], [[лыко|лык]], [[люк]]\n* [[луг]], [[лужа|луж]], [[луза|луз]], [[луна|лун]], [[лупа|луп]], [[луч]]\n\n=== Библиография ===\n* {{ак}}\n* {{Россия}}\n* {{гсря}}\n* {{Тихонов-2003|лук I (Л354)|1|562}}\n* \n\n{{improve|ru|примеры|переводы}}\n\n{{Категория|язык=ru|Лук|Приправы||||}}\n\n== {{з|II}} ==\n{{Лексема в Викиданных|L145066}}\n{{commons|Category:Bows}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|лук|м 3a\n|слоги={{по-слогам|лук}}\n|дореф=лукъ\n}}\n\n{{слобр|ru|-|и=т3}}\n\n{{морфо-ru|лук|+∅|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|лук|лу́ки|Ru-лук.ogg||омофоны=луг}}\n\n=== Семантические свойства ===\n{{илл|Longbow.jpg|Лук}}\n\n==== Значение ====\n# [[разновидность]] [[метательный|метательного]] [[оружие|оружия]], [[предназначенный|предназначенная]] для [[стрельба|стрельбы]] [[стрела]]ми {{пример|Человек освоил {{выдел|лук}} и стрелы задолго до изучения законов механики и сделал вполне приличный металлический топор без изучения микроскопических свойств металла. |Геннадий Горелик|Андрей Сахаров. Наука и свобода|2004|и=НКРЯ}}\n\n==== Синонимы ====\n# —\n\n==== Антонимы ====\n# —\n\n==== Гиперонимы ====\n# [[оружие]]\n\n==== Гипонимы ====\n# [[длинный лук]], [[короткий лук]]\n\n==== Согипонимы ====\n# [[арбалет]]\n\n==== Холонимы ====\n# —\n\n==== Меронимы ====\n# [[рукометь]], [[тетива]]\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=лучок#II\n|существительные=лучник\n|прилагательные=лучной#II\n|глаголы=\n|наречия=\n|полн=лук II\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:лук-2|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[олимпийский лук]]\n\n==== Пословицы и поговорки ====\n* [[из лука — не мы, из пищали — не мы, а язык почесать — против нас не сыскать]]\n\n=== Перевод ===\n{{перев-блок|\n|ab=\n|abq=\n|ady=\n|af=\n|agh=\n|aja=\n|ale=\n|als=\n|alt=\n|am=[[ቀስት]]\n|an=\n|ang=\n|ar=[[قوس]]\n|arc.jud=\n|arc.syr=\n|arn=\n|art=\n|asm=\n|ast=\n|av=\n|ave=\n|ay=\n|az=\n|ba=\n|bar=\n|be=\n|bg=[[лък]]\n|bm=\n|bn=\n|bo=\n|br=\n|bs=\n|bua=\n|ca=\n|ce=\n|chm=\n|chr=\n|chu.cyr=\n|chu.glag=\n|cjs=\n|co=\n|crh=\n|cs=[[luk]]\n|csb=\n|cv=\n|cy=\n|da=\n|dar=[[урги-дерга]]\n|de=[[Bogen]] {{m}}\n|dsb=\n|dv=\n|el=[[τόξο]]\n|en=[[bow]]\n|eo=\n|es=[[arco]] {{m}}\n|et=\n|eu=\n|ext=\n|fa=[[کمان]]\n|fi=\n|fo=\n|fr=[[arc]]\n|fur=\n|fy=\n|ga=\n|gag=\n|gd=\n|gl=\n|gld=\n|gn=\n|grc=\n|gu=\n|gv=\n|ha=\n|haw=\n|he=[[קשת]] (ке́шет)\n|hi=\n|hr=[[luk]] {{m}}\n|hsb=\n|ht=\n|hu=\n|hy=\n|ia=\n|id=\n|ik=\n|io=\n|is=\n|it=\n|iu=\n|ja=[[弓矢]]\n|jv=\n|ka=\n|kaa=\n|kbd=\n|kjh=\n|kk=\n|kl=\n|km=\n|kn=\n|ko=\n|koi=\n|kok=\n|kom=\n|krc=\n|krl=\n|ku=\n|kw=\n|ky=[[жаа]]\n|la=\n|lad=\n|lb=\n|lez=\n|li=\n|lmo=\n|ln=\n|lo=\n|lt=\n|lv=\n|mdf=\n|mg=\n|mi=\n|mk=\n|ml=\n|mn=\n|mo=\n|ms=\n|mt=\n|my=\n|myv=\n|na=\n|nah=\n|nap=\n|new=\n|nio=\n|nl=\n|no=\n|nv=\n|oc=\n|orv=\n|os=\n|pap=\n|pi=[[dhanu]]\n|pl=[[łuk]]\n|pms=\n|prs=\n|ps=\n|pt=\n|qu=\n|rap=\n|rm=\n|ro=\n|rom=\n|ru-old=\n|rue=\n|sa=\n|sah=\n|sc=\n|scn=\n|sco=\n|sd=\n|se=\n|sgs=\n|si=\n|sjd=\n|sk=[[luk]]\n|sl=[[lok]]\n|slovio-c=[[Словио#|лук]]\n|slovio-l=[[luk]]\n|so=\n|sq=\n|sr-l=[[luk]]\n|sr=[[Сербский#|лук]]\n|sv={{t|sv|pilbåge|c}}, {{t|sv|båge|c}}\n|sw=\n|ta=\n|tab=\n|te=\n|tg=[[камон]]\n|th=\n|tk=\n|tl=\n|tn=\n|tpi=\n|tr=\n|tt.cyr=[[җәя]]\n|tt.lat=\n|tt=\n|ty=\n|tyv=\n|udm=\n|ug=\n|uk=[[Украинский#|лук]]\n|ur=\n|uz=\n|vep=\n|vi=\n|vo=\n|vot=\n|vro=\n|wa=\n|wo=\n|xal=\n|xh=\n|yi=\n|yrk=\n|ze=\n|zh-cn=\n|zh-tw=\n|zh=[[弓]]\n|zu=\n|zza=\n}}\n\n=== Библиография ===\n* {{ак}}\n* {{гсря}}\n* {{Тихонов-2003|лук II (Л355)|1|562}}\n* \n\n{{improve|ru|}}\n\n{{Категория|язык=ru|Метательное оружие|||}}\n\n== {{з|III}} ==\n{{Лексема в Викиданных|L145068}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|лук|м 3a\n|слоги={{по-слогам|лук}}\n}}\n\n{{слобр|ru|-|и=}}\n\n{{морфо-ru|лук|+∅|и=}}\n\n=== Произношение ===\n{{transcriptions-ru|лук|лу́ки|Ru-лук.ogg||омофоны=луг}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{жарг.|ru}}, {{неол.|ru}} [[внешний вид]] и [[стиль]] человека (прежде всего одежда, аксессуары, причёска) {{пример|Монки и дерби глубокого синего, черного или коричневого цвета из гладкой телячьей кожи или бархатистой замши станут отличными компаньонами как строгим классическим, так и более расслабленным «{{выдел|лукам}}».|Потребление|||Эксперт|2015|и=НКРЯ}}\n# {{жарг.|ru}}, {{неол.|ru}} [[фотография]], демонстрирующая такой стиль {{пример|}}\n\n==== Синонимы ====\n# ?\n# ?\n\n==== Антонимы ====\n# —\n# —\n\n==== Гиперонимы ====\n# [[внешний вид]]\n# [[фотография]]\n\n==== Гипонимы ====\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=лук III\n}}\n\n=== Этимология ===\nПроисходит от {{lang|en|look|[[вид]], [[внешность]]}}, далее от {{lang|enm|loken|[[выглядеть]]}}, далее от {{lang|ang|locian|[[видеть]]}}, далее от {{lang|празападногерм|*lokon|видеть}}, далее из неустановленной формы. Возможно, связано с {{lang|pie|*lewg-|[[глаз]]}} (от которого, предположительно, произошли {{lang|br|lagad|[[взгляд]]}}, {{lang|cy|llygad|глаз}}, {{lang|[[корнский|корн]]|lagas|глаз}}).\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|внешний вид и стиль\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарский -->\n|en=[[appearance]], [[look]]\n|ar=<!-- Арабский-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->\n|ba=<!-- Башкирский-->\n|be=[[аблічча]], [[знешнасць]]\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=[[kinézet]]\n|vi=<!-- Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=[[εμφάνιση]] (emfánisi), [[όψη]] (ópsi)\n|ka=[[გარეგნობა]] (garegnoba)\n|da=[[udseende]]\n|dar=[[куц]]\n|he=<!-- Иврит-->\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=[[apariencia]], [[look]]\n|it=[[aspetto]], [[look]]\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=[[aparença]]\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=[[izskats]]\n|lt=[[išvaizda]]\n|mk=<!-- Македонский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=[[aussehen]]\n|nl=[[look]], [[uiterlijk]]\n|no=[[utseende]]\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=[[aparycja]]\n|pt=[[aparência]]\n|ro=[[aparență]], [[înfățișare]]\n|sa=<!-- Санскрит-->\n|sr=[[вањштина]]\n|sr-l=[[vanjština]]\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-C