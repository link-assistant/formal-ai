ечия=\n}}\n\n=== Этимология ===\nОт {{этимология:лук-2|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|be|морфо|транскрипция/мн|пример}}\n{{Категория|язык=be|Метательное оружие||}}\n{{длина слова|3|be}}\n\n= {{-bg-}} =\n{{wikipedia|lang=bg}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg 1|слоги={{по-слогам|лук}}|лук}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{as ru|I}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:лук-1|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|морфо|транскрипция/мн|пример}}\n{{Категория|язык=bg|Лук||}}\n{{длина слова|3|bg}}\n\n= {{-slovio-}} =\n{{wikipedia|lang=slovio}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ slovio |слоги={{по-слогам|лук}}|лук}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{as ru|II}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:лук-2|slovio}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|slovio|морфо|транскрипция/мн|пример}}\n{{Категория|язык=slovio|Метательное оружие}}\n{{длина слова|3|slovio}}\n\n= {{-sr-}} =\n{{Омонимы|sr|2}}\n\n{{wikipedia|lang=sr}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr m|слоги={{по-слогам|лук}}|лук}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{as ru|I}} {{пример|Ја волим да једем {{выдел|лук}}.|перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:лук-1|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|sr|морфо|транскрипция/мн}}\n{{Категория|язык=sr|Лук||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr m|слоги={{по-слогам|лук}}|лук}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# {{as ru|II}} {{пример|Он је узео {{выдел|лук}} и стрелу.|перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:лук-2|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|sr|морфо|транскрипция/мн}}\n{{Категория|язык=sr|Метательное оружие||}}\n{{длина слова|3|sr}}\n\n= {{-kca-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ kca |слоги={{по слогам|лук}}|соотв=||}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл||}}\n\n==== Значение ====\n# [[глухарь]] {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# [[лўк]] (современ