eo=[[skribi]]\n|et=[[kirjutama]]\n|ext=[[escrebil]]\n|yua=\n|yue=\n|jv=\n|sah=[[суруй]]\n|ja=[[書く]] ([[かく]], kaku)\n}}\n\n{{перев-блок|быть автором\n|ab=[[аҩра]]\n|av=\n|aja=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|ale=\n|en=[[write]], [[author]], [[narrate]]\n|ar=\n|an=\n|arc.syr=\n|hy=\n|ast=\n|af=\n|eu=\n|bar=\n|bm=\n|ba=\n|be=\n|bn=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|hsb=\n|wo=\n|vi=\n|vro=\n|haw=\n|gl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|da=\n|grc=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|ga=\n|is=\n|es=\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=[[著]] [zhù]; [[执笔]] [zhíbǐ]\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=\n|nl=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ro=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|tl=\n|tg=\n|th=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=[[skriva]], [[författa]], [[dikta]], [[berätta]]\n|cjs=\n|eo=[[verki]]\n|et=\n|sah=\n|ja=\n}}\n\n{{перев-блок|создавать произведения живописи\n|ab=\n|av=\n|aja=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|ale=\n|en=[[paint]] ''vt (sth, so)''\n|ar=\n|an=\n|arc.syr=\n|hy=\n|ast=\n|af=\n|eu=\n|bar=\n|bm=\n|ba=\n|be=\n|bn=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|hsb=\n|wo=\n|vi=\n|vro=\n|haw=\n|gl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|da=\n|grc=[[ἐνζωγραφέω]]; [[ζωγραφέω]]\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|ga=\n|is=\n|es=[[pintar]] ''vt''\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=[[写生]] [xiěshēng]; [[画]] [huà]\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=[[malen]] ''vt A (jdn, etw)''\n|nl=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ro=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|tl=\n|tg=\n|th=\n|tt=\n|art=\n|kim=\n|tyv=[[чуруур]]\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=[[måla]], [[teckna]], [[rita]]\n|cjs=\n|eo=[[pentri]]\n|et=\n|sah=\n|ja=\n}}\n\n=== Библиография ===\n* '''Апресян Ю. Д.''' ''рисовать 1.1'', ''зарисовывать 1'', ''писать 1.1'', ''малевать'' // '''Апресян Ю. Д.''' (рук.) Новый объяснительный словарь русского языка. Проспект. М.: Русские словари, 1995, с. 438–443.\n\n== {{заголовок|ударение=пи́сать}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{гл ru 1a\n|основа =пи́са\n|НП=1\n|слоги={{по слогам|пи́|сать}}\n}}\n\n{{морфо-ru|пис|-а|+ть}}\n\n=== Произношение ===\n{{transcription-ru|пи́сать}}\n\n=== Семантические свойства ===\n{{илл|Manneken Pis (crop).jpg|Пи́сать}}\n\n==== Значение ====\n# {{разг.|ru}} [[испускать]] [[моча|мочу]]; [[мочиться]] {{пример|{{-}}{{выдел|Пи́сать}} хочу, где туалет?|Ольга Некрасова|Платит последний|2000|источник=НКРЯ}} {{пример|Понимаешь, я как-то однажды взяла себе котика… Ну всё сделала как надо: поставила ему тазик для писанья{{-}}в уборной, постелила ему одеяльце{{-}}на собственной кровати… Отгадай, чем кончилось? Кот {{выдел|пи́сал}} в мою кровать, а спал в тазике{{-}}в уборной…|Эдвард Радзинский|Я стою у ресторана…|уточнение титула=(Монолог женщины)|дата=1990—2000 гг.|источник=НКРЯ}}\n\n==== Синонимы ====\n# [[писять]], [[пысать]], [[мочиться]], [[оправляться]]; {{разг.|-}}: [[справлять нужду]]; {{детск.|-}}: [[сикать]]; {{рег.|-}}: [[ходить до ветру]]; {{груб.|-}}: [[ссать]]\n\n==== Антонимы ====\n# —\n\n==== Гиперонимы ====\n# [[испускать]]\n\n==== Гипонимы ====\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=писун, писька, пиписька, писуар\n|прилагательные=описанный\n|глаголы=писаться, обописать; описаться\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:писаю|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[писать против ветра]]\n* [[писать кипятком]]\n\n=== Перевод ===\n{{перев-блок|\n|ab=\n|av=\n|aja=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|ale=\n|en=<!-- [[piss]], -->[[pee]]\n|ar=\n|an=\n|arc.syr=\n|hy=\n|ast=\n|af=\n|eu=\n|bar=\n|bm=\n|ba=\n|be=\n|bn=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|hsb=\n|wo=\n|vi=\n|vro=\n|haw=\n|gl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|da=\n|grc=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|ga=\n|is=\n|es=\n|it=[[pisciare]], [[orinare]]\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|crh=\n|la=\n|lv=[[urinēt]], [[čurāt]], [[mīzt]], [[cisāt]]\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=[[pinkeln]], [[pissen]] ''vi''\n|nl=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=[[sikać]]\n|pt=\n|ro=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|tl=\n|tg=\n|th=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=[[kusta]]\n|fr=\n|fy=\n|hi=\n|hr=\n|cs=[[čurat]]\n|cv=\n|sv=[[kissa]], [[pinka]], [[pissa]], [[urinera]]\n|cjs=\n|eo=[[pisi]], [[urini]]\n|et=[[kusema]]\n|sah=\n|ja=[[おしっこ]]する, [[小便]](しょうべん)する\n}}\n\n=== Библиография ===\n* {{БТС, 2014}}\n* {{РОС-4}}\n\n<!-- Служебное: -->\n{{Категория|язык=ru|Глаголы письма|Глаголы создания|Глаголы мочеиспускания}}\n{{Категория|язык=ru|Глаголы коммуникации}}\n{{длина слова|6|ru}}"}}