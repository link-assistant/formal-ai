, [[そして]] (soshite)\n}}\n{{перев-блок|но\n|ab=[[аха]]\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en=[[but]], [[however]]\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=[[բայց]] (bayc(); [[սակայն]] (sakayn)\n|ba=<!-- Башкирский -->\n|be=[[але]], [[ды]], [[аднак]]\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийский -->\n|br=[[met]]\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|da=[[men]]\n|io=[[ma]]\n|ia=<!-- Интерлингва -->\n|is=[[en]]\n|es=[[pero]]\n|it=[[ma]]\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=[[però]]\n|ky=[[бирок]]\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=[[sed]]\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=[[aber]]\n|nl=[[maar]], [[echter]]\n|no=<!-- Норвежский -->\n|pl=[[ale]], [[lecz]]\n|pt=[[mas]], [[porém]]\n|sr=[[али]]\n|sr-l=[[ali]]\n|sk=<!-- Словацкий -->\n|sl= [[toda]]\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=[[ama]]\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=[[але]]\n|fo=[[men]]\n|fi=<!-- Финский -->\n|fr=[[mais]]\n|hr=<!-- Хорватский -->\n|cs=[[ale]]\n|sv=[[men]]\n|eo=[[sed]]\n|et=[[aga]], [[ent]]\n|ja=[[が]], [[けれども]], ''см. тж.'' [[ばかり]]\n}}\n\n=== Библиография ===\n* \n\n{{improve|ru|}}\n\n{{Категория|язык=ru|||}}\n\n{{длина слова|2|ru}}\n\n= {{-be-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{prep be|слоги={{по-слогам|да}}}}\n\n{{морфо||да}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[до]] {{пример||перевод=}}\n# [[к]] {{пример||перевод=}}\n# [[на]] {{пример||перевод=}}\n\n==== Синонимы ====\n# ?\n# ?\n# ?\n\n==== Антонимы ====\n# ?\n# ?\n# ?\n\n==== Гиперонимы ====\n# —\n# —\n# —\n\n==== Гипонимы ====\n# —\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:до|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|be|транскрипция|пример}}\n{{Категория|язык=be|Предлоги направления}}\n{{длина слова|2|be}}\n\n= {{-bg-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{part bg|слоги={{по-слогам|да}}}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{помета|(утвердительный ответ)}} {{as ru}} {{пример|Довърши ли работата? — Да.|перевод=Ты закончил работу? — Да.}}\n# [[чтобы]] {{пример|Искам вие {{выдел|да}} знаете това.|перевод=Хочу, {{выдел|чтобы}} вы это знали.}}\n# \n\n==== Синонимы ====\n# ?\n# ?\n# \n\n==== Антонимы ====\n# ?\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# ?\n# \n\n==== Гипонимы ====\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:да|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|морфо|транскрипция}}\n{{Категория|язык=bg|Согласие|Причинность}}\n{{длина слова|2|bg}}\n\n= {{-orv-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{conj orv|слоги={{по-слогам|да}}}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{помета|(утвердительный ответ)}} {{as ru}} {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# —\n# \n\n==== Гипонимы ====\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существите