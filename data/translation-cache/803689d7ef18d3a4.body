is]]; [[rooti]]\n|sot=[[bohobe]]\n|sq=[[bukea]]; [[bukë]] {{f}}\n|sr=[[хлеб]] {{m}}, [[хљеб]] {{m}}\n|sr-l=[[hleb]] {{m}}\n|srn=[[brede]]\n|ss=[[sí-nkhwa]]\n|su=\n|sv={{t|sv|bröd|n}}\n|sw=[[mkate]]\n|szl=[[chlyb]]\n|ta=[[பாண்]] (pāṇ); [[ரொட்டி]] (rōṭṭi)\n|tab=[[уьл]]\n|te=[[బ్రెడ్డు]] (), [[రొట్టె]] (roṭṭe)\n|tet=[[paun]]\n|tg=[[нон]]\n|th=[[ขนมปัง]]; [[ปัง]] (pâṅ)\n|tk=[[çörek]]\n|tl=[[tinapay]]\n|tn=[[borotho]]\n|tpi=[[bret]]\n|tr=[[ekmek]]\n|tt=[[ашлык]] ([[aşlıq]]); [[икмәк]]; [[ипи]]\n|ttt=[[нун]] ([[נאוּנ]])\n|ty=[[faraoa]]\n|tyv=хлеб\n|udm=[[нянь]]\n|ug=[[بولكا]] ([[bolka]]; [[болка]]); [[نان]] ([[nan]]; [[нан]])\n|uk=[[хліб]] {{m}}\n|ur=[[روٹی]] (roṫī)\n|uz=[[non]]\n|vec=[[pan]]\n|vep=[[leib]]; [[liib]]\n|vi=[[bánh mì]]; [[làm thủng]]\n|vo=\n|vro=[[leib]]\n|wa=[[pwin]]\n|war=[[pan]]\n|wo=[[mburu]]\n|xal=[[өдмг]]; [[хальш]]\n|xh=[[isonka]]\n|xsr=[[खाट]] (kʰāṭ)\n|yi=[[ברויט]] (broyt) {{n}}\n|yo=[[àkàrà òyìnbóonje̩búrè̩dì]]\n|yrk=[[нянь]]\n|yua=[[waaj]]\n|ze=[[pan]]\n|zh-cn=''в сочет''. [[粮]] (''пиньинь'': [[liáng]])\n|zh-tw=''в сочет''. [[粮]]\n|zh=[[麵包]], [[面包]] (miànbāo)\n|zu=[[isinkwa]]\n|zza=[[nan]]\n}}\n\n{{перев-блок|конкретное изделие\n|az=çörək\n|ain=\n|sq=\n|en=[[bread]], [[loaf]]\n|ar=\n|hy=\n|ast=\n|af=\n|eu=\n|ba=\n|be=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|vi=\n|vro=\n|gl=\n|el=\n|ka=\n|da=\n|grc=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|is=\n|es=\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=[[Brot]] {{n}} -(e)s, -e\n|nl=\n|no=\n|oc=\n|os=\n|pap=\n|fa=\n|pl=\n|pt=\n|ppol=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|th=\n|tt=\n|art=\n|kim=\n|tr=[[ekmek]]\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=[[pain]] {{m}}\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=\n|cjs=\n|eo=\n|et=\n|sah=\n|ja=\n}}\n\n{{перев-блок|злак\n|az=\n|ain=\n|sq=\n|en=\n|ar=\n|hy=\n|ast=\n|af=\n|eu=\n|ba=\n|be=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|vi=\n|vro=\n|gl=\n|el=\n|ka=\n|da=\n|grc=[[ἀκτή]] {{f}}; [[σῖτος]] {{m}}\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|is=\n|es=\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=[[Getreide]] {{n}} -s, -, [[Korn]] {{n}} -s, -\n|nl=\n|no=\n|oc=\n|os=\n|pap=\n|fa=\n|pl=\n|pt=\n|ppol=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|th=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=[[céréale]](s) {{f}}, [[blé]] {{m}}\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=\n|cjs=\n|eo=\n|et=\n|sah=\n|ja=\n}}\n\n{{перев-блок|пропитание\n|az=\n|ain=\n|sq=\n|en=[[living]]\n|ar=\n|hy=\n|ast=\n|af=\n|eu=\n|ba=\n|be=\n|bg=\n|bs=\n|br=\n|cy=\n|hu=\n|vep=\n|vi=\n|vro=\n|gl=\n|el=\n|ka=\n|da=\n|grc=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|is=\n|es=\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=[[Lebensunterhalt]] {{m}} -(e)s, -\n|nl=\n|no=\n|oc=\n|os=\n|pap=\n|fa=\n|pl=\n|pt=\n|ppol=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|th=\n|tt=\n|art=[[moku]]\n|kim=\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=[[pain]] {{m}}\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=\n|cjs=\n|eo=[[pano]]\n|et=\n|sah=\n|ja=\n}}\n\n=== Метаграммы ===\n* [[Глеб]], [[хлев]]\n\n=== Библиография ===\n* \n\n{{Категория|язык=ru|Пища|Хлеб|Существительные с вариативным склонением}}\n{{длина слова|4|ru}}\n\n= {{-be-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ be m ina|слоги={{по-слогам|хлеб}}|хлеб}}\n\n{{морфо|прист1=|корень1=хлеб|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}} {{медиа|Be-хлеб.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:хлеб|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|be|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=be|Хлеб||}}\n{{длина слова|4|be}}\n\n= {{-sr-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{падежи sr\n|слоги={{по-слогам|хле̏б}}\n|alt=hleb\n|nom-sg=хле̏б\n|nom-pl=хлѐбови\n|gen-sg=хлеба\n|gen-pl=хлебова\n|dat-sg=хлебу\n|dat-pl=хлебовима\n|acc-sg=хлеб\n|acc-pl=хлебове\n|ins-sg=хлебом\n|ins-pl=хлебовима\n|loc-sg=хлебу\n|loc-pl=хлебовима\n|voc-sg=хлебе\n|voc-pl=хлебови\n|род=мужской\n}}\n\n{{морфо|прист1=|корень1=хлеб|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|xlêb|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# [[хљеб]]\n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:хлеб|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|sr|морфология/шаблон|пример|гиперонимы}}\n{{Категория|язык=sr|Хлеб||}}\n{{длина слова|4|sr}}"}}