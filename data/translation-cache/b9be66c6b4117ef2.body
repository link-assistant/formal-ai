[コーヒー豆]] (kōhīmame), [[コーヒー粉]] (kōhīko)\n}}\n\n{{перев-блок|напиток\n|abq=[[къахӀауа]]\n|ab=[[акаҳуа]]\n|av=\n|ave=\n|agh=\n|aja=\n|ady=[[коф]]\n|az=[[qəhvə]]\n|ay=[[junt'u uma]]; [[kaphiya]]\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=[[kafe]]\n|als=\n|ale=\n|alt=[[кофе]]\n|am=[[ቡና]] (buna)\n|en=[[coffee]]\n|ar=[[قهوة]] (qáhwa) {{f}}\n|an=\n|arc.syr=\n|arc.jud=\n|hy=[[սուրճ]] (surch)\n|ast=[[café]]\n|af=[[koffie]]\n|bar=\n|bm=\n|eu=[[kafe]]\n|ba=[[ҡәһүә]]\n|be=[[кава]] {{f}}\n|bn=[[কফি]]\n|bg=[[кафе]] {{n}}\n|bs=[[kahva]]\n|br=[[kafe]]\n|bua=\n|cy=[[coffi]] {{m}}\n|wa=[[cafè]]\n|hu=[[kávé]]\n|vep=\n|hsb=[[kofej]] {{m}}\n|vo=[[kaf]]\n|wo=[[kafe]]\n|vro=\n|vi=[[cà phê]]\n|haw=[[kope]]\n|gl=[[café moído]]\n|kl=[[kaffi]]\n|el=[[καφές]] {{m}}\n|ka=[[ყავა]] (qava)\n|gn=[[kafery]]; [[keferykue]]\n|gu=[[કૉફી]]\n|gd=[[cofhaid]]\n|prs=\n|da=[[kaffe]]\n|ang=\n|grc=\n|sgs=[[kava]] {{f}}\n|zza=\n|zu=[[ikhofi]]\n|he=[[קפה]] (qafé) {{m}}\n|yi=[[קאַווע]] (kawe) {{f}}\n|io=[[kafeo]]\n|id=[[kopi]]\n|ia=[[caffe]]\n|iu=\n|ik=[[kuukpiaq]]\n|ga=[[caife]]\n|is=[[kaffi]]\n|es=[[café]]\n|it=[[caffè]]\n|yo=[[ohun mímu]]\n|kbd=\n|kk=[[кофе]]\n|xal=[[кофе]]\n|kn=[[ಕಾಫಿ]]\n|kaa=\n|krc=\n|krl=\n|ca=[[cafè]]\n|csb=\n|qu=[[kajwi]]; [[pusu]]\n|ky=[[кофе]]\n|zh=[[咖啡]] (kāfēi)\n|zh-tw=\n|zh-cn=\n|koi=\n|kw=[[koffi]]\n|ko=[[커피]] (keopi)\n|co=[[caffè]]\n|xh=[[ikofu]]\n|crh=[[qave]]\n|kum=[[кофе]]\n|ku=[[qehwe]] {{f}}, [[qawe]] {{f}}\n|lo=[[ກາເຟ]]\n|la=\n|lez=[[кофе]]\n|lv=[[kafija]] {{f}}\n|li=[[kaffee]] ; [[koffie]]\n|ln=[[kafe]]; [[kawa]]\n|lt=[[kava]] {{f}}\n|lb=[[Kaffi]]\n|mk=[[кафе]] {{n}}\n|mg=[[kafe]]\n|ml=[[കാപ്പി]]\n|ms=[[kopi]]\n|mt=[[kafè]]\n|mi=[[kawhi]]\n|mr=[[कोफी]]\n|chm=[[кофе]]\n|mas=[[olkahawa oldurungi]]\n|mdf=[[кофе]]\n|mn=[[кофе]]\n|gv=[[caffee]]\n|nah=\n|na=\n|nap=[[cafè]]\n|de=[[Kaffee]] {{m}}\n|yrk=\n|nl=[[koffie]]\n|dsb=[[kafej]] {{m}}\n|no=[[kaffe]]\n|nn=[[kaffi]]\n|oj=[[makade-mashkikiwaaboo]]\n|oc=[[cafè]]\n|om=[[buna]]\n|os=[[къофи]], [[хъауа]]\n|pa=[[ਕਾਫ਼ੀ]]\n|pap=[[kòfi]]\n|fa=[[قهوه]] (qahve)\n|pl=[[kawa]] {{f}}\n|pt=[[café]]\n|rm=\n|ro=[[cafea]]\n|sm=[[kofe]]\n|sa=\n|sc=[[cafè]]; [[caffei]] (кампид.)\n|sr=\n|sr-l=\n|sot=[[kofi]]\n|scn=[[café]]\n|sk=[[káva]] {{f}}\n|sl=[[kava]] {{f}}\n|slovio-c=\n|slovio-l=\n|so=[[bun]]\n|chu=\n|sw=[[kahawa]]\n|tab=[[кофе]]\n|tl=[[kape]]\n|tg=[[қаҳва]]\n|th=[[กาแฟ]] (ka:fɛ)\n|ta=[[காபி]] (kap:i)\n|tt=[[каһвә]]\n|te=[[కాఫీ]]\n|tet=[[kafé]]\n|art=\n|tpi=[[kopi]]\n|kim=\n|tn=[[kofi]]\n|tyv=[[кофе]]\n|tr=[[kahve]]\n|tk=[[kofe]]\n|udm=[[кофе]]\n|ug=\n|uz=[[qahva]] ([[қаҳва]])\n|uk=[[кава]] {{f}}\n|ur=[[قہوہ]] (qahva) {{m}}, [[کوفی]] (kofī) {{f}}, [[کافی]] (kāfī) {{f}}\n|fo=[[kaffi]]\n|fi=[[kahvi]]\n|fr=[[café]] {{m}}\n|fy=[[kofje]]\n|fur=[[cafè]]\n|kjh=\n|ha=\n|hi=[[क़हवा]] (qahva) {{m}}, कोफ़ी (kofī) {{f}}\n|hr=[[kava]] {{f}}\n|chr=[[ᎧᏫ]]\n|ce=[[къахьо]]; [[кофэ]]\n|cs=[[káva]] {{f}}\n|cv=[[кофе]]\n|chy=[[moˀȯhtávėhohpe]]\n|sv=[[kaffe]]\n|sn=[[kofi]]\n|cjs=\n|evn=[[кофе]]\n|myv=\n|eo=[[kafo]]\n|et=[[kohv]]\n|jv=\n|sah=[[кофе]]\n|ja=[[珈琲]] ([[コーヒー]], kōhī)\n}}\n\n{{перев-блок|употребление, питьё такого напитка\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарский -->\n|en=<!-- Английский-->\n|ar=<!-- Арабский-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->\n|ba=<!-- Башкирский-->\n|be=<!-- Белорусский-->\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=<!-- Венгерский-->\n|vi=<!-- Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=<!-- Греческий-->\n|ka=<!-- Грузинский-->\n|da=<!-- Датский-->\n|he=<!-- Иврит-->\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский-->\n|lt=<!-- Литовский-->\n|mk=<!-- Македонский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=<!-- Немецкий-->\n|nl=<!-- Нидерландский-->\n|no=<!-- Норвежский-->\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=<!-- Польский-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-->\n|sr=<!-- Сербский (кир)-->\n|sr-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянский (кир)-->\n|cu-Glag=<!-- Старославянский (глаг)-->\n|tl=<!-- Тагальский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Турецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fi=<!-- Финский-->\n|fr=<!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cs=<!-- Чешский-->\n|cv=<!-- Чувашский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|sah=<!--Якутский-->\n|ja=<!--Японский-->\n}}\n\n=== Метаграммы ===\n* [[кафе]]\n\n=== Библиография ===\n* {{гсря}}\n* {{ак}}\n* {{вт-д|}}\n* {{Ушаков|кофе|feb=11/us1e9011|том=1|стб=1490}}\n* {{библио|Е. Ю. Богданова, С. Е. Никитина.|''Кофе''|И. А. Мельчук, А. К. Жолковский.|Толково-комбинаторный словарь русского языка. Опыты семантико-синтаксического описания русской лексики.|Wiener Slawistischer Almanach. Sonderband 14. Wien, 1984|387–392}}\n* {{Ожегов-Шведова-1949-1992|кофе|https://web.archive.org/web/20230224224752/https://dic.academic.ru/dic.nsf/ogegova/90870|}}\n* {{МАС2|статья=кофе|ссылка=https://feb-web.ru/feb/mas/mas-abc/11/ma211610.htm|том=2. К—О|страницы=116}}\n* {{БТС}}\n* {{Зарва}}\n* {{И-Рез||стр=465}}\n* {{книга |автор = Горбачевич К. С. |часть = кофе |ссылка часть = https://web.arc