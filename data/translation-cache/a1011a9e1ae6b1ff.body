u=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co=\n|xh=\n|crh=\n|ku=\n|km=\n|lad=\n|lo=\n|la=\n|lez=\n|lv=\n|li=\n|ln=\n|lt=\n|lb=\n|mk=\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|de=[[Werk]]\n|yrk=\n|nl=\n|dsb=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=\n|rom=\n|ce=\n|cs=\n|cv=\n|sv=\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo=\n|et=\n|jv=\n|sah=\n|ja=\n}}\n\n=== Анаграммы ===\n* {{анаграммы:АДОЧ}}\n\n=== Метаграммы ===\n* {{метаграммы:*адо}}\n* {{метаграммы:ч*до}}\n* {{метаграммы:ча*о}}\n* {{метаграммы:чад*}}\n\n=== Библиография ===\n* \n\n{{improve|ru|}}\n\n{{Категория|lang=ru|Отношения родства|Дети|Произведения}}\n{{длина слова|4|ru}}\n\n= {{-orv-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ orv |слоги=|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=orv|}}\n\n==== Значение ====\n# {{помета.|orv}} [[дитя]] {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|и=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|orv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{unfinished|orv|p=1|m=1|e=1}}\n\n{{Категория|lang=orv|Дети||}}\n{{длина слова|4|lang=orv}}\n\n= {{-chu-ru-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ chu-ru n a 1a|ча́д|ча̑д|слоги={{по-слогам|ча́|до}}\n}}\n\n{{морфо|прист1=|корень1={{Chu-cyrs|ча́д}}|суфф1=|оконч={{Chu-cyrs|о}}|частица=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример|lang=chu-ru|Ви́дѣвъ же і҆и҃съ вѣ́рꙋ и҆́хъ, гл҃а разсла́бленномꙋ: {{выдел|ча́до}}, ѿпꙋща́ютсѧ тебѣ̀ грѣсѝ твоѝ.|перевод=Иисус, видя веру их, говорит расслабленному: {{выдел|чадо}}! прощаются тебе грехи твои.||Елизаветинская Библия|часть={{Cyrs|Ѿ ма́рка ст҃о́е бл҃говѣствова́нїе в҃:є҃}}||дата издания=1751}}\n# \n\n==== Синонимы ====\n# —\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# —\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от&nbsp;{{этимология:|}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|chu-ru|транскрипция/мн|пример}}\n{{Категория|lang=chu-ru|Дети}}\n{{длина слова|4|chu-ru}}\n\n{{multilang|3}}"}}