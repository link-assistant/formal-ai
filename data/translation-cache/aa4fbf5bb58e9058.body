tr=\n|tk=<!-- Туркменский -->\n|udm=\n|uz=\n|ug=<!-- Уйгурский-->\n|uk=\n|ur=<!-- Урду-->\n|fo=<!-- Фарерский-->\n|fi=\n|fr=\n|fy=<!-- Фризский -->\n|fur=<!--Фриульский-->\n|kjh=<!--Хакасский-->\n|ha=<!-- Хауса -->\n|hi=\n|hr=\n|chu.cyr=<!--Церковнославянский (кир.)-->\n|chu.glag=<!-- Церковнославянский (глаг.)-->\n|rom=<!--Цыганский-->\n|ce=\n|cs=\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|sv=\n|cjs=<!--Шорский-->\n|sco=<!--Шотландский -->\n|ewe=<!--Эве-->\n|evn=<!--Эвенкийский-->\n|myv=<!--Эрзянский-->\n|eo=\n|et=\n|jv=<!-- Яванский -->\n|sah=\n|ja=\n}}\n\n=== Библиография ===\n* {{ак}}\n* {{МАС2|статья=свинина|ссылка=https://feb-web.ru/feb/mas/mas-abc/18/ma404919.htm|том=4. С—Я|страницы=49}}\n* {{вт-д|Свинья}}\n* {{Ушаков|свинина|feb=18/us409010|том=4|стб=90.}}\n* {{Ефремова-2000|свинина|https://archive.li/yqofe|}}\n* {{гсря}}\n* {{Ожегов-Шведова-1949–1992|свинина|https://web.archive.org/web/20250420202016/https://dic.academic.ru/dic.nsf/ogegova/215206|}}\n* {{Тихонов-2003|свинья (С151)|2|80}}\n* {{бтс-2014}}\n* \n\n{{прочее-блок\n|частотность = \n|анаграммы = \n|метаграммы = свидина\n}}\n\n{{improve|ru|}}\n\n{{Категория|язык=ru|Мясо|Свиньи|}}\n{{длина слова|7|ru}}\n\n= {{-orv-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ orv f *ā|слоги=|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=orv|}}\n\n==== Значение ====\n# {{помета.|orv}} свиное [[мясо]] {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|и=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|полн=\n}}\n\n=== Этимология ===\nИз {{этимология:|orv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{unfinished|orv|p=1|m=1|e=1}}\n\n{{Категория|язык=orv|Мясо|Свиньи|}}\n{{длина слова|7|lang=orv}}\n\n= {{-uk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk f|свинина|слоги={{по-слогам|свинина}}}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{с|ru|свинина}} {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|и=}}\n#\n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|полн=\n}}\n\n=== Этимология ===\nОт {{этимология:|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|uk|??}}\n{{Категория|язык=uk|Мясо|Свиньи|}}\n{{длина слова|7|lang=uk}}\n\n{{multilang|3}}"}}