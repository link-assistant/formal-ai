|hi=\n|hr=[[prozor]]\n|cs=[[okno]] {{n}}\n|cv=\n|sv={{t|sv|fönster|n}}\n|cjs=\n|eo=[[fenestro]]\n|et=\n|sah=\n|ja=[[ウィンドウ]] (uindō)\n}}\n\n{{перев-блок|количество блоков данных\n|en= [[window]]\n|de=\n|sv={{t|sv|fönster|n}}\n}}\n\n{{перев-блок|место для обслуживания клиентов\n|it= [[sportello]]\n|sv={{t|sv|lucka|c}}\n}}\n\n=== Анаграммы ===\n* [[онко]], [[Онко]]\n\n=== Библиография ===\n* {{НСЗ-60}}\n{{Мельчук|Жолковский А. К., Мельчук И. А.|Окно|488–497}}\n\n[[Категория:Существительные с вариативным склонением]]\n{{Категория|язык=ru|Окно|}}\n{{длина слова|4|ru}}\n\n= {{-mk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ mk n|слоги={{по-слогам|ок|но}}}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{архитект.|mk}} [[#Русский|окно]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:окно|mk}}\n\n<!-- Служебное: -->\n{{improve|mk|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=mk|Окно||}}\n{{длина слова|4|mk}}\n\n= {{-sr-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr n|окн|слоги={{по-слогам|ок|но}}|alt=okno}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{архитект.|sr}} [[окно]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:окно|sr}}\n\n<!-- Служебное: -->\n{{improve|sr|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=sr|Окно||}}\n{{длина слова|4|sr}}\n\n= {{-slovio-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{СущСловКи-|окно|слоги={{по-слогам|окно}}|alt=okno|род=средний}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{архитект.|slovio}} [[#Русский|окно]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:окно|slovio}}\n\n<!-- Служебное: -->\n{{improve|slovio|морфо|транскрипция|пример|синонимы|гиперонимы}}\n{{Категория|язык=slovio|Окно||}}\n{{длина слова|4|slovio}}\n\n= {{-evn-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ evn|слоги={{по-слогам|ок|но}}}}\n\n{{морфо|}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{архитект.|evn}} [[#Русский|окно]] {{пример||перевод=}}\n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nИз {{сэ|ru|окно|и=evn}}.\n\n<!-- Служебное: -->\n{{improve|evn|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=evn|Окно}}\n{{длина слова|4|evn}}\n\n{{multilang|}}"}}