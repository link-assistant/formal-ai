\n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:город|mk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|mk|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=mk|||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ mk m|слоги={{по-слогам|град}}|град|}}\n\n{{морфо |прист1=|корень1=град|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# град (аналог. русск. град I) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:град|mk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|mk|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=mk|||}}\n{{длина слова|4|mk}}\n\n= {{-sr-}} =\n{{Омонимы|sr|2}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr m|слоги={{по-слогам|град}}|град|alt=grad}}\n\n{{морфо |прист1=|корень1=град|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|ɡrâːd|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# город, град (аналог. русск. град II) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{э