инский-->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|udm=<!--Удмуртский-->\n|uz=<!-- Узбекский-->\n|ug=<!-- Уйгурский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fo=<!-- Фарерский-->\n|fi=<!-- Финский-->\n|fr=<!-- Французский -->\n|fy=<!-- Фризский -->\n|fur=<!--Фриульский-->\n|kjh=<!--Хакасский-->\n|ha=<!-- Хауса -->\n|hi=<!-- Хинди -->\n|hr=<!-- Хорватский-->\n|chu.cyr=<!--Церковнославянский (кир.)-->\n|chu.glag=<!-- Церковнославянский (глаг.)-->\n|rom=<!--Цыганский-->\n|ce=<!-- Чеченский-->\n|cs=<!-- Чешский-->\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|sv=<!-- Шведский -->\n|cjs=<!--Шорский-->\n|sco=<!--Шотландский -->\n|ewe=<!--Эве-->\n|evn=<!--Эвенкийский-->\n|myv=<!--Эрзянский-->\n|eo=<!-- Эсперанто-->\n|et=<!-- Эстонский-->\n|jv=<!-- Яванский -->\n|sah=<!--Якутский -->\n|ja=<!-- Японский -->\n}}\n\n{{перев-блок|имеющий цвет апельсина; жёлтый (''или густо-жёлтый'') с красным (''или красноватым'') оттенком (один из основных цветов солнечного спектра, средний между красным и жёлтым)\n|abq=<!-- Абазинский-->\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ave=<!-- Авестийский-->\n|agx=<!-- Агульский-->\n|ajg=<!-- Аджа (Бенин)-->\n|aja=<!-- Аджа (Судан)-->\n|ady=<!-- Адыгейский-->\n|az=[[narincı]]\n|az.arab=<!-- Азербайджанский (арабск.)-->\n|az.cyr=<!-- Азербайджанский (кир.)-->\n|az.lat=<!-- Азербайджанский (лат.)-->\n|ay=<!-- Аймарский-->\n|ain=<!-- Айнский-->\n|ain.kana=<!-- Айнский (кана)-->\n|ain.lat=<!-- Айнский (лат)-->\n|akk=<!-- Аккадский†-->\n|akz=[[yalàaha]]\n|sq=[[bojëportokall]]\n|alq=<!-- Алгонквинский-->\n|gsw=<!-- Алеманнский-->\n|ale=<!-- Алеутский-->\n|alt=<!-- Алтайский-->\n|alr=<!-- Алюторский-->\n|am=<!-- Амхарский-->\n|en=[[orange]]\n|ar=[[برتقالي]] (burtuqaaliy)\n|an=<!-- Арагонский-->\n|arc.jud=<!-- Арамейский (иуд.)-->\n|arc.syr=<!-- Арамейский (сир.)-->\n|arp=<!-- Арапахо-->\n|arn=<!-- Арауканский-->\n|hy=[[նարնջագույն]] (narnjaguyn)\n|rup=<!-- Арумынский-->\n|aqc=<!-- Арчинский-->\n|asm=<!-- Ассамский-->\n|aii=<!-- Асси