ْگی]] (naranghi)\n|fo=[[brandgulur]]\n|fj=[[senikavika]]\n|fi=[[oranssi]]\n|fon=<!-- Фон-->\n|frk=<!-- Франкский-->\n|fr=[[orange]]\n|fy=[[oranje]]\n|fur=<!-- Фриульский-->\n|kjh=<!-- Хакасский-->\n|hak=<!-- Хакка-->\n|kca=<!-- Хантыйский-->\n|ha=[[mai ruwan lemo]], [[lemo]]\n|ha.arab=<!-- Хауса (араб.)-->\n|ha.lat=<!-- Хауса (лат.)-->\n|hit=<!-- Хеттский†-->\n|hi=[[नारंगी]] (nāraṅgī)\n|hop=<!-- Хопи-->\n|hr=[[narančast]]\n|tkr=<!-- Цахурский-->\n|ddo=<!-- Цезский-->\n|chu-ru=<!-- Церковнославянский-->\n|rom=<!-- Цыганский-->\n|ch=<!-- Чаморро-->\n|twi=<!-- Чви-->\n|chr=[[ᎠᏓᎶᏂᎨ]] (adalonige)\n|ce=[[цlеран бос]]\n|cs=[[oranžový]], [[pomerančový]]\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|chy=<!-- Шайенский-->\n|sv={{t|sv|orange}}, {{t|sv|brandgul}}, {{t|sv|apelsinfärgad}}\n|xsr=<!-- Шерпский-->\n|shp=<!-- Шипибо-->\n|sn=[[ranjisi]]\n|cjs=<!-- Шорский-->\n|sco=<!-- Шотландский-->\n|sux=<!-- Шумерский†-->\n|ewe=<!-- Эве-->\n|evn=<!-- Эвенкийский-->\n|eve=<!-- Эвенский-->\n|eml=<!-- Эмилиано-романьольский-->\n|myv=<!-- Эрзянский-->\n|eo=[[oranĝa]], [[oranĝkolora]]\n|et=[[oranž]]\n|ext=<!-- Эстремадурский-->\n|eya=<!-- Эякский†-->\n|yua=<!-- Юкатекский-->\n|yur=<!-- Юрок-->\n|yue=<!-- Юэ-->\n|jv=<!-- Яванский-->\n|sah=<!-- Якутский-->\n|ium=<!-- Яо-->\n|ja=[[オレンジ色]] (orenji-iro), [[橙色]] ([[だいだいいろ]], daidai-iro)\n}}\n\n=== Библиография ===\n* {{гсря}}\n* {{ак}}\n* {{вт-д|Оранжевый}}\n* {{Ушаков|оранжевый|feb=15/us284303|том=2|стб=843.}}\n* {{Ожегов-Шведова-1949-1992|оранжевый|https://web.archive.org/web/20230225132157/https://dic.academic.ru/dic.nsf/ogegova/140526|}}\n* {{МАС2|статья=оранжевый|ссылка=http://feb-web.ru/feb/mas/mas-abc/15/ma263602.htm|том=2. К—О|страницы=636}}\n* {{Ефремова-2000|оранжевый|https://web.archive.org/web/20240722134620/https://dic.academic.ru/dic.nsf/efremova/203621/Оранжевый|}}\n* {{Дмитриев-2003|оранжевый|https://web.archive.org/web/20220419083102/https://dic.academic.ru/dic.nsf/dmitriev/3159/оранжевый|}}\n* {{епишкин|27237}}\n* {{книга|автор = В. В. Виноградов. |часть = оранжевый (''в ст.'' «''фрезовый''») |ссылка часть = https://web.archive.org/web/20221008205619/https://dic.academic.ru/dic.nsf/wordhistory/1429/фрезовый |заглавие = История слов |ссылка = |издание = |место = |издательство = |год = 2010 |том = |страницы = |страниц = |серия = |isbn = |тираж =}}\n* {{бтс-2014}}\n\n{{improve|ru|примеры}}\n\n{{Категория|язык=ru|Оранжевый цвет|Апельсин|}}\n\n== {{з|(существительное)}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|ора́нжевый|м <п 1a>\n|слоги={{по-слогам|о|.|ра́н|же|вый}}\n|дореф=\n}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{слобр|ru|-|и=}}\n\n{{морфо-ru|оранжев|+ый|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|ора́нжевый|ора́нжевые||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{===|оранжевый цвет}}, один из [[цвет]]ов [[радуга|радуги]] в русском языке {{пример|}}\n# {{мед.|ru}} [[гистологический]] [[краситель]] из группы кислых [[азокраситель|азокрасителей]], применяемый в составе многих красящих смесей {{пример|}}\n# \n\n==== Синонимы ====\n# [[оранжевый цвет]]\n# ?\n\n==== Антонимы ====\n# —\n# ?\n\n==== Гиперонимы ====\n# [[цвет]]\n# [[краситель]]\n\n==== Гипонимы ====\n# —\n# ?\n\n==== Холонимы ====\n# [[радуга]]\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nОт {{этимология:|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|оранжевый цвет, один из цветов радуги в русском языке\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|als=\n|ale=\n|alt=\n|en=\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|bg=\n|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\