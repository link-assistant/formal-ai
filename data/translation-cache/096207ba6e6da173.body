chy=<!-- Шайенский-->\n|sv=<!-- Шведский-->\n|xsr=<!-- Шерпский-->\n|shp=<!-- Шипибо-->\n|sn=<!-- Шона-->\n|cjs=<!-- Шорский-->\n|sco=<!-- Шотландский-->\n|sux=<!-- Шумерский†-->\n|ewe=<!-- Эве-->\n|evn=<!-- Эвенкийский-->\n|eve=<!-- Эвенский-->\n|eml=<!-- Эмилиано-романьольский-->\n|myv=<!-- Эрзянский-->\n|eo=<!-- Эсперанто-->\n|et=<!-- Эстонский-->\n|ext=<!-- Эстремадурский-->\n|eya=<!-- Эякский†-->\n|yua=<!-- Юкатекский-->\n|yur=<!-- Юрок-->\n|yue=<!-- Юэ-->\n|jv=<!-- Яванский-->\n|sah=<!-- Якутский-->\n|ium=<!-- Яо-->\n|ja=<!-- Японский-->\n}}\n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ru|пример}}\n{{Категория|язык=ru|Луковые||}}\n\n== {{з|II}} ==\n{{Лексема в Викиданных|L179087}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ru m ina 3b\n|основа=чесно́к\n|основа1=чеснок\n|слоги={{по-слогам|чес|но́к}}\n|st=1\n}}\n\n{{морфо-ru|чеснок}}\n\n=== Произношение ===\n{{transcription-ru|чесно́к|Ru-чеснок.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{устар.|ru}}, {{диал.|ru}}, {{помета|Сиб., Якут., Амур.}}: [[заграждение]] из заострённых деревянных кольев {{семантика|синонимы=|антонимы=-|гиперонимы=заграждение|гипонимы=}} {{пример|{{--}}Круг острогу {{выдел|чеснок}} поделали, и церковь в остроге воздвигнули… да 12 тюрем, а около тех тюрем 15 тынов, а на тынах {{выдел|чеснок}} троезубной.|Якут., 1645}} {{пример|Круг того рву бит {{выдел|чеснок}} деревяной, а круг того {{выдел|чесноку}} деревяново бит {{выдел|чеснок}} железной стрельной опотайной.|Амур., 1655}} {{пример|Круг оне острогу Камарскова Оне глубокой ров вели, Высокой вал валилися, Рогатки ставили, {{выдел|Чеснок}} колотили.|КД, «Во сибирской украине, во Доурской стороне».}}\n# {{устар.|ru}} [[частокол]], [[палисадник]] {{Даль|толкование}} {{семантика|синонимы=частокол, палисадник|антонимы=-|гиперонимы=|гипонимы=}} {{пример|}}\n# {{устар.|ru}} частые [[столбы]], [[колья]] {{Даль|толкование}} {{семантика|синонимы=|антонимы=-|гиперонимы=столбы, колья|гипонимы=}} {{пример|И около острогу ж, против приступных мест, рву не копано и {{выдел|чесноку}} не побито.}}{{Даль}}\n# {{устар.|ru}} [[пни]], [[стулья]] под избу {{Даль|толкование}} {{семантика|синонимы=|антонимы=-|гиперонимы=пни, стулья|гипонимы=}} {{пример|}}\n# {{устар.|ru}} сплошная забойка свай {{Даль|толкование}} {{семантика|синонимы=|антонимы=|гиперонимы=забойка|гипонимы=}} {{пример|Под Исакиевским собором {{выдел|чеснок}}, или сваи биты чесноком.}}{{Даль}}\n# {{воен.|ru}} [[военный|военное]] [[заграждение]], состоящее из нескольких соединённых [[звездообразно]] острых стальных [[штырь|штырей]], направленных в разные стороны {{семантика|синонимы=|антонимы=-|гиперонимы=заграждение|гипонимы=}} {{пример|}}\n\n{{списки семантических связей}}\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=частый\n|глаголы=\n|наречия=чесноком\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n{{table-top|ffffff}}\n\n* [[бить чеснок]]\n* \n\n{{table-bot}}\n\n=== Перевод ===\n{{перев-блок|заграждение из заострённых деревянных кольев\n|abq=<!-- Абазинский-->\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ave=<!-- Авестийский-->\n|agx=<!-- Агульский-->\n|ajg=<!-- Аджа (Бенин)-->\n|aja=<!-- Аджа (Судан)-->\n|ady=<!-- Адыгейский-->\n|az=<!-- Азербайджанский-->\n|az.arab=<!-- Азербайджанский (арабск.)-->\n|az.cyr=<!-- Азербайджанский (кир.)-->\n|az.lat=<!-- Азербайджанский (лат.)-->\n|ay=<!-- Аймарский-->\n|ain=<!-- Айнский-->\n|ain.kana=<!-- Айнский (кана)-->\n|ain.lat=<!-- Айнский (лат)-->\n|akk=<!-- Аккадский†-->\n|akz=<!-- Алабамский-->\n|sq=<!-- Албанский-->\n|alq=<!-- Алгонквинский-->\n|gsw=<!-- Алеманнский-->\n|ale=<!-- Алеутский-->\n|alt=<!-- Алтайский-->\n|alr=<!-- Алюторский-->\n|am=<!-- Амхарский-->\n|en=<!-- Английский-->\n|ar=<!-- Арабский-->\n|an=<!-- Арагонский-->\n|arc.jud=<!-- Арамейский (иуд.)-->\n|arc.syr=<!-- Арамейский (сир.)-->\n|arp=<!-- Арапахо-->\n|arn=