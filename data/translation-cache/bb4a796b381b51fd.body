n|sa=<!-- Санскрит -->\n|sc=<!-- Сардинский-->\n|ceb=<!-- Себуано-->\n|se=<!-- Северносаамский-->\n|sr=[[паста]]\n|sr-l=\n|si=<!-- Сингальский -->\n|sd=<!-- Синдхи-->\n|scn=<!--Сицилийский -->\n|sk=\n|sl=\n|slovio-c=<!-- Словио (кир.)-->\n|slovio-l=<!-- Словио (лат.)-->\n|so=<!-- Сомалийский -->\n|sw=<!-- Суахили-->\n|tab=<!--Табасаранский-->\n|tl=<!-- Тагальский-->\n|tg=<!-- Таджикский-->\n|ty=<!-- Таитянский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=\n|tt.lat=<!--Татарский (лат.)-->\n|ttt=<!--Татский-->\n|te=<!-- Телугу-->\n|bo=<!-- Тибетский-->\n|tir=<!--Тигринья -->\n|art=\n|tpi=<!--Ток-писин-->\n|kim=\n|tn=<!-- Тсвана-->\n|tyv=<!--Тувинский-->\n|tr=\n|tk=\n|udm=<!--Удмуртский-->\n|uz=\n|ug=<!-- Уйгурский-->\n|uk=[[паста]]\n|ur=<!-- Урду-->\n|fo=\n|fi=\n|fr=[[pâte]]\n|fy=<!-- Фризский -->\n|fur=<!--Фриульский-->\n|kjh=<!--Хакасский-->\n|ha=<!-- Хауса -->\n|hi=<!-- Хинди -->\n|hr=\n|chu.cyr=<!--Церковнославянский (кир.)-->\n|chu.glag=<!-- Церковнославянский (глаг.)-->\n|rom=<!--Цыганский-->\n|ce=<!-- Чеченский-->\n|cs=\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|sv=\n|cjs=<!--Шорский-->\n|sco=<!--Шотландский -->\n|ewe=<!--Эве-->\n|evn=<!--Эвенкийский-->\n|myv=<!--Эрзянский-->\n|eo=\n|et=\n|jv=<!-- Яванский -->\n|sah=<!--Якутский -->\n|ja=\n}}\n\n{{перев-блок|пища\n|ain=\n|sq=\n|en={{t|en|pasta}}\n|hy=\n|ast=\n|af=\n|ba=\n|be=\n|bg=\n|bs=\n|br=\n|hu=\n|vi=\n|vro=\n|gl={{t|gl|pasta}}\n|el=\n|ka=\n|da={{t|da|pasta}}\n|he={{t|he|פסטה}}\n|io={{t|io|paste}}\n|ia=\n|is=\n|es=\n|it={{t|it|pasta|f}}\n|kk=\n|krl=\n|ca=\n|ky=\n|zh={{t|zh|意大利粉}}\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|la=\n|lv=\n|lt=\n|mdf=\n|mn=\n|gv=\n|nah=\n|de={{t|de|Nudel}}\n|nl={{t|nl|pasta}}\n|no={{t|no|pasta}}\n|os=\n|pl={{t|pl|pasta|f}}\n|ppol=\n|pt=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|uz=\n|uk=\n|fo=\n|fi={{t|fi|pasta}}\n|fr=\n|hr=\n|cs=\n|sv=\n|eo=\n|et=\n|ja=\n}}\n\n{{перев-блок|стержень шариковой ручки\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en=[[refill]]\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=<!-- Армянский -->\n|ba=<!-- Башкирский -->\n|be=<!-- Белорусский -->\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийский -->\n|br=<!-- Бретонский -->\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|da=<!-- Датский -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=<!-- Немецкий -->\n|no=<!-- Норвежский -->\n|nl=<!-- Нидерландский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украинский -->\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский -->\n|fr=<!-- Французский -->\n|hr=<!-- Хорватский -->\n|cs=<!-- Чешский -->\n|sv=<!-- Шведский -->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|ja=<!--Японский-->\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n=== Анаграммы ===\n* [[Апсат]], [[Патас]], [[тапас]]\n\n<!-- Служебное: -->\n{{improve|ru|примеры|семантика|переводы}}\n{{Категория|язык=ru|Вещества|Пища|}}\n{{длина слова|5|ru}}\n\n= {{-bg-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg |слоги={{по-слогам|па|ста}}|паст}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл}}\n\n==== Значение ====\n# {{помета.|bg}} [[паста]] (аналог. русск. паста 1) {{пример||перевод=}}\n# [[пирожное]] {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:паста|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[бадемова паста]]\n* [[паста за зъби]]\n\n<!-- Служебное: -->\n{{improve|bg|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=bg|Вещества||}}\n{{длина слова|5|bg}}\n\n= {{-mk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ mk |слоги={{по-слогам|па-ста}}|паст}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл}}\n\n==== Значение ====\n# {{помета.|mk}} [[паста]] (аналог. русск. ''паста 1'') {{пример||перевод=}}\n# [[макароны]] {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:паста|mk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n \n\n<!-- Служебное: -->\n{{improve|mk|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=mk|Вещества||}}\n{{длина слова|5|mk}}\n\n= {{-sr-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ sr |слоги={{по-слогам|па-ста}}|паст}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл}}\n\n==== Значение ====\n# {{помета.|sr}} [[паста]] (аналог. русск. ''паста 1'') {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:паста|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n \n\n<!-- Служебное: -->\n{{improve|sr|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=sr|Вещества||}}\n{{длина слова|5|sr}}\n\n= {{-uk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk |слоги={{по-слогам|па-ста}}|паст}}\n\n{{морфо |прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл}}\n\n==== Значение ====\n# {{помета.|uk}} [[паста]] (аналог. русск. ''паста 1'') {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:паста|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n \n\n<!-- Служебное: -->\n{{improve|uk|морфо|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=uk|Вещества||}}\n{{длина слова|5|uk}}\n\n{{multilang|}}"}}