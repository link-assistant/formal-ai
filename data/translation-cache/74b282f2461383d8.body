-->\n|fr=<!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cv=<!-- Чувашский-->\n|cs=<!-- Чешский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|ja=[[桃色]]\n}}\n\n=== Анаграммы ===\n* [[превысокий]]\n\n=== Библиография ===\n* {{ГСРЯ}}\n* {{Академос}}\n* {{Ефремова-2000|Пе́рсиковый|http://rus-yaz.niv.ru/doc/dictionary-efremova/fc/slovar-207-18.htm#zag-77924|}}\n\n{{improve|ru|примеры|переводы}}\n\n{{Категория|язык=ru|Розоцветные|Оранжевый цвет}}\n{{длина слова|10|ru}}"}}