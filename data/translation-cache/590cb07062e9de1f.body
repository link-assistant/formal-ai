n|id=<!-- Индонезийский-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский-->\n|lt=<!-- Литовский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=<!-- Немецкий-->\n|nl=<!-- Нидерландский-->\n|no=<!-- Норвежский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=<!-- Польский-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-->\n|sr=<!-- Сербский (кир)-->\n|sr-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянский (кир)-->\n|cu-Glag=<!-- Старославянский (глаг)-->\n|sw=<!-- Суахили-->\n|tl=<!-- Тагальский-->\n|tg=<!-- Таджикский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Турецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fi=<!-- Финский-->\n|fr=<!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cs=<!-- Чешский-->\n|cv=<!-- Чувашский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|ja=<!--Японский-->\n}}\n\n=== Анаграммы ===\n* [[адов]], [[во]] [[ад]], [[о два]]\n\n=== Метаграммы ===\n* [[года]], [[йода]], [[кода]], [[мода]], [[под]]а, [[рода]], [[сода]], [[хода]]\n* [[вида]]\n* [[воза]], [[вола]], [[вона]], [[вор]]а\n* [[водить|води]]\n\n=== Библиография ===\n* {{Абрамов, 2002}}\n* {{Академос}}\n* {{гсря}}\n* {{БТС}}\n* {{Львов, 2002}}\n* {{Тихонов-2003}}\n* \n\n{{прочее-блок\n|частотность=B\n|сводеш=150\n|анаграммы = адов, [[во]] [[ад]], о два (кислород)\n|метаграммы = \n** года, йода, кода, мода, [[под]]а, рода, сода, хода\n** вида\n** воза, вола, вона, [[вор]]а\n** [[водить|води]]\n|граф=Метаграммы вода.svg\n}}\n\n{{improve|ru|примеры|переводы}}\n\n{{Категория|язык=ru|Вода|Безалкогольные напитки|Водоёмы|Оксиды|Соединения водорода|Текст|Биологические жидкости|Природные явления|Возраст|Косметика|||}}\n\n== {{з|ударение=во́да}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|во́да|мо-жо 1a\n|слоги={{по-слогам|во́|да}}\n|st=1\n}}\n\n{{слобр|ru|водить|вод + '''∅''' + а|с0|усеч=1|и=}}\n\n{{морфо-ru|вод|-∅|+а|и=}}\n\n=== Произношение ===\n{{transcriptions-ru|во́да|во́ды||Ru-во́ды 1.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{детск.|ru}} тот, кто [[водить|водит]] в игре в [[прятки]], [[салочки]] {{итп}} {{пример|Великан голодный ищет, // Кто ему сгодится в пищу, // Звери спрятались в кусты — // Значит, {{выдел|во́дой}} будешь ты!||1000 стихов, считалок, скороговорок, пословиц для чтения до́ма и в детском саду́|2013|ответственный=Сост. В. Дмитриева|и=GB}}\n# \n\n==== Синонимы ====\n# [[водящий]], [[ведущий]] <!-- [[водила]] ?-->\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# [[игрок]]\n# \n\n==== Гипонимы ====\n# —\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=водить\n|наречия=\n|предикативы=\n|предлоги=\n|полн=вес-вод\n|lang=ru\n}}\n\n=== Этимология ===\n{{через|гл|водить|ru|тип=s}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарский -->\n|en={{t|en|tagger}}\n|ar=<!-- Арабский-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->\n|ba=<!-- Башкирский-->\n|be=<!-- Белорусский-->\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=<!-- Венгерский-->\n|vi=<!-- Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=<!-- Греческий-->\n|ka=<!-- Грузинский-->\n|da=<!-- Датский-->\n|he=<!-- Иврит-->\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский-->\n|lt=<!-- Литовский-->\n|mk=<!-- Македонский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=<!-- Немецкий-->\n|nl=<!-- Нидерландский-->\n|no=<!-- Норвежский-->\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=<!-- Польский-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-->\n|sr=<!-- Сербский (кир)-->\n|sr-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянский (кир)-->\n|cu-Glag=<!-- Старославянский (лат)-->\n|tl=<!-- Тагальский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Турецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fi=<!-- Финский-->\n|fr=<!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cs=<!-- Чешский-->\n|cv=<!-- Чувашский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|sah=<!--Якутский-->\n|ja=<!--Японский-->\n}}\n\n=== Анаграммы ===\n* [[адов]], [[во]] [[ад]], [[о два]]\n\n=== Метаграммы ===\n* [[года]], [[йода]], [[кода]], [[мода]], [[под]]а, [[рода]], [[сода]], [[хода]]\n* [[вида]]\n* [[воза]], [[вола]], [[вона]], [[вор]]а\n* [[водить|води]]\n\n=== Библиография ===\n* \n\n{{improve|ru|}}\n\n{{прочее-блок\n|частотность=\n|анаграммы = адов, [[во]] [[ад]], о два (кислород)\n|метаграммы = \n** года, йода, кода, мода, [[под]]а, рода, сода, хода\n** вида\n** воза, вола, вона, [[вор]]а\n** [[водить|води]]\n|граф=Метаграммы вода.svg\n}}\n\n{{Категория|язык=ru|Игроки||}}\n{{длина слова|4|ru}}\n\n= {{-bg-}} =\n{{wikipedia|lang=bg|Вода}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg f 41|вод|слоги={{по-слогам|во|да́}}}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcription|vɔˈda}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} в значении 1 ([[влага]]) и 2 ([[H₂O]]) {{пример|И тутакси като възлязваше от {{выдел|водата}} видя че се разтваряха небесата, и Духът като гълъб слязваше на него. ||Цариградска Библия|1871|ч=Евангелие от Марка 1:10|||перевод=И когда выходил из {{выдел|воды}}, тотчас увидел Иоанн  разверзающиеся небеса и Духа, как голубя, сходящего на Него.}}\n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=воденица, вододел, водоливник, вододайка, водомер, водомерка, водород\n|прилагательные=воден, воднист, вододаен, водоносен\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=bg\n}}\n\n=== Этимология ===\nОт {{этимология:вода|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n{{table-top|ffffff}}\n\n* [[като две капки вода]]\n* [[по-тих от водата, по-нисък от тревата]]\n* \n\n{{table-bot}}\n\n=== Библиография ===\n* \n\n{{improve|bg|}}\n\n{{Категория|язык=bg|Вода||}}\n{{длина слова|4|bg}}\n\n= {{-orv-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ orv f *ā\n|основа=вод\n|слоги={{по-слогам|во|да}}\n}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} в значении 1 ([[влага]]) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=orv\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:вода|orv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|orv|транскрипция/мн|пример}}\n\n{{Категория|язык=orv|Вода||}}\n{{длина слова|4|orv}}\n\n= {{-mk-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ mk f|слоги={{по-слогам|во|да}}|вод}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} в значении 1 ([[влага]]) и 2 ([[H₂O]]) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водород\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=mk\n}}\n\n=== Этимология ===\nОт {{этимология:вода|mk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|mk|транскрипция/мн|пример}}\n\n{{Категория|язык=mk|Вода||}}\n{{длина слова|4|mk}}\n\n= {{-rue-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ rue f ina\n|основа=вод\n|слоги={{по-слогам|во|да́}}\n}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} 1 ([[влага]]) и 2 ([[H₂O]]) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водник, водоєм, водка\n|прилагательные=водный, водяный\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=rue\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:вода|rue}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|rue|транскрипция/мн|пример}}\n\n{{Категория|язык=rue|Вода||}}\n{{длина слова|4|rue}}\n\n= {{-sr-}} =\n{{wikipedia|lang=sr|Вода}}\n\n=== Морфологические и синтаксические свойства ===\n{{морфо||вод||а}}\n\n{{падежи sr\n|Номинатив (ед)=вода\n|Номинатив (мн)=воде\n|Генитив (ед)=воде\n|Генитив (мн)=вода\n|Датив (ед)=води\n|Датив (мн)=водама\n|Акузатив (ед)=вода\n|Акузатив (мн)=воде\n|Вокатив (ед)=водо\n|Вокатив (мн)=воде\n|Инструментал (ед)=водом\n|Инструментал (мн)=водама\n|Локатив (ед)=водом\n|Локатив (мн)=водама\n|слоги={{по-слогам|во|да}}\n|род=женский\n}}\n\n=== Произношение ===\n{{transcription|ˌvɔda}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} 1 ([[влага]]) и 2 ([[H₂O]]) {{пример|{{выдел|Вода}} је неопходна за живот||перевод={{выдел|Вода}} необходима для жизни.}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водоноша, водњикав, воденица, водоник\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=sr\n}}\n\n=== Этимология ===\nОт {{этимология:вода|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|sr|морфология/шаблон}}\n\n{{Категория|язык=sr|Вода||}}\n{{длина слова|4|sr}}\n\n= {{-slovio-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ slovio-c|слоги={{по-слогам|во|да}}|осн-к=вода|осн-л=voda|род=ж|морфо={{морфо|корень1=вод|оконч=а}}}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водица\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=slovio\n}}\n\n=== Этимология ===\nОт {{этимология:вода|slovio}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|slovio|транскрипция/мн|пример}}\n\n{{Категория|язык=slovio|Вода||}}\n{{длина слова|4|slovio}}\n\n= {{-cu-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ cu (-а)|основа=вод|слоги={{по-слогам|во|да}}|alt=ⰲⱁⰴⰰ}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} в значении 1 ([[влага]]) {{пример||перевод=}}\n# [[потоп]], [[наводнение]] {{пример||перевод=}}\n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водица\n|прилагательные=водьнъ\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=cu\n}}\n\n=== Этимология ===\nОт {{этимология:вода|cu}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|cu|транскрипция/мн|пример|семантика}}\n\n{{Категория|язык=cu|Вода|}}\n{{длина слова|4|cu}}\n\n= {{-uk-}} =\n{{wikipedia|lang=uk|Вода}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk f ina 1b|слоги={{по-слогам|во|да́}}|вод|вод}}\n\n{{морфо||вод||а}}\n\n=== Произношение ===\n{{transcriptions|vɔˈdɑ|vɔˈdɪ|Uk-вода.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример|{{выдел|Вода}} має величезне значення в житті людини, тварин і рослин.||перевод={{выдел|Вода}} имеет огромное значение в жизни человека, животных и растений.}}\n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=водиця, водичка, водиченька\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=водень, електроводонагрівач, водогін, водомір, водолаз, водопій\n|прилагательные=водневий, водний\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n|lang=uk\n}}\n\n=== Этимология ===\nОт {{этимология:вода|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n{{Фразеологизмы|\n* ані за холодну воду\n* [[багато води спливло|багато/чимало води спливло/сплило/упливло/утекло]]\n* буря у склянці води\n* варити воду\n* в вогонь і в воду\n* взяла вода\n* [[вивести на свіжу воду|вивести на свіжу/чисту воду]]\n* вийти сухим з води\n* [[вилами по воді|вилами по воді (писано)]]\n* [[в ложці води не піймаєш|в ложці води не піймаєш/спіймаєш]]\n* вода не відсвятиться/і вода відсвятиться\n* [[водою не розілляти|водою не розілляти/розлити]]\n* воду товкти\n* все одно з мосту та в воду\n* втопити в ложці води\n* грішна вода\n* кінці в воду\n* з роси та з води\n* і води не замутить/не закаламутити води\n* і за холодну воду братись\n* іти проти води\n* каламутити воду\n* канути у воду\n* краще з мосту та в воду\n* линути холодною водою/лити холодну воду за комір\n* лити воду на млин\n* лізти у воду, не знаючи броду\n* [[ловити рибу в мутній воді|ловити рибу в мутній/каламутній воді]]\n* лопнути, як булька на воді\n* [[носити воду решетом|носити/міряти воду решетом]], решетом у воді зірки ловити\n* мов вода вмила\n* мов камінь у воду\n* мов облитий зимною водою/мов холодною водою обдати\n* набрати води в рот/як води в рот набрати\n* на ясні зорі, на тихі води\n* не братися ані за холодну воду\n* немає промитої води\n* [[перебиватися з хліба на воду|перебиватися з хліба/юшки на воду]]/посадити на хліб та воду\n* пливти, куди вода несе\n* [[пройти вогонь і воду|пройти (крізь) вогонь і воду (і мідні труби)]]\n* [[сьома вода на киселі|сьома/десята вода на киселі]]\n* [[тихший води, нижчий трави|тих(і)ший (від) води, нижчий (від) трави]]\n* товкти воду в ступі\n* хоч води напийся\n* хоч водою розливай\n* хоч з гори та в воду\n* [[хоч з лиця води напийся|хоч з лиця води пий/напийся]]\n* хоч у воду стрибай\n* чистісінької води/чистої води\n* як вода змила\n* як водою облитий\n* як дві каплі води\n* як дідько свяченої води\n* [[як з гусака вода|як з гусака/гуски вода]]\n* як линули водою з льодом\n* як лист за водою\n* як плюнути на воду\n* як риба з водою/як риба у воді\n* як скупаний у мертвій воді\n* [[як у воду глянути|як у воду глянути/дивитися]]\n* як у воду опущений/як у воду шубовснути\n}}\n\n=== Библиография ===\n* \n\n{{improve|uk|}}\n\n{{Категория|язык=uk|Вода||}}\n{{длина слова|4|uk}}\n\n= {{-chu-ru-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ chu-ru |слоги={{по-слогам|вода}}|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=chu-ru|}}\n\n==== Значение ====\n# {{as ru}} {{пример|а҆́зъ ѹ҆́бѡ крести́хъ вы̀ {{выдел|водо́ю}}: то́й же крⷭ҇ти́тъ вы̀ дх҃омъ ст҃ы́мъ.|перевод=я крестил вас {{выдел|водою}}, а Он будет крестить вас Духом Святым.||Елизаветинская Библия|часть=Ѿ ма́рка ст҃о́е бл҃говѣствова́нїе а҃:и҃||дата издания=1751}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n|lang=chu-ru\n}}\n\n=== Этимология ===\nИз {{этимология:вода|chu-ru}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|chu-ru|морфо|транскрипция/мн}}\n\n{{Категория|язык=chu-ru|Вода||}}\n{{длина слова|4|chu-ru}}\n\n{{multilang|10}}\n\n{{Избранная статья}}"}}