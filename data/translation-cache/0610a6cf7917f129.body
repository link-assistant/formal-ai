n|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\n|haw=\n|ht=\n|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|bat-smg=\n|zza=\n|zu=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=[[territorio]]\n|it=\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co=\n|xh=\n|crh=\n|ku=\n|km=\n|lad=\n|lo=\n|la=\n|lez=\n|lv=\n|li=\n|ln=\n|lt=\n|lb=\n|mk=[[краj]] {{m}}\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|de=\n|yrk=\n|nl=\n|dsb=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=[[regiune]]\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|so=\n|cu-Сyrl=\n|cu-Glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=[[kray]], [[eyalet]]\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=[[kraï]] {{m}}, [[région]] {{f}}\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=\n|rom=\n|ce=\n|cs=\n|cv=\n|sv=[[kraj]]; [[region]], [[provins]], [[landskap]], [[område]]\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo=\n|et=\n|jv=\n|sah=\n|ja=(行政単位) [[地方]] (chihō), [[クライ]] (kurai)\n}}\n\n=== Библиография ===\n* {{гсря}}\n* {{ак}}\n* {{вт-д|Край}}\n* {{Ушаков|край|feb=11/us1e9504|том=1|стб=1495.}}\n* {{статья|автор = Мартемьянов Ю. С. |заглавие = Заметки о строении ситуации и форме её описания |ссылка =  |автор издания = [Розенцвейг В. Ю.] |издание = Машинный перевод и прикладная лингвистика |тип =  |место = М. |издательство = I МГПИИЯ |год = 1964 |выпуск = 8 |страницы = 129 |isbn =  |doi =}}\n* {{Ожегов-Шведова-1949-1992|край|https://archive.li/Q8pdR|}}\n* {{МАС2|статья=край¹|ссылка=https://feb-web.ru/feb/mas/mas-abc/11/ma211903.htm\n|том=2. К—О|страницы=119}}\n* {{МАС2|статья=край²|ссылка=https://feb-web.ru/feb/mas/mas-abc/11/ma211904.htm\n|том=2. К—О|страницы=119}}\n* {{Ефремова-2000|край|https://web.archive.org/web/20250514021735/https://dic.academic.ru/dic.nsf/efremova/178253/Край|}}\n* {{Дмитриев-2003|край|https://web.archive.org/web/20241004071538/https://dic.academic.ru/dic.nsf/dmitriev/1975/край|}}\n* {{статья|автор = Мартемьянов Ю. С. |заглавие = Заметки о строении ситуации и форме её описания |ссылка =  |автор издания =  |издание = Логика ситуаций. Строение текста. Терминологичность слов |тип =  |место = М. |издательство = Языки славянской культуры |год = 2004 |выпуск =  |страницы = 106 |isbn =  |doi =}}\n* {{бтс-2014}}\n\n{{прочее-блок\n|частотность = \n|анаграммы = \n|метаграммы = \n}}\n\n{{improve|ru|}}\n\n{{Категория|язык=ru|Граница|Края||}}\n{{длина слова|4|ru}}\n\n= {{-be-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ be m|слоги={{по-слогам|край}}|соотв=||}}\n\n{{морфо|прист1=|корень1=край|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|[kraɪ̯]|}}\n\n=== Семантические свойства ===\n{{илл||}}\n\n==== Значение ====\n# {{помета.|be}} {{as ru|1}} {{пример|Haш poдны бeлapycкi кpaй.|автор=Иван Данилович Сипаков|перевод=Наш родной белорусский край.|титул=Янка Сипако́в}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# —\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:край|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|be|}}\n{{Категория|язык=be|Граница||}}\n{{длина слова|4|be}}\n\n= {{-bg-}} =\n{{Омонимы|bg|2}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ bg m 36|слоги={{по-слогам|кра}}|кра|кра}}\n\n{{морфо|прист1=|корень1=край|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|krai}}\n\n=== Семантические свойства ===\n{{илл||}}\n\n==== Значение ====\n# {{помета.|bg}} {{as ru|1}} [[конец]] {{пример||перевод=}}\n# {{помета.|bg}} {{as ru|2}} {{пример||перевод=}}\n# {{помета.|bg}} {{as ru|3}} {{пример||перевод=}}\n\n==== Синонимы ====\n# [[завършек]]\n# [[покрайнина]]\n# [[област]]\n# \n\n==== Антонимы ====\n# [[начало]]\n# ?\n# —\n\n==== Гиперонимы ====\n# ?\n# ?\n# ?\n\n==== Гипонимы ====\n# —\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=краен\n|числительные=\n|глаголы=\n|наречия=крайно\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:край|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|пример}}\n{{Категория|язык=bg|||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{prep bg\n|слоги={{по-слогам|край}}\n}}\n\n{{морфо |прист1=|корень1=край|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[у]], [[возле]], [[около]] {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# ?\n# \n# \n\n==== Антонимы ====\n# ?\n# \n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:край|bg}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|bg|транскрипция|пример}}\n{{Категория|язык=bg|Конец|Граница||}}\n{{длина слова|4|bg}}\n\n= {{-uk-}} =\n{{Омонимы|uk|2}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ uk m ina 6c|слоги={{по-слогам|край}}|соотв=кра|кра́|кра}}\n\n{{морфо|прист1=|корень1=край|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|kraj||Uk-край.ogg}}\n\n=== Семантические свойства ===\n{{илл||}}\n\n==== Значение ====\n# край; [[граница]]; (часть поверхности, противополагаемая началу или середине) [[конец]]; (удалённая от центра часть местности) [[окраина]]; (у острова, полуострова) [[оконечность]]; (боковая часть дороги, леса) [[обочина]]; {{спец.|uk}} (загнутая боковая кромка) [[закраина]] {{пример||перевод=}}\n# [[конец]]; [[предел]] {{пример||перевод=}}\n# [[территория]], [[страна]], [[сторона]], край, [[предел]]; [[местность]], чем-нибудь характеризующаяся (всегда с зависимым род. п.) [[область]] {{пример||перевод=}}\n# [[окончание]] жизни; [[смерть]], [[кончина]] {{пример||перевод=}}\n# [[заключение]], [[прекращение]] некоего действия, состояния {{пример||перевод=}}\n\n==== Синонимы ====\n# ?\n# ?\n# ?\n# ?\n# ?\n\n==== Антонимы ====\n# ?\n# ?\n# —\n# ?\n# ?\n\n==== Гиперонимы ====\n# ?\n# ?\n# ?\n# ?\n# ?\n\n==== Гипонимы ====\n# —\n# —\n# —\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nОт {{этимология:край|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[через край]]\n* [[краєм вуха чути]]\n* [[передній край]]\n* [[рідний край]]\n\n<!-- Служебное: -->\n{{improve|uk|пример}}\n{{Категория|язык=uk|||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{prep uk\n|слоги={{по-слогам|край}}\n}}\n\n{{морфо |прист1=|корень1=край|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[у]], [[возле]], [[около]], [[подле]]; [[при]]; [[край]] {{пример||перевод=}}\n\n==== Синонимы ====\n# [[біля]], [[коло]], [[побіля]], [[попри]], [[поблизу]], [[при]], [[окрай]], [[близько]]\n\n==== Антонимы ====\n# ?\n\n==== Гиперонимы ====\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:край|uk}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|uk|транскрипция|пример|семантика?}}\n{{Категория|язык=uk|Граница||}}\n{{длина слова|4|uk}}\n\n= {{-chu-ru-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ chu-ru m ina 6a|кра́|кра̑|слоги={{по-слогам|кра́й}}}}\n\n{{морфо|прист1=|корень1={{Chu-cyrs|край}}|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример|lang=chu-ru|(и҆) пристꙋ́пльши созадѝ, коснꙋ́сѧ {{выдел|кра́ѧ}} ри́зъ є҆гѡ̀: и҆ а҆́бїе ста̀ то́къ кро́ве є҆ѧ̀.|перевод=подойдя сзади, коснулась {{выдел|края}} одежды Его; и тотчас течение крови у ней остановилось.||Елизаветинская Библия|часть={{Cyrs|Ѿ лꙋкѝ ст҃о́е бл҃говѣствова́нїе и҃:м҃д}}||дата издания=1751}}\n# [[берег]] {{пример|lang=chu-ru|И҆́же є҆гда̀ и҆спо́лнисѧ, и҆звлеко́ша и҆ на {{выдел|кра́й}}, и҆ сѣ́дше и҆збра́ша дѡ́брыѧ въ сосꙋ́ды, а҆ ѕлы̑ѧ и҆зверго́ша во́нъ.|перевод=который, когда наполнился, вытащили на {{выдел|берег}} и, сев, хорошее собрали в сосуды, а худое выбросили вон.||Елизаветинская Библия|часть={{Cyrs|Ѿ матѳе́а ст҃о́е бл҃говѣствова́нїе г҃і:м҃и}}||дата издания=1751}}\n# [[земля]], [[страна]] {{пример||перевод=}}\n\n==== Синонимы ====\n# —\n# ?\n# ?\n\n==== Антонимы ====\n# ?\n# ?\n# —\n\n==== Гиперонимы ====\n# ?\n# ?\n# ?\n\n==== Гипонимы ====\n# —\n# —\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:край|chu-ru}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|chu-ru|транскрипция/мн|примеры}}\n{{Категория|язык=chu-ru|Граница}}\n{{длина слова|4|chu-ru}}\n{{multilang|5}}"}}