\n|jbo=[[rectu]]\n|mk=[[месо]] {{n}}\n|ms=[[daging]]\n|ml=[[മാംസം]] (māmsam)\n|mt=[[laħam]] {{m}}\n|mdf=[[сиволь]], [[пал]]\n|mn=[[мах]]\n|gv=\n|nv=[[atsįʼ]]\n|nah=\n|na=\n|de=[[Fleisch]] {{n}}\n|nl=[[vlees]] {{n}}\n|dsb=[[měso]] {{n}}\n|nog=[[эт]]\n|no=[[kjøtt]] {{n}}\n|nn=[[kjøt]] {{n}}\n|oc=[[carn]] {{f}}\n|os=[[фыд]], [[фыдызгъӕл]], [[дзидза]]\n|ota=[[ات]] (et)\n|pa=[[گوشت]] (gośt) {{m}}\n|pap=\n|fa=[[گوشت]] (gušt)\n|pl=[[mięso]] {{n}}\n|pt=[[carne]] {{f}}\n|ps=[[غوښه]] (ǧwëẍa) {{f}}\n|ro=[[carne]] {{f}}\n|rm=[[charn]] {{f}}, [[carn]] {{f}}, [[tgarn]] {{f}}, [[tgern]] {{f}}\n|sa=[[मांसं]] (mā̃san)\n|sr=[[месо]] {{n}}\n|sr-l=[[meso]] {{n}}\n|si=[[මස්]] (mas)\n|sk=[[mäso]] {{n}}\n|sl=[[meso]] {{n}}\n|st=[[nama]]\n|slovio-c=\n|slovio-l=\n|cu=[[мѧсо]] {{n}}\n|sw=[[nyama]]\n|tl=[[karne]], [[laman]]\n|tg=[[гӯшт]]\n|th=[[เนื้อ]] (néua)\n|tly=[[گوژد]] (gužd)\n|ta=[[இறைச்சி]] (iṟaicci)\n|tt=[[ит]]\n|tt.lat=[[it]]\n|te=[[మాంసం]] (māmsam)\n|bo=[[ཤ]] (sha), [[གཟོལ་དཀྲུམ]] (gzol dkrum) (почтительная форма)\n|tpi=[[mit]], [[abus]]\n|art=\n|kim=[[эът]]\n|tyv=[[эът]]\n|tr=[[et]]\n|tk=[[et]]\n|udm=\n|uz=[[goʻsht]]\n|=[[گۆش]] ([[гөш]], [[gösh‍]])\n|uk=[[м'ясо]] {{n}}\n|ur=[[گوشت]] (gośt) {{m}}, [[مانس]] (mā̃ns) {{m}}\n|fo=[[kjøt]] {{n}}\n|fi=[[liha]]\n|fr=[[viande]] {{f}}, [[chair]] {{f}}\n|fy=[[fleis]] {{n}}\n|fur=[[cjar]]\n|hi=[[गोश्त]] (gośt) {{m}}, [[मांस]] (mā̃s) {{m}}, [[माँस]] (mā̃s) {{m}}\n|hr=[[meso]] {{n}}\n|ce=[[жижиг]], [[жижи]]\n|cs=[[maso]] {{n}}\n|cv=[[аш]]\n|sv=[[kött]] {{n}}\n|cjs=\n|evn=[[уллэ]]\n|myv=[[сывель]]\n|eo=[[viando]]\n|et=[[liha]]\n|jv=\n|sah=\n|ja=[[肉]] ([[にく]], niku)\n}}\n\n=== Библиография ===\n* {{гсря}}\n* {{И-Рез||стр=566}}\n\n{{improve|ru|семантика|переводы}}\n\n{{Категория|язык=ru|Мясо||}}\n{{длина слова|4|ru}}"}}