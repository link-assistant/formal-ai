ık)\n|pi=[[maccha]]\n|pa=[[ਮੱਛੀ]] (mačʰčʰī)\n|pap=[[piská]]\n|fa=[[ماهی]] (māhi)\n|pcd=[[pichon]]\n|gem-pro=[[*fiskaz]] m\n|psl=[[*ryba]] {{f}}\n|pl=[[ryba]] {{f}}\n|pt=[[peixe]], [[pescado]]\n|ps=[[کب]] (kab)\n|pms=[[pess]]\n|rap=[[ika]]; [[ma' īto]]\n|rm=[[pesch]]\n|ro=[[peşte]] {{m}}\n|sjd=[[кӯлль]]\n|sm=[[i'a]]\n|sa=[[मत्स्यः]] (matsyaḥ)\n|sc=[[pische]]\n|sva=[[ცუზ]] ‎(cuz), [[კალმახ]] ‎(ḳalmax)\n|ceb=[[isda]]\n|se=[[guolli]]\n|frr=[[Fesk]]\n|sr=[[риба]] {{f}}\n|sr-l=[[riba]] {{f}}\n|st=[[sehlapi]]\n|szl=[[ryba]]\n|syl=[[ꠝꠣꠍ]]\n|si=[[මාළුවා]] ‎(māḷuvā)\n|sd=[[مڇي]] (mačʰī)\n|scn=[[pisci]]\n|sk=[[ryba]] {{f}}\n|sl=[[riba]] {{f}}\n|slovio-c=[[риба]]\n|dum=[[visc]] {{m}}, [[visch]] {{m}}\n|so=[[kaluun]]\n|srn=[[fisi]]\n|cu-Cyrl={{Cyrs|[[рꙑба]]}} {{f}}\n|cu-Glag={{Cyrs|[[ⱃⱏⰺⰱⰰ]]}} {{f}}\n|sw=[[samaki]]\n|su=[[lauk]]; [[ikan]]\n|tab=[[балугъ]]; [[хяд]]; [[чичӀ]], [[чечӀ]] (мелкая)\n|tl=[[isdá]]\n|tg=[[моҳӣ]]\n|ty=[[iʻa]]\n|th=[[ปลา]] (bplaa)\n|tly=[[мој]]\n|ta=[[மீன்]] (mīṉ)\n|tt=[[балык]]\n|ttt=[[гъурзум]]\n|te=[[చేప]] (caepa); [[మత్స్యము]] (matsyamu)\n|tet=[[ikan]]\n|bo=[[ཉ།]] (ña); [[ཉ]] ‎(nya)\n|tir=[[ዓሳ]] (ʿasa)\n|tin=[[чва]]\n|tpi=[[pis]]\n|kim=[[балыӄ]]\n|tn=[[tlhapi]]\n|tyv=[[балык]]\n|tr=[[balık]]\n|tk=[[balyk]]\n|uby=[[psa]]\n|udi=[[чаьли]]\n|udm=[[чорыг]]\n|uz=[[baliq]]\n|ug=[[béliq]] ([[белиқ]])\n|uk=[[риба]] {{f}}\n|ur=[[مچھلی]] (mačlī) {{f}}, [[متسیہ]] (matsya) {{m}}, [[ماہی]] (māhī) {{f}}\n|fo=[[fiskur]] {{m}}\n|fj=[[ika]]\n|fi=[[kala]]\n|fr=[[poisson]] {{m}}\n|fy=[[fisk]] {{c}}\n|fur=[[pes]]\n|ff=[[liingu]]\n|kjh=[[палых]]\n|kca=[[хул’]], [[хул]]\n|ha=[[kifi]] ([[kı̋fı̋]])\n|hi=[[मछली]] (mačlī) {{f}}, [[मत्स्य]] (matsya) {{m}}, [[माही]] (māhī) {{f}}\n|hop=[[paakiw]]\n|hr=[[riba]] {{f}}\n|ddo=[[бесуро]]\n|rom=[[мачё]], [[мачо]]\n|chr=[[ᎠᏣᏗ]] (atsadi)\n|ce=[[чӀара]]\n|cs=[[ryba]] {{f}}\n|cv=[[пулӑ]]\n|ckt=[[ыннээн]]\n|sv=[[fisk]] {{c}}\n|xsr=[[ङेय]] (ṅey)\n|shp=[[huáca]]\n|sn=[[hove]]\n|cjs=[[палық]]\n|sco=[[fish]]\n|ewe=\n|evn=[[олло]]\n|eve=[[олра]]\n|myv=[[кал]]\n|eo=[[fiŝo]]\n|et=[[kala]]\n|yua=[[kay]]\n|jv=[[iwak]], [[ulam]]\n|yai=[[моҳӣ]]\n|sah=[[балык]]\n|ium=[[mbiauz]]\n|ja=[[魚]] ([[さかな]], sakana), [[魚肉]]\n}}\n\n{{перев-блок|добытая, выловленная или выращенная ''рыба'' [I.1.], сохраняемая живой и предназначенная для продажи\n|az=\n|ain=\n|sq=\n|en=\n|hy=\n|ast=\n|af=\n|eu=\n|ba=\n|be=\n|bg=\n|bs=\n|br=\n|hu=\n|vep=\n|vi=\n|vro=\n|gl=\n|el=\n|ka=\n|da=\n|grc=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|is=\n|es=[[pescado]]\n|it=\n|kk=\n|krc=\n|krl=\n|ca=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|ko=\n|co=\n|crh=\n|la=\n|lv=\n|lt=\n|mk=\n|ms=\n|mdf=\n|mn=\n|gv=\n|nah=\n|na=\n|de=\n|nl=\n|no=\n|oc=\n|os=\n|pap=\n|fa=\n|pl=\n|pt=\n|ppol=\n|sr=\n|sr-l=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|chu=\n|sw=\n|th=\n|tt=\n|art=\n|kim=\n|tr=\n|tk=\n|udm=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|hi=\n|hr=\n|cs=\n|cv=\n|sv=\n|cjs=\n|eo=\n|et=\n|sah=\n|ja=\n}}\n\n=== Анаграммы ===\n* [[бары]]\n\n=== Библиография ===\n* \n\n{{improve|ru|}}\n\n{{Категория|язык=ru|Рыбы||}}\n\n== {{з|II}} ==\n{{Лексема в Викиданных|L309315}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru\n|ры́ба\n|f ina 1a\n|слоги={{по-слогам|ры́|ба}}\n}}\n\n{{слобр|ru|-|и=т3}}\n\n{{морфо-ru|рыб|+а|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|ры́ба|ры́бы|Ru-рыба 2.ogg|Ru-рыбы 2.ogg}}\n\n=== Семантические свойства ===\n{{илл|SturgeonTurkmarket.jpg|№=2}}\n\n==== Значение ====\n# {{ед.}} добытая, выловленная {{выдел|рыба}} [I.1., I.2.] в качестве промысла, улова {{пример|Хищнический улов {{выдел|рыбы}} в низовьях Амура скупщиками, отправляющими рыбу в Европу, лишил 5 000 местных рыбаков пропитания.||бк=1|Вести||Новости дня|26 октября 1903|источник=НКРЯ}}\n# {{кулин.|ru}}, {{ед.}} употребляемое в пищу [[мясо]] {{выдел|рыбы}} [I.1., I.2.] {{пример|На столе стоял {{l}} пирог с {{выдел|рыбой}}, пирог с малиной и ещё что-то лежало, что я не мог различить сыздали.|Ф. М. Решетников|бк=1|Очерки обозной жизни|1867|источник=НКРЯ}}\n# {{кулин.|ru}} [[кушанье]], [[блюдо]] приготовленное из мяса {{выдел|рыбы}} [I.1., I.2.] {{пример|Обед весь состоял из {{выдел|рыбы}}: уха, жареная {{выдел|рыба}} и гомар чудовищных размеров и блестящих красок.|И. А. Гончаров|Фрегат {{\"|Паллада}}|1855|источник=НКРЯ}}\n\n==== Синонимы ====\n# ?\n# ?\n# ?\n\n==== Антонимы ====\n# ?\n# ?\n# ?\n\n==== Гиперонимы ====\n# [[улов]]\n# [[мясо]], [[пища]]\n# [[кушанье]], [[еда]]\n\n==== Гипонимы ====\n# ?\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=рыбачить\n|наречия=\n|предикативы=\n|предлоги=\n|полн=рыб\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:рыба|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n==== Пословицы и поговорки ====\n* [[на безрыбье и рак рыба]]\n\n=== Перевод ===\n{{перев-блок|добытая, выловленная {{выдел|рыба}} [I.1., I.2.] в качестве промысла, улова\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарский -->\n|en=<!-- Английский-->\n|ar=<!-- Арабский-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->\n|ba=<!-- Башкирский-->\n|be=<!-- Белорусский-->\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=<!-- Венгерский-->\n|vi=<!-- Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=<!-- Греческий-->\n|ka=<!-- Грузинский-->\n|da=<!-- Датский-->\n|he=<!-- Иврит-->\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский-->\n|lt=<!-- Литовский-->\n|mk=<!-- Македонский-->\n|ms=<!-- Малайс