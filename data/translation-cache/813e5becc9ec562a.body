Военно-морской Словарь |ссылка = |ответственный = |издание = |место = |издательство = EdwART |год = 2010 |том = |страницы = |страниц = |серия = |isbn = |тираж = }}\n* {{Ожегов-Шведова-1949–1992|учение|https://web.archive.org/web/20251010004709/https://dic.academic.ru/dic.nsf/ogegova/255410|}}\n* {{МАС2|статья=учение|ссылка=https://feb-web.ru/feb/mas/mas-abc/20/ma454216.htm|том=4. С—Я|страницы=542}}\n* {{бтс}}\n* {{Ефремова-2000|учение|https://web.archive.org/web/20230225152354/https://dic.academic.ru/dic.nsf/efremova/260500/Учение|}}\n\n{{прочее-блок\n|частотность =\n|анаграммы =\n|метаграммы =\n}}\n\n{{improve|ru|пример|переводы}}\n\n{{Категория|язык=ru|Обучение|Учёба|Результаты действий}}\n\n== {{з|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|уче́ние|с 7a\n|слоги={{по-слогам|у|.|че́|ни|.|е}}\n|коммент=\n|дореф=уче́ніе\n}}\n\n{{тж|тип=wd|[[ученье]]}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{морфо-ru|уч|-ениj|+е|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|уче́ние|уче́ния|Ru-учение.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[совокупность]] теоретических положений какой-либо области знаний {{пример|{{выдел|Учение}} об иммунитете.}}\n# [[система]] [[взгляд]]ов какого-либо [[учёный|учёного]], [[мыслитель|мыслителя]] {{пример|{{выдел|Учение}} Дарвина.}} {{пример|{{выдел|Учение}} Маркса.}} {{пример|{{выдел|Учение}} Конфуция.}}\n# [[совокупность]] [[догмат]]ов какого-либо религиозного культа; [[вероучение]] {{пример|Христианское {{выдел|учение}}.}} {{пример|Суфийское {{выдел|учение}}.}} {{пример|Буддийское {{выдел|учение}}.}}\n\n==== Синонимы ====\n# [[теория]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ученье]]\n# [[доктрина]], [[теория]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ученье]]\n# [[вероучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[вероученье]]\n\n==== Антонимы ====\n# —\n# —\n# —\n\n==== Гиперонимы ====\n# [[совокупность]]\n# [[система]]\n# [[совокупность]]\n\n==== Гипонимы ====\n# ?\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=уч-ук\n}}\n\n=== Этимология ===\nПроисходит {{через|гл|учить|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|совокупность теоретических положений какой-либо области знаний\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ady=<!-- Адыгейский-->\n|az={{t|az|təlim}}, {{t|az|doktrina}}\n|sq={{t|sq|doktrinë|f}}, {{t|sq|mësim|m}}\n|am={{t|am|ትምህርት|tr=təmhərt}}\n|en={{t|en|doctrine}}, {{t|en|theory}}, {{t|en|teaching}}\n|ar={{t|ar|مَذْهَب|tr=maḏhab|m}}, {{t|ar|عَقِيدَة|tr=ʻaqīda|f}}, {{t|ar|نَظَرِيَّة|tr=naẓariyya|f}}\n|an=<!-- Арагонский-->\n|ast={{t|ast|doctrina|f}}\n|hy={{t|hy|ուսմունք|tr=usmunkʻ}}, {{t|hy|դոկտրին|tr=doktrin}}\n|af={{t|af|leerstelling}}, {{t|af|doktrine}}\n|eu={{t|eu|doktrina}}\n|ba={{t|ba|тәғлимәт}}\n|be={{t|be|вучэнне|n}}, {{t|be|дактрына|f}}\n|bn={{t|bn|মতবাদ|tr=môtbad}}, {{t|bn|তত্ত্ব|tr=tôttô}}\n|my={{t|my|အဆုံးအမ|tr=a.hcum:a.ma.}}\n|bg={{t|bg|учение|n}}, {{t|bg|доктрина|f}}\n|bs={{t|bs|učenje|n}}, {{t|bs|doktrina|f}}\n|br={{t|br|kelenadur|m}}\n|cy={{t|cy|athrawiaeth|f}}\n|wa=<!-- Валлонский -->\n|hu={{t|hu|tanítás}}, {{t|hu|doktrína}}\n|hsb={{t|hsb|wučba|f}}\n|vi={{t|vi|học thuyết}}\n|haw=<!-- Гавайский-->\n|ht={{t|ht|doktrin}}\n|gl={{t|gl|doutrina|f}}\n|kl=<!-- Гренландский-->\n|el={{t|el|δόγμα|tr|dógma|n}}, {{t|el|θεωρία|tr|theoría|f}}\n|ka={{t|ka|მოძღვრება|tr=moʒɣvreba}}, {{t|ka|დოქტრინა|tr=dokṭrina}}\n|gu={{t|gu|સિદ્ધાંત|tr=siddhānt|m}}\n|gd={{t|gd|teagasg|m}}\n|da={{t|da|lære|c}}, {{t|da|doktrin|c}}\n|dv=<!-- Дивехи-->\n|grc={{t|grc|δόγμα|tr=dógma|n}}\n|zu=<!-- Зулу-->\n|he={{t|he|תּוֹרָה|tr=torá|f}}, {{t|he|דּוֹקְטְרִינָה|tr=doktrína|f}}\n|yi={{t|yi|לערע|tr|lere|f}}\n|io={{t|io|doktrino}}\n|inh=<!-- Ингушский-->\n|id={{t|id|ajaran}}, {{t|id|doktrin}}\n|ia={{t|ia|doctrina}}\n|ga={{t|ga|tea