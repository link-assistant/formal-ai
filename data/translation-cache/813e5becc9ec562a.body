{"parse":{"title":"учение","pageid":65559,"redirects":[],"wikitext":"{{w}}\n\n= {{-ru-}} =\n{{Омонимы|ru|2}}\n\n== {{з|I}} ==\n{{Лексема в Викиданных|L173874}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|уче́ние|с 7a\n|слоги={{по-слогам|у|.|че́|ни|.|е}}\n|коммент=\n|дореф=уче́ніе\n}}\n\n{{тж|тип=wd|[[ученье]]}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{морфо-ru|уч|-ениj|+е|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|уче́ние|уче́ния|Ru-учение.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{действие|lang=ru|учить}}; [[деятельность]] [[учителя]] {{пример|}}\n# [[результат]] такого действия {{пример|}}\n# {{действие|lang=ru|учиться}}; [[деятельность]] [[ученик]]а в овладении знаниями, умениями и навыками; [[учёба]] {{пример|}}\n# [[результат]] такого действия {{пример|}}\n\n==== Синонимы ====\n# [[обучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[обученье]], [[ученье]]\n# [[научение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ученье]], [[наученье]]\n# [[учёба]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ученье]]; {{сленг|-}} и {{разг.|-}}, {{сниж.|-}}: [[учёбля]]\n# [[научение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ученье]], [[наученье]]\n\n==== Антонимы ====\n# [[ненаучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ненаученье]]\n# [[ненаучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ненаученье]]\n# [[неучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[неученье]]\n# [[ненаучение]]; {{уст.|-}}, {{поэт.|-}} и {{разг.|-}}: [[ненаученье]]\n\n==== Гиперонимы ====\n# [[действие]]; [[деятельность]]\n# [[результат]]\n# [[действие]]; [[деятельность]]\n# [[результат]]\n\n==== Гипонимы ====\n# ?\n# ?\n# ?\n# ?\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=ученьице\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=учебный\n|числительные=\n|местоимения=\n|глаголы=учить, учиться\n|наречия=\n|предикативы=\n|предлоги=\n|полн=уч-ук\n}}\n\n=== Этимология ===\n{{через|гл|учить|тип=s|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|действие по значению гл. учить; деятельность учителя\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ady=<!-- Адыгейский-->\n|az={{t|az|öyrətmə}}, {{t|az|tədris}}\n|sq={{t|sq|mësimdhënie|f}}\n|am={{t|am|ማስተማር|tr=mastämar}}\n|en={{t|en|teaching}}, {{t|en|instruction}}\n|ar={{t|ar|تَعْلِيم|tr=taʻlīm|m}}\n|an=<!-- Арагонский-->\n|ast={{t|ast|enseñanza|f}}\n|hy={{t|hy|ուսուցում|tr=usucʻum}}\n|af={{t|af|onderrig}}\n|eu={{t|eu|irakaskuntza}}\n|ba={{t|ba|уҡытыу}}\n|be={{t|be|навучанне|n}}, {{t|be|выкладанне|n}}\n|bn={{t|bn|শিক্ষাদান|tr=śikkhādān}}\n|my={{t|my|သင်ကြားခြင်း|tr=sangkra:hkrang:}}\n|bg={{t|bg|преподаване|n}}, {{t|bg|учене|n}}\n|bs={{t|bs|podučavanje|n}}\n|br={{t|br|kelenn|m}}\n|cy={{t|cy|dysgu|m}}\n|wa=<!-- Валлонский -->\n|hu={{t|hu|tanítás}}\n|hsb={{t|hsb|wučba|f}}\n|vi={{t|vi|sự dạy}}, {{t|vi|sự giảng dạy}}\n|haw=<!-- Гавайский-->\n|ht={{t|ht|ansèyman}}\n|gl={{t|gl|ensinanza|f}}\n|kl=<!-- Гренландский-->\n|el={{t|el|διδασκαλία|tr|didaskalía|f}}\n|ka={{t|ka|სწავლება|tr=sc̣avleba}}\n|gu={{t|gu|શિક્ષણ|tr=śikṣaṇ|n}}\n|gd={{t|gd|teagasg|m}}\n|da={{t|da|undervisning|c}}\n|dv=<!-- Дивехи-->\n|grc={{t|grc|διδασκαλία|tr|didaskalía|f}}\n|zu=<!-- Зулу-->\n|he={{t|he|הוֹרָאָה|tr=hora'á|f}}\n|yi={{t|yi|לערנען|tr|lernen|n}}\n|io={{t|io|instrukto}}\n|inh=<!-- Ингушский-->\n|id={{t|id|pengajaran}}\n|ia={{t|ia|inseniamento}}\n|ga={{t|ga|teagasc|m}}\n|is={{t|is|kennsla|f}}\n|es={{t|es|enseñanza|f}}\n|it={{t|it|insegnamento|m}}\n|yo=<!-- Йоруба-->\n|kk={{t|kk|оқыту}}\n|xal=<!-- Калмыцкий-->\n|kn={{t|kn|ಬೋಧನೆ|tr=bōdhane}}\n|ca={{t|ca|ensenyament|m}}\n|ky={{t|ky|окутуу}}\n|zh=<!-- Китайский (общ.) -->\n|zh-tw={{t|zh|教學|tr=jiàoxué}}\n|zh-cn={{t|zh|教学|tr=jiàoxué}}\n|ko={{t|ko|가르침|tr=gareuchim}}\n|xh=<!-- Коса-->\n|ku={{t|ku|fêrkirin|f}}\n|ckb={{t|ckb|فێرکردن|tr=fêr kirdin}}\n|km={{t|km|ការបង្រៀន|tr=kaa bɑngriən}}\n|lo={{t|lo|ການສອນ|tr=kān sǭn}}\n|la={{t|la|doctrina|f}}\n|lv={{t|lv|mācīšana|f}}\n|lez=<!