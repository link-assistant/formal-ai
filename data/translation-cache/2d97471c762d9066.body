|mk|покраина|f}}, {{t|mk|провинција|f}}\n|mg={{t|mg|faritany}}\n|ms={{t|ms|wilayah}}, {{t|ms|provinsi}}\n|ml={{t|ml|പ്രവിശ്യ|tr=praviśya}}\n|mt={{t|mt|provinċja|f}}\n|mr={{t|mr|प्रांत|tr=prānta|m}}\n|mn={{t|mn|аймаг}}, {{t|mn|муж}}\n|de={{t|de|Provinz|f}}, {{t|de|Land|n}}\n|ne={{t|ne|प्रदेश|tr=pradeś}}\n|nl={{t|nl|provincie|f}}\n|no={{t|no|provins|m}}\n|oc={{t|oc|província|f}}\n|or={{t|or|ପ୍ରଦେଶ|tr=prôdeśô}}\n|os={{t|os|провинци}}, {{t|os|зæхх}}\n|pa={{t|pa|ਪ੍ਰਾਂਤ|tr=prānt|m}}\n|fa={{t|fa|استان|tr=ostân}}\n|pl={{t|pl|prowincja|f}}, {{t|pl|województwo|n}} (в Польше)\n|pt={{t|pt|província|f}}\n|ro={{t|ro|provincie|f}}, {{t|ro|județ|n}} (в Румынии)\n|sa=\n|sr={{t|sr|покрајина|f}}, {{t|sr|провинција|f}}\n|sr-l={{t|sr|pokrajina|f}}, {{t|sr|provincija|f}}\n|si={{t|si|පළාත|tr=paḷāta}}\n|sk={{t|sk|provincia|f}}, {{t|sk|kraj|m}}\n|sl={{t|sl|pokrajina|f}}, {{t|sl|provinca|f}}\n|sw={{t|sw|mkoa}}\n|ta={{t|ta|மாகாணம்|tr=mākāṇam}}\n|tl={{t|tl|lalawigan}}\n|tg={{t|tg|вилоят|tr=viloyat}}, {{t|tg|устони|tr=ustoni}} (в Иране)\n|th={{t|th|จังหวัด|tr=jang-wàt}}, {{t|th|มณฑล|tr=mon-ton}}\n|tt={{t|tt|өлкә}}, {{t|tt|провинция}}\n|te={{t|te|ప్రాంతం|tr=prāntaṁ}}\n|tr={{t|tr|il}}, {{t|tr|vilayet}}\n|tk={{t|tk|welaýat}}\n|uz={{t|uz|viloyat}}, {{t|uz|provintsiya}}\n|uk={{t|uk|провінція|f}}, {{t|uk|область|f}}\n|ur={{t|ur|صوبہ|tr=ṣūba|m}}\n|fo={{t|fo|landspartur|m}}, {{t|fo|fylki|n}}\n|fi={{t|fi|maakunta}}, {{t|fi|provinssi}}\n|fr={{t|fr|province|f}}, {{t|fr|département|m}} (во Франции)\n|ha={{t|ha|lardi}}\n|hi={{t|hi|प्रांत|tr=prānt|m}}, {{t|hi|सूबा|tr=sūbā|m}}\n|hr={{t|hr|pokrajina|f}}, {{t|hr|provincija|f}}\n|ce={{t|ce|провинци}}\n|cv={{t|cv|провинци}}, {{t|cv|тăрăх}}\n|cs={{t|cs|provincie|f}}, {{t|cs|kraj|m}}\n|sv={{t|sv|provins|c}}, {{t|sv|landskap|n}}\n|eo={{t|eo|provinco}}\n|et={{t|et|provints}}, {{t|et|maakond}}\n|jv={{t|jv|provinsi}}\n|sah=<!-- Якутский-->\n|ja={{t|ja|州|tr=しゅう, shū}}, {{t|ja|省|tr=しょう, shō}} (в Китае), {{t|ja|県|tr=けん, ken}} (в Японии)\n}}\n{{перев-блок|местность, находя