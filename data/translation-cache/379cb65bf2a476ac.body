{"parse":{"title":"студентка","pageid":174447,"redirects":[],"wikitext":"= {{-ru-}} =\n{{Лексема в Викиданных|L167261}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ru f a 3*a\n|основа=студе́нтк\n|основа1=студе́нток\n|слоги={{по-слогам|сту|де́нт|ка}}\n}}\n\n{{морфо-ru|студент|-к|+а|и=т}}\n\n=== Произношение ===\n{{transcription-ru|студе́нтка|Ru-студентка.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{женск.|ru|студент}} {{пример|Больше других мне запомнился рассказ «Не те отношения», про то, как {{выдел|студентка}} Верочка пришла к преподавателю сопромата на дом сдавать зачёт.|Н. Ю. Климонтович|Далее{{-}}везде|2001|источник=НКРЯ}}\n\n==== Синонимы ====\n# частичн.: [[ученица]]\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# [[учащаяся]]\n# \n\n==== Гипонимы ====\n# [[первокурсница]], [[второкурсница]], [[третьекурсница]], [[четверокурсница]]\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=студенточка\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=студент\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=студент\n}}\n\n=== Этимология ===\nПроисходит от сущ. [[студент]], из {{этимология:студент|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|\n|ab=<!-- Абхазский-->\n|av=<!-- Аварский-->\n|ady=<!-- Адыгейский-->\n|az={{t|az|tələbə qız}}\n|sq={{t|sq|studente|f}}\n|am=<!-- Амхарский-->\n|en={{t|en|female student}}, {{t|en|student}} {{t|en|f}}\n|ar={{t|ar|طَالِبَة|tr=ṭāliba|f}}\n|an={{t|an|estudianta|f}}\n|ast={{t|ast|estudiante|f}}\n|hy={{t|hy|ուսանողուհի|tr=usanoġuhi}}\n|af={{t|af|student}}\n|eu={{t|eu|ikasle}}\n|ba={{t|ba|студентка}}, {{t|ba|студент ҡыҙ}}\n|be={{t|be|студэнтка|f}}\n|bn={{t|bn|ছাত্রী|tr=chatrī}}\n|my=<!-- Бирманский-->\n|bg={{t|bg|студентка|f}}\n|bs={{t|bs|studentica|f}}, {{t|bs|studentkinja|f}}\n|br={{t|br|studier|f}}\n|cy={{t|cy|myfyrwraig|f}}\n|wa=<!-- Валлонский-->\n|hu={{t|hu|diáklány}}, {{t|hu|hallgatónő}}\n|hsb={{t|hsb|studentka|f}}\n|vi={{t|vi|nữ sinh viên}}\n|haw=<!-- Гавайский-->\n|ht=<!-- Гаитянский-->\n|gl={{t|gl|estudante|f}}\n|kl=<!-- Гренландский-->\n|el={{t|el|φοιτήτρια|tr=foitítria|f}}, {{t|el|μαθήτρια|tr=mathítria|f}}\n|ka={{t|ka|სტუდენტი ქალი|tr=sṭudenṭi kali}}\n|gu=<!-- Гуджарати-->\n|gd={{t|gd|oileanach|m}}\n|da={{t|da|studine|f}}\n|dv=<!-- Дивехи-->\n|grc=<!-- Древнегреческий-->\n|zu=<!-- Зулу-->\n|he={{t|he|סְטוּדֶנְטִית|tr=studéntit|f}}\n|yi={{t|yi|סטודענטקע|tr|studentke|f}}\n|io={{t|io|studentino}}\n|inh=<!-- Ингушский-->\n|id={{t|id|mahasiswi}}\n|ia={{t|ia|studente}}\n|ga={{t|ga|mac léinn|f}}\n|is={{t|is|nemandi|m}}, {{t|is|stúdent|m}}\n|es={{t|es|estudiante|f}}, {{t|es|alumna|f}}\n|it={{t|it|studentessa|f}}\n|yo=<!-- Йоруба-->\n|kk={{t|kk|студентка}}, {{t|kk|студент қыз}}\n|xal=<!-- Калмыцкий-->\n|kn=<!-- Каннада-->\n|ca={{t|ca|estudiant|f}}\n|ky={{t|ky|студентка}}\n|zh=<!-- Китайский (общ.) -->\n|zh-tw={{t|zh|女學生|tr=nǚxuéshēng}}\n|zh-cn={{t|zh|女学生|tr=nǚxuéshēng}}\n|ko={{t|ko|여학생|tr=yeohaksaeng}}\n|xh=<!-- Коса-->\n|ku={{t|ku|xwendekar|f}}, {{t|ku|şagirt|f}}\n|ckb={{t|ckb|قوتابی|tr=qutabî}}\n|km=<!-- Кхмерский-->\n|lo=<!-- Лаосский-->\n|la={{t|la|studens|f}}\n|lv={{t|lv|student|f}}\n|lez=<!-- Лезгинский-->\n|ln=<!-- Лингала-->\n|lt={{t|lt|studentė|f}}\n|lb={{t|lb|Studentin|f}}\n|mk={{t|mk|студентка|f}}\n|mg=<!-- Малагасийский-->\n|ms={{t|ms|pelajar perempuan}}\n|ml={{t|ml|വിദ്യാർത്ഥിനി|tr=vidyārtthini}}\n|mt=<!-- Мальтийский-->\n|mi=<!-- Маори-->\n|mr={{t|mr|विद्यार्थिनी|tr=vidyārthinī|f}}\n|mn={{t|mn|оюутан бүсгүй}}\n|gv=<!-- Мэнский-->\n|nv=<!-- Навахо-->\n|de={{t|de|Studentin|f}}\n|ne={{t|ne|छात्रा|tr=chātrā}}\n|nl={{t|nl|studente|f}}, {{t|nl|studente|f}}\n|dsb={{t|dsb|studentka|f}}\n|no={{t|no|student|m}}, {{t|no|studine|f}}\n|oc={{t|oc|estudianta|f}}\n|or=<!-- Ория-->\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби-->\n|fa={{t|fa|دانشجو|tr=dânešju}}\n|pl={{t|pl|studentka|f}}\n|pt={{t|pt|estudante|f}}, {{t|pt|aluna|f}}\n|ps=<!-- Пушту-->\n|ro={{t|ro|studentă|f}}\n|sa={{t|sa|छात्रा|tr=chātrā|f}}\n|ceb=<!-- Себуано-->\n|sr={{t|sr|студенткиња|f}}, {{t|sr|студентица|f}}\n|sr-l={{t|sr|studentkinja|f}}, {{t|sr|studentica|f}}\n|si=<!-- Сингальский-->\n|sk={{t|sk|študentka|f}}\n|sl={{t|sl|študentka|f}}\n|sw=<!-- Суахили-->\n|ta=<!-- Тамильский-->\n|tl=<!-- Тагальский-->\n|tg={{t|tg|донишҷӯдухтар}}\n|th={{t|th|นักศึกษา|tr=nák-sʉ̀k-sǎa}}\n|tt={{t|tt|студентка}}, {{t|tt|студент кыз}}\n|te={{t|te|విద్యార్థిని|tr=vidyārthini}}\n|bo=<!-- Тибетский-->\n|tr={{t|tr|kız öğrenci}}, {{t|tr|üniversiteli kız}}\n|tk={{t|tk|studentka}}\n|uz={{t|uz|studentka}}, {{t|uz|talaba qiz}}\n|ug={{t|ug|ستۇدېنت قىز|tr|studënt qiz}}\n|uk={{t|uk|студентка|f}}\n|ur={{t|ur|طالبہ|tr=tāliba|f}}\n|fo=<!-- Фарерский-->\n|fi={{t|fi|naisopiskelija}}, {{t|fi|opiskelijatar}}\n|fr={{t|fr|étudiante|f}}\n|ha=<!-- Хауса-->\n|hi={{t|hi|छात्रा|tr=chātrā|f}}\n|hr={{t|hr|studentica|f}}, {{t|hr|studentkinja|f}}\n|chr=<!-- Чероки-->\n|ce=<!-- Чеченский-->\n|cv={{t|cv|студентка}}\n|cs={{t|cs|studentka|f}}\n|sv={{t|sv|studentska|c}}, {{t|sv|studerande|c}}\n|eo={{t|eo|studentino}}\n|et={{t|et|üliõpilane}}, {{t|et|naisüliõpilane}}\n|jv=<!-- Яванский-->\n|sah=<!-- Якутский-->\n|ja={{t|ja|女子学生|tr=じょしがくせい, joshigakusei}}\n}}\n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ru|}}\n{{Категория|язык=ru|Женщины||}}\n{{длина слова|9|ru}}"}}