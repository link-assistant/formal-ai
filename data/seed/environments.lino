environments
  environment browser
    label "GitHub Pages chat demo"
    runtime "JavaScript + WebAssembly worker"
    seed_path seed/
    memory_store "IndexedDB events object-store"
    memory_export_command "Export memory button (formal-ai-memory.lino, full bundle)"
    bundle_export_command "Export memory button (alias for formal-ai-memory.lino since issue #27)"
    bundle_import_command "Import memory button (drag .lino)"
    tools ("intent_routing" "write_program" "concept_lookup" "fact_lookup" "summarize_conversation" "brainstorm" "coreference" "roleplay" "wikipedia_lookup" "calculator" "http_fetch" "url_navigate" "web_search" "conversation_recall" "read_local_file" "eval_js" "append_memory" "export_memory" "import_memory")
  environment rust_library
    label "formal-ai Rust crate"
    runtime "Rust 2021 edition (compiled in via include_str!)"
    seed_path data/seed/
    memory_store "default native doublets-rs link store; MemoryStore .lino projection with --no-default-features"
    memory_export_command "default_native_link_store()?.export_memory_links_notation / MemoryStore::export_links_notation"
    bundle_export_command "seed::merged_bundle / bundle_with_memory"
    bundle_import_command "default_native_link_store()?.import_memory_links_notation / seed::parse_bundle"
    tools ("intent_routing" "write_program" "concept_lookup" "fact_lookup" "summarize_conversation" "brainstorm" "coreference" "roleplay" "calculator" "recall" "telegram_html" "http_chat")
  environment cli
    label "formal-ai command-line interface"
    runtime "Rust binary (clap + lino-arguments)"
    seed_path "data/seed/ (embedded)"
    memory_store "Local .lino projection on disk (path configurable; imports into native doublets-rs store)"
    memory_export_command "formal-ai memory export --path PATH"
    bundle_export_command "formal-ai bundle export --path PATH"
    bundle_import_command "formal-ai memory import --path PATH"
    tools ("chat" "dataset" "memory" "bundle" "serve" "telegram")
  environment http_server
    label "OpenAI-compatible HTTP API"
    runtime "Rust std HTTP server"
    seed_path "data/seed/ (embedded)"
    memory_store "Per-request only (stateless responses)"
    memory_export_command "GET /v1/bundle (returns formal_ai_seed_bundle)"
    bundle_export_command "GET /v1/bundle"
    bundle_import_command "n/a (use the formal-ai CLI to ingest)"
    tools ("v1_chat_completions" "v1_responses" "v1_graph" "v1_bundle" "telegram_webhook")
  environment desktop
    label "Electron desktop shell"
    runtime "Electron main process; in-process agent by default, optional local Rust HTTP API"
    seed_path "src/web/seed/ mirror plus data/seed/ fallback"
    memory_store "Browser IndexedDB full bundle projection"
    memory_export_command "Export memory button (formal-ai-memory.lino, formal_ai_bundle)"
    bundle_export_command "Export memory button or formal-ai memory export --path PATH"
    bundle_import_command "Import memory button or formal-ai memory import --path PATH"
    start_command "npm run desktop:dev (in-process by default; FORMAL_AI_DESKTOP_SERVER=1 starts formal-ai serve on 127.0.0.1)"
    package_command "npm --prefix desktop run build"
    tool_routing "Permission-gated router (default-deny); http_fetch/read_local_file served by the local process, code_exec/shell routed to konard/box-dind:2.1.1"
    local_sync "Browser IndexedDB reconciled with the native store over /v1/memory/since and /v1/memory/import (demo_memory Links Notation)"
    tools ("desktop_shell" "formal-ai serve" "v1_chat_completions" "v1_graph" "export_memory" "import_memory" "agent_permission_gate" "tool_router" "http_fetch" "read_local_file" "code_exec_box_dind" "memory_sync")
  environment vscode
    label "VS Code extension (desktop + web)"
    runtime "Dual host: Node extension host (desktop/remote) and Web Worker host (vscode.dev/github.dev); in-process agent by default, optional local Rust HTTP API on the Node host"
    seed_path "vscode/dist-web/seed/ when packaged plus data/seed/ in a checkout"
    memory_store "Webview IndexedDB full bundle projection (same as the browser surface)"
    memory_export_command "Export memory button (formal-ai-memory.lino, formal_ai_bundle)"
    bundle_export_command "Export memory button or formal-ai memory export --path PATH (Node host)"
    bundle_import_command "Import memory button or formal-ai memory import --path PATH (Node host)"
    start_command "Install the .vsix or run npm --prefix vscode run dev, then run formal-ai: Open Chat; the local server is opt-in via the formal-ai.server.enabled setting (Node host only)"
    package_command "npm --prefix vscode run package (vsce package)"
    tool_routing "Permission-gated router (default-deny) on the Node host; http_fetch/read_local_file served by the local process, code_exec/shell routed to the configured konard/box-dind:2.1.1 sandbox; the web host stays in-process with no tool execution"
    local_sync "Webview IndexedDB reconciled with the native store over /v1/memory/since and /v1/memory/import on the Node host (demo_memory Links Notation); the web host keeps memory in the browser"
    tools ("vscode_webview" "formal-ai serve" "v1_chat_completions" "v1_graph" "export_memory" "import_memory" "agent_permission_gate" "tool_router" "http_fetch" "read_local_file" "code_exec_box_dind" "memory_sync")
  environment telegram
    label "Telegram bot (polling or webhook)"
    runtime "Rust binary forwarding to the shared engine"
    seed_path "data/seed/ (embedded)"
    memory_store "Telegram chat history (provider-side)"
    memory_export_command "/bundle command (returns the seed bundle)"
    bundle_export_command "/bundle command"
    bundle_import_command "n/a (memory is provider-side)"
    tools ("intent_routing" "write_program" "concept_lookup" "fact_lookup" "summarize_conversation" "brainstorm" "coreference" "roleplay" "html_replies")
  environment docker_microservice
    label "Docker-in-Docker Telegram bot image"
    runtime "Rust binary on konard/box-dind:2.1.1 with an inner Docker daemon"
    seed_path "data/seed/ (embedded in the binary)"
    memory_store "Telegram chat history plus start-command logs under /tmp/start-command/logs/"
    memory_export_command "formal-ai telegram --mode polling (default container command)"
    bundle_export_command "formal-ai bundle export from inside the container"
    bundle_import_command "formal-ai memory import from inside the container"
    tools ("telegram_polling" "telegram_webhook" "start_command" "docker_isolation" "inner_docker_daemon" "bundle" "memory")
migration
  note "Every environment reads from data/seed/. Memory is portable as Links Notation."
  flow browser_to_cli
    note "Click Export memory in the browser, run formal-ai memory import --path <file>"
    file_format "demo_memory Links Notation"
  flow cli_to_browser
    note "Run formal-ai memory export --path <file>, drag <file> into Import memory in the browser"
    file_format "demo_memory Links Notation"
  flow browser_to_browser
    note "Click Export memory in browser A, drag the .lino into Import memory in browser B"
    file_format "formal_ai_bundle Links Notation"
  flow browser_to_desktop
    note "Click Export memory in the browser, drag the .lino into Import memory in the desktop shell"
    file_format "formal_ai_bundle Links Notation"
  flow desktop_to_cli
    note "Click Export memory in the desktop shell, run formal-ai memory import --path <file>"
    file_format "formal_ai_bundle Links Notation"
  flow desktop_local_sync
    note "With FORMAL_AI_DESKTOP_SERVER=1 the desktop shell reconciles its browser memory with the native store automatically over /v1/memory/since and /v1/memory/import"
    file_format "demo_memory Links Notation"
  flow browser_to_vscode
    note "Click Export memory in the browser, drag the .lino into Import memory in the VS Code chat panel"
    file_format "formal_ai_bundle Links Notation"
  flow vscode_local_sync
    note "With the formal-ai.server.enabled setting on, the VS Code Node host reconciles its webview memory with the native store automatically over /v1/memory/since and /v1/memory/import"
    file_format "demo_memory Links Notation"
  flow cli_to_cli
    note "Copy the .lino file between machines and run formal-ai memory import --path <file>"
    file_format "demo_memory Links Notation"
