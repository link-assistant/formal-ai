  body "=ru|Пища|Хлеб|Существительные с вариативным склонением}}\n{{длина слова|4|ru}}\n\n= {{-be-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ be m ina|слоги={{по-слогам|хлеб}}|хлеб}}\n\n{"
  body "{морфо|прист1=|корень1=хлеб|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription||}} {{медиа|Be-хлеб.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}"
  body "\n# \n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собстве"
  body "нные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:хлеб|be}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: "
  body "-->\n{{improve|be|транскрипция/мн|пример|синонимы|гиперонимы}}\n{{Категория|язык=be|Хлеб||}}\n{{длина слова|4|be}}\n\n= {{-sr-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{падежи sr\n|с"
  body "логи={{по-слогам|хле̏б}}\n|alt=hleb\n|nom-sg=хле̏б\n|nom-pl=хлѐбови\n|gen-sg=хлеба\n|gen-pl=хлебова\n|dat-sg=хлебу\n|dat-pl=хлебовима\n|acc-sg=хлеб\n|acc-pl=хлебове\n|ins-sg=хлебом\n|ins-pl=хлебовима\"
  body "n|loc-sg=хлебу\n|loc-pl=хлебовима\n|voc-sg=хлебе\n|voc-pl=хлебови\n|род=мужской\n}}\n\n{{морфо|прист1=|корень1=хлеб|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcription|xlêb|}}\n\n=== Семантически"
  body "е свойства ===\n\n==== Значение ====\n# {{as ru}} {{пример||перевод=}}\n# \n# \n\n==== Синонимы ====\n# [[хљеб]]\n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ===="
  body "\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:хле"
  body "б|sr}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|sr|морфология/шаблон|пример|гиперонимы}}\n{{Категория|язык=sr|Хлеб||}}\n{{длина слова|4|sr}}""}}"

response_0106_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D1%8F%D0%B1%D0%BB%D0%BE%D0%BA%D0%BE&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""яблоко"",""pageid"":3563,""redirects"":[],""wikitext"":""{{wikipedia}}\n{{commons|Apple}}\n{{статья недели|42|2006}}\n{{кандидат в избранные статьи}}\n\n= {{-ru-}} =\n{{Лексема в Викиданных"
  body "|L37724}}\n\n=== Морфологические и синтаксические свойства ===\n\n{{сущ-ru\n|я́блоко\n|с 3a①\n|слоги={{по-слогам|я́б|ло|ко}}\n}}\n\n{{также|стиль=устар.|тип=d|add =в род. п. мн. ч.|формы=''я́блоков''}"
  body "}\n\n{{морфо-ru|яблок|+о|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|я́блоко|я́блоки|Ru-яблоко.ogg}}\n\n=== Семантические свойства ===\n\n{{илл|Red delicious and cross section.jpg|Яблоки [1]}}\"
  body "n\n==== Значение ====\n# [[плод]] [[яблоня|яблони]], [[кисло-сладкий]] [[фрукт]] {{семантика|синонимы=—|антонимы=—|гиперонимы=[[плод]], [[фрукт]]|гипонимы=[[антоновка]], [[анис]], [[штрифель]]}} {{при"
  body "мер|Спелое {{выдел|яблоко}}}} {{пример|Зелёное {{выдел|яблоко}}.}} {{пример|Сладкие {{выдел|яблоки}}.}} {{пример|Сушёные {{выдел|яблоки}}.}} {{пример|Гнилое {{выдел|яблоко}}.}} {{пример|Она поднялась "
  body "до первых ветвей яблони, срывала {{выдел|яблоки}} и ела.|Ю. О. Домбровский|Хранитель древностей|1964|источник=НКРЯ}}\n# {{ботан.|ru}} [[нераскрывающийся]], [[многосемянный]], обычно сочный плод [[груш"
  body "а|груши]], [[яблоня|яблони]], [[айва|айвы]], [[рябина|рябины]] или другого растения семейства розовых подсемейства яблоневых {{семантика|синонимы=—|антонимы=—|гиперонимы=[[орган]], [[плод]], [[фрукт]]"
  body "|гипонимы=—}} {{пример|При созревании {{выдел|яблока}} ткань околоплодника дифференцируется на наружную сочную и внутреннюю хрящевидную или кожистую (у яблони, груши, рябины и др.), иногда она целиком"
  body " становится деревянистой (например, у кизильника).|БСЭ}}\n# {{архит.|ru}} {{п.|ru}} декоративная [[деталь]] в виде сферы в завершении шпиля {{семантика|синонимы=[[кугель]]|антонимы=|гиперонимы=|гипони"
  body "мы=}} {{пример|Шпиль Петропавловского собора завершается {{выдел|яблоком}} и крестом с летящим ангелом.}} {{пример|Стебло, которое выше кугеля, или {{выдел|яблока}}, вкруг котораго Ангел обращается, д"
  body "линою пять футов… {{выдел|Яблоко}}, которое было на шпице колоколни, медное, позолоченное, мерою во округлости во одну сторону пять футов и шесть дюймов, в другую пять футов и два дюйма.|А. И. Богдано"
  body "в|Описание Санктпетербурга |1751|источник=НКРЯ}} {{пример|Как поигрывает солнечный луч в {{выдел|яблоке}} адмиралтейского шпица, будто в золотом шарике, который вертится поверх скачущего водомета!|И. "
  body "И. Лажечников|Ледяной дом|1835|источник=НКРЯ}}\n# {{техн.|ru}} {{п.|ru}} [[противовес]] в виде [[шар]]а на [[рычаг]]е {{семантика|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример|Надъяблочник{{-}}"
  body "чугунная коробка на конце коромысла цилиндрических мехов, в которую вкладывается железное {{выдел|яблоко}} поршневого стержня.|источник=Даль}} {{пример|Жом дубовой окованой с винтами, з гайками и ключ"
  body "ами и {{выдел|яблоки}} медными, в котором жмут и ровняют бумагу 30 р. итого на 64 р.|И. Богданов|Экстракт о взятье в Сенат двух типографских станов из Москвы от библиотекаря Василья Киприанова|1725|ис"
  body "точник=НКРЯ}}\n# {{истор.|ru}} {{п.|ru}} [[навершие]], [[шар]] на конце [[эфес]]а [[меч]]а или другого холодного оружия, исполняющий роль [[противовес]]а и декоративного элемента {{семантика|синонимы="
  body "|антонимы=|гиперонимы=|гипонимы=}} {{пример|Никогда историческим фехтованием не занимался, но мне чисто интуитивно кажется весьма логичным в определённых ситуациях в бою наносить удары эфесом меча как"
  body " кастетом, в частности, {{выдел|яблоком}} в лицо оппонента.|Интернет-форум}}\n# {{истор.|ru}} {{п.|ru}} рабочая часть [[булава|булавы]] и [[шестопёр]]а {{семантика|синонимы=|антонимы=|гиперонимы=|гипо"
  body "нимы=}} {{пример|{{выдел|Яблоко}} булавы украшено золотыми орнаментальными медальонами и увенчано золотым стилизованным венцом, украшенным камнями и эмалью.|источник=GB}}\n# {{истор.|ru}} {{п.|ru}} ра"
  body "сширение на шейке наконечника колющего древкового холодного оружия {{семантика|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример|Копьё чрезвычайно просто по своему устройству: оно состоит из древка"
  body "-ратовища, иногда называемого также искепищем, и железного или булатного («трещат копья харалужные») наконечника, состоящего, в свою очередь, из пера, то есть самого острия, трубки или тульи, куда вст"
  body "авляется древко, шейки{{-}}самой тонкой части между тульёй и пером и у более поздних копий{{-}}{{выдел|яблока}}{{-}}расширения на шейке.|М. М. Денисова, М. Э. Портнов, Е. Н. Денисов|Русское оружие XI–"
  body "XIX вв.|1953|источник=}}\n# круглое пятно на шкуре лошади или другого животного, иногда на одежде {{семантика|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример|Фрак у Ивана Яковлевича (Иван Яковлев"
  body "ич никогда не ходил в сюртуке) был пегий; то есть он был чёрный, но весь в коричнево-жёлтых и серых {{выдел|яблоках}}; воротник лоснился, а вместо трёх пуговиц висели одни только ниточки.|Н. В. Гоголь"
  body "|Нос|1836|источник=НКРЯ}} {{пример|Каждое утро она каталась в своём собственном экипаже на паре серых с {{выдел|яблоками}} жеребцов, с кучером, кафтан которого кругом был опушен котиком.|А. Ф. Писемск"
  body "ий|Масоны|1880|источник=НКРЯ}}\n# {{устар.|ru}} {{t:=|держава}}; символ монархической власти {{семантика|синонимы=|антонимы=|гиперонимы=|гипонимы=}} {{пример|…Прежде ещё посылали Пражмовского к Рагоци"
  body " с короною, скипетром и {{выдел|яблоком}} (державою), призывая его на королевство: всё это знак явной неправды.|С. М. Соловьёв|История России с древнейших времён|1860|источник=НКРЯ}} {{пример|Фёдор, о"
  body "детый в царское облачение с короной на голове, сидел на возвышенном месте и с улыбкою любовался своим скипетром и державным {{выдел|яблоком}}…|Н. И. Костомаров|Русская история в жизнеописаниях её глав"
  body "нейших деятелей|дата=1862–1875 гг.|источник=НКРЯ}}\n\n{{списки семантических связей}}\n\n==== Холонимы ====\n# [[яблоня]], [[сад]]\n# —\n\n==== Меронимы ====\n# [[семя]], [[плодолистик]], [[мякоть]], "
  body "[[кожица]]\n# [[семя]], [[плодолистик]], [[мякоть]], [[кожица]]\n\n=== Родственные слова ===\n\n{{родств-блок\n|умласк=яблочко\n|имена-собственные=\n|фамилии=Яблоков, Яблочков\n|существительные=подъяб"
  body "лочник, яблокорезка, яблочник, яблочница\n|прилагательные=наяблочный, подъяблочный, яблоковидный, яблокообразный, яблокоподобный, яблочный\n|глаголы=\n|наречия=\n|полн=ябл\n}}\n\n=== Этимология ===\nО"
  body "т {{этимология:яблоко}}\n\nПервоначально яблоком называли плод любого [[дерево|дерева]] и [[кустарник]]а (исключая [[ягода|ягоды]], но включая [[орех]]и). Отсюда пошло и библейское ''запретное яблоко'"
  body "'{{-}}т. е. «запретный плод» (не обязательно яблони).\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[адамово яблоко]]\n* [[антоновские яблоки]]\n* [[Большое яблоко]]\n* [[в яблоках]]\n* [[глазно"
  body "е яблоко]]\n* [[Город большого яблока]]\n* [[запретное яблоко]]: ''библ.'' то же, что [[запретный плод]]\n* [[земляное яблоко]]\n* [[китайское яблоко]]\n* [[мясные пирожки с яблоками]]\n* [[яблоко раз"
  body "дора]]\n* [[яблоку негде упасть]]\n\n==== Пословицы и поговорки ====\n* [[яблоко от яблони недалеко падает]]\n\n=== Перевод ===\n{{перев-блок|плод яблони\n|abq=[[чӏва]]\n|ab=[[аҵәа]] (აწºა)\n|av=[[гӏе"
  body "ч]]\n|ave=\n|agh=\n|aja=\n|ady=[[мыӏэрыс]], (шапсугский диалект) [[мые]]\n|az.lat=[[alma]]\n|az.cyr=[[алма]]\n|az.arab=[[آلما]]\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|akz=[[takkólchoba]]\n|sq=[[mollë]]"
  body "\n|als=\n|ale=\n|alt=[[яблок]]\n|alr=[[яплук]]\n|am=[[ፖም]] (pom)\n|en=[[apple]]\n|ar=[[تفاحة]] (tuffāḥâ)\n|an=[[mazana]] {{f}}\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=[[խնձոր]] (ȟnǳor)\n|rup=[[meare]]\n|asm"
  body "=[[আপেল]] (āpel)\n|ast=[[mazana]]; [[poma]]\n|af=[[appel]]\n|bar=\n|bm=\n|eu=[[sagar]]\n|ba=[[алма]]\n|be=[[яблык]]\n|bn=[[সেব]] (seb); [[আপেল]] (āpel)\n|my=[[ပန်းသီး]] (pan:dhi:)\n|bg=[[ябълка]] {{f}"
  body "}\n|bs=[[jabuka]]\n|br=[[aval]]\n|bua=[[яблока]]\n|cy=[[afal]]\n|wa=[[peme]]\n|war=[[mansanas]]\n|hu=[[alma]]\n|vec=[[pomo]]\n|vep=[[jablok]]\n|hsb=[[jabłuko]], [[jabłonko]]\n|vot=[[õuna#Водский|õuna]"
  body "]\n|vo=[[pod]]\n|wo=[[pom]]\n|stq=[[Appel]]\n|vro=[[upin]]\n|vi=[[quả táo]]\n|gag=[[alma]]\n|haw=[[ʻāpala]]\n|ht=[[pòm]]\n|gl=[[mazá]]\n|ze=[[meia]]\n|got=[[𐌰𐍀𐌻𐌿𐍃]] (aplus)\n|kl=[[iipili]]\n|el=[[μήλο"
  body "]] {{n}}\n|ka=[[ვაშლი]] (vashli)\n|gn=[[guavirana’a]]; [[yva]]\n|gu=[[સફરજન]] (sapharajana)\n|gd=[[ubhal]]\n|dar=[[гӏинц]]\n|prs=[[سیب]] (sīb)\n|da=[[æble]]\n|dv=[[އާފަލު]] (āfalu)\n|ang=[[æppel]] {{m"
  body "}}\n|goh=[[apful]] {{m}}\n|grc=[[μῆλον]] (mēlon)\n|non=[[epli]] {{n}}\n|orv=[[аблъко]]\n|cu-Cyrl={{t|cu|аблъко|sc=Cyrs|n}}\n|cu-Glag={{t|cu|ⰰⰱⰾⱏⰽⱁ|sc=Cyrs|n}}\n|chu-ru={{t|chu|аблоко|alt=а҆́блоко|sc=C"
  body "yrs|n}}\n|arz=[[تفاحة]] {{f}} (tuffāḥa)\n|sgs=[[vuobelis]]\n|zza=[[saye]]\n|zu=[[i-apula]]\n|he=[[תפוח]] (tapuach) {{m}}\n|yi=[[עפּל]] (epl)\n|io=[[pomo]]\n|inh=[[ӏаж]]\n|id=[[apel]]\n|ia=[[pomo]], [["
  body "malo]]\n|iu=[[ᑭᒻᒥᓇᐅᔭᖅ]] (kimminaujaq)\n|ik=\n|ga=[[úll]] {{m}}\n|is=[[epli#Исландский|]] {{n}}\n|es=[[manzana]] {{f}}\n|it=[[pomo]]; [[mela]] {{f}}\n|yo=èso òro òyìnbó\n|kbd=[[мыӏэрысэ]]\n|kk=[[алма]]"
  body "\n|xal=[[альмн]]\n|kn=[[ಸೇಬು]] (sēbu)\n|pam=[[mansanas]]\n|kaa=[[alma]]\n|krc=[[алма]]\n|krl=[[juablukku]]\n|ca=[[poma]]\n|csb=[[jabko]]\n|qu=[[mansana]]\n|ky=[[алма]]\n|run=[[ipome]]\n|zh=\n|zh-tw=[["
  body "蘋果]] (píngguǒ)\n|zh-cn=[[苹果]]\n|nan=[[蓬果]] (phōng-kó), [[蘋果]] (pîn-kó), [[lìn-go]]\n|kom=[[улмӧ]], [[яблӧк]]\n|koi=[[яблок]]\n|kok=[[सेबु]] (sebu)\n|kw=[[aval]]\n|ko=[[사과]] (sagwa)\n|co=[[mela]]\n|xh="
  body "[[i-apile]]\n|crh=[[alma]]\n|kum=[[алма]]\n|ku=[[sêv]]; [[سێو]] (sêw)\n|km=[[ផ្លែប៉ោម]] (pʰlæbōm)\n|lad=[[מאנסאנה]] (mansana); [[pom]]\n|lzz=[[უშქირი]] (uşkiri)\n|lbe=[[гьивч]]\n|lo=[[ໝາກປົ່ມ]], [[ໝາກ"
  body "ໂປມ]]\n|ltg=[[uobeļs]]\n|la=[[malum]] {{n}}; [[pomum]]\n|lv=[[ābols]]\n|lez=[[ич]]\n|li=[[appel]]\n|ln=\n|lt=[[obuolys]]\n|jbo=[[plise]]\n|lmo=[[pòmm]]\n|lb=[[Apel]]\n|mk=[[јаболка]] / [[jabolka]]\n|m"
  body "g=[[paoma]], [[pôma]]\n|ms=[[epal]]\n|ml=[[ആപ്പിള്]] (āppiḷ)\n|mt=[[tuffieħa]]\n|mi=[[āporo]]\n|mr=[[सफरचंद]] (sapharacanda)\n|chm=[[олма]]\n|mas=\n|mwl=[[pom]]\n|moh=[[sewahyowane]]\n|mdf=[[мар]] ([["
  body "марь]])\n|mo=[[мэр]]\n|mn=[[алим]]\n|gv=[[ooyl]]\n|nv=[[bilasáana]]\n|gld=[[яблоко#Нанайский|яблоко]]\n|nah=[[xocotl]]\n|na=\n|nio=\n|nap=[[mìlo]], [[méla]]\n|new=\n|de=[[Apfel]] {{m}} -s, Äpfel\n|yrk"
  body "=[[яблоко#Ненецкий|яблоко]]\n|ne=[[स्याउ]] (syāu)\n|nl=[[appel]] {{m}}\n|dsb=[[jabłuko]]\n|nds=[[Appel]]\n|nov=[[pome]]\n|nog=[[алма]]\n|no=[[eple]] {{n}}\n|roa-nor=\n|oc=[[poma]] {{f}}\n|os=(иронский"
  body ") [[фӕткъуы]]; (дигорский) [[фӕткъу]]\n|ota=[[آلما]] (alma), [[الما]] (elma)\n|pi=[[sītāphala]]\n|pa=[[ਸਿਓ]] (sio); [[ਸੇਬ]] (seb)\n|pap=[[apel]]\n|fa=[[سیب]] (sib)\n|pl=[[jabłko]] {{n}}\n|pt=[[maçã]] "
  body "{{f}}\n|ps=[[مڼه]] (maṅâ)\n|pms=[[pom]]\n|rap=\n|ksh=[[Appel]]\n|rm=[[mail]]\n|ro=[[măr]] {{n}}\n|sjd=\n|sm=[['apu]]\n|sa=[[सेवम]]; [[सेवः]] (sevaḥ)\n|sc=[[meba]] (логуд.); [[mela]] (камп., униф.)\n|s"
  body "s=[[li-hhábhula]]\n|se=[[ēppel]]\n|sr=[[јабука]]\n|sr-l=[[jabuka]]\n|sot=[[apole]]\n|szl=[[jabko]]\n|si=[[ඇපල්]] (æpal)\n|sd=[[صوُفُ]] (ṣūfu)\n|scn=[[pumu]]\n|sk=[[jablko]]\n|sl=[[jabolko]]\n|slovio-c"
  body "=[[йаблок]]\n|slovio-l=[[jablok]]\n|so=[[tufaax]]\n|chu.cyr=\n|chu.glag=\n|sw=[[tufaa]]\n|su=[[apel]]\n|tab=[[вич]]\n|tl=[[mansana]]\n|tg=[[себ]]\n|ty=[[ʻāpara]]\n|th=[[แอปเปิล]] (ǣppə̄́n)\n|ta=[[ஆப்ப"
  body "ிளஂ பழம்]] (āppiḷ paḻam)\n|tt.cyr=[[алма]]\n|tt.lat=\n|ttt=[[сиб]] (סאִבּ)\n|te=[[పండు]] (paṃḍu); [[కాయ]] (kāya)\n|tet=\n|bo=[[ཀུ་ཤུ།]] (ku.šu)\n|tir=[[ቱፋሕ]] (tufaḥ); [[ሜለ]] (melä)\n|art=\n|tpi=\n|kim"
  body "=\n|tn=[[apole]]\n|tyv=[[яблок]]\n|tr=[[elma]]\n|tk=[[alma]]\n|udm=[[яблок]]; [[улмо]]\n|ug=[[ئالما]] (ālmā)\n|uz=[[olma]]\n|uk=[[яблуко]]\n|ur=[[سيب]] (sīb/sēb)\n|fo=[[súrepli]]\n|fj=[[yapolo]]\n|fi="
  body "[[omena]]\n|fr={{t|fr|pomme|f}}\n|fy=[[appel]] (apel)\n|fur=[[miluç]]\n|kjh=[[яблоко#Хакасский|яблоко]]\n|ha=\n|hi=[[सेब]] (seba)\n|hr=[[jabuka]]\n|rom=[[пхабай]] ([[пхаба]]); [[aṗái]]; [[ṗabǝ́y]], [["
  body "phabaj]]\n|ch=[[månsåna]]\n|chr=[[ᏒᎦᏔ]] (svgata)\n|ce=[[Ӏаж]]\n|cs=[[jablko]] {{n}}\n|cv=[[пан улми]]; [[улма]]\n|ckt=[[яплок]]\n|sv=[[äpple]] {{n}}\n|xsr=[[स्यउ]] (syau)\n|sn=[[apuro]]\n|cjs=\n|sco=["
