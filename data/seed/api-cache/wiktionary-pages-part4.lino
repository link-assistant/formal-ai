  body "n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|si=\n|sd=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|"
  body "th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=\n|rom=\n|ce=\n|cs=\n|cv=\"
  body "n|sv=\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo=\n|et=\n|jv=\n|sah=\n|ja=\n}}\n\n<!-- Служебное: -->\n{{improve|ru|пример|перевод}}\n{{Категория|язык=ru|||}}\n\n== {{заголовок|ударение=|I}} ==\n\n=== Морфологи"
  body "ческие и синтаксические свойства ===\n{{гл ru 6cXСВ\n|основа =попис\n|основа1 =попиш\n|основа2 =попи́ш\n|основа3 =попи́с\n|слоги={{по слогам|по|пи|са́ть}}\n|соотв=[[писать]]\n}}\n\n{{морфо-ru|по-|пис|"
  body "-а|+ть}}\n\n=== Произношение ===\n{{transcription-ru|пописа́ть}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# провести некоторое время, пиша, записывая что-либо (на бумагу и т. п.) {{при"
  body "мер|}}\n# провести некоторое время, пиша, записывая, фиксируя что-либо с помощью магнитофона, видеокамеры и т. п. {{пример|}}\n\n==== Синонимы ====\n# —\n# —\n\n==== Антонимы ====\n# —\n# —\n\n==== Ги"
  body "перонимы ====\n# —\n# —\n\n==== Гипонимы ====\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|глаголы=писать\n|наречия=\n|по"
  body "лн=\n}}\n\n=== Этимология ===\nИз [[по-]] + [[писать]] (пишу), далее от {{этимология:пишу}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|\n|abq=\n|ab=\n|av=\n|a"
