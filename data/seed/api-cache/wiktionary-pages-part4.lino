  body "{""parse"":{""title"":""пописать"",""pageid"":261758,""redirects"":[],""wikitext"":""= {{-ru-}} =\n{{Омонимы|ru|3|омографы=1}}\n\n== {{заголовок|ударение=попи́сать}} ==\n\n=== Морфологические и синтаксические свой"
  body "ства ===\n{{гл ru 1aСВ\n|основа =попи́са\n|НП=1\n|слоги={{по слогам|по|пи́|сать}}\n}}\n\n{{морфо-ru|по-|пис|-а|+ть}}\n\n=== Произношение ===\n{{transcription-ru|попи́сать}}\n\n=== Семантические свойст"
  body "ва ===\n\n==== Значение ====\n# {{разг.|ru}} [[помочиться]] {{пример|}}\n\n==== Синонимы ====\n# [[сделать пи-пи]] (детск.); [[помочиться]]; [[справить нужду]]; [[поссать]] (груб.)\n\n==== Антонимы =="
  body "==\n# —\n\n==== Гиперонимы ====\n# [[помочиться]]\n\n==== Гипонимы ====\n# [[описаться]]\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительны"
  body "е=писун, писька, пиписька, писуар\n|прилагательные=описанный\n|глаголы=[[писать#пи́сать|пи́сать]], описаться\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:писаю}}\n\n=== Фразеологиз"
  body "мы и устойчивые сочетания ===\n* [[лысый, иди пописай]]\n\n=== Перевод ===\n{{перев-блок|\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|als=\n|ale=\n"
  body "|alt=\n|en=\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|bg=\n|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n"
  body "|vi=\n|gag=\n|haw=\n|ht=\n|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|sgs=\n|zza=\n|zu=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n"
