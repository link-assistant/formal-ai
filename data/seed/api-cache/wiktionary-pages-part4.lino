response_0096_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BF%D1%80%D0%B8%D0%B2%D0%B5%D1%82&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""привет"",""pageid"":110875,""redirects"":[],""wikitext"":""= {{-ru-}} =\n{{Лексема в Викиданных|L150880}}\n{{Лексема в Викиданных|L592368}}\n=== Морфологические и синтаксические свойства =="
  body "=\n{{сущ ru m ina 1a\n|основа=приве́т\n|слоги={{по-слогам|при|ве́т}}\n|дореф=привѣ́тъ\n}}\n\n{{слобр|ru|-|и=}}\n\n{{морфо-ru|привет|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|приве́т|приве́ты|"
  body "Ru-привет.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# обращённое к кому-либо выражение дружелюбия, расположения, добрых пожеланий {{пример|Послать друзьям {{выдел|привет}}.}} {{пр"
  body "имер|Старый бродяга в Аддис-Абебе, // Покоривший многие племена, // Прислал ко мне чёрного копьеносца // С {{выдел|приветом}}, составленным из моих стихов.|[[:w:Гумилёв, Николай Степанович|Н. С. Гумил"
  body "ёв]]|[[:s:Мои читатели (Гумилёв)|Мои читатели]]|1921|источник=Викитека}}\n# {{помета|междомет.}}; {{разг.|ru}} слово, произносимое при встрече (реже — при расставании) в знак доброго расположения или "
  body "вежливости {{пример|{{выдел|Привет}}, как дела?}}\n\n==== Синонимы ====\n# [[приветствие]]\n# {{синонимы:здравствуй}}\n\n==== Антонимы ====\n# частичн.: [[враждебность]], [[проклятие]]\n# [[пока]], [["
  body "до встречи]]\n\n==== Гиперонимы ====\n# —\n# [[приветствие]]\n\n==== Гипонимы ====\n# —\n# —\n\n=== Родственные слова ===\n{{родств-блок\n|умласк=приветик\n|имена-собственные=Привет\n|существительные="
  body "приветствие\n|прилагательные=приветливый, приветственный\n|глаголы=приветствовать\n|наречия=приветливо, приветственно\n}}\n\n=== Этимология ===\nИз {{этимология:привет|да}}\n\n=== Фразеологизмы и усто"
  body "йчивые сочетания ===\n{{Фразеологизмы|\n* братский привет\n* вам привет от\n** тебе привет от\n* горячий привет\n** пламенный привет\n* дружеский привет\n* и — привет\n* ни ответа, ни привета\n* но во"
  body "т только с личным — привет\n** ну, вот только с личным — привет\n* передавать привет / передать привет\n* получить привет\n* послать привет\n* привет от наших штиблет\n** привет от старых штиблет\n* п"
  body "ривет, привет, привет, и утром два привета\n* с приветом\n}}\n\n=== Перевод ===\n{{перев-блок|выражение дружелюбия\n|en=[[greeting]], [[greetings]]; [[regards]], [[compliments]]\n|de=[[hallo]], [[Gruß"
  body "]]\n|os=[[салам]], [[арфӕ]]\n|fr=[[salut]], [[compliment]], [[salutations]]\n|et=[[tervitus]]\n|ja=[[こんにちは]]\n|eo=[[saluto]]\n|sv=[[hälsning]] {{c}}\n|tt=[[сәлам]]\n|pt=[[saudação]]\n}}\n\n{{перев-бло"
  body "к|междометие\n|abq=[[мыш бзи]] (мыш бзи)\n|ady=[[фэсапщи]] (фэсапши)\n|agx=[[салам]] (салам)\n|ain=[[иранкарапте]] (иранкараптэ)\n|ale=[[aang]] (аанг)\n|alt=[[эзендер]] (эзэндэр)\n|aqc=[[варчӀами]] (в"
  body "арчами)\n|ba=[[һаумыһығыҙ]] (хаумыхыгыс)\n|be=[[прывітанне]], [[вітаю]], [[вітаем]]\n|bg=[[привет]]\n|bua=[[сайн байна]] (сайн байна)\n|xcl=[[ողջո՜յն]] (олджойн)\n|en=[[hello]] (хэлло), [[hi]] (хай)\n"
  body "|ce=[[маршалла]] (маршалла)\n|ckt=[[амын еттык]] (амын еттык)\n|cs=[[nazdar]]! [[ahoj]]!\n|cv=[[авани]] (авани)\n|dar=[[салам]] (салам)\n|ddo=[[ассаламу гӀалейкум]] (ассаламу галейкум)\n|dlg=[[дорообо"
  body "]] (дорообо)\n|es=¡[[salud]]! ¡[[hola]]! ¡[[ola]]!\n|eve=[[торова]] (торова)\n|evn=[[дорово]] (дорово)\n|myv=[[шумбрачи]] (шумбрачи)\n|koi=[[здорово]] (здорово)\n|kom=[[чолӧм ]] (чолём)\n|fi=[[päivää]"
  body "] (пяйвяа), [[moi]], [[terve]], [[hei]]\n|id=[[halo]]!\n|inh=[[салам]] (салам)\n|izh=[[tere]] (тэрэ)\n|it=[[ciao]]! [[salve]]!\n|itl=[[торова]] (торова)\n|kbd=[[уузыншэм]] (уузыншэм)\n|xal=[[мендвт]] "
  body "(мэндвт)\n|krc=[[селам]] (сэлам)\n|kum=[[саламалейкум]] (саламалейкум)\n|kok=[[नमस्कारु]] (намаскаару)\n|lbe=[[ча увкра]] (ча увкра)\n|lez=[[хийир]] (хийир)\n|mns=[[пася]] (пася)\n|mdf=[[шумбрачи]] (ш"
  body "умбрачи)\n|krl=[[terveh]] (тэрвех)\n|kjh=[[изен]] (изэн)\n|kca=[[узя]] (узя)\n|kk=[[сәлем]]!\n|hu=[[szia]]!\n|haw=[[aloha kākou]]!\n|ml=[[നമസ്കാരം]] (намаскаарам)\n|sa=[[नमस्ते]] (намастэ)\n|or=[[ନମସ୍"
  body "କର]] (намаскара)\n|el=[[γειά]]! [[χαίρε]]!\n|qu=[[allillanchu]]!\n|la=[[salve]]!\n|lv=[[sveiks]], [[sveiki]]!\n|lt=[[sveikas]]!\n|mg=[[sarasara]]!\n|mi=[[kia ora]]!, [[ooh]]!\n|de=[[hallo]]!\n|nl=[[ha"
  body "llo]]!\n|no=[[hallo]]!\n|pl=[[cześć]]!\n|pt=[[oi]], [[ola]]!\n|ro=[[salut]]! [[noroc]]!\n|sw=[[salam]]! [[wambaje]]!\n|tyv=[[экии]] (экии)\n|ta=[[வணக்கம்]] (ванаккам)\n|te=[[నమస్కారము]] (намаскаарам)\"
  body "n|tk=[[salam]]!\n|tr=[[merhaba]]! [[selâm]]!\n|tt=[[сәлам]]!, [[ать]]!\n|uz=[[salom]]!\n|uk=[[привіт]]!\n|fj=[[bula]]!\n|fr=[[salut]]!\n|eo=[[saluton]]!\n|et=[[tervist]]!, [[tere]]!\n|sv=[[hej]], [[he"
  body "jsan]], [[tjenare]], [[tjena]], [[tjenis]]\n}}\n\n=== Библиография ===\n* {{книга|автор=Добрушина Н. Р., Данова М. К.|часть=Привет|заглавие=Два века в двадцати словах|год=2016|isbn=978-5-7598-1148-0}}"
  body "\n\n{{Категория|язык=ru|Приветствия|Прощания||}}\n[[Категория:Русские междометия]]\n\n{{длина слова|6|lang=ru}}""}}"

response_0097_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BF%D1%80%D1%8F%D0%BD%D0%B8%D0%BA&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""пряник"",""pageid"":164722,""redirects"":[],""wikitext"":""{{commons|Category:Gingerbread}}\n{{wikipedia}}\n= {{-ru-}} =\n{{Лексема в Викиданных|L153459}}\n\n=== Морфологические и синтаксич"
  body "еские свойства ===\n{{сущ ru m ina 3a\n|основа=пря́ник\n|слоги={{по-слогам|пря́|ник}}\n}}\n\n{{морфо-ru|пряник|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|пря́ник|пря́ники|Ru-пряник.ogg}}\n\n=="
  body "= Семантические свойства ===\n{{илл|PL gingerbread from Torun.jpg|Пряники}}\n\n==== Значение ====\n# {{гастрон.|ru}} мучное [[кондитерское изделие]] в виде толстой лепешки на меду, сахаре или патоке с"
  body " добавлением каких-либо пряностей {{пример|Большая семья расселась в кружок перед раскрытой корзинкой, и нянька, ломая на куски тульский {{выдел|пряник}}, наделяла им детей.|К. А. Федин|Первые радости"
  body "|1943–1945||источник=НКРЯ}} {{пример|Она лукаво подмигнула и сунула мне большой медовый {{выдел|пряник}} и глиняную свистульку.|Ф. В. Гладков|Повесть о детстве|1948||источник=НКРЯ}}\n# {{перен.|ru}}, "
  body "{{разг.|ru}} дорога со срезанным [[асфальт]]ным покрытием {{пример|На соседней улице новый асфальт ещё не положили, машины едут по {{выдел|прянику}} и объезжают люки.}}\n#\n\n==== Синонимы ====\n# —\n"
  body "# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# [[кондитерское изделие]]\n# \n\n==== Гипонимы ====\n# [[тульский пряник]]\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=пряничек"
  body "\n|имена-собственные=пряничник, пряничница\n|существительные=\n|прилагательные=пряничный\n|глаголы=\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит {{этимология:пряник|да}}\n\n=== Фразеологизмы и уст"
  body "ойчивые сочетания ===\n* [[кнут и пряник]]\n* [[тульский пряник]]\n** [[ломаться как тульский пряник]]\n\n=== Перевод ===\n{{перев-блок|\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=\n|ay=\n|ai"
  body "n=\n|ain.kana=\n|ain.lat=\n|sq=\n|als=\n|ale=\n|alt=\n|en=\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=[[пернік]] {{m}}\n|bn=\n|bg=\n|bs=\n|br=\n|b"
  body "ua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\n|haw=\n|ht=\n|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|bat-smg=\n|zza=\n|zu=\"
  body "n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co="
  body "\n|xh=\n|crh=\n|ku=\n|km=\n|lad=\n|lo=\n|la=\n|lez=\n|lv=\n|li=\n|ln=\n|lt=\n|lb=\n|mk=\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|de=[[Leb"
