  body "so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=\n|fr=\n|f"
