  body "ки-->\n|zu=<!-- Зулу-->\n|he=<!-- Иврит -->\n|yi=<!-- Идиш-->\n|io=\n|inh=<!--Ингушский-->\n|id=<!-- Индонезийский-->\n|ia=\n|iu=<!-- Инуктитут-->\n|ik=<!-- Инупиак-->\n|ga=<!-- Ирландский-->\n|is=\n|"
  body "es=\n|it=\n|yo=<!-- Йоруба-->\n|kbd=<!--Кабардино-черкесский -->\n|kk=\n|xal=<!--Калмыцкий-->\n|kn=<!-- Каннада-->\n|kaa=<!--Каракалпакский -->\n|krc=<!--Карачаево-балкарский -->\n|krl=\n|ca=\n|csb=<!"
  body "--Кашубский-->\n|qu=<!-- Кечуа -->\n|ky=\n|zh=<!-- Китайский-->\n|zh-tw=\n|zh-cn=\n|kom=<!--Коми-зырянский -->\n|koi=<!--Коми-пермяцкий -->\n|kok=<!--Конкани-->\n|ko=\n|kw=<!-- Корнский -->\n|co=\n|xh"
  body "=<!-- Коса-->\n|crh=<!--Крымскотатарский-->\n|kum=<!--Кумыкский-->\n|ku=<!-- Курдский -->\n|ckb=<!--Курдский (сорани) -->\n|km=<!-- Кхмерский-->\n|lad=<!--Ладино-->\n|lbe=<!--Лакский-->\n|lo=<!-- Лаос"
  body "ский -->\n|la=\n|lv=\n|lez=<!--Лезгинский-->\n|li=<!-- Лимбургский -->\n|ln=<!-- Лингала-->\n|lt=\n|lmo=<!--Ломбардский -->\n|lb=<!-- Люксембургский -->\n|mk=<!-- Македонский -->\n|mg=<!-- Малагасийск"
  body "ий-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам -->\n|mt=<!-- Мальтийский -->\n|mi=<!-- Маори -->\n|chm=<!--Марийский-->\n|mdf=\n|mo=<!-- Молдавский-->\n|mn=\n|gv=\n|nv=<!-- Навахо-->\n|gld=<!--Нанайс"
  body "кий-->\n|nah=\n|na=<!-- Науру -->\n|nio=<!--Нганасанский-->\n|agh=<!--Нгелима-->\n|nap=<!--Неаполитано-калабрийский-->\n|new=<!--Неварский-->\n|de=\n|yrk=<!--Ненецкий -->\n|nl=\n|dsb=<!--Нижнелужицкий"
  body "-->\n|no=\n|oc=<!-- Окситанский -->\n|os=<!-- Осетинский-->\n|pi=<!-- Пали -->\n|pa=<!-- Панджаби -->\n|pap=<!--Папьяменту-->\n|fa=<!-- Персидский-->\n|pl=\n|pt=\n|ps=<!-- Пушту -->\n|pms=<!--Пьемонтс"
  body "кий -->\n|rap=<!--Рапануйский -->\n|rm=<!-- Ретороманский-->\n|ro=<!-- Румынский-->\n|sjd=<!--Саамский (кильдинский)-->\n|sa=<!-- Санскрит -->\n|sc=<!-- Сардинский-->\n|ceb=<!-- Себуано-->\n|se=<!-- С"
  body "еверносаамский-->\n|sr=\n|sr-l=\n|si=<!-- Сингальский -->\n|sd=<!-- Синдхи-->\n|scn=<!--Сицилийский -->\n|sk=\n|sl=\n|slovio-c=<!-- Словио (кир.)-->\n|slovio-l=<!-- Словио (лат.)-->\n|so=<!-- Сомалийс"
  body "кий -->\n|sw=<!-- Суахили-->\n|tab=<!--Табасаранский-->\n|tl=<!-- Тагальский-->\n|tg=<!-- Таджикский-->\n|ty=<!-- Таитянский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=\n|tt.lat=<!--Татарски"
  body "й (лат.)-->\n|ttt=<!--Татский-->\n|te=<!-- Телугу-->\n|bo=<!-- Тибетский-->\n|tir=<!--Тигринья -->\n|art=\n|tpi=<!--Ток-писин-->\n|kim=\n|tn=<!-- Тсвана-->\n|tyv=<!--Тувинский-->\n|tr=\n|tk=\n|udm=<!-"
  body "-Удмуртский-->\n|uz=\n|ug=<!-- Уйгурский-->\n|uk=\n|ur=<!-- Урду-->\n|fo=\n|fi=\n|fr=\n|fy=<!-- Фризский -->\n|fur=<!--Фриульский-->\n|kjh=<!--Хакасский-->\n|ha=<!-- Хауса -->\n|hi=<!-- Хинди -->\n|hr"
  body "=\n|chu.cyr=<!--Церковнославянский (кир.)-->\n|chu.glag=<!-- Церковнославянский (глаг.)-->\n|rom=<!--Цыганский-->\n|ce=<!-- Чеченский-->\n|cs=\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|sv=\n|cj"
  body "s=<!--Шорский-->\n|sco=<!--Шотландский -->\n|ewe=<!--Эве-->\n|evn=<!--Эвенкийский-->\n|myv=<!--Эрзянский-->\n|eo=\n|et=\n|jv=<!-- Яванский -->\n|sah=<!--Якутский -->\n|ja=\n}}\n\n<!-- Служебное: -->\n"
  body "{{improve|ru|пример|переводы}}\n{{Категория|язык=ru|Приветствия||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{interj ru|слоги={{по-слогам|са|лю́т}}}}\n\n{{морфо"
  body "-ru|салют}}\n\n=== Произношение ===\n{{transcription-ru|салю́т|Ru-салют.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{разг.|ru}} используется в качестве приветствия при встрече (р"
  body "еже — при расставании) в знак доброго расположения {{пример|}}\n# \n\n==== Синонимы ====\n# {{синонимы:здравствуй}}\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы"
  body " ====\n# —\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\"
  body "n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nОт {{этимология:салют|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев-блок|\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\"
  body "n|aja=\n|ady=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|als=\n|ale=\n|alt=\n|en=\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|bg=\n"
  body "|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\n|haw=\n|ht=\n|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|sgs=\n|z"
  body "za=\n|zu=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n|kbd=\n|kk=\n|xal=\n|kn=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n"
  body "|ko=\n|co=\n|xh=\n|crh=\n|ku=\n|km=\n|lad=\n|lo=\n|la=\n|lez=\n|lv=\n|li=\n|ln=\n|lt=\n|lmo=\n|lb=\n|mk=\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\"
  body "n|nap=\n|new=\n|de=\n|yrk=\n|nl=\n|dsb=\n|no=\n|oc=\n|os=\n|pa=\n|pap=\n|fa=\n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=\n|sjd=\n|sa=\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|si=\n|sd=\n|sk=\n|sl=\n|slovio-"
  body "c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo"
  body "=\n|fi=\n|fr=\n|fy=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=\n|rom=\n|ce=\n|cs=\n|cv=\n|sv=\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo=\n|et=\n|jv=\n|sah=\n|ja=\n}}\n\n=== Библиография ===\n* {{НСЗ-60}}\n\n<!-- Служебно"
  body "е: -->\n{{improve|ru|пример|перевод}}\n{{Категория|язык=ru|Приветствия|Прощания}}\n{{длина слова|5|ru}}\n\n= {{-ce-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ce |слоги=|основа=|о"
  body "снова1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=ce|}}\n\n==== Значение ====\n# {{помета.|ce}} {{as ru"
  body "}} {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|источник=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?"
  body "\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n\n=== Этимология ===\nИз {{сэ|ru"
  body "|салют|и=ce}}{{этимология:|ce}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{improve|ce|морфо|транскрипция/мн|пример}}\n\n{{Категория|язык=ce|Приветствия||}}\n{"
  body "{длина слова|5|ce}}\n\n{{multilang|2}}""}}"

response_0101_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D1%81%D0%BB%D1%83%D1%88%D0%B0%D1%82%D1%8C&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""слушать"",""pageid"":9812,""redirects"":[],""wikitext"":""= {{-ru-}} =\n{{Лексема в Викиданных|L1097911}}\n\n=== Морфологические и синтаксические свойства ===\n{{гл ru 1a\n|основа=слу́ша\n|"
  body "основа1=слу́ша\n|слоги={{по-слогам|слу́|шать}}\n}}\n\n{{морфо-ru|слуш|-а|+ть|и=т}}\n\n=== Произношение ===\n{{transcription-ru|слу́шать|Ru-слушать.ogg}}\n\n=== Семантические свойства ===\n\n==== Значе"
  body "ние ====\n# [[воспринимать]] звуковую информацию, сосредотачивая на ней [[внимание]] {{семантика|синонимы=частичные: [[внимать]], [[слышать]] (слышать не предполагает сосредоточения внимания)|антонимы"
  body "=[[игнорировать]], [[пропускать мимо ушей]]|гиперонимы=воспринимать|гипонимы=[[вслушиваться]], [[прислушиваться]], [[подслушивать]]}} {{пример|{{выдел|Слушать}} музыку.}} {{пример|{{выдел|Слушать}} ра"
  body "диопередачу.}}\n# [[рассматривать]] и [[обсуждать]] [[вопрос]] или проблему в официальной организации {{семантика|синонимы=[[дебатировать]], [[обсуждать]], [[рассматривать]]|антонимы=откладывать|гипер"
  body "онимы=рассматривать|гипонимы=}} {{пример|{{выдел|Слушать}} дело в суде.}}\n# [[следовать]] чьим-то [[совет]]ам, [[доверять]] чьему-то мнению {{семантика|синонимы=доверять, слушаться|антонимы=|гиперони"
  body "мы=следовать|гипонимы=}} {{пример|Я всегда его {{выдел|слушаю}}.}} {{пример|Не {{выдел|слушайте}} демагогов и шарлатанов!}}\n# [[изучать]], посещая лекции {{семантика|синонимы=изучать|антонимы=пропуск"
  body "ать|гиперонимы=воспринимать|гипонимы=}} {{пример|Но тут узнал я, сколько нужен молодому человеку французский язык, и для тою твердо предпринял и начал учиться оному, а между тем, продолжал латинский, "
  body "на коем {{выдел|слушал}} логику у профессора Шадена, бывшего тогда ректором.|Фонвизин|Чистосердечное признание в делах моих и помышлениях|1798|источник=НКРЯ}}\n# [[выслушивать]] работу внутренних [[ор"
  body "ган]]ов {{семантика|синонимы=выслушивать|антонимы=-|гиперонимы=диагностировать|гипонимы=}} {{пример|{{выдел|Слушать}} вашу грудь, давать вам микстуры ― совершенно напрасно.|Чернышевский|Что делать?|18"
  body "63|источник=НКРЯ}}\n# {{помета|повел. накл.}} выражает [[желание]] привлечь внимания [[собеседник]]а с своей речи {{пример|{{выдел|Слушай}}, поляк, ― сказал незнакомый твёрдым голосом, ― постоялый дво"
  body "р не для тебя одного выстроен; а если тебе тесно, так убирайся сам отсюда.|Загоскин|Юрий Милославский, или русские в 1612 году|1829|источник=НКРЯ}}\n# {{помета|частица}} ''слушаю!'' — [[выражение]] пр"
  body "инятия распоряжения к исполнению {{пример|Вам, как бывшему офицеру, надлежит взяться у них на учёт. ― {{выдел|Слушаю}}. ― Григорий откозырял, ничем не выдав охватившего его волнения.|Шолохов|Тихий Дон"
  body "|1928–1940|источник=НКРЯ}} {{пример|Попросите его приехать ко мне после полудня. ― {{выдел|Слушаю-с}}. Больше никаких приказаний, ваше превосходительство?|К. М. Станюкович|Товарищи|1900|источник=НКРЯ}"
  body "}\n\n{{списки семантических связей}}\n\n=== Родственные слова ===\n{{родств-блок\n|имена-собственные=\n|существительные=слушатель, слушательница, слух, слушание\n|прилагательные=\n|глаголы=слушаться, "
  body "выслушать, заслушать, подслушать; слышать, слышаться, подслушивать, прислушиваться; слыхать, услыхать\n|наречия=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:слушать|да}}\n\n=== Фразеологизмы"
  body " и устойчивые сочетания ===\n* [[слушать пиздой]]\n\n=== Перевод ===\n{{перев-блок|воспринимать звуковую информацию, сосредотачивая на ней внимание\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az="
  body "\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|gsw=\n|ale=\n|alt=\n|en=[[listen]]\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=\n|am=[[ሰማ]]\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|bg=[[слуш"
