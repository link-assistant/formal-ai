response_0056_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%B0%D0%BB%D0%BB%D0%BE&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""алло"",""pageid"":132760,""redirects"":[],""wikitext"":""{{Cf|алло-|ало}}\n{{wikipedia|Алло (значения)}}\n= {{-ru-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{interj ru|{{по"
  body "-слогам|ал|ло́}}}}\n\n{{морфо-ru|алло|и=т}}\n\n=== Произношение ===\n{{transcription-ru|алё|источник=БОС}}\n{{transcription-ru|алло́|LL-Q7737 (rus)-Rominf-алло.wav|источник=БОС}}\n\n=== Семантические "
  body "свойства ===\n\n==== Значение ====\n# при разговоре по телефону означает приветствие: '''слушаю''' {{пример|И тут же вспомнилось, как вчера её муж кричал в трубку: «{{выдел|Алло}}!»|[[w:Муравьёва, Ири"
  body "на Лазаревна|Ирина Муравьёва]]|Мещанин во дворянстве|1994|источник=НКРЯ}}\n\n==== Синонимы ====\n# [[алё]], [[ало]], [[алле]]\n\n==== Антонимы ====\n\n==== Гиперонимы ====\n\n==== Гипонимы ====\n\n==="
  body " Родственные слова ===\n{{родств-блок\n|существительные=\n|глаголы=алёкать\n}}\n\n=== Этимология ===\nПроисходит от {{lang|en|hallo|приветствовать по телефону}}, предложенное Грэхемом Беллом как приве"
  body "тствие при использовании телефона, в русском языке трансформироваллось в {{выдел|алло}}.\n\n=== Фразеологизмы и устойчивые сочетания ===\n\n=== Перевод ===\n{{перев-блок||\n|en=[[hello]]!, [[hullo]]!,"
  body " [[hallo]]!\n|fr=[[allô]]\n|ko=[[여보세요]]?\n|sv=[[hallå]]\n|ka={{t|ka|ალო}}! \n}}\n\n=== Анаграммы ===\n* [[Лало]], [[Лола]]\n\n=== Библиография ===\n{{примечания}}\n\n<!-- Служебное: -->\n{{improve|ru|"
  body "гиперонимы}}\n{{Категория|язык=ru|Телефоны||}}\n[[Категория:Удвоение и без/ru|ало+л]]\n{{длина слова|4|ru}}""}}"

