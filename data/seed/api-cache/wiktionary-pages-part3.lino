  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BD%D0%B0%D0%BF%D0%BE%D0%B8%D1%82%D1%8C&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""напоить"",""pageid"":258051,""redirects"":[],""wikitext"":""= {{-ru-}} =\n{{Омонимы|ru|2}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{гл ru 4c/4b(8)-лС"
  body "В\n|основа=напо\n|основа1=напо́\n|слоги={{по-слогам|на|по|и́ть}}\n|соотв=пои́ть, напаивать#I\n}}\n\n{{морфо-ru|на-|поj|-и|+ть|и=т}}\n\n=== Произношение ===\n{{transcription-ru|напои́ть|Ru-напоить.ogg}"
  body "}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[дать]] [[попить]], [[утолить]] жажду  {{пример|}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ===="
  body "\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=напоение, напоенье\n|прилагательные=\n|числитель"
  body "ные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\n{{произв|ru|п|на|поить}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{перев"
  body "-блок\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en=<!-- Английский -->\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=<!-- Армянский -->\n|ba=<!-- Башкирский -->\n|be=<!-- Белорус"
  body "ский -->\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийский -->\n|br=<!-- Бретонский -->\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Грече"
  body "ский -->\n|ka=<!-- Грузинский -->\n|da=<!-- Датский -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n"
  body "|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\"
  body "n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=<!-- Немецкий -->\n|no=<!-"
  body "- Норвежский -->\n|nl=<!-- Нидерландский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский"
  body " -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украин"
  body "ский -->\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский -->\n|fr=<!-- Французский -->\n|hr=<!-- Хорватский -->\n|cs=<!-- Чешский -->\n|sv=<!-- Шведский -->\n|eo=[[drinkigi]]\n|et=<!--Эстонский-->\n|ja=<!--"
  body "Японский-->\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|slovio-l=<!-- Словио (лат) -->\n}}\n\n=== Библиография ===\n* {{ГСРЯ}}\n\n<!-- Служебное: -->\n{{improve|ru|пример|син"
  body "онимы|гиперонимы}}\n{{Категория|язык=ru|||}}\n\n== {{заголовок|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{гл ru 4bСВ\n|основа=напо\n|основа1=напо́\n|слоги={{по-слогам|на|по|и́ть}}"
  body "\n|соотв=напаивать#I\n}}\n\n{{морфо-ru|на-|поj|-и|+ть|и=т}}\n\n=== Произношение ===\n{{transcription-ru|напои́ть|Ru-напоить.ogg}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# угощая, зас"
  body "тавляя пить спиртные напитки, [[довести]] до опьянения {{пример|}}\n# {{п.|ru}}, {{высок.|ru}} [[наполнить]], [[насытить]] чем-либо {{пример|}}\n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \"
  body "n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|"
