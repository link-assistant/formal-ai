  body "m=<!-- Ретороманский-->\n|ro=<!-- Румынский-->\n|sjd=<!--Саамский (кильдинский)-->\n|sa=<!-- Санскрит -->\n|sc=<!-- Сардинский-->\n|ceb=<!-- Себуано-->\n|se=<!-- Северносаамский-->\n|sr=\n|sr-l=\n|si="
  body "<!-- Сингальский -->\n|sd=<!-- Синдхи-->\n|scn=<!--Сицилийский -->\n|sk=\n|sl=\n|slovio-c=<!-- Словио (кир.)-->\n|slovio-l=<!-- Словио (лат.)-->\n|so=<!-- Сомалийский -->\n|sw=<!-- Суахили-->\n|tab=<!"
  body "--Табасаранский-->\n|tl=<!-- Тагальский-->\n|tg=<!-- Таджикский-->\n|ty=<!-- Таитянский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=\n|tt.lat=<!--Татарский (лат.)-->\n|ttt=<!--Татский-->\n|te"
  body "=<!-- Телугу-->\n|bo=<!-- Тибетский-->\n|tir=<!--Тигринья -->\n|art=\n|tpi=<!--Ток-писин-->\n|kim=\n|tn=<!-- Тсвана-->\n|tyv=<!--Тувинский-->\n|tr=\n|tk=\n|udm=<!--Удмуртский-->\n|uz=\n|ug=<!-- Уйгурс"
  body "кий-->\n|uk={{с|uk|ау}}\n|ur=<!-- Урду-->\n|fo=\n|fi=\n|fr=[[ohé]], [[oho]]\n|fy=<!-- Фризский -->\n|fur=<!--Фриульский-->\n|kjh=<!--Хакасский-->\n|ha=<!-- Хауса -->\n|hi=<!-- Хинди -->\n|hr=\n|chu.cy"
  body "r=<!--Церковнославянский (кир.)-->\n|chu.glag=<!-- Церковнославянский (глаг.)-->\n|rom=<!--Цыганский-->\n|ce=<!-- Чеченский-->\n|cs=\n|cv=<!-- Чувашский-->\n|ckt=<!-- Чукотский-->\n|sv={{t|sv|hallå}}\"
  body "n|cjs=<!--Шорский-->\n|sco=<!--Шотландский -->\n|ewe=<!--Эве-->\n|evn=<!--Эвенкийский-->\n|myv=<!--Эрзянский-->\n|eo=\n|et=\n|jv=<!-- Яванский -->\n|sah=<!--Якутский -->\n|ja=\n}}\n{{перев-блок|2|\n|e"
  body "n=[[good bye to that]]!, [[good bye to all that]]!\n}}\n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ru|пример|синонимы|гиперонимы|этимология}}\n{{Категория|язык=ru|||}}\n{{длина слова"
  body "|2|ru}}\n\n= {{-ba-}} =\n{{Омонимы|ba|2}}\n\n== {{з|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ba 3a\n|основа=ау\n|слоги={{по-слогам|ау}}\n}}\n\n{{морфо ba|корень1=ау}}\n\n=== "
  body "Произношение ===\n{{transcription|ɑw}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[ловушка]], [[западня]]; [[силок]] {{пример||перевод=}}\n# [[сети]], [[бредень]], [[невод]] {{пример|"
  body "Тәжрибәле, ҡарт ынйы эҙләүсе тәүҙә, һыу төбөнә төшөп, якорға кәрзин йәки ау бәйләп менә.|перевод=Старый опытный ловец опустится на дно и привяжет к якорю корзинку или сеть.}}\n\n==== Синонимы ====\n# "
  body "\n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|сущест"
  body "вительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|ba}}\n\n=== Фразеологизмы и устойчив"
  body "ые сочетания ===\n* \n\n<!-- Служебное: -->\n{{improve|ba|примеры|синонимы|гиперонимы|этимология}}\n{{Категория|язык=ba|||}}\n\n== {{з|II}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{с"
  body "ущ ba 3a\n|основа=ау\n|слоги={{по-слогам|ау}}\n}}\n\n{{морфо ba|корень1=ау}}\n\n=== Произношение ===\n{{transcription|ɑw}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[охота]] ([[охотн"
  body "ичий]]) {{пример||перевод=}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n"
  body "|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисх"
  body "одит от пратюркск. *Āb «охота».\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ba|пример|синонимы|гиперонимы}}\n{{Категория|язык=ba|О"
  body "хота||}}\n{{длина слова|2|ba}}\n\n= {{-tt-}} =\n{{Омонимы|tt|2}}\n\n== {{заголовок|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ tt задн согласн ау|ау|ав|слоги={{по слогам|а́у}}|a"
  body "lt=aw}}\n\n{{морфо tt|корень=ау}}\n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[охота]] ([[охотничий]]) {{пример||перевод=}}\n# [[ловля]], [["
  body "облава]] {{пример||перевод=}}\n# [[сети]], [[бредень]], [[невод]], [[ловушка]], [[силок]] {{пример||перевод=}}\n# {{п.|tt}} [[сеть]], [[ловушка]], [[западня]] {{пример||перевод=}}\n\n=== Фразеологизмы"
  body " и устойчивые сочетания ===\n* [[ау эте]]\n* [[ау ятьмәсе]]\n* [[ау корырга]]\n\n=== Родственные слова ===\n{{родств-блок\n|существительные=аучы, аучылык\n|глаголы=ауларга\n}}\n\n=== Этимология ===\nО"
  body "бщетюркское.\n\n<!-- Служебное: -->\n{{improve|tt|транскрипция/мн|пример|семантика?}}\n{{Категория|язык=tt|||}}\n\n== {{заголовок|II}} ==\n* Форма глагола [[аварга]] ([[валиться]]) в повел. накл. в ед"
  body ". числе.\n\n<!-- Служебное: -->\n{{improve|tt|}}\n{{Категория|язык=tt|Словоформы|}}\n{{длина слова|2|tt}}""}}"

response_0059_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%B1%D0%B0%D0%B1%D0%BA%D0%B8&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""бабки"",""pageid"":467871,""redirects"":[],""wikitext"":""{{Cf|Бабки}}\n\n{{w}}\n\n= {{-ru-}} =\n{{Омонимы|ru|3}}\n\n== {{з|I}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{су"
  body "щ-ru|ба́бки|мн <f ina 3*a>\n|слоги={{по-слогам|ба́б|ки}}\n|коммент=\n|дореф=\n}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{морфо-ru|баб|-к|+и}}\n\n=== Произношение ===\n{{transcription-ru|ба́бки|"
  body "Ru-бабки.ogg}}\n\n=== Семантические свойства ===\n{{илл|size=300px|lang=ru|Игра в бабки.jpg|Игра в бабки [1]}}\n\n==== Значение ====\n# {{устар.|ru}} [[игра]], в которой [[бабка|бабкой]] выбивают из к"
  body "руга другие [[кость|кости]], расставленные определённым образом {{пример|Минин стоит в русской одежде на Красной площади в Москве; Сусанин ― в Костроме, перед бюстом спасённого им Михаила Фёдоровича; "
  body "есть много статуй, изображающих русских мальчиков и юношей, играющих в {{выдел|бабки}} или свайку.|Н. Я. Данилевский|Россия и Европа|1869|источник=НКРЯ}} {{пример|Пошлёт его, бывало, отец в кабак за в"
  body "одкой, а Никитка, позабыв все заповеди на свете, задувает себе с парнишками в {{выдел|бабки}} и лихо разбивает ряды костыжек битком, налитым оловом: не до отца ему, не до водки.|П. В. Засодимский|Тёмн"
  body "ые силы|1870|источник=НКРЯ}} {{пример|Недельный отдых или воскресный день калмыками празднуется по четвергам разными играми: в {{выдел|бабки}}, чехарду, фанты, единоборством {{итп}}|П. И. Огородников|"
  body "На пути в Персию и прикаспийские провинции её|1873|источник=НКРЯ}} {{пример|Около церковной ограды азартно играла в {{выдел|бабки}} большая компания мастеровых.|Горький|В людях|1915–1916|источник=НКРЯ"
  body "}}\n# \n\n==== Синонимы ====\n# {{част.}}: [[городки]]\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# [[игра]]\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-"
