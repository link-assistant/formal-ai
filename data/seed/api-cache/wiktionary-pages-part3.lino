  body "рбский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татарский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -"
  body "->\n|tr=[[yok]]\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=[[нема]]\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский -->\n|fr=[[il n'y a pas]]\n|hr=<!-- Хорватский -->\n|cs=[[není]]\n|sv=[[det fi"
  body "nns inte]]\n|cjs=[[чоқ]]\n|eo=[[ne estas]]\n|et=[[ei ole]], [[pole]]\n|ja=[[無い]] (nai), [[いない]] (inai), [[存在しない]] (sonzaishinai)\n|ppol=<!-- Протополинезийский -->\n|slovio-c=<!-- Словио (кир) -->\n|s"
  body "lovio-l=<!-- Словио (лат) -->\n}}\n\n=== Библиография ===\n{{библио\n|авторы= Арутюнова Н. Д.\n|название=Тождество и подобие\n|издание=Логический анализ языка. Тождество и подобие. Сравнение и идентиф"
  body "икация.\n|редактор=Арутюнова Н. Д.\n|изд-во=М.: Институт языкознания АН СССР, 1990\n|стр=20\n|детально=\n}}\n* {{СНС 50-80}}\n* {{бтс}}\n* {{ак}}\n\n{{прочее-блок\n|частотность = \n|анаграммы = \n|мет"
  body "аграммы = \n}}\n\n{{improve|ru|гиперонимы|переводы}}\n\n{{Категория|язык=ru|Отрицание||}}\n\n== {{заголовок|(существительное I)}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{сущ-ru|нет|"
  body "м 1a\n|слоги={{по-слогам|нет}}\n|коммент=может согласовываться с другими частями речи как мужского, так и среднего рода\n}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{морфо-ru|нет}}\n\n=== Произно"
  body "шение ===\n{{transcriptions-ru|нет|неты}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{устар.|ru}}, {{прост.|ru}}, {{помета|обычно в поговорках}}: состояние недостатка, отсутствия чего"
  body "-либо {{пример|Пирог с {{выдел|нетом}} ''(без начинки)''.|и=Даль}} {{пример|{{выдел|Нета}}-то у нас у самих много.|и=Даль}} {{пример|{{выдел|Неты}} считать ''(поверять недостачу чего)''.|и=Даль}}\n# \"
  body "n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперонимы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|им"
  body "ена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:нет|"
  body "да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[не от нета]]\n\n==== Пословицы и поговорки ====\n{{Фразеологизмы|\n* девичье нет — не отказ\n* девичье нет дороже естя\n* до самого нета все б"
  body "ыло есть\n* есть — лучше нета\n* есть у молодца не хоронится, а нет — не ворошится\n* из нета ничего не скроишь\n** из нета ничего не выкроишь\n* нетом не возьмешь и летом\n* нетом не разживешься\n* с"
  body " нета в брюхи не зарычать\n* с одного конца нет, и с другого нет, а в середки и небывало\n* у нас всякого нета припасено с лета\n* у нета ничего не возьмешь\n* у скупа — не у нета: и есть, да не выпро"
  body "сишь\n* человек родился из нета, и пойдет в нет\n}}\n\n=== Перевод ===\n{{перев-блок|\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарсикй-->\n|en=<!-- Английский-->\n|ar=<!-- Арабс"
  body "кий-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->\n|ba=<!-- Башкирский-->\n|be=<!-- Белорусский-->\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!"
  body "-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=<!-- Венгерский-->\n|vi=<!-- Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=<!-- Греческий-->\n|ka=<!-- Грузинский-->\n|da=<!-- Датский-->\n|he=<!-- Иврит--"
  body ">\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казах"
  body "ский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корей"
