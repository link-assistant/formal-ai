  body "ия/мн|этимология}}\n{{Категория|язык=ce|Отношения родства}}\n{{длина слова|2|ce}}\n\n= {{-evn-}} =\n\n=== Морфологические и синтаксические свойства ===\n{{сущ evn\n|основа=да\n|слоги={{по-слогам|да}}\"
  body "n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcriptions||}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# [[родственник]] {{пример||перевод=}}\n"
  body "# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увели"
  body "ч=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|evn}"
  body "}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{unfinished|evn|p=1|e=1|m=1}}\n{{Категория|язык=evn|Отношения родства||}}\n{{длина слова|2|evn}}\n\n= {{-sah-}} =\"
  body "n{{Омонимы|sah|2}}\n\n== {{з|(союз)}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{conj sah\n|основа=да\n|слоги={{по-слогам|да}}\n}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=|частица=}}\"
  body "n\n=== Произношение ===\n{{transcription|}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# [[как]] [[только]] {{пример||перевод=}}\n# [[но]], [[а]] {{пример||перевод=}}\n# [[хотя"
  body "]] … [[но]] {{пример||перевод=}}\n\n==== Синонимы ====\n# ?\n# ?\n# ?\n\n==== Антонимы ====\n# ?\n# ?\n# ?\n\n==== Гиперонимы ====\n# —\n# —\n# —\n\n==== Гипонимы ====\n# —\n# —\n# —\n\n=== Родственны"
  body "е слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|пол"
  body "н=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|sah}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* {{БТСяя|статья=да|ссылка=https://sakhatyla.ru/books/sakha"
  body "-tylyn-tyljyta-3/63|том=3|страницы=59-61}}\n\n== {{з|(частица)}} ==\n\n=== Морфологические и синтаксические свойства ===\n{{part sah\n|основа=да\n|слоги={{по-слогам|да}}\n}}\n\n{{морфо|прист1=|корень1"
  body "=|суфф1=|оконч=|частица=}}\n\n=== Произношение ===\n{{transcription||}}\n\n=== Семантические свойства ===\n{{илл|}}\n\n==== Значение ====\n# [[какой]] {{пример||перевод=}}\n# \n\n==== Синонимы ====\n#"
  body " [[даҕаны]]\n# \n\n==== Антонимы ====\n# ?\n# \n\n==== Гиперонимы ====\n# ?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собстве"
  body "нные=\n|существительные=\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|причастия=\n|предлоги=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|sah}}\n\n=== Фразеологиз"
  body "мы и устойчивые сочетания ===\n* \n* \n\n=== Библиография ===\n* {{БТСяя|статья=да (даҕаны)|ссылка=https://sakhatyla.ru/books/sakha-tylyn-tyljyta-3/65|том=3|страницы=61-63}}\n\n<!-- Служебное: -->\n{{"
