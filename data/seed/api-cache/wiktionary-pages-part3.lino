  body "<!--Яванский-->\n|ja=<!--Японский-->\n}}\n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ru|пример|семантика?|этимология|перевод}}\n{{Категория|язык=ru|||}}\n\n== {{з|ударение=ау́}} ==\n"
  body "\n=== Морфологические и синтаксические свойства ===\n{{interj ru\n|слоги={{по-слогам|ау!}}\n}}\n\n{{морфо-ru|ау}}\n\n=== Произношение ===\n{{transcription-ru|ау́|}}\n\n=== Семантические свойства ===\n"
