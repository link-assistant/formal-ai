  body "- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргизский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у)"
  body " -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский-->\n|lt=<!-- Литовский-->\n|mk=<!-- Македонский-->\n|ms=<!-- Малайский--"
  body ">\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de={{t|de|ja}}\n|nl=<!-- Нидерландский-->\n|no=<!-- Норвежский-->\n|os=<!-- Осетинский-->\n|pa=<!-- Пан"
