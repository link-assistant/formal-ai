  body "ский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейск"
  body "ий -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -"
