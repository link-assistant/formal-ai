  body "- Малаялам -->\n|mt=<!-- Мальтийский -->\n|mi=<!-- Маори -->\n|chm=<!--Марийский-->\n|mdf=\n|mo=<!-- Молдавский-->\n|mn=\n|gv=\n|nv=<!-- Навахо-->\n|gld=<!--Нанайский-->\n|nah=\n|na=<!-- Науру -->\n|n"
