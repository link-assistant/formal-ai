  body "ий -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|dar=[[агара]]\n|da=<!-- Датский -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=[[no]] [[hay]]\n|it=<!-- Итальян"
  body "ский -->\n|kk=[[жоқ]]\n|kaa=[[жоқ]]\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Коре"
