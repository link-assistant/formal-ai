response_0085_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BC%D0%BE%D1%87%D0%B0&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""моча"",""pageid"":108972,""redirects"":[],""wikitext"":""{{Cf|Моча|моща}}\n{{wikipedia}}\n= {{-ru-}} =\n{{Омонимы|ru|2}}\n\n== {{з|(существительное)}} ==\n{{Лексема в Викиданных|L145201}}\n"
  body "\n=== Морфологические и синтаксические свойства ===\n{{сущ ru f ina 4b\n|основа=моч\n|основа1=моч\n|слоги={{слоги|мо/ча́}}\n|st=1\n|затрудн=1\n}}\n\n{{морфо-ru|моч|+а|и=т}}\n\n=== Произношение ===\n{{"
  body "transcription-ru|моча́|Ru-моча.ogg}}\n\n=== Семантические свойства ===\n{{илл|Urinbecher.jpg}}\n\n==== Значение ====\n# [[продукт]] [[жизнедеятельность|жизнедеятельности]] животных и человека, [[выдел"
  body "яемый]] [[почка]]ми {{пример|Садовая и особенно огородная земля, в которую с удобрениями попала {{выдел|моча}} домашних животных, содержит ароматические вещества, частично растворимые в воде, так как "
  body "{{выдел|моча}} содержит ароматическую группу в форме сульфосоединений.|А. Я. Данилевский|О распределении в природе ароматической группы, происходящей из животных и растительных тканей|1884|источник=НК"
  body "РЯ}} {{пример|Смятение пришло в тот миг, когда радио передало бюллетень о здоровье Сталина: «Дыхание Чейн-Стокса… {{выдел|моча}}… пульс… кровяное давление…» Обожествлённый владыка вдруг обнаружил свою"
  body " старческую немощную плоть.|Гроссман|Всё течёт|дата=1955–1963 гг.|издание=Октябрь|дата издания=1989 г.|источник=НКРЯ}}\n# \n\n==== Синонимы ====\n# [[урина]]; [[ссака]], [[ссаки]], [[ссаньё]], ({{груб"
  body ".|-}}); [[рассол]] ({{эвф.|-}}); [[жёлтый дождь]] ({{жарг.|-}}), писы(разг.)\n\n==== Антонимы ====\n# —\n\n==== Гиперонимы ====\n# [[экскрет]], [[жидкость]]\n\n==== Гипонимы ====\n# —\n\n=== Родственн"
  body "ые слова ===\n{{родств-блок\n|имена-собственные=\n|существительные=мочевина, мочевыделение, мочеточник\n|прилагательные=мочевой, мочегонный\n|глаголы=мочиться\n|наречия=\n|полн=мок-моч\n}}\n\n=== Этим"
  body "ология ===\nПроисходит от {{этимология:моча|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n{{table-top}}\n\n* [[анализ мочи]]\n* [[бычья моча]], [[верблюжья моча]], [[моча дохлого бегемота]], ["
  body "[моча сиротки Аси]]\n* [[кобылья моча]], [[кошачья моча]]\n* [[моча в голову вступила]], [[моча в голову ударила]], [[моча в голову стукнула]]; [[моча ударила в голову]], [[моча вступила в голову]], ["
  body "[моча стукнула в голову]]\n* [[моча в котелке]]\n* [[моча инопланетянина]]\n* [[моча старухи Изергиль]]\n* {{скр2|[[всё говно, что не моча]], [[что не говно, то моча]]}}\n* \n\n{{table-bot}}\n\n=== Пе"
  body "ревод ===\n{{перев-блок|\n|abq=\n|ab=\n|av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=\n|ay=\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=\n|als=\n|ale=\n|alt=\n|en=[[urine]], [[piss]]\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\"
  body "n|arn=\n|hy=\n|asm=\n|ast=\n|af=\n|bar=\n|bm=\n|eu=\n|ba=\n|be=\n|bn=\n|bg=[[пикня]], [[урина]]\n|bs=\n|br=\n|bua=\n|cy=\n|wa=\n|hu=\n|vep=\n|hsb=\n|vot=\n|vo=\n|wo=\n|vro=\n|vi=\n|gag=\n|haw=\n|ht=\n"
  body "|gl=\n|ze=\n|kl=\n|el=\n|ka=\n|gn=\n|gu=\n|gd=\n|dar=\n|prs=\n|da=\n|dv=\n|ang=\n|grc=\n|bat-smg=\n|zza=\n|zu=\n|he=\n|yi=\n|io=\n|id=\n|ia=\n|iu=\n|ik=\n|ga=\n|is=\n|es=\n|it=\n|kbd=\n|kk=\n|xal=\n|k"
  body "n=\n|kaa=\n|krc=\n|krl=\n|ca=\n|csb=\n|qu=\n|ky=\n|zh=\n|zh-tw=\n|zh-cn=\n|kom=\n|koi=\n|kok=\n|kw=\n|ko=\n|co=\n|xh=\n|crh=\n|ku=[[mîz]]\n|km=\n|lad=\n|lo=\n|la=[[urina]] {{f}}\n|lez=\n|lv=\n|li=\n|l"
  body "n=\n|lt=\n|lb=\n|mk=\n|mg=\n|ms=\n|ml=\n|mt=\n|mi=\n|chm=\n|mdf=\n|mo=\n|mn=\n|gv=\n|nv=\n|gld=\n|nah=\n|na=\n|nio=\n|nap=\n|de=\n|yrk=\n|nl=\n|dsb=\n|no=\n|oc=\n|os=\n|pi=[[mutta]]\n|pa=\n|pap=\n|fa="
  body "\n|pl=\n|pt=\n|ps=\n|pms=\n|rap=\n|rm=\n|ro=\n|sjd=\n|sa=[[मूत्र]] (мутра)\n|sc=\n|se=\n|sr=\n|sr-l=\n|scn=\n|sk=\n|sl=\n|slovio-c=\n|slovio-l=\n|so=\n|chu.cyr=\n|chu.glag=\n|sw=\n|tab=\n|tl=\n|tg=[[п"
  body "ешоб]], [[мезак]]\n|ty=\n|th=\n|ta=\n|tt=\n|tt.cyr=\n|tt.lat=\n|te=\n|art=[[telo jelo]]\n|tpi=\n|kim=\n|tn=\n|tyv=\n|tr=\n|tk=\n|udm=\n|ug=\n|uz=\n|uk=\n|ur=\n|fo=\n|fi=[[kusi]], [[virtsa]]\n|fr=\n|fy"
  body "=\n|fur=\n|kjh=\n|ha=\n|hi=\n|hr=\n|rom=\n|ce=\n|cs=\n|cv=\n|sv=[[urin]], [[kiss]], [[piss]]\n|cjs=\n|sco=\n|ewe=\n|myv=\n|eo=\n|et=[[kusi]]; [[virts]] (''животных'')\n|jv=\n|sah=\n|ja=\n}}\n\n=== Ана"
  body "граммы ===\n* [[мачо]], [[омач]], [[чамо]], [[Чома]]\n\n=== Библиография ===\n* \n\n<!-- Служебное: -->\n{{improve|ru|}}\n{{Категория|язык=ru|||}}\n\n== {{з|(деепричастие)}} ==\n{{Форма-гл|мочить|наст"
  body "|деепр=1|слоги={{слоги|мо/ча́}}|МФА={{t-ru|моча́}}}} {{пример|Воспомни и представь, Терей, моё мученье, // Которым я с тобой в несносном разлученье // Питала грудь мою, {{выдел|моча}} потоком слёз; //"
  body " Стремя свой робкий взор на высоту небес, // Дрожащим голосом молитвы воссылала, // И именем твоим молитвы наполняла.|Крылов|[[s:Филомела (Крылов)/Действие третье#ЯВЛЕНИЕ ТРЕТЬЕ|Филомела]]|источник=so"
  body "urce}} {{пример|Городовой поднял завалившуюся голову и попытался влить воду в рот, но арестант не принимал её; вода выливалась по бороде, {{выдел|моча}} на груди куртку и посконную пыльную рубаху.|Тол"
  body "стой|Воскресение|1899|источник=НКРЯ}}\n\n<!-- Служебное: -->\n{{improve|ru|}}\n{{Категория|язык=ru|Моча|Ч и Щ}}\n{{длина слова|4|ru}}\n= {{-orv-}} =\n\n=== Морфологические и синтаксические свойства =="
  body "=\n{{сущ orv |слоги=|основа=|основа1=}}\n\n{{морфо|прист1=|корень1=|суфф1=|оконч=}}\n\n=== Произношение ===\n{{transcriptions|||}}\n\n=== Семантические свойства ===\n{{илл|lang=orv|}}\n\n==== Значение"
  body " ====\n# {{помета.|orv}} [[дождь]] {{пример||перевод=|автор=|титул=|дата=|перев=|дата издания=|источник=}}\n# \n\n==== Синонимы ====\n# ?\n# \n\n==== Антонимы ====\n# —\n# \n\n==== Гиперонимы ====\n# "
  body "?\n# \n\n==== Гипонимы ====\n# ?\n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|глаголы=\n|наречия=\n|полн=\n}}\n"
  body "\n=== Этимология ===\nИз {{этимология:|orv}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Библиография ===\n* \n\n{{unfinished|orv|p=1|m=1|e=1}}\n\n{{Категория|язык=orv|Дождь||}}\n{{длин"
