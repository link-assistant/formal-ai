  body "n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Турецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украински"
