  body "-- Латышский-->\n|lt=<!-- Литовский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=<!-- Немецкий-->\n|nl=<!-- Нидерландский"
  body "-->\n|no=<!-- Норвежский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=<!-- Польский-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-->\n|sr=<!-- Сербский (кир)-->\n|sr"
  body "-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянский (кир)-->\n|cu-Glag=<!-- Старосла"
