  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BC%D0%BE%D1%80%D0%BA%D0%BE%D0%B2%D0%BA%D0%B0&prop=wikitext&formatversion=2&format=json&redirects=1"
