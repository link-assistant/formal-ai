response_0060_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%B1%D0%B0%D0%B1%D0%BB%D0%BE&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""бабло"",""pageid"":629798,""redirects"":[],""wikitext"":""= {{-ru-}} =\n{{Лексема в Викиданных|L104578}}\n\n=== Морфологические и синтаксические свойства ===\n{{сущ ru n ina 1b\n|основа=баб"
  body "л\n|основа1=бабел\n|слоги={{по-слогам|баб|ло́}}\n|st=1\n|затрудн=1\n}}\n\n{{морфо-ru|баб|-л|+о}}\n\n=== Произношение ===\n{{transcription-ru|бабло́}}\n\n=== Семантические свойства ===\n\n==== Значение"
  body " ====\n# {{жарг.|ru}} [[деньги]] {{пример|{{--}}Не очень-то весёлая получается штука{{-}}жизнь.{{--}}{{выдел|Бабло}} есть{{-}}весёлая,{{-}}говорит Дэн.{{--}}Да нет, всё равно не хватает чего-то.|Роман"
  body " Сенчин|Афинские ночи||Знамя|2000|источник=НКРЯ}}\n# \n\n==== Синонимы ====\n# {{синонимы:деньги}}\n\n==== Антонимы ====\n# —\n\n==== Гиперонимы ====\n# [[деньги]]\n\n==== Гипонимы ====\n# {{разг.|-}}"
  body ": [[еврик]]и; {{разг.|-}}, {{шутл.|-}}: [[тугрик]]и; {{п.|-}}, {{жарг.|-}}, {{ед.}}: [[капуста]]; {{п.|-}}, {{жарг.|-}}, {{собир.|-}}: [[зелень]]; {{жарг.|-}}: [[бакс]]ы, [[нефтебабло]], [[госбабло]]\"
  body "n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=бабки\n|прилагательные=\n|числительные=\n|местоимения=\n|глаголы=\n|наречия=\n|предикат"
  body "ивы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от сущ. [[бабки]], далее от [[бабка]], из [[баба]] + [[-к]], далее от {{этимология:баба|да}}\n\n=== Фразеологизмы и устойчивые сочетания "
  body "===\n{{Фразеологизмы|\n* бабло побеждает зло\n* зашибать бабло\n** бабло зашибать\n* косить бабло / накосить бабла\n** бабло косить / бабла накосить\n* нарубить бабла\n** бабла нарубить\n* отмывать ба"
  body "бло / отмыть бабло\n** бабло отмывать / бабло отмыть\n* поднять бабла\n** бабла поднять\n* попадос на бабло\n* попил бабла\n** распил бабла\n* поставить на бабло\n** на бабло поставить\n* разводить на"
  body " бабло / развести на бабло\n** на бабло разводить / на бабло развести\n* срубить бабла\n** бабла срубить\n}}\n\n=== Перевод ===\n{{перев-блок||\n|ain=<!-- Айнский (лат) -->\n|sq=<!-- Албанский-->\n|en"
  body "=[[cash]], [[dough]], [[money]]\n|ast=<!-- Астурийский -->\n|af=<!-- Африкаанс -->\n|hy=<!-- Армянский -->\n|ba=<!-- Башкирский -->\n|be=<!-- Белорусский -->\n|bg=<!-- Болгарский -->\n|bs=<!-- Боснийс"
  body "кий -->\n|br=<!-- Бретонский -->\n|hu=<!-- Венгерский -->\n|vi=<!-- Вьетнамский -->\n|vro=<!-- Выруский -->\n|gl=<!-- Галисийский -->\n|el=<!-- Греческий -->\n|ka=<!-- Грузинский -->\n|da=<!-- Датский"
  body " -->\n|io=<!-- Идо -->\n|ia=<!-- Интерлингва -->\n|is=<!-- Исландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\"
  body "n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) -->\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|l"
  body "t=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Монгольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de=<!-- Немецкий -->\n|no=<!-- Норвежский -->\n|nl=<!-- Нидерландский -->\n|pl=<"
  body "!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (кир) -->\n|sr-l=<!-- Сербский (лат) -->\n|sk=<!-- Словацкий -->\n|sl=<!-- Словенский -->\n|chu=<!-- Старославянский -->\n|tt=<!-- Татар"
  body "ский -->\n|art=<!-- Токипона -->\n|kim=<!-- Тофаларский -->\n|tr=<!-- Турецкий -->\n|tk=<!-- Туркменский -->\n|uz=<!-- Узбекский -->\n|uk=<!-- Украинский -->\n|fo=<!-- Фарерский -->\n|fi=<!-- Финский "
  body "-->\n|fr=<!-- Французский -->\n|hr=<!-- Хорватский -->\n|cs=<!-- Чешский -->\n|sv=[[deg]], [[stålar]], [[pengar]]\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|ja=<!--Японский-->\n}}\n\n=== Библиограф"
  body "ия ===\n* {{Скляревская 2006}}\n\n{{improve|ru}}\n{{Категория|язык=ru|Деньги|}}\n{{длина слова|5|ru}}""}}"

