  body "й-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-->\n|sr=<!-- Сербский (кир)-->\n|sr-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Сл"
  body "овио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянский (кир)-->\n|cu-Glag=<!-- Старославянский (лат)-->\n|tl=<!-- Тагальский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt="
  body "<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Турецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fi=<!-- Финский-->\n|fr=<"
  body "!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cs=<!-- Чешский-->\n|cv=<!-- Чувашский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|sah=<"
  body "!--Якутский-->\n|ja=<!--Японский-->\n}}\n\n=== Библиография ===\n* {{ВТ-Даль|Нет}}\n* {{бтс}}\n\n{{Категория|язык=ru|Отсутствие|Недостаток}}\n\n== {{заголовок|(существительное II)}} ==\n\n=== Морфолог"
  body "ические и синтаксические свойства ===\n{{сущ-ru\n|нет\n|м 1a\n|слоги={{по-слогам|нет}}\n}}\n\n{{слобр|ru||||усеч=|черед=|интер=|и=}}\n\n{{морфо-ru|нет}}\n\n=== Произношение ===\n{{transcriptions-ru|нэ"
  body "т|нэ́ты}}\n\n=== Семантические свойства ===\n\n==== Значение ====\n# {{интернет.|ru}} {{t:=|интернет}} {{пример|Я ей всякие распечатки из {{выдел|нета}} таскаю{{-}}про прикорм, про сок, про каши, мясн"
  body "ой бульон, йогурты с красителями и прочее такое…||Наши дети: Малыши до года|уточнение титула=форум|2004|источник=НКРЯ}}\n# \n\n==== Синонимы ====\n# \n# \n\n==== Антонимы ====\n# \n# \n\n==== Гиперони"
  body "мы ====\n# \n# \n\n==== Гипонимы ====\n# \n# \n\n=== Родственные слова ===\n{{родств-блок\n|умласк=\n|уничиж=\n|увелич=\n|имена-собственные=\n|существительные=\n|прилагательные=\n|числительные=\n|мест"
  body "оимения=\n|глаголы=\n|наречия=\n|предикативы=\n|предлоги=\n|полн=\n}}\n\n=== Этимология ===\nПроисходит от {{этимология:|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* \n\n=== Перевод ===\n{{"
  body "перев-блок|\n|az=<!-- Азербайджанский-->\n|sq=<!-- Албанский-->\n|am=<!-- Амхарсикй-->\n|en=<!-- Английский-->\n|ar=<!-- Арабский-->\n|hy=<!-- Армянский-->\n|af=<!-- Африкаанс-->\n|eu=<!-- Баскский-->"
  body "\n|ba=<!-- Башкирский-->\n|be=<!-- Белорусский-->\n|bn=<!-- Бенгали-->\n|bg=<!-- Болгарский-->\n|bs=<!-- Боснийский-->\n|br=<!-- Бретонский-->\n|cy=<!-- Валлийский-->\n|hu=<!-- Венгерский-->\n|vi=<!--"
  body " Вьетнамский-->\n|gl=<!-- Галисийский-->\n|el=<!-- Греческий-->\n|ka=<!-- Грузинский-->\n|da=<!-- Датский-->\n|he=<!-- Иврит-->\n|yi=<!-- Идиш-->\n|io=<!-- Идо-->\n|id=<!-- Индонезийский-->\n|ia=<!-- "
  body "Интерлингва-->\n|ga=<!-- Ирландский-->\n|is=<!-- Исландский-->\n|es=<!-- Испанский-->\n|it=<!-- Итальянский-->\n|kk=<!-- Казахский-->\n|krl=<!-- Карельский-->\n|ca=<!-- Каталанский-->\n|ky=<!-- Киргиз"
  body "ский-->\n|zh-tw=<!-- Китайский (традиц.)-->\n|zh-woo=<!-- Китайский (у) -->\n|zh-cn=<!-- Китайский (упрощ.)-->\n|ko=<!-- Корейский-->\n|ku=<!-- Курдский-->\n|la=<!-- Латинский-->\n|lv=<!-- Латышский--"
  body ">\n|lt=<!-- Литовский-->\n|mk=<!-- Македонский-->\n|ms=<!-- Малайский-->\n|ml=<!-- Малаялам-->\n|mr=<!-- Маратхи-->\n|mdf=<!-- Мокшанский-->\n|mn=<!-- Монгольский-->\n|de=<!-- Немецкий-->\n|nl=<!-- Ни"
  body "дерландский-->\n|no=<!-- Норвежский-->\n|os=<!-- Осетинский-->\n|pa=<!-- Панджаби-->\n|fa=<!-- Персидский-->\n|pl=<!-- Польский-->\n|pt=<!-- Португальский-->\n|ro=<!-- Румынский-->\n|sa=<!-- Санскрит-"
  body "->\n|sr=<!-- Сербский (кир)-->\n|sr-l=<!-- Сербский (лат)-->\n|sk=<!-- Словацкий-->\n|sl=<!-- Словенский-->\n|slovio-c=<!-- Словио (кир)-->\n|slovio-l=<!-- Словио (лат)-->\n|cu-Cyrl=<!-- Старославянск"
  body "ий (кир)-->\n|cu-Glag=<!-- Старославянский (лат)-->\n|tl=<!-- Тагальский-->\n|th=<!-- Тайский-->\n|ta=<!-- Тамильский-->\n|tt=<!-- Татарский-->\n|te=<!-- Телугу-->\n|art=<!-- Токипона-->\n|tr=<!-- Тур"
  body "ецкий-->\n|tk=<!-- Туркменский-->\n|uz=<!-- Узбекский-->\n|uk=<!-- Украинский-->\n|ur=<!-- Урду-->\n|fi=<!-- Финский-->\n|fr=<!-- Французский-->\n|hi=<!-- Хинди-->\n|hr=<!-- Хорватский-->\n|cs=<!-- Че"
  body "шский-->\n|cv=<!-- Чувашский-->\n|sv=<!-- Шведский-->\n|eo=<!--Эсперанто-->\n|et=<!--Эстонский-->\n|jv=<!--Яванский-->\n|sah=<!--Якутский-->\n|ja=<!--Японский-->\n}}\n\n=== Библиография ===\n* {{НСЗ-9"
  body "0}}\n* {{ак}}\n\n{{improve|ru|синонимы|гиперонимы|этимология|перевод}}\n\n{{Категория|язык=ru|Отрицание}}\n{{длина слова|3|ru}}""}}"

response_0088_api_php_action_parse_pag
  url "https://ru.wiktionary.org/w/api.php?action=parse&page=%D0%BE%D0%B3%D1%83%D1%80%D0%B5%D1%86&prop=wikitext&formatversion=2&format=json&redirects=1"
  body "{""parse"":{""title"":""огурец"",""pageid"":19686,""redirects"":[],""wikitext"":""{{wikipedia}}\n{{слово дня|3|8|2012}}\n= {{-ru-}} =\n{{Лексема в Викиданных|L3525}}\n\n=== Морфологические и синтаксические свойств"
  body "а ===\n{{сущ ru m ina 5*b\n|основа= огур\n|основа1= огурц\n|слоги={{по-слогам|о|.|гу|ре́ц}}\n}}\n\n{{морфо-ru|огурец|и=т}}\n\n=== Произношение ===\n{{transcriptions-ru|огуре́ц|огурцы́|Ru-огурец.ogg}}\"
  body "n\n=== Семантические свойства ===\n{{илл|Cucumis sativus 0001.JPG|Огурец [1]}}\n{{илл|Cucumis sativus1.jpg|Огурцы [2]}}\n\n==== Значение ====\n# {{ботан.|ru}} однолетнее травянистое [[растение]] из се"
  body "мейства тыквенных с продолговатым зелёным [[плод]]ом (Cucumis sativus) {{пример|И брат тоже начинает полоть {{выдел|огурцы}}, или свёклу мотыжить, или картошку окучивать.|Пришвин|Кладовая солнца|1945|"
  body "источник=НКРЯ}} {{пример|Город утопал в яблоневых и вишнёвых садах, из овощных культур на продажу выращивали {{выдел|огурцы}}, лук и чеснок.|Ирина Грачёва|Суздальские тайны|2009|издание=Наука и жизнь|"
  body "источник=НКРЯ}}\n# {{кулин.|ru}} [[плод]] огурца [1], употребляемый в пищу; [[огородный]] [[овощ]] {{пример|Дядя Сандро, так и не выбрав курятины, подозрительно покосился на собаку, а потом взял {{выд"
  body "ел|огурец}}, ножом разрезал его вдоль и, густо, как повидлом, намазав одну долю аджикой, откусил, с удовольствием крякнув от остроты.|Фазиль Искандер|Чик чтит обычаи|1967|источник=НКРЯ}} {{пример|Пото"
  body "м я сделаю весенний салат, со свежими {{выдел|огурцами}}, и сварю кило сосисок.|Ильф, Петров|Широкий размах|1935|источник=НКРЯ}}\n# {{п.|ru}}, {{разг.|ru}} о ком-либо здоровом, крепком, свежем на вид "
  body "{{пример|Я менеджер самого среднего звена, у меня есть дети, у меня есть жена, я работаю в компании «Связь-интерком» и каждый понедельник я {{выдел|огурцом}}, и каждый вторник я {{выдел|огурцом}}, и к"
  body "аждую среду я {{выдел|огурцом}}, и каждый четверг {{выдел|огурцом}} я… Но в понедельник я опять {{выдел|огурцом}}, хэй! Каждый понедельник я {{выдел|огурцом}}… Но полвоскресенья я {{выдел|огурцом}}, ч"
  body "тобы в понедельник быть {{выдел|огурцом}}, хэй!|Семён Слепаков|Гимн офисного работника|2012|источник=НКРЯ}}\n\n==== Синонимы ====\n# —\n# —\n# [[трезвый]], [[бодрый]]\n\n==== Антонимы ====\n# —\n# —\n"
  body "# [[пьяный]], [[вялый]]\n\n==== Гиперонимы ====\n# [[тыквенное]], [[двудольное]], [[покрытосеменное]], [[растение]]\n# [[овощ]], [[плод]]\n# ?\n\n==== Гипонимы ====\n# —\n# [[корнишон]]\n# ?\n\n=== Ро"
  body "дственные слова ===\n{{родств-блок\n|умласк=огурчик, огуречик\n|имена-собственные=Огурцов\n|существительные=огуречник\n|прилагательные=огуречный, огурцовый\n|глаголы=\n|наречия=\n}}\n\n=== Этимология "
  body "===\nПроисходит от {{этимология:огурец|да}}\n\n=== Фразеологизмы и устойчивые сочетания ===\n* [[алюминиевые огурцы]]\n* [[бешеный огурец]]\n* [[малосольный огурец]]\n* [[морской огурец]]\n* [[праздни"
  body "к огурца]] (в Суздале)\n* [[солёный огурец]]\n\n==== Пословицы и поговорки ====\n* [[коль пошла такая пьянка, режь последний огурец]]\n\n=== Перевод ===\n{{перев-блок|растение\n|abq=\n|ab=[[анаша]]\n|"
  body "av=\n|ave=\n|agh=\n|aja=\n|ady=\n|az=[[xiyar]]\n|ay=[[pipinu]]\n|ain=\n|ain.kana=\n|ain.lat=\n|sq=[[kastravec]]\n|als=\n|ale=\n|alt=\n|en=[[cucumber]]\n|ar=\n|an=\n|arc.jud=\n|arc.syr=\n|arn=\n|hy=[[վ"
  body "արունգ]] (varung)\n|asm=\n|ast=[[pepín]]\n|af=[[komkommer]]\n|bar=\n|bm=\n|eu=[[luzoker]]\n|ba=[[ҡыяр]]\n|be=[[агурок]] {{m}}\n|bn=\n|bis=[[kukamba]]\n|bg=[[краставица]]\n|bs=[[krastavac]] {{m}}\n|br="
  body "[[kokombrezenn]]\n|bua=[[үгэрсэ]]\n|cy={{t|cy|ciwcymbr|m}}\n|wa=[[concombe]]\n|hu=[[uborka]]\n|vec=[[cocumaro]]\n|vep=\n|hsb=[[kórka]]\n|vot=\n|vo=\n|wo=[[komkombar]]\n|vro=[[kurk']], [[ugurits]]\n|vi"
