  body "сландский -->\n|es=<!-- Испанский -->\n|it=<!-- Итальянский -->\n|kk=<!-- Казахский -->\n|krl=<!-- Карельский -->\n|ca=<!-- Каталанский -->\n|ky=<!-- Киргизский -->\n|zh-tw=<!-- Китайский (традиц.) --"
  body ">\n|zh-cn=<!-- Китайский (упрощ.) -->\n|ko=<!-- Корейский -->\n|co=<!-- Корсиканский -->\n|la=<!-- Латинский -->\n|lv=<!-- Латышский -->\n|lt=<!-- Литовский -->\n|mdf=<!-- Мокшанский -->\n|mn=<!-- Мон"
  body "гольский -->\n|gv=<!-- Мэнский -->\n|nah=<!-- Науатль -->\n|de={{t|de|so}}\n|nl=<!-- Нидерландский -->\n|no=<!-- Норвежский -->\n|pl=<!-- Польский -->\n|pt=<!-- Португальский -->\n|sr=<!-- Сербский (к"
