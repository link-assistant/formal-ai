concept_universal_solver
  term "universal solver"
  intent "concept_lookup"
  category "algorithm"
  aliases "the universal solver|universal problem solver"
  summary "The universal solver is formal-ai's deterministic 11-step loop: impulse, formalization, context, history, decomposition, TDD, synthesis, combination, verification, simplification, documentation. Every interface routes through the same loop."
  source "docs/case-studies/issue-12/README.md"
  source_kind "project-docs"

concept_event_log
  term "event log"
  intent "concept_lookup"
  category "data-structure"
  aliases "the event log|eventlog|append-only log"
  summary "The event log is formal-ai's append-only system of record. Every step in the universal solver loop appends an Event with a stable content-addressed id; the user-facing answer is, by construction, a projection of this log."
  source "docs/NON-GOALS.md"
  source_kind "project-docs"

concept_links_notation
  term "Links Notation"
  intent "concept_lookup"
  category "data-format"
  aliases "links notation|lino|the links notation format"
  summary "Links Notation is an indentation-based, untyped serialization format used by the Deep Theory project to represent links and link networks as portable text."
  source "https://github.com/linksplatform/Documentation"
  source_kind "project-docs"

concept_links_meta_theory
  term "Links meta-theory"
  intent "concept_lookup"
  category "knowledge-representation"
  aliases "links meta-theory|the links meta-theory|links theory|the links theory|link theory|theory of links|deep theory|deep theory of links|теория связей|теории связей|теорию связей|теория связи|глубокая теория связей|глубокой теории связей|глубокую теорию связей|метатеория связей|мета-теория связей"
  summary "In the Link Foundation context, links theory means the link-foundation/meta-theory repository and its archived Links Theory articles. It describes information representation through links: references to links, with the compact set-theory projection L -> L^2. In formal-ai, a bare question about links theory assumes this product; if you mean another similarly named theory, specify the domain because those theories are described differently."
  source "https://github.com/link-foundation/meta-theory"
  source_kind "official-repository"
  localized "en"
    term "Links meta-theory"
    aliases "links meta-theory|the links meta-theory|links theory|the links theory|link theory|theory of links|deep theory|deep theory of links"
    summary "In the Link Foundation context, links theory means the link-foundation/meta-theory repository and its archived Links Theory articles. It describes information representation through links: references to links, with the compact set-theory projection L -> L^2. In formal-ai, a bare question about links theory assumes this product; if you mean another similarly named theory, specify the domain because those theories are described differently."
    source "https://github.com/link-foundation/meta-theory"
    source_kind "official-repository"
  localized "ru"
    term "Теория связей"
    aliases "теория связей|теории связей|теорию связей|теория связи|глубокая теория связей|глубокой теории связей|глубокую теорию связей|метатеория связей|мета-теория связей"
    summary "В контексте Link Foundation «теория связей» означает репозиторий link-foundation/meta-theory и архивированные статьи о Links Theory. Она описывает представление информации через связи: ссылки на связи, с компактной проекцией в теории множеств L -> L^2. В formal-ai такой запрос по умолчанию относится к этому продукту; если имеется в виду другая теория с похожим названием, укажите область, потому что другие теории описываются иначе."
    source "https://github.com/link-foundation/meta-theory"
    source_kind "official-repository"

concept_doublet
  term "doublet"
  intent "concept_lookup"
  category "data-structure"
  aliases "doublet link|a doublet|two-link"
  summary "A doublet is a link with exactly two endpoints. In Deep Theory it is the canonical reduction target for higher-arity links because every higher arity can be encoded as a chain of doublets."
  source "docs/VISION.md"
  source_kind "project-docs"

