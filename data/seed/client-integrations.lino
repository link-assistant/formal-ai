client_integrations
  tool "codex"
    label "Codex CLI"
    command "codex"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "FORMAL_AI_API_KEY"
    api_key_default "formal-ai"
    ephemeral
      temp_home_env "HOME"
      non_interactive_arg "exec"
      mode_arg_position "before_invocation"
      arg "--skip-git-repo-check"
      arg "--sandbox"
      arg "read-only"
      arg "-c"
      arg "model_providers.{provider_id}.name=\"formal-ai server\""
      arg "-c"
      arg "model_providers.{provider_id}.base_url=\"{endpoint_base_url}\""
      arg "-c"
      arg "model_providers.{provider_id}.env_key=\"{api_key_env}\""
      arg "-c"
      arg "model_providers.{provider_id}.wire_api=\"responses\""
      arg "-c"
      arg "model_provider=\"{provider_id}\""
      arg "-c"
      arg "model=\"{model}\""
      env "FORMAL_AI_API_KEY={api_key}"
    global
      kind "toml"
      path ".codex/config.toml"
      backup_suffix ".formal-ai.bak"
      toml_set "model_provider={provider_id}"
      toml_set "model={model}"
      toml_set "model_providers.{provider_id}.name=formal-ai server"
      toml_set "model_providers.{provider_id}.base_url={endpoint_base_url}"
      toml_set "model_providers.{provider_id}.env_key={api_key_env}"
      toml_set "model_providers.{provider_id}.wire_api=responses"
  tool "opencode"
    label "OpenCode"
    command "opencode"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "FORMAL_AI_API_KEY"
    api_key_default "formal-ai"
    model_selector "{provider_id}/{model}"
    ephemeral
      non_interactive_arg "run"
      mode_arg_position "before_invocation"
      env "FORMAL_AI_API_KEY={api_key}"
      config_env "OPENCODE_CONFIG"
      config_dir_env "OPENCODE_CONFIG_DIR"
      model_arg "-m"
      model_arg_position "after_first_arg"
      config_json_set "$schema=https://opencode.ai/config.json"
      config_json_set "provider.{provider_id}.name=formal-ai server"
      config_json_set "provider.{provider_id}.npm=@ai-sdk/openai-compatible"
      config_json_set "provider.{provider_id}.options.baseURL={endpoint_base_url}"
      config_json_set "provider.{provider_id}.options.apiKey={env:{api_key_env}}"
      config_json_set "provider.{provider_id}.models.{model}.name={model}"
      config_json_set "model={model_selector}"
    global
      kind "json"
      path ".config/opencode/opencode.json"
      backup_suffix ".formal-ai.bak"
      json_set "$schema=https://opencode.ai/config.json"
      json_set "provider.{provider_id}.name=formal-ai server"
      json_set "provider.{provider_id}.npm=@ai-sdk/openai-compatible"
      json_set "provider.{provider_id}.options.baseURL={endpoint_base_url}"
      json_set "provider.{provider_id}.options.apiKey={env:{api_key_env}}"
      json_set "provider.{provider_id}.models.{model}.name={model}"
      json_set "model={model_selector}"
  tool "agent"
    label "Link Assistant Agent CLI"
    command "agent"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "FORMAL_AI_API_KEY"
    api_key_default "formal-ai"
    model_selector "{provider_id}/{model}"
    ephemeral
      interactive_arg "--interactive"
      non_interactive_arg "-p"
      temp_home_env "HOME"
      no_summarize_arg "--no-summarize-session"
      no_summarize_arg "--compaction-model"
      no_summarize_arg "same"
      env "FORMAL_AI_API_KEY={api_key}"
      config_content_env "LINK_ASSISTANT_AGENT_CONFIG_CONTENT"
      model_arg "--model"
      model_arg_position "before_args"
      config_json_set "$schema=https://opencode.ai/config.json"
      config_json_set "provider.{provider_id}.name=formal-ai server"
      config_json_set "provider.{provider_id}.npm=@ai-sdk/openai-compatible"
      config_json_set "provider.{provider_id}.options.baseURL={endpoint_base_url}"
      config_json_set "provider.{provider_id}.options.apiKey={env:{api_key_env}}"
      config_json_set "provider.{provider_id}.models.{model}.name={model}"
      config_json_set "model={model_selector}"
    global
      kind "json"
      path ".config/link-assistant-agent/opencode.json"
      backup_suffix ".formal-ai.bak"
      json_set "$schema=https://opencode.ai/config.json"
      json_set "provider.{provider_id}.name=formal-ai server"
      json_set "provider.{provider_id}.npm=@ai-sdk/openai-compatible"
      json_set "provider.{provider_id}.options.baseURL={endpoint_base_url}"
      json_set "provider.{provider_id}.options.apiKey={env:{api_key_env}}"
      json_set "provider.{provider_id}.models.{model}.name={model}"
      json_set "model={model_selector}"
  tool "gemini"
    label "Gemini CLI"
    command "gemini"
    provider_id "formalai"
    default_protocol "gemini"
    supported_protocols ("gemini" "vertex")
    endpoint_gemini "/api/gemini"
    endpoint_vertex "/api/vertex"
    api_key_env "GEMINI_API_KEY"
    api_key_default "formal-ai"
    ephemeral
      interactive_arg "--prompt-interactive"
      non_interactive_arg "-p"
      env "GEMINI_API_KEY={api_key}"
      env "GEMINI_DEFAULT_AUTH_TYPE={google_auth_type}"
      env "GEMINI_CLI_TRUST_WORKSPACE=true"
      env "{protocol_base_env}={endpoint_base_url}"
      temp_home_env "GEMINI_CLI_HOME"
      temp_home_config_path ".gemini/settings.json"
      temp_home_json_set "security.auth.selectedType={google_auth_type}"
      model_arg "-m"
      model_arg_position "before_args"
    global
      kind "shell_env"
      path ".profile"
      backup_suffix ".formal-ai.bak"
      shell_env "GEMINI_API_KEY=${FORMAL_AI_API_KEY:-formal-ai}"
      shell_env "GEMINI_DEFAULT_AUTH_TYPE={google_auth_type}"
      shell_env "GEMINI_CLI_TRUST_WORKSPACE=true"
      shell_env "{protocol_base_env}={endpoint_base_url}"
  tool "claude"
    label "Claude Code"
    command "claude"
    provider_id "formalai"
    default_protocol "anthropic"
    supported_protocols ("anthropic")
    endpoint_anthropic "/api/anthropic"
    api_key_env "ANTHROPIC_AUTH_TOKEN"
    api_key_default "formal-ai"
    ephemeral
      non_interactive_arg "--print"
      temp_home_env "CLAUDE_CONFIG_DIR"
      env "ANTHROPIC_AUTH_TOKEN={api_key}"
      env "ANTHROPIC_API_KEY="
      env "ANTHROPIC_BASE_URL={endpoint_base_url}"
      model_arg "--model"
      model_arg_position "before_args"
    global
      kind "shell_env"
      path ".profile"
      backup_suffix ".formal-ai.bak"
      shell_env "ANTHROPIC_AUTH_TOKEN=${FORMAL_AI_API_KEY:-formal-ai}"
      shell_env "ANTHROPIC_BASE_URL={endpoint_base_url}"
  tool "qwen"
    label "Qwen Code"
    command "qwen"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "OPENAI_API_KEY"
    api_key_default "formal-ai"
    ephemeral
      interactive_arg "--prompt-interactive"
      non_interactive_arg "-p"
      env "OPENAI_API_KEY={api_key}"
      env "OPENAI_BASE_URL={endpoint_base_url}"
      env "OPENAI_MODEL={model}"
      temp_home_env "HOME"
      model_arg "--model"
      model_arg_position "before_args"
    global
      kind "shell_env"
      path ".profile"
      backup_suffix ".formal-ai.bak"
      shell_env "OPENAI_API_KEY=${FORMAL_AI_API_KEY:-formal-ai}"
      shell_env "OPENAI_BASE_URL={endpoint_base_url}"
  tool "grok"
    label "Grok Build"
    command "grok"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "XAI_API_KEY"
    api_key_default "formal-ai"
    ephemeral
      non_interactive_arg "--prompt"
      temp_home_env "HOME"
      env "XAI_API_KEY={api_key}"
      env "XAI_BASE_URL={endpoint_base_url}"
      model_arg "--model"
      model_arg_position "before_args"
    global
      kind "shell_env"
      path ".profile"
      backup_suffix ".formal-ai.bak"
      shell_env "XAI_API_KEY=${FORMAL_AI_API_KEY:-formal-ai}"
      shell_env "XAI_BASE_URL={endpoint_base_url}"
  tool "aider"
    label "Aider"
    command "aider"
    provider_id "formalai"
    default_protocol "openai"
    supported_protocols ("openai")
    endpoint_openai "/api/openai/v1"
    api_key_env "OPENAI_API_KEY"
    api_key_default "formal-ai"
    model_selector "openai/{model}"
    ephemeral
      non_interactive_arg "--message"
      temp_home_env "HOME"
      env "OPENAI_API_KEY={api_key}"
      env "OPENAI_API_BASE={endpoint_base_url}"
      arg "--no-auto-commits"
      model_arg "--model"
      model_arg_position "before_args"
    global
      kind "shell_env"
      path ".profile"
      backup_suffix ".formal-ai.bak"
      shell_env "OPENAI_API_KEY=${FORMAL_AI_API_KEY:-formal-ai}"
      shell_env "OPENAI_API_BASE={endpoint_base_url}"
