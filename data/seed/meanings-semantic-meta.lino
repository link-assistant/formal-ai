meanings
  meaning "semantic_facet"
    gloss "a meaning-to-meaning relation that describes one aspect of another meaning: how it is written, explained, denoted, or associated. Facets are themselves meanings, so new semantic axes can be added as data without changing parser code."
    wiktionary "facet"
    defined_by "relation"
    role "ontology_category"
    facet "notation"
      meaning "links_notation_format"
    facet "annotation"
      meaning "semantic_gloss"
    facet "denotation"
      meaning "relation"
    facet "connotation"
      meaning "concept"
    lexeme "en"
      word "semantic facet"
        description "English noun phrase for an aspect of meaning represented as another meaning link."
        facet "notation"
          meaning "word_surface"
        facet "denotation"
          meaning "semantic_facet"
        facet "part_of_speech"
          meaning "noun_phrase"
