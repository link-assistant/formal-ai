  meaning "semantic_gloss"
    gloss "a concise annotation meaning that explains another meaning in reviewable language. It names the role currently played by each meaning's gloss field and lets that annotation target be referenced recursively as data."
    wiktionary "gloss"
    defined_by "annotation"
    role "semantic_annotation_artifact"
