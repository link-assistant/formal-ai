program_cst_grammars
  description "Tree-sitter grammar metadata for generated programs. The Rust solver uses the real tree-sitter Rust binding and the grammar crates below to parse generated source before accepting it, so coding handlers reason from a semantic plan and then validate the concrete language CST instead of treating code text as opaque output."
  parser_binding "tree-sitter/lib/binding_rust"
  cst_grammar "javascript"
    program_language "javascript"
    grammar_crate "tree-sitter-javascript"
    grammar_symbol "LANGUAGE"
    root_kind "program"
    source_repository "https://github.com/tree-sitter/tree-sitter-javascript"
  cst_grammar "typescript"
    program_language "typescript"
    grammar_crate "tree-sitter-typescript"
    grammar_symbol "LANGUAGE_TYPESCRIPT"
    root_kind "program"
    source_repository "https://github.com/tree-sitter/tree-sitter-typescript"
  cst_grammar "python"
    program_language "python"
    grammar_crate "tree-sitter-python"
    grammar_symbol "LANGUAGE"
    root_kind "module"
    source_repository "https://github.com/tree-sitter/tree-sitter-python"
  cst_grammar "rust"
    program_language "rust"
    grammar_crate "tree-sitter-rust"
    grammar_symbol "LANGUAGE"
    root_kind "source_file"
    source_repository "https://github.com/tree-sitter/tree-sitter-rust"
  cst_grammar "go"
    program_language "go"
    grammar_crate "tree-sitter-go"
    grammar_symbol "LANGUAGE"
    root_kind "source_file"
    source_repository "https://github.com/tree-sitter/tree-sitter-go"
  cst_grammar "ruby"
    program_language "ruby"
    grammar_crate "tree-sitter-ruby"
    grammar_symbol "LANGUAGE"
    root_kind "program"
    source_repository "https://github.com/tree-sitter/tree-sitter-ruby"
  cst_grammar "java"
    program_language "java"
    grammar_crate "tree-sitter-java"
    grammar_symbol "LANGUAGE"
    root_kind "program"
    source_repository "https://github.com/tree-sitter/tree-sitter-java"
  cst_grammar "csharp"
    program_language "csharp"
    grammar_crate "tree-sitter-c-sharp"
    grammar_symbol "LANGUAGE"
    root_kind "compilation_unit"
    source_repository "https://github.com/tree-sitter/tree-sitter-c-sharp"
  cst_grammar "c"
    program_language "c"
    grammar_crate "tree-sitter-c"
    grammar_symbol "LANGUAGE"
    root_kind "translation_unit"
    source_repository "https://github.com/tree-sitter/tree-sitter-c"
  cst_grammar "cpp"
    program_language "cpp"
    grammar_crate "tree-sitter-cpp"
    grammar_symbol "LANGUAGE"
    root_kind "translation_unit"
    source_repository "https://github.com/tree-sitter/tree-sitter-cpp"
