    localized hi
      name write_program
      note "language और task parameters से seeded programs दिखाता है।"
  tool tool_intent_routing
    name intent_routing
    note "Route normalized prompts through seeded multilingual keywords, phrases, tokens, and combos."
    mode thinking
    inputs prompt|language
    outputs intent|confidence|evidence
    isolation seed
    sources "data/seed/intent-routing.lino|data/seed/prompt-patterns.lino"
    localized ru
      name intent_routing
      note "Маршрутизирует нормализованные запросы через seed-ключи, фразы, токены и комбинации на разных языках."
    localized zh
      name intent_routing
      note "通过 seed 多语言关键词、短语、标记和组合路由规范化提示。"
    localized hi
      name intent_routing
      note "normalized prompts को seeded multilingual keywords, phrases, tokens, और combos से route करता है।"
