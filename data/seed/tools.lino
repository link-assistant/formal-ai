tools_registry
  tool "tool_http_fetch"
    name "http_fetch"
    description "Issue an HTTP GET request from the current environment (browser fetch, Rust reqwest, etc.) and return body + status."
    mode "thinking"
    inputs "url"
    outputs "status|body|headers"
    isolation "network"
    sources "browser:fetch|rust:reqwest"
  tool "tool_web_search"
    name "web_search"
    description "Search the open web via a third-party search engine and return ranked result links."
    mode "thinking"
    inputs "query"
    outputs "results"
    isolation "network"
    sources "duckduckgo|wikipedia"
  tool "tool_wikipedia_lookup"
    name "wikipedia_lookup"
    description "Fetch a structured Wikipedia REST summary for the given title in the detected language, falling back to English."
    mode "thinking"
    inputs "term|language"
    outputs "title|extract|url|language"
    isolation "network"
    sources "wikipedia"
  tool "tool_calculator"
    name "calculator"
    description "Evaluate calculator-parsable math, unit, currency, percentage, and datetime expressions through link-calculator."
    mode "thinking"
    inputs "expression"
    outputs "result|lino|steps|engine"
    isolation "local-library"
    sources "rust:link-calculator"
  tool "tool_eval_js"
    name "eval_js"
    description "Evaluate a JavaScript snippet inside the browser worker sandbox (no DOM, no network). Records stdout / return value / errors."
    mode "agent"
    inputs "program"
    outputs "stdout|returned|error"
    isolation "browser-worker"
    sources "browser:Function"
  tool "tool_read_local_file"
    name "read_local_file"
    description "Read a file the user has selected through the browser File picker. Pure read-only — never touches the host filesystem."
    mode "thinking"
    inputs "file_handle"
    outputs "text"
    isolation "browser-user-selected"
    sources "browser:FileReader"
  tool "tool_append_memory"
    name "append_memory"
    description "Append a single event to the AI's append-only memory log (Links Notation). Available in agent mode only."
    mode "agent"
    inputs "event"
    outputs "id"
    isolation "browser-indexeddb"
    sources "browser:IndexedDB"
  tool "tool_export_memory"
    name "export_memory"
    description "Serialize the entire append-only memory log as Links Notation text suitable for a .lino bundle."
    mode "thinking"
    inputs ""
    outputs "lino_text"
    isolation "browser-indexeddb"
    sources "browser:IndexedDB"
