tools_registry
  tool tool_http_fetch
    name http_fetch
    note "Issue an HTTP GET request from the current environment and return body, status, and headers; when CORS blocks the response, check frame-policy metadata before using an iframe preview."
    mode thinking
    inputs url
    outputs status|body|headers|iframe|external_link|frame_policy
    isolation network
    sources "browser:fetch|rust:reqwest|browser:iframe|microlink:headers|direct_link"
    localized ru
      name http_fetch
      note "Выполняет HTTP GET в текущей среде и возвращает тело, статус и заголовки; при блокировке CORS проверяет frame-policy перед iframe-превью."
    localized zh
      name http_fetch
      note "在当前环境中执行 HTTP GET，并返回正文、状态和标头；当 CORS 阻止响应时先检查 frame-policy 元数据，再决定是否使用 iframe 预览。"
    localized hi
      name http_fetch
      note "मौजूदा वातावरण से HTTP GET चलाता है और body, status, headers लौटाता है; CORS रोकने पर iframe preview से पहले frame-policy metadata जांचता है।"
  tool tool_url_navigate
    name url_navigate
    note "Normalize a requested URL, check CORS-readable frame-policy metadata, and return either an iframe preview or a direct external HTTPS link."
    mode thinking
    inputs url
    outputs url|iframe|external_link|frame_policy
    isolation browser-frame-policy
    sources "microlink:headers|browser:iframe|direct_link|browser:new_tab"
    localized ru
      name url_navigate
      note "Нормализует запрошенный URL, проверяет CORS-доступные frame-policy данные и возвращает iframe-превью или прямую внешнюю HTTPS-ссылку."
    localized zh
      name url_navigate
      note "规范化请求的 URL，检查可通过 CORS 读取的 frame-policy 元数据，并返回 iframe 预览或直接外部 HTTPS 链接。"
    localized hi
      name url_navigate
      note "मांगे गए URL को normalize करता है, CORS-readable frame-policy metadata जांचता है, और iframe preview या सीधा external HTTPS link लौटाता है।"
  tool tool_web_search
    name web_search
    note "Search the open web through the configured search provider and return ranked result links."
    mode thinking
    inputs query
    outputs results
    isolation network
    sources "browser:fetch|wikipedia"
    localized ru
      name web_search
      note "Ищет в открытом вебе через настроенный поисковый источник и возвращает ранжированные ссылки."
    localized zh
      name web_search
      note 通过配置的搜索提供方检索开放网络，并返回排序后的结果链接。
    localized hi
      name web_search
      note "कॉन्फिगर किए गए search provider से खुले वेब में खोजता है और ranked links लौटाता है।"
  tool tool_wikipedia_lookup
    name wikipedia_lookup
    note "Fetch a structured Wikipedia REST summary for the given title in the detected language, falling back to English."
    mode thinking
    inputs term|language
    outputs title|extract|url|language
    isolation network
    sources wikipedia
    localized ru
      name wikipedia_lookup
      note "Получает структурированное резюме Wikipedia REST для указанного названия на найденном языке с запасным английским."
    localized zh
      name wikipedia_lookup
      note "按检测到的语言获取指定标题的 Wikipedia REST 结构化摘要，并可回退到英文。"
    localized hi
      name wikipedia_lookup
      note "दिए गए title के लिए detected भाषा में Wikipedia REST summary लाता है, जरूरत पर English fallback करता है।"
  tool tool_calculator
    name calculator
    note "Evaluate calculator-parsable math, unit, currency, percentage, and datetime expressions through link-calculator."
    mode thinking
    inputs expression
    outputs result|lino|steps|engine
    isolation local-library
    sources "rust:link-calculator"
    localized ru
      name calculator
      note "Вычисляет математические, единичные, валютные, процентные и временные выражения через link-calculator."
    localized zh
      name calculator
      note "通过 link-calculator 计算数学、单位、货币、百分比和日期时间表达式。"
    localized hi
      name calculator
      note "link-calculator से math, unit, currency, percentage, और datetime expressions का मूल्य निकालता है।"
  tool tool_eval_js
    name eval_js
    note "Evaluate a JavaScript snippet inside the browser worker sandbox with no DOM and no network."
    mode agent
    inputs program
    outputs stdout|returned|error
    isolation browser-worker
    sources "browser:Function"
    localized ru
      name eval_js
      note "Выполняет JavaScript-фрагмент в sandbox браузерного worker без DOM и сети."
    localized zh
      name eval_js
      note "在浏览器 worker 沙箱中执行 JavaScript 片段，不提供 DOM 或网络。"
    localized hi
      name eval_js
      note "browser worker sandbox में JavaScript snippet चलाता है, DOM और network उपलब्ध नहीं होते।"
  tool tool_read_local_file
    name read_local_file
    note "Read a file the user selected through the browser file picker without touching the host filesystem."
    mode thinking
    inputs file_handle
    outputs text
    isolation browser-user-selected
    sources "browser:FileReader"
    localized ru
      name read_local_file
      note "Читает выбранный пользователем файл через браузерный выбор файла, не обращаясь к файловой системе хоста."
    localized zh
      name read_local_file
      note 读取用户通过浏览器文件选择器选中的文件，不访问主机文件系统。
    localized hi
      name read_local_file
      note "browser file picker से चुनी गई file पढ़ता है और host filesystem को नहीं छूता।"
  tool tool_append_memory
    name append_memory
    note "Append a single event to the AI append-only memory log in Links Notation."
    mode agent
    inputs event
    outputs id
    isolation browser-indexeddb
    sources "browser:IndexedDB"
    localized ru
      name append_memory
      note "Добавляет одно событие в append-only журнал памяти AI в формате Links Notation."
    localized zh
      name append_memory
      note "向 AI 的 Links Notation 追加式记忆日志添加单个事件。"
    localized hi
      name append_memory
      note "AI के append-only Links Notation memory log में एक event जोड़ता है।"
  tool tool_export_memory
    name export_memory
    note "Serialize the full memory bundle as Links Notation text for download or migration."
    mode thinking
    inputs
    outputs lino_text
    isolation browser-indexeddb
    sources "browser:IndexedDB"
    localized ru
      name export_memory
      note "Сериализует полный bundle памяти как Links Notation для скачивания или миграции."
    localized zh
      name export_memory
      note "将完整记忆 bundle 序列化为 Links Notation 文本，用于下载或迁移。"
    localized hi
      name export_memory
      note "पूरे memory bundle को download या migration के लिए Links Notation text में बदलता है।"
  tool tool_import_memory
    name import_memory
    note "Import a demo_memory log or full formal_ai_bundle from a user-selected .lino file."
    mode thinking
    inputs lino_text
    outputs inserted_events|migration_hints
    isolation browser-indexeddb
    sources "browser:IndexedDB"
    localized ru
      name import_memory
      note "Импортирует demo_memory журнал или полный formal_ai_bundle из выбранного пользователем .lino файла."
    localized zh
      name import_memory
      note "从用户选择的 .lino 文件导入 demo_memory 日志或完整 formal_ai_bundle。"
    localized hi
      name import_memory
      note "user-selected .lino file से demo_memory log या पूरा formal_ai_bundle import करता है।"
  tool tool_conversation_recall
    name conversation_recall
    note "Search the append-only memory log for prior mentions and group matches by conversation."
    mode thinking
    inputs term|scope|current_conversation
    outputs matches|conversation_report
    isolation browser-indexeddb
    sources "browser:IndexedDB"
    localized ru
      name conversation_recall
      note "Ищет прошлые упоминания в append-only памяти и группирует совпадения по разговорам."
    localized zh
      name conversation_recall
      note 在追加式记忆日志中搜索过去提及，并按对话分组匹配结果。
    localized hi
      name conversation_recall
      note "append-only memory log में पुराने mentions खोजता है और matches को conversation से group करता है।"
  tool tool_concept_lookup
    name concept_lookup
    note "Resolve a seeded concept, alias, or Wikidata-backed entity to a grounded summary."
    mode thinking
    inputs term|language|context
    outputs summary|source|wikidata
    isolation seed
    sources "data/seed/concepts.lino|data/seed/concept-contexts.lino"
    localized ru
      name concept_lookup
      note "Сопоставляет seed-понятие, псевдоним или Wikidata-сущность с проверяемым резюме."
    localized zh
      name concept_lookup
      note "将 seed 概念、别名或 Wikidata 实体解析为有依据的摘要。"
    localized hi
      name concept_lookup
      note "seed concept, alias, या Wikidata-backed entity को grounded summary से resolve करता है।"
