program_cst_grammars
  description "CST/AST engine metadata for generated programs. The sole engine is the link-foundation meta-language links network (meta_language::LinkNetwork), a single mutable links-network representation that ships real tree-sitter grammars for every target language (JavaScript, Python, Rust, Java, C, C++, C#, TypeScript, Go, Ruby). Coding handlers reason from a semantic plan, render concrete source, and then validate that source through meta-language before accepting it — code text is never treated as opaque output."
  component "meta-language"
  component_repository "https://github.com/link-foundation/meta-language"
  cst_grammar "javascript"
    program_language "javascript"
    engine "meta_language"
    meta_language_label "javascript"
    source_repository "https://github.com/link-foundation/meta-language"
  cst_grammar "python"
    program_language "python"
    engine "meta_language"
    meta_language_label "python"
    source_repository "https://github.com/link-foundation/meta-language"
