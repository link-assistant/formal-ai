    language "en"
    text "Hi, how may I help you?"
    variant "Hi, how may I help you?"
    variant "Hello! How can I assist you today?"
    variant "Hi there! What can I do for you?"
    variant "Hey, how can I help?"
    variant "Hello — what would you like to explore?"
