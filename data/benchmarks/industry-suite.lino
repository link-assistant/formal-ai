  upstream_id "held_out_renumbered:test.jsonl line 1"
  variant "held_out"
  prompt "Marisol's hens lay 24 eggs per day. She eats five for breakfast every morning and bakes cakes for her neighbors every day with seven. She sells the remainder at the market daily for $3 per fresh egg. How much in dollars does she make every day at the market?"
  check "contains_all"
  expected_contains "36"
  expected_answer "36"
  verification "renumbered variant must recompute the remainder sale instead of reusing the seed answer"
  allow_current_failure "true"
