benchmark_suite_issue_304_industry_permissive_slice
  record_type "benchmark_suite"
  id "issue_304_industry_permissive_slice"
  title "Permissive industry benchmark slice"
  purpose "Deterministic unseen-task benchmark cases for programming, math, and general problem-solving."
  runner "cargo test --test unit issue_304_benchmark_suite_reports_pass_fail_counts -- --nocapture"
  report_mode "Pass/fail counts are reported; failing benchmark cases document capability gaps unless the pass-count floor regresses."
  minimum_pass_count "12"
  ratchet_policy "CI asserts passed >= minimum_pass_count so solved benchmark progress cannot silently regress."
  held_out_policy "Each source has one self-authored held-out or paraphrased variant that changes wording, numbers, or distractors while preserving the source task structure."
  imported_at "2026-05-26"
  updated_at "2026-07-14"
