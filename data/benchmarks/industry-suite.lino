benchmark_case_humaneval_0_has_close_elements
  record_type "benchmark_case"
  id "humaneval_0_has_close_elements"
  source "humaneval"
  domain "programming"
  upstream_id "HumanEval/0"
  prompt "Implement Python function has_close_elements(numbers: list[float], threshold: float) -> bool. Return True when any two distinct numbers differ by less than threshold; otherwise return False."
  check "contains_all"
  expected_contains "```python"
  expected_contains "def has_close_elements"
  expected_contains "return False"
  expected_answer "Python function satisfying HumanEval/0 tests"
  verification "static response contains the function name, a Python fence, and an explicit false branch"
  allow_current_failure "true"
