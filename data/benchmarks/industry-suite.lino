  upstream_id "held_out_paraphrase:HumanEval/0"
  variant "held_out"
  prompt "Write Python function has_close_elements(numbers: list[float], threshold: float) -> bool. Inspect every distinct pair of numbers; return True if any absolute difference is less than threshold, otherwise return False."
  check "contains_all"
  expected_contains "```python"
