  license "CC-BY-4.0"
  license_url "https://creativecommons.org/licenses/by/4.0/legalcode"
  source_url "https://github.com/link-assistant/formal-ai/issues/662"
  source_ref "issue-662"
  original_size "self-authored search-only slice"
  imported_cases "0"
  suite_cases "2"
  held_out_variants "1"
  note "Search-only cases (issue #662): no reusable part or single rule derives the answer, so only the step-7 budget-driven random/evolutionary search combines the given numbers with the allowed operators to reach the target."
benchmark_case_arithmetic_reachability_search_reach_32
  record_type "benchmark_case"
  id "arithmetic_reachability_search_reach_32"
  source "arithmetic_reachability_search"
  domain "general_problem_solving"
  upstream_id "self_authored:reach_32"
  prompt "Combine the numbers 4, 6, and 8 using the operations + and * to reach 32."
  check "contains_all"
  expected_contains "budget-driven search"
  expected_contains "= 32"
  expected_answer "A composition of 4, 6, and 8 with + and * that evaluates to 32"
  verification "only the budget-driven search combines the operands with the allowed operators to reach the target; the trace records a search:solution marker"
  allow_current_failure "true"
