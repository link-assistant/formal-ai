benchmark_suite_issue_702_world_state_tracking_slice
  record_type "benchmark_suite"
  id "issue_702_world_state_tracking_slice"
  title "bAbI-style world-state tracking slice"
  purpose "Deterministic capability slice for issue #702: a short dialogue states facts and a goal, and the assistant must answer 'what is left to do?' from the current->target difference of its symbolic world model rather than from memory of the words. Cases follow the shape of the bAbI state-tracking tasks (single supporting fact, two supporting facts, object state change) and of everyday goal dialogues, in all four supported languages. Every case is self-authored in the style of the upstream task (the local-profile convention issue #408 established); no upstream text is copied, so the slice carries no upstream text licensing."
  runner "cargo test --test unit issue_702_world_state_suite_tracks_each_case -- --nocapture"
  report_mode "Pass/fail counts are reported; a failing case documents a tracking gap unless the pass-count floor regresses."
  minimum_pass_count "16"
  ratchet_policy "CI asserts passed >= minimum_pass_count so world-state tracking progress cannot silently regress."
  held_out_policy "Each source carries held-out/paraphrased variants that change wording (and language) while preserving the tracked state, so passing cannot come from memorized phrasing."
  topic "world_model / state_tracking"
  imported_at "2026-07-21"
  updated_at "2026-07-21"
benchmark_source_babi
  record_type "benchmark_source"
  id "babi"
  domain "state_tracking"
  title "bAbI tasks (20 QA tasks for text understanding and reasoning)"
  license "CC-BY-3.0"
  license_url "https://research.facebook.com/downloads/babi/"
  source_url "https://github.com/facebookarchive/bAbI-tasks"
  source_ref "8a6f3dbf1a7b1a5bd9c9a5b8dbd8b1b31e6dbdc6"
  note "Tasks 1, 2 and 6 track where an entity is and how its state changes over a short story; represented here by self-authored dialogues of the same shape."
  usage_note "Only the task shape is reproduced; every prompt below is self-authored, so no upstream text is redistributed."
benchmark_source_goal_dialog
  record_type "benchmark_source"
  id "goal_dialog"
  domain "assistant_dialog"
  title "Everyday goal-directed assistant dialogues"
  license "CC-BY-4.0"
  license_url "https://creativecommons.org/licenses/by/4.0/"
  source_url "https://github.com/link-assistant/formal-ai"
  source_ref "issue-702"
  note "Self-authored dialogues in which the user states the situation, states a wish, and later asks what is left — the case study shape issue #702 describes."
  usage_note "Authored inside this repository for the issue #702 slice."
benchmark_case_babi_location_en
  record_type "benchmark_case"
  id "babi_location_en"
  source "babi"
  language "en"
  upstream_id "babi:task1_single_supporting_fact"
  turn "john is in the kitchen"
  turn "I want john in the garden"
  query "what is left to do?"
  expected_intent "world_state_remaining"
  expected_remaining "john -> in_garden"
  verification "the single supporting fact and the wish must produce one open target link"
benchmark_case_babi_location_en_held_out
  record_type "benchmark_case"
  id "babi_location_en_held_out"
  source "babi"
  language "en"
  variant "held_out"
  upstream_id "held_out_paraphrase:babi:task1_single_supporting_fact"
  turn "mary is in the office"
  turn "I need mary in the hallway"
  query "what remains?"
  expected_intent "world_state_remaining"
  expected_remaining "mary -> in_hallway"
  verification "paraphrased wording and a different entity track the same way"
benchmark_case_babi_two_facts_en
  record_type "benchmark_case"
  id "babi_two_facts_en"
  source "babi"
  language "en"
  upstream_id "babi:task2_two_supporting_facts"
  turn "the box is in the kitchen"
  turn "the key is in the box"
  turn "I want the key in the garden"
  query "what is left to do?"
  expected_intent "world_state_remaining"
  expected_remaining "key -> in_garden"
  verification "two supporting facts leave exactly the goal statement open"
benchmark_case_babi_two_facts_en_held_out
  record_type "benchmark_case"
  id "babi_two_facts_en_held_out"
  source "babi"
  language "en"
  variant "held_out"
  upstream_id "held_out_paraphrase:babi:task2_two_supporting_facts"
  turn "the folder is in the office"
  turn "the report is in the folder"
  turn "I need the report in the archive"
  query "what is still missing?"
  expected_intent "world_state_remaining"
  expected_remaining "report -> in_archive"
  verification "a paraphrased two-fact story leaves the same single open target"
benchmark_case_babi_state_change_en
  record_type "benchmark_case"
  id "babi_state_change_en"
  source "babi"
  language "en"
  upstream_id "babi:task6_yes_no_state_change"
  turn "the door is closed"
  turn "I want the door to be open"
  turn "the door is open"
  query "what is left to do?"
  expected_intent "world_state_reached"
  verification "once the reported state matches the goal, nothing is left"
benchmark_case_goal_dialog_two_goals_en
  record_type "benchmark_case"
  id "goal_dialog_two_goals_en"
  source "goal_dialog"
  language "en"
  upstream_id "goal_dialog:two_open_goals"
  turn "the door is closed"
  turn "the light is off"
  turn "I want the door to be open"
  turn "I want the light to be on"
  turn "the door is open"
  query "what is left to do?"
  expected_intent "world_state_remaining"
  expected_remaining "light -> on"
  verification "a partially satisfied goal set reports only the still-open half"
benchmark_case_goal_dialog_two_goals_en_held_out
  record_type "benchmark_case"
  id "goal_dialog_two_goals_en_held_out"
  source "goal_dialog"
  language "en"
  variant "held_out"
  upstream_id "held_out_paraphrase:goal_dialog:two_open_goals"
  turn "the window is closed"
  turn "the heater is off"
  turn "I would like the window to be open"
  turn "I would like the heater to be on"
  turn "the window is open"
  query "what do i still need?"
  expected_intent "world_state_remaining"
  expected_remaining "heater -> on"
  verification "different entities and a paraphrased wish keep the same tracking"
