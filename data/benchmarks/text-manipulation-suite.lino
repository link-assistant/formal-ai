text_manipulation_suite_issue_408
  record_type "text_manipulation_suite"
  id "issue_408_text_code_edit_profile"
  title "Issue 408 deterministic text/code edit profile"
  purpose "Executable local benchmark profile for deterministic chat-driven text and code edits."
  runner "cargo test --test unit issue_408_text_code_edit_profile_passes_local_ratchet -- --nocapture"
  minimum_pass_count "1440"
  minimum_pass_count_per_source "30"
  local_10_percent_floor_per_source "3"
  sources_required "48"
  additional_sources_required "40"
  variations_per_source "30"
  pass_rate_basis_points "10000"
  local_profile_percent_basis_points "1000"
  ratchet_policy "CI asserts every local profile case passes and every source clears its per-source pass floor; raise minimum_pass_count only after new cases pass locally and in CI."
  upstream_payload_policy "External benchmark payloads are represented by source provenance records; the repository-local profile commits 30 deterministic edit tests per source and requires 30/30 per-source passes."
  updated_at "2026-06-12"
