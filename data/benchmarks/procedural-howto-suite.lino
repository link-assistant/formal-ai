benchmark_case_ifeval_apology_letter
  record_type "benchmark_case"
  id "ifeval_apology_letter"
  source "ifeval"
  domain "instruction_following"
  upstream_id "ifeval:procedural_drafting"
  prompt "How to draft a formal apology letter?"
  followup "Can you give me specific instructions?"
  expected_intent "procedural_how_to"
  check "intent_and_contains"
  expected_contains "apology letter"
  expected_answer "Procedural discovery plan rebound to the apology-letter task"
  verification "the elaboration follow-up must rebind to the prior how-to and restate the task"
  allow_current_failure "true"

benchmark_case_ifeval_apology_letter_held_out
  record_type "benchmark_case"
  id "ifeval_apology_letter_held_out"
  source "ifeval"
  domain "instruction_following"
  upstream_id "held_out_paraphrase:ifeval:procedural_drafting"
  variant "held_out"
  prompt "How can I compose a formal apology letter step by step?"
  expected_intent "procedural_how_to"
  check "intent_and_contains"
  expected_contains "apology letter"
  expected_answer "Procedural discovery plan for the apology-letter task"
  verification "paraphrased procedural prompt still routes to the how-to handler"
  allow_current_failure "true"

