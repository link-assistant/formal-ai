benchmark_suite_issue_444_procedural_howto_slice
  record_type "benchmark_suite"
  id "issue_444_procedural_howto_slice"
  title "Procedural how-to / instruction-following slice"
  purpose "Deterministic capability slice for issue #444: procedural \"how to X\" prompts (and their elaboration follow-ups) drawn from popular instruction-following benchmarks must route to the procedural_how_to handler instead of the unknown opener. Cases are self-authored, representative prompts in the style of each upstream benchmark (the same local-profile convention issue #408 established), with paraphrased held-out variants for anti-memorization."
  runner "cargo test --test unit issue_444_procedural_howto_suite_routes_each_case -- --nocapture"
  report_mode "Pass/fail counts are reported; a failing case documents a routing gap unless the pass-count floor regresses."
  minimum_pass_count "12"
  ratchet_policy "CI asserts passed >= minimum_pass_count so procedural-routing progress cannot silently regress."
  held_out_policy "Each source carries one self-authored held-out/paraphrased variant that changes wording while preserving the procedural task."
  topic "procedural_how_to / instruction_following"
  imported_at "2026-06-13"
  updated_at "2026-06-13"

