external_benchmark_harness_issue_698
  record_type "external_benchmark_harness"
  id "issue_698_external_benchmark_harness"
  title "Issue 698 real external benchmark harness"
  purpose "Run real upstream benchmark suites end to end and record honest passed/total scores against the upstream case set."
  runner "cargo run --bin formal-ai -- benchmark run --suite all --slice 20 --append"
  network_runner "cargo test --test unit external_benchmarks -- --ignored --nocapture"
  ratchet_runner "cargo run --bin formal-ai -- benchmark ratchet"
  scheduled_workflow ".github/workflows/external-benchmarks.yml"
  honesty_policy "Scores are passed/total over the first N upstream cases in upstream order. No curated subset, no invented floor: 0 passed is recorded as 0 passed."
  download_policy "Upstream payloads are fetched at run time into target/formal-ai-benchmarks and are never vendored into the repository."
  unavailable_policy "A suite that cannot run is recorded as a benchmark_unavailable record with its reason; no repository-local proxy is ever substituted for it."
  license_policy "Only permissively licensed suites are fetched (MIT, Apache-2.0, CC-BY-4.0); per-suite licenses are recorded here and in data/benchmarks/LICENSES.md."
  ratchet_policy "A pull request may not reduce any recorded upstream pass count, and minimum_pass_count may only rise."
  updated_at "2026-07-20"
