  meanings
    entry
      definitions
        entry
          definition "(reflexive pronoun) Me, as direct or indirect object the speaker as the object of a verb or preposition, when the speaker is also the subject."
          example "I taught myself."
        entry
          definition "Personally, for my part; used in apposition to I, sometimes for simple emphasis and sometimes with implicit exclusion of any others performing the activity described."
        entry
          definition "In my normal state of body or mind."
        entry
          definition "Me (as the object of a verb or preposition)."
          example "I feel like myself."
        entry
          definition "I (as the subject of a verb)."
        entry
          definition "My name is..."
          example "Myself John."
      partOfSpeech pronoun
      synonyms (me)
  phonetic "/maɪˈsɛlf/"
