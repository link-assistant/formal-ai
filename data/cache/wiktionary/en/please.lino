entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "Used to make a polite request."
          example "Could you tell me the time, please?"
        entry
          definition "Used as an affirmative to an offer."
          example "—May I help you? —Please."
        entry
          definition "An expression of annoyance or impatience."
          example "Oh, please, do we have to hear that again?"
      partOfSpeech adverb
  phonetic "/pliːz/"
