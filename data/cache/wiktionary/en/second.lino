entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "One who supports another in a contest or combat, such as a dueller's assistant."
        entry
          definition "One who supports or seconds a motion, or the act itself, as required in certain meetings to pass judgement etc."
          example "If we want the motion to pass, we will need a second."
        entry
          definition "Aid; assistance; help."
      partOfSpeech noun
    entry
      definitions
        entry
          definition "To transfer temporarily to alternative employment."
          example "The army officer was seconded while he held civil office."
        entry
          definition "To assist or support; to back."
        entry
          definition "To agree as a second person to (a proposal), usually to reach a necessary quorum of two. (This may come from the English adjective above.)"
          example "I second the motion."
        entry
          definition "To accompany by singing as the second performer."
      partOfSpeech verb
  sourceUrls ("https://en.wiktionary.org/wiki/second")
  word second
