entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "One-sixtieth of a minute; the SI unit of time, defined as the duration of 9,192,631,770 periods of radiation corresponding to the transition between two hyperfine levels of caesium-133 in a ground state at a temperature of absolute zero and at rest."
        entry
          definition "A unit of angle equal to one-sixtieth of a minute of arc or one part in 3600 of a degree."
        entry
          definition "A short, indeterminate amount of time."
          example "I'll be there in a second."
      partOfSpeech noun
      synonyms (sec arcsecond "second of arc" "Words used as placeholders to count seconds")
  phonetic "/ˈsɛk.(ə)nd/"
