  meanings
    entry
      definitions
        entry
          definition 'A unit of mass equal to 16 avoirdupois ounces (= 453.592 37 g). Today this value is the most common meaning of "pound" as a unit of weight.'
          synonyms (lb)
        entry
          definition "A unit of mass equal to 12 troy ounces (≈ 373.242 g). Today, this is a common unit of weight when measuring precious metals, and is little used elsewhere."
          synonyms ("lb t")
        entry
          definition "The symbol # (octothorpe, hash)"
          synonyms (hash sharp)
        entry
          definition "The unit of currency used in the United Kingdom and its dependencies. It is divided into 100 pence."
          synonyms (GBP nicker "pound sterling" quid "£")
        entry
          definition "Any of various units of currency used in Egypt and Lebanon, and formerly in the Republic of Ireland, Cyprus and Israel."
          synonyms (punt)
        entry
          definition "Any of various units of currency formerly used in the United States."
          example "the Rhode Island pound; the New Hampshire pound"
        entry
          definition "Abbreviation for pound-force, a unit of force/weight. Using this abbreviation to describe pound-force is inaccurate and unscientific."
      partOfSpeech noun
      synonyms (GBP nicker "pound sterling" quid "£" hash sharp lb "lb t" punt)
  phonetic "/paʊnd/"
  phonetics
