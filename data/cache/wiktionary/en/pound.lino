  word pound
entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "A place for the detention of stray or wandering animals. An animal shelter."
        entry
          definition "A place for the detention of automobiles that have been illegally parked, abandoned, etc. Short form of impound."
        entry
          definition "A section of a canal between two adjacent locks."
          synonyms (reach)
        entry
          definition "A kind of fishing net, having a large enclosure with a narrow entrance into which fish are directed by wings spreading outward."
      partOfSpeech noun
      synonyms (reach)
    entry
      definitions
        entry
          definition "To confine in, or as in, a pound; to impound."
      partOfSpeech verb
