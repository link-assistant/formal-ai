entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "A hard blow."
          synonyms (pounding)
      partOfSpeech noun
      synonyms (pounding)
    entry
      definitions
        entry
          definition "To strike hard, usually repeatedly."
        entry
          definition "To crush to pieces; to pulverize."
        entry
          definition "To eat or drink very quickly."
          example "You really pounded that beer!"
        entry
          definition "To pitch consistently to a certain location."
          example "The pitcher has been pounding the outside corner all night."
        entry
          definition "(of a body part, generally heart, blood, or head) To beat strongly or throb."
          example "As I tiptoed past the sleeping dog, my heart was pounding but I remained silent."
        entry
          definition "To penetrate sexually, with vigour."
          example "I was pounding her all night!"
        entry
          definition "To advance heavily with measured steps."
        entry
          definition "To make a jarring noise, as when running."
          example "The engine pounds."
        entry
          definition "To wager a pound on."
      partOfSpeech verb
      synonyms (pulverate triturate bolt chug down drill "get up in" nail poke hammer pelt)
