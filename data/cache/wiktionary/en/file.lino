entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition 'A column of people one behind another, whether "single file" or in a large group with many files side by side.'
          example "The troops marched in Indian file."
        entry
          definition "A small detachment of soldiers."
        entry
          definition "One of the eight vertical lines of squares on a chessboard (i.e., those identified by a letter). The analog horizontal lines are the ranks."
      partOfSpeech noun
    entry
      definitions
        entry
          definition "To move in a file."
          example "The applicants kept filing into the room until it was full."
      partOfSpeech verb
