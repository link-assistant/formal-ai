entry
  license
    name "CC BY-SA 3.0"
    url "https://creativecommons.org/licenses/by-sa/3.0"
  meanings
    entry
      definitions
        entry
          definition "A binary digit, generally represented as a 1 or 0."
        entry
          definition "The smallest unit of storage in a digital computer, consisting of a binary digit."
          synonyms (b)
        entry
          definition "Any datum that may take on one of exactly two values."
          example "permission bits in a file system"
        entry
          definition "A unit of measure for information entropy."
        entry
          definition "A microbitcoin, or a millionth of a bitcoin (0.000001 BTC)."
      partOfSpeech noun
      synonyms (b)
