        "course"
      ]
    },
    {
      "id": "oewn-05835238-n",
      "partOfSpeech": "n",
      "definition": "evidence pointing to a possible solution",
      "examples": [
        "the police are following a promising lead",
        "the trail led straight to the perpetrator"
      ],
      "synonyms": [
        "lead",
        "trail"
      ]
    },
    {
      "id": "oewn-04471218-n",
      "partOfSpeech": "n",
      "definition": "a pair of parallel rails providing a runway for wheels"
