language en
lemma record
license
  name "CC BY 4.0"
  url "https://creativecommons.org/licenses/by/4.0/"
senses
  entry
    definition "anything (such as a document or a phonograph record or a photograph) providing permanent evidence of or information about past events"
    examples ("the film provided a valuable record of stage techniques")
    id oewn-06659969-n
    partOfSpeech n
  entry
    definition "sound recording consisting of a disk with a continuous groove; used to reproduce music by rotating while a phonograph needle tracks in the groove"
    id oewn-03930191-n
    partOfSpeech n
    synonyms ("phonograph record" "phonograph recording" disk disc platter)
  entry
    definition "the number of wins versus losses and ties a team has had"
    examples ("at 9-0 they have the best record in their league")
    id oewn-13618229-n
    partOfSpeech n
  entry
    definition "the sum of recognized accomplishments"
    examples ("the lawyer has a good record" "the track record shows that he will be a good president")
    id oewn-00048486-n
    partOfSpeech n
    synonyms ("track record")
  entry
    definition "a compilation of the known facts regarding something or someone"
    examples ("Al Smith used to say, ‘Let's look at the record’" "his name is in all the record books")
    id oewn-06649049-n
    partOfSpeech n
    synonyms ("record book" book)
  entry
    definition "an extreme attainment; the best (or worst) performance ever attested (as in a sport)"
    examples ("he tied the Olympic record" "coffee production last year broke all previous records" "Chicago set the homicide record")
    id oewn-00063834-n
    partOfSpeech n
  entry
    definition "a document that can serve as legal evidence of a transaction"
    examples ("they could find no record of the purchase")
    id oewn-13424816-n
    partOfSpeech n
  entry
    definition "a list of crimes for which an accused person has been previously convicted"
    examples ("he ruled that the criminal record of the defendant could not be disclosed to the court" "the prostitute had a record a mile long")
    id oewn-06502164-n
    partOfSpeech n
    synonyms ("criminal record")
  entry
    definition "make a record of; set down in permanent form"
    id oewn-01002259-v
    partOfSpeech v
    synonyms (enter "put down")
  entry
    definition "register electronically"
    examples ("They recorded her singing")
    id oewn-01000444-v
    partOfSpeech v
    synonyms (tape)
  entry
    definition "indicate a certain reading; of gauges and instruments"
    examples ("The thermometer showed thirteen degrees below zero" "The gauge read ‘empty’")
    id oewn-00924838-v
    partOfSpeech v
    synonyms (read register show)
  entry
    definition "be aware of"
    examples ("Did you register any change when I pressed the button?")
    id oewn-02110264-v
    partOfSpeech v
    synonyms (register)
source "oewn:2024"
