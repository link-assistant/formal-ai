senses
  entry
    definition "(cricket) the division of play during which six balls are bowled at the batsman by one player from the other team from the same end of the pitch"
    id oewn-15283505-n
    partOfSpeech n
  entry
    definition "at or to a point across intervening space etc."
    examples ("come over and see us some time" "over there")
    id oewn-00228167-r
    partOfSpeech r
  entry
    definition "throughout an area"
    examples ("he is known the world over")
    id oewn-00228294-r
    partOfSpeech r
  entry
    definition "throughout a period of time"
    examples ("stay over the weekend")
    id oewn-00228075-r
    partOfSpeech r
    synonyms ("o'er")
  entry
    definition "beyond the top or upper surface or edge; forward from an upright position"
    examples ("a roof that hangs over")
    id oewn-00228375-r
    partOfSpeech r
  entry
    definition "over the entire area"
    examples ("the wallpaper was covered all over with flowers" "she ached all over" "everything was dusted over with a fine layer of soot")
    id oewn-00199469-r
    partOfSpeech r
    synonyms ("all over")
  entry
    definition "having come or been brought to a conclusion"
    examples ("the harvesting was complete" "the affair is over, ended, finished" "the abruptly terminated interview")
    id oewn-01006696-s
