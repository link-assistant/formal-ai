  "senses": [
    {
      "id": "oewn-00645186-n",
      "partOfSpeech": "n",
      "definition": "the act of scanning; systematic examination of a prescribed region",
      "examples": [
        "he made a thorough scan of the beach with his binoculars"
      ]
    },
    {
      "id": "oewn-04149614-n",
      "partOfSpeech": "n",
      "definition": "an image produced by scanning",
      "examples": [
        "he analyzed the brain scan",
        "you could see the tumor in the CAT scan"
      ],
      "synonyms": [
        "CAT scan"
      ]
    },
    {
      "id": "oewn-02156934-v",
      "partOfSpeech": "v",
      "definition": "examine minutely or intensely",
      "examples": [
        "the surgeon scanned the X-ray"
      ]
    },
    {
      "id": "oewn-02156708-v",
      "partOfSpeech": "v",
      "definition": "examine hastily",
      "examples": [
        "She scanned the newspaper headlines while waiting for the taxi"
      ],
      "synonyms": [
        "skim",
        "rake",
        "glance over",
        "run down"
      ]
    },
    {
      "id": "oewn-01321319-v",
      "partOfSpeech": "v",
      "definition": "make a wide, sweeping search of",
      "examples": [
        "The beams scanned the night sky"
      ]
    },
    {
      "id": "oewn-02667220-v",
      "partOfSpeech": "v",
      "definition": "conform to a metrical pattern"
    },
    {
      "id": "oewn-01859433-v",
      "partOfSpeech": "v",
      "definition": "move a light beam over; in electronics, to reproduce an image"
    },
    {
      "id": "oewn-01053700-v",
      "partOfSpeech": "v",
      "definition": "read metrically",
      "examples": [
        "scan verses"
      ]
    },
    {
      "id": "oewn-00629157-v",
      "partOfSpeech": "v",
      "definition": "obtain data from magnetic tapes or other digital sources",
      "examples": [
        "This dictionary can be read by the computer"
      ],
      "synonyms": [
        "read"
      ]
    }
  ]
}
