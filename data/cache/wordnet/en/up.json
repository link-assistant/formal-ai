  "senses": [
    {
      "id": "oewn-02499848-a",
      "partOfSpeech": "a",
      "definition": "being or moving higher in position or greater in some value; being above a former position or level",
      "examples": [
        "the anchor is up",
        "the sun is up",
        "he lay face up",
        "he is up by a pawn",
        "the market is up",
        "the corn is up"
      ]
    },
    {
      "id": "oewn-00096883-r",
      "partOfSpeech": "r",
      "definition": "spatially or metaphorically from a lower to a higher position",
      "examples": [
        "look up!",
        "the music surged up",
        "the fragments flew upwards",
        "prices soared upwards",
        "upwardly mobile"
      ],
      "synonyms": [
        "upwards",
        "upward",
        "upwardly"
      ]
    },
    {
