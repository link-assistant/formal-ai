senses
  entry
    definition "a person who possesses great material wealth"
    id oewn-10548806-n
    partOfSpeech n
    synonyms ("rich person" "wealthy person")
  entry
    definition "have or possess, either in a concrete or an abstract sense"
    examples ("She has $1,000 in the bank" "He has got two beautiful daughters" "She holds a Master's degree from Harvard" "I have two years left" "I don't have any money left" "They have two more years before they retire")
    id oewn-02208144-v
    partOfSpeech v
    synonyms ("have got" hold)
  entry
    definition "have as a feature"
    examples ("This restaurant features the most famous chefs in France")
    id oewn-02636270-v
    partOfSpeech v
    synonyms (feature)
  entry
    definition "go through (mental or physical states or experiences)"
    examples ("get an idea" "experience vertigo" "get nauseous" "receive injuries" "have a feeling")
    id oewn-02112480-v
    partOfSpeech v
    synonyms (experience receive get)
  entry
    definition "have ownership or possession of"
    examples ("He owns three houses in Florida" "How many cars does she have?")
    id oewn-02209474-v
    partOfSpeech v
    synonyms (own possess)
  entry
    definition "cause to move; cause to be in a certain position or condition"
    examples ("He got his squad on the ball" "This let me in for a big surprise" "He got a girl into trouble")
    id oewn-00120604-v
    partOfSpeech v
    synonyms (get let)
  entry
    definition "serve oneself to, or consume regularly"
    examples ("Have another bowl of chicken soup!" "I don't take sugar in my coffee")
    id oewn-01159300-v
    partOfSpeech v
    synonyms (consume ingest "take in" take)
  entry
    definition "have a personal or business relationship with someone"
    examples ("have a postdoc" "have an assistant" "have a lover")
    id oewn-02383544-v
    partOfSpeech v
  entry
