language en
lemma direct
license
  name "CC BY 4.0"
  url "https://creativecommons.org/licenses/by/4.0/"
senses
  entry
    definition "direct in spatial dimensions; proceeding without deviation or interruption; straight and short"
    examples ("a direct route" "a direct flight" "a direct hit")
    id oewn-00764460-a
    partOfSpeech a
  entry
    definition "straightforward in means or manner or behavior or language or action"
    examples ("a direct question" "a direct response" "a direct approach")
    id oewn-00767444-a
    partOfSpeech a
  entry
    definition "in a straight unbroken line of descent from parent to child"
    examples ("lineal ancestors" "lineal heirs" "a direct descendant of the king" "direct heredity")
    id oewn-01419359-a
    partOfSpeech a
    synonyms (lineal)
  entry
    definition "moving from west to east on the celestial sphere; or — for planets — around the sun in the same direction as the Earth"
    id oewn-00773485-a
    partOfSpeech a
  entry
    definition "similar in nature or effect or relation to another quantity"
    examples ("a term is in direct proportion to another term if it increases (or decreases) as the other increases (or decreases)")
    id oewn-00772799-a
    partOfSpeech a
  entry
    definition "(of a current) flowing in one direction only"
    examples ("direct current")
    id oewn-00767176-a
    partOfSpeech a
  entry
    definition "without deviation"
    examples ("the path leads directly to the lake" "went direct to the office")
    id oewn-00052386-r
    partOfSpeech r
    synonyms (directly straight)
  entry
    definition "having no intervening persons, agents, conditions"
    examples ("in direct sunlight" "in direct contact with the voters" "direct exposure to the disease" "a direct link" "the direct cause of the accident" "direct vote")
    id oewn-00774039-s
    partOfSpeech s
    synonyms (unmediated)
  entry
    definition "being an immediate result or consequence"
    examples ("a direct result of the accident")
    id oewn-01858594-s
    partOfSpeech s
  entry
    definition "in precisely the same words used by a writer or speaker"
    examples ("a direct quotation" "repeated their dialog verbatim")
    id oewn-00917922-s
    partOfSpeech s
    synonyms (verbatim)
  entry
    definition "lacking compromising or mitigating elements"
    examples ("the direct opposite")
    id oewn-00005472-s
    partOfSpeech s
    synonyms (exact)
  entry
    definition "command with authority"
    examples ("He directed the children to do their homework")
    id oewn-00751211-v
    partOfSpeech v
  entry
    definition "intend (something) to move towards a certain goal"
    examples ("He aimed his fists towards his opponent's face" "criticism directed at her superior" "direct your anger towards others, not towards yourself")
