[2026-07-20T06:22:43.931Z] [INFO]         "content": "46aa1dd7 fix: preserve bundled browser framework seals\n57b45a44 fix(desktop-release): reseal macOS ad-hoc app bundles\nfdcde5ea Fix macOS desktop signing and smoke tests\n1a28793ba8c40dca319ab0c7bed220b90ebe1cb2\n166:        run: node scripts/prepare-resources.mjs\n168:      - name: Check macOS signing secrets\n189:            echo \"::notice::macOS signing/notarization secrets are not configured: ${missing[*]}\"\n190:            echo \"Building ad-hoc signed macOS artifacts without notarization for direct testing.\"\n193:            echo \"mode=signed\" >> \"$GITHUB_OUTPUT\"\n203:      - name: Package desktop app (macOS signed)\n215:      # Issue #479: electron-builder 26 changed macOS signing control flow. Its\n216:      # MacPackager.sign() now calls findSigningIdentity(), which returns null --\n217:      # skipping signing entirely and NEVER invoking the custom `mac.sign` hook --\n222:      # pre-upload smoke test failed with \"missing its signed CodeResources\n225:      # sign via @electron/osx-sign + an explicit root-bundle re-seal).\n233:          DEBUG: electron-builder,electron-osx-sign*\n234:        run: npx --no-install electron-builder ${{ matrix.ebflag }} --publish never -c.mac.notarize=false -c.mac.identity=- -c.mac.sign=./scripts/adhoc-sign-mac.cjs\n306:              echo \"::error file=$dmg::Mounted app is missing its signed CodeResources envelope.\"\n311:            codesign --verify --deep --strict --verbose=2 \"$installed_app\"\n313:            if [ \"$MACOS_BUILD_MODE\" = \"signed\" ]; then\n317:              codesign --display --verbose=2 \"$installed_app\" 2>&1 | tee \"$RUNNER_TEMP/formal-ai-macos-codesign.txt\"\n318:              if ! grep -Fq 'Signature=adhoc' \"$RUNNER_TEMP/formal-ai-macos-codesign.txt\"; then\n319:                echo \"::error file=$dmg::Expected ad-hoc macOS signature for no-Apple-account build.\"\n329:      # shipped. The deep checks are macOS-only by nature (hdiutil, codesign),\n484:          # `vscode:prepublish` (prepare-resources.mjs) syncs the extension\n614:            echo \"Signing    : macOS artifacts are ad-hoc signed (no Apple Developer ID).\"",
