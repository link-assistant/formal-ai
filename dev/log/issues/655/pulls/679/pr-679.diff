diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
index cce2c14cd..ab5e8ab51 100644
--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@ -1078,6 +1078,25 @@ jobs:
           MIN_POSTS: 3
         run: experiments/agent_cli_e2e/run_agent_cli.sh
 
+      - name: Run agent CLI E2E — general unpinned change plan (issue #654)
+        # No `*_TASK` constant names this request. The fallback planner derives the
+        # target, literal payload, evidence, and verification command from the
+        # formalized requirement, writes its plan event first, then executes it.
+        env:
+          PORT: 8773
+          TASK: "Create file artifacts/general-agent-plan.txt containing general planner e2e passed"
+          EXPECT_FILE: artifacts/general-agent-plan.txt
+          EXPECT_TEXT: general planner e2e passed
+          MIN_POSTS: 4
+        run: experiments/agent_cli_e2e/run_agent_cli.sh
+
+      - name: Replay Hive Mind self-coding inner loop (issue #655)
+        env:
+          PORT: 8774
+        run: |
+          examples/self-coding/run.sh
+          cargo test self_coding_session_replays
+
       - name: Upload E2E logs on failure
         if: failure()
         uses: actions/upload-artifact@v7
diff --git a/CONTRIBUTING.md b/CONTRIBUTING.md
index 79601ca38..eb5f653bd 100644
--- a/CONTRIBUTING.md
+++ b/CONTRIBUTING.md
@@ -76,6 +76,18 @@ guide defines the fixture markers, logging proxy assertions, phrasing matrices,
 and CI shape needed to prove that a result came from Formal AI and that the
 client actually executed the expected tools.
 
+### Replaying the self-coding loop
+
+```bash
+cargo build --release --bin formal-ai
+examples/self-coding/run.sh
+cargo test self_coding_session_replays
+```
+
+For a real GitHub issue, run `examples/self-coding/run.sh --live ISSUE_URL`.
+This invokes `solve ISSUE_URL --tool agent --model formal-ai`: Hive Mind drives
+the Agent CLI, which drives the local Formal AI server.
+
 ## Development Setup
 
 1. **Fork and clone the repository**
