[2026-07-19T12:32:16.850Z] [INFO]         "content": "{\n  \"name\": \"formal-ai-vscode\",\n  \"displayName\": \"formal-ai\",\n  \"version\": \"0.297.2\",\n  \"private\": true,\n  \"description\": \"VS Code extension (desktop + web) embedding the formal-ai symbolic chat UI\",\n  \"publisher\": \"link-assistant\",\n  \"license\": \"Unlicense\",\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/link-assistant/formal-ai\"\n  },\n  \"engines\": {\n    \"vscode\": \"^1.84.0\"\n  },\n  \"categories\": [\n    \"Machine Learning\",\n    \"Chat\",\n    \"Other\"\n  ],\n  \"main\": \"./src/extension.node.cjs\",\n  \"browser\": \"./src/extension.web.cjs\",\n  \"activationEvents\": [\n    \"onView:formal-ai.chatView\",\n    \"onCommand:formal-ai.openChat\"\n  ],\n  \"capabilities\": {\n    \"virtualWorkspaces\": true,\n    \"untrustedWorkspaces\": {\n      \"supported\": true,\n      \"description\": \"The in-process symbolic agent is safe everywhere; the opt-in local server and Docker code execution only run in trusted desktop windows.\"\n    }\n  },\n  \"contributes\": {\n    \"commands\": [\n      {\n        \"command\": \"formal-ai.openChat\",\n        \"title\": \"Open Chat\",\n        \"category\": \"formal-ai\"\n      },\n      {\n        \"command\": \"formal-ai.toggleServer\",\n        \"title\": \"Toggle Local Server\",\n        \"category\": \"formal-ai\"\n      },\n      {\n        \"command\": \"formal-ai.syncMemory\",\n        \"title\": \"Sync Memory\",\n        \"category\": \"formal-ai\"\n      },\n      {\n        \"command\": \"formal-ai.openNetworkView\",\n        \"title\": \"Open Network View\",\n        \"category\": \"formal-ai\"\n      }\n    ],\n    \"viewsContainers\": {\n      \"activitybar\": [\n        {\n          \"id\": \"formal-ai\",\n          \"title\": \"formal-ai\",\n          \"icon\": \"media/icon.svg\"\n        }\n      ]\n    },\n    \"views\": {\n      \"formal-ai\": [\n        {\n          \"type\": \"webview\",\n          \"id\": \"formal-ai.chatView\",\n          \"name\": \"Chat\"\n        }\n      ]\n    },\n    \"menus\": {\n      \"view/title\": [\n        {\n          \"command\": \"formal-ai.toggleServer\",\n          \"when\": \"view == formal-ai.chatView\",\n          \"group\": \"navigation@1\"\n        },\n        {\n          \"command\": \"formal-ai.openNetworkView\",\n          \"when\": \"view == formal-ai.chatView\",\n          \"group\": \"navigation@2\"\n        }\n      ]\n    },\n    \"configuration\": {\n      \"title\": \"formal-ai\",\n      \"properties\": {\n        \"formal-ai.server.enabled\": {\n          \"type\": \"boolean\",\n          \"default\": false,\n          \"markdownDescription\": \"Start a local OpenAI-compatible `formal-ai serve` process and route chat through `POST /v1/chat/completions`. Desktop (Node) host only; ignored in the web host, which always runs the in-process symbolic agent.\"\n        },\n        \"formal-ai.server.host\": {\n          \"type\": \"string\",\n          \"default\": \"127.0.0.1\",\n          \"description\": \"Loopback host the local server binds to (desktop host only).\"\n        },\n        \"formal-ai.server.port\": {\n          \"type\": \"number\",\n          \"default\": 18080,\n          \"minimum\": 1,\n          \"maximum\": 65535,\n          \"description\": \"Port the local server binds to (desktop host only).\"\n        },\n        \"formal-ai.docker.image\": {\n          \"type\": \"string\",\n          \"default\": \"konard/box-dind:2.1.1\",\n          \"description\": \"Docker image used to sandbox code-execution tool calls (desktop host only, when a permitted tool runs).\"\n        },\n        \"formal-ai.tools.allowByDefault\": {\n          \"type\": \"boolean\",\n          \"default\": false,\n          \"description\": \"Grant write, edit, host shell, and sandboxed code-execution tool calls by default. Read-only file and web tools remain available when this is off.\"\n        },\n        \"formal-ai.agent.defaultOn\": {\n          \"type\": \"boolean\",\n          \"default\": false,\n          \"description\": \"Enable agent mode (which drives tool grants) by default when the chat view opens.\"\n        }\n      }\n    }\n  },\n  \"scripts\": {\n    \"dev\": \"vscode-test-web --browserType=chromium --extensionDevelopmentPath=.\",\n    \"prepare-resources\": \"node scripts/prepare-resources.mjs\",\n    \"vscode:prepublish\": \"node scripts/prepare-resources.mjs\",\n    \"package\": \"vsce package\",\n    \"smoke\": \"node scripts/smoke.mjs\",\n    \"test\": \"node --test scripts/config.test.mjs scripts/bridge.test.mjs scripts/webview-html.test.mjs scripts/chat-view.test.mjs scripts/server-process.test.mjs && node scripts/smoke.mjs\"\n  },\n  \"devDependencies\": {\n    \"@vscode/test-web\": \"^0.0.80\",\n    \"@vscode/vsce\": \"^3.9.2\"\n  },\n  \"dependencies\": {\n    \"@link-assistant/web-capture\": \"^1.10.10\",\n    \"@link-assistant/web-search\": \"^0.10.3\"\n  }\n}",
