\"type\": \"statement\",\n                \"qualifiers\": {\n                  \"P5237\": [\n                    {\n                      \"snaktype\": \"value\",\n                      \"property\": \"P5237\",\n                      \"hash\": \"c22ed230107969afc0ac70ee5e257e90104129b7\",\n                      \"datavalue\": {\n                        \"value\": {\n                          \"entity-type\": \"item\",\n                          \"numeric-id\": 7979,\n                          \"id\": \"Q7979\"\n                        },\n                        \"type\": \"wikibase-entityid\"\n                      },\n                      \"datatype\": \"wikibase-item\"\n                    }\n                  ]\n                },\n                \"qualifiers-order\": [\n                  \"P5237\"\n                ],\n                \"id\": \"L3784-F1$4d35bd38-4f9f-29fc-4d6c-9e315e6fab71\",\n                \"rank\": \"normal\"\n              },\n              {\n                \"mainsnak\": {\n                  \"snaktype\": \"value\",\n                  \"property\": \"P898\",\n                  \"hash\": \"e8b6c87a9a162b31c8a525dc797ecd5aa47a8a5e\",\n                  \"datavalue\": {\n                    \"value\": \"[pə̥ˈtʰeɪtʰəʊ]\",\n                    \"type\": \"string\"\n                  },\n                  \"datatype\": \"string\"\n                },\n                \"type\": \"statement\",\n                \"qualifiers\": {\n                  \"P5237\": [\n                    {\n                      \"snaktype\": \"value\",\n                      \"property\": \"P5237\",\n                      \"hash\": \"c22ed230107969afc0ac70ee5e257e90104129b7\",\n                      \"datavalue\": {\n                        \"value\": {\n                          \"entity-type\": \"item\",\n                          \"numeric-id\": 7979,\n                          \"id\": \"Q7979\"\n                        },\n                        \"type\": \"wikiba