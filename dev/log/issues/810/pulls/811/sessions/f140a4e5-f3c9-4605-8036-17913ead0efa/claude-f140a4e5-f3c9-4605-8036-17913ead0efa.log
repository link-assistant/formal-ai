[2026-07-20T12:13:37.737Z] [INFO]           "+    // Mentions formal-ai, but never names the session it claims to document --",
[2026-07-20T12:13:37.737Z] [INFO]           "+    // exactly the shape of commit 10e65ae2.",
[2026-07-20T12:13:37.737Z] [INFO]           "+    fs::write(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        repo.join(\"docs/evidence/analysis.md\"),",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"formal-ai analysis without the session id\\n\",",
[2026-07-20T12:13:37.737Z] [INFO]           "+    )",
[2026-07-20T12:13:37.737Z] [INFO]           "+    .expect(\"evidence must be written\");",
[2026-07-20T12:13:37.737Z] [INFO]           "+    fs::write(repo.join(\"code.txt\"), \"base\\nchanged\\n\").expect(\"code must be written\");",
[2026-07-20T12:13:37.737Z] [INFO]           "+    commit(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        &repo,",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"formal ai change\\n\\nFormal-AI-Session: orphan-session\\nFormal-AI-Evidence: \\",
[2026-07-20T12:13:37.737Z] [INFO]           "+         docs/evidence/analysis.md\",",
[2026-07-20T12:13:37.737Z] [INFO]           "+    );",
[2026-07-20T12:13:37.737Z] [INFO]           "+",
[2026-07-20T12:13:37.737Z] [INFO]           "+    let strict = metric_script::measure(&repo, \"v1.0.0\", \"HEAD\");",
[2026-07-20T12:13:37.737Z] [INFO]           "+    assert!(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        strict.is_err(),",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"the pull-request gate must still reject a malformed evidence record\"",
[2026-07-20T12:13:37.737Z] [INFO]           "+    );",
[2026-07-20T12:13:37.737Z] [INFO]           "+",
[2026-07-20T12:13:37.737Z] [INFO]           "+    let row = metric_script::record_release(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        &repo,",
[2026-07-20T12:13:37.737Z] [INFO]           "+        &repo.join(\"data/meta/self-hosting-ledger.lino\"),",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"v1.1.0\",",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"v1.0.0\",",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"HEAD\",",
[2026-07-20T12:13:37.737Z] [INFO]           "+        3,",
[2026-07-20T12:13:37.737Z] [INFO]           "+    )",
[2026-07-20T12:13:37.737Z] [INFO]           "+    .expect(\"a release must not be blocked by an immutable malformed commit\");",
[2026-07-20T12:13:37.737Z] [INFO]           "+    assert_eq!(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        row.self_authored_commits, 0,",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"an unverifiable commit must not be counted as self-authored\"",
[2026-07-20T12:13:37.737Z] [INFO]           "+    );",
[2026-07-20T12:13:37.737Z] [INFO]           "+    assert_eq!(",
[2026-07-20T12:13:37.737Z] [INFO]           "+        row.commits, 1,",
[2026-07-20T12:13:37.737Z] [INFO]           "+        \"the commit must still count toward total changed work\"",
[2026-07-20T12:13:37.737Z] [INFO]           "+    );",
[2026-07-20T12:13:37.737Z] [INFO]           "+",
[2026-07-20T12:13:37.737Z] [INFO]           "+    fs::remove_dir_all(repo).expect(\"fixture directory must be removed\");",
[2026-07-20T12:13:37.737Z] [INFO]           "+}",
[2026-07-20T12:13:37.737Z] [INFO]           "+",
[2026-07-20T12:13:37.737Z] [INFO]           "+#[test]",
[2026-07-20T12:13:37.737Z] [INFO]           " fn release_pipeline_and_ledger_remain_pinned_to_the_metric() {",
