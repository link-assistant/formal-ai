[2026-07-20T12:13:10.547Z] [INFO]           "+/// How a malformed evidence record is treated.",
[2026-07-20T12:13:10.547Z] [INFO]           "+///",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// Issue #810: the `Formal-AI-Evidence` gate (`evidence-check` in",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// `.github/workflows/release.yml`) was introduced in 39fdef91, *after* commit",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// 10e65ae2 had already merged with an evidence document that never spells out",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// its own `Formal-AI-Session` id. Because `record_release` measures",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// `<last tag>..HEAD`, that historical commit stayed inside the release range",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// forever, `Auto Release` aborted on it every single run (29737218421), and no",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// new tag could ever be cut to move the range past it — a permanent deadlock",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// that history cannot be edited out of.",
[2026-07-20T12:13:10.547Z] [INFO]           "+///",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// So the two callers get different policies:",
[2026-07-20T12:13:10.547Z] [INFO]           "+///",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// - `Strict` — the pull-request gate. New commits must be well formed, and a",
[2026-07-20T12:13:10.547Z] [INFO]           "+///   malformed record is a hard error *before* it can reach the default branch.",
[2026-07-20T12:13:10.547Z] [INFO]           "+/// - `Lenient` — release recording. A malformed record is reported on stderr and",
[2026-07-20T12:13:10.547Z] [INFO]           "+///   the commit simply does not count as self-authored. The metric can only",
[2026-07-20T12:13:10.547Z] [INFO]           "+///   under-report, never over-report, so the ratchet stays honest.",
[2026-07-20T12:13:10.547Z] [INFO]           "+#[derive(Clone, Copy, Debug, Eq, PartialEq)]",
[2026-07-20T12:13:10.547Z] [INFO]           "+pub enum EvidencePolicy {",
[2026-07-20T12:13:10.547Z] [INFO]           "+    Strict,",
[2026-07-20T12:13:10.547Z] [INFO]           "+    Lenient,",
[2026-07-20T12:13:10.547Z] [INFO]           "+}",
[2026-07-20T12:13:10.547Z] [INFO]           "+",
[2026-07-20T12:13:10.547Z] [INFO]           " pub fn measure(repo: &Path, since: &str, until: &str) -> Result<Measurement, String> {",
[2026-07-20T12:13:10.547Z] [INFO]           "+    measure_with_policy(repo, since, until, EvidencePolicy::Strict)",
[2026-07-20T12:13:10.547Z] [INFO]           "+}",
[2026-07-20T12:13:10.547Z] [INFO]           "+",
[2026-07-20T12:13:10.547Z] [INFO]           "+pub fn measure_with_policy(",
[2026-07-20T12:13:10.547Z] [INFO]           "+    repo: &Path,",
[2026-07-20T12:13:10.547Z] [INFO]           "+    since: &str,",
