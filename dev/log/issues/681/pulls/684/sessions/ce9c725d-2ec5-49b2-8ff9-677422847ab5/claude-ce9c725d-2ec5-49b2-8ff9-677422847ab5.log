[2026-07-13T17:36:24.325Z] [INFO]         "content": "1\t//! Deterministic fallback planner for repository change requests (issue #654).\n2\t//!\n3\t//! Unlike the stored recipe fixtures, this planner derives its target and payload\n4\t//! from the formalized request.  The resulting plan is data: it is serialized to\n5\t//! Links Notation and written before execution, so the tool transcript is an\n6\t//! append-only record of the decision that caused the change.\n7\t\n8\tuse std::fmt::Write as _;\n9\t\n10\tuse crate::engine::stable_id;\n11\tuse crate::intent_formalization::formalize_intent;\n12\t\n13\tuse super::planner::Capability;\n14\t\n15\t/// Workspace-relative event-log artifact written before a general plan executes.\n16\tpub const PLAN_PATH: &str = \".formal-ai/general-change-plan.lino\";\n17\t\n18\t/// One ordered, capability-tagged operation in a general change plan.\n19\t#[derive(Debug, Clone, PartialEq, Eq)]\n20\tpub struct GeneralPlanStep {\n21\t    pub capability: Capability,\n22\t    pub action: String,\n23\t    pub expected_evidence: String,\n24\t    pub command: Option<String>,\n25\t}\n26\t\n27\t/// A deterministic plan composed from a formalized, previously unrecognised request.\n28\t#[derive(Debug, Clone, PartialEq, Eq)]\n29\tpub struct GeneralChangePlan {\n30\t    pub id: String,\n31\t    pub goal: String,\n32\t    pub target: String,\n33\t    pub content: String,\n34\t    pub steps: Vec<GeneralPlanStep>,\n35\t    pub verification_command: String,\n36\t}\n37\t\n38\timpl GeneralChangePlan {\n39\t    /// Render the plan shape consumed by the driver and documented by the meta fixture.\n40\t    #[must_use]\n41\t    pub fn links_notation(&self) -> String {\n42\t        let mut out = String::from(\"general_change_plan\\n\");\n43\t        field(&mut out, \"id\", &self.id);\n44\t        field(&mut out, \"goal\", &self.goal);\n45\t        field(&mut out, \"target\", &self.target);\n46\t        for (index, step) in self.steps.iter().enumerate() {\n47\t            let _ = writeln!(out, \"  step {}\", index + 1);\n48\t            field_nested(&mut out, \"capability\", capability_slug(step.capability));\n49\t            field_nested(&mut out, \"action\", &step.action);\n50\t            field_nested(&mut out, \"expected_evidence\", &step.expected_evidence);\n51\t            if let Some(command) = &step.command {\n52\t                field_nested(&mut out, \"command\", command);\n53\t            }\n54\t        }\n55\t        field(&mut out, \"verification_command\", &self.verification_command);\n56\t        out\n57\t    }\n58\t}\n59\t\n60\t/// Compose a safe file-creation plan from arbitrary English or Russian wording.\n61\t///\n62\t/// The universal intent formalizer supplies the stable impulse identity.  The\n63\t/// decomposition is deliberately bounded to requests that state both a relative\n64\t/// target file and literal content; ambiguous requests continue to the ordinary\n65\t/// solver instead of inventing a patch or shell command.\n66\t#[must_use]\n67\tpub fn compose_general_change_plan(request: &str) -> Option<GeneralChangePlan> {\n68\t    let target = extract_target(request)?;\n69\t    let content = extract_content(request)?;\n70\t    if !safe_relative_path(&target) {\n71\t        return None;\n72\t    }\n73\t    let intent = formalize_intent(request, language(request), None);\n74\t    let verification_command = format!(\"cat {target}\");\n75\t    let steps = vec![\n76\t        GeneralPlanStep {\n77\t            capability: Capability::Write,\n78\t            action: format!(\"append the composed plan to {PLAN_PATH}\"),\n79\t            expected_evidence: format!(\"written plan event {}\", intent.impulse_id),\n80\t            command: None,\n81\t        },\n82\t        GeneralPlanStep {\n83\t            capability: Capability::Write,\n84\t            action: format!(\"write the requested content to {target}\"),\n85\t            expected_evidence: format!(\"workspace file {target}\"),\n86\t            command: None,\n87\t        },\n88\t        GeneralPlanStep {\n89\t            capability: Capability::Run,\n90\t            action: String::from(\"run the request-derived verification command\"),\n91\t            expected_evidence: content.clone(),\n92\t            command: Some(verification_command.clone()),\n93\t        },\n94\t    ];\n95\t    Some(GeneralChangePlan {\n96\t        id: stable_id(\n97\t            \"general_change_plan\",\n98\t            &format!(\"{}:{target}:{content}\", intent.impulse_id),\n99\t        ),\n100\t        goal: intent.source_text,\n101\t        target,\n102\t        content,\n103\t        steps,\n104\t        verification_command,\n105\t    })\n106\t}\n107\t\n108\tfn extract_target(request: &str) -> Option<String> {\n109\t    let words: Vec<&str> = request.split_whitespace().collect();\n110\t    words.iter().enumerate().find_map(|(index, word)| {\n111\t        let cleaned = word.trim_matches(|c: char| matches!(c, '`' | '\"' | '\\'' | ',' | ':' | ';'));\n112\t        let previous = index\n113\t            .checked_sub(1)\n114\t            .and_then(|i| words.get(i))\n115\t            .map(|w| w.to_lowercase());\n116\t        let looks_like_file = cleaned.contains('.') && !cleaned.contains(\"://\");\n117\t        (looks_like_file\n118\t            && previous\n119\t                .as_deref()\n120\t                .is_some_and(|p| [\"file\", \"файл\", \"in\", \"в\", \"create\", \"создай\"].contains(&p)))\n121\t        .then(|| cleaned.to_owned())\n122\t    })\n123\t}\n124\t\n125\tfn extract_content(request: &str) -> Option<String> {\n126\t    let lower = request.to_lowercase();\n127\t    [\n128\t        \" containing \",\n129\t        \" with content \",\n130\t        \" with text \","
