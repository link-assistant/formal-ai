[2026-07-13T17:36:42.916Z] [INFO]         "content": "1\tuse formal_ai::agentic_coding::general_planner::{compose_general_change_plan, PLAN_PATH};\n2\tuse formal_ai::agentic_coding::{plan_chat_step, run_agentic_task, AgenticPlan};\n3\tuse formal_ai::protocol::ChatMessage;\n4\t\n5\tconst EN_TASK: &str = \"Create file notes/general-demo.txt containing planner fallback works\";\n6\tconst EN_TASK_ALT: &str = \"Write file artifacts/unseen-case.md with text capability composed plan\";\n7\tconst RU_TASK: &str = \"Создай файл output/пример.txt с текстом общий план работает\";\n8\t\n9\t#[test]\n10\tfn agentic_general_planner_composes_capability_steps_and_verification() {\n11\t    let plan = compose_general_change_plan(EN_TASK).expect(\"general plan\");\n12\t    assert!(plan.steps.len() >= 3);\n13\t    assert!(plan\n14\t        .steps\n15\t        .iter()\n16\t        .all(|step| !step.expected_evidence.is_empty()));\n17\t    assert_eq!(plan.verification_command, \"cat notes/general-demo.txt\");\n18\t}\n19\t\n20\t#[test]\n21\tfn agentic_general_planner_is_deterministic() {\n22\t    assert_eq!(\n23\t        compose_general_change_plan(EN_TASK),\n24\t        compose_general_change_plan(EN_TASK)\n25\t    );\n26\t}\n27\t\n28\t#[test]\n29\tfn agentic_general_planner_accepts_three_unpinned_phrasings_in_two_languages() {\n30\t    for request in [EN_TASK, EN_TASK_ALT, RU_TASK] {\n31\t        let plan = compose_general_change_plan(request).expect(request);\n32\t        assert!(!plan.goal.is_empty());\n33\t        assert!(plan.links_notation().contains(\"expected_evidence\"));\n34\t    }\n35\t}\n36\t\n37\t#[test]\n38\tfn agentic_general_planner_rejects_unsafe_or_ambiguous_requests() {\n39\t    assert!(compose_general_change_plan(\"Create file ../escape.txt containing no\").is_none());\n40\t    assert!(compose_general_change_plan(\"Please improve the repository\").is_none());\n41\t}\n42\t\n43\t#[test]\n44\tfn general_plan_is_emitted_before_execution() {\n45\t    let messages = vec![ChatMessage::user(EN_TASK)];\n46\t    let tools = [\"write_file\", \"run_command\"];\n47\t    let AgenticPlan::ToolCalls(calls) = plan_chat_step(&messages, &tools).expect(\"plan\") else {\n48\t        panic!(\"tool call expected\")\n49\t    };\n50\t    assert!(calls[0].arguments.contains(PLAN_PATH));\n51\t    assert!(calls[0].arguments.contains(\"general_change_plan\"));\n52\t}\n53\t\n54\t#[test]\n55\tfn general_task_runs_end_to_end() {\n56\t    let outcome = run_agentic_task(EN_TASK).expect(\"workspace\");\n57\t    assert!(!outcome.hit_turn_cap);\n58\t    let tools: Vec<&str> = outcome\n59\t        .steps\n60\t        .iter()"
