[2026-07-13T17:35:50.362Z] [INFO]         "content": "114\t/// Plan the next agentic step from the conversation and advertised tools.\n115\t/// Returns [`None`] when neither a stored recipe nor a safe general plan applies.\n116\t#[must_use]\n117\tpub fn plan_chat_step(messages: &[ChatMessage], tool_names: &[&str]) -> Option<AgenticPlan> {\n118\t    let task = latest_user_text(messages)?;\n119\t    // The self-AST recipe is checked first because it is the most specific router\n120\t    // (it requires both an AST/CST intent word *and* a self-reference). A self-AST\n121\t    // request legitimately mentions \"Links Notation\" as its output format, which\n122\t    // would otherwise be captured by the broad formalization keyword match below.\n123\t    // The self-healing recipe is checked before self-AST: both are self-inspection\n124\t    // recipes, but self-healing has its own dedicated keywords (self-heal, repair\n125\t    // case, auto-learning) that never overlap the AST/CST keywords, so ordering only\n126\t    // guards against a request that names both.\n127\t    if self_heal::is_self_heal_task(&task) {\n128\t        return Some(plan_self_heal_step(messages, tool_names));\n129\t    }\n130\t    if dreaming_audit::is_dreaming_audit_task(&task) {\n131\t        return Some(plan_dreaming_audit_step(messages, tool_names));\n132\t    }\n133\t    if self_ast::is_self_ast_task(&task) {\n134\t        return Some(plan_self_ast_step(messages, tool_names));\n135\t    }\n136\t    // The whole-repository source-graph recipe: checked alongside the other\n137\t    // self-inspection recipes and before formalization, because its request\n138\t    // legitimately names \"links\" (its output format), which the broad\n139\t    // formalization keyword match below would otherwise capture.\n140\t    if source_graph::is_source_graph_task(&task) {\n141\t        return Some(plan_source_graph_step(messages, tool_names));\n142\t    }\n143\t    // The learning-ledger recipe: the promotion step that follows an approved repair\n144\t    // case. Checked after self-healing (which owns the \"auto learning\" keywords) and\n145\t    // before formalization, since its request legitimately names \"Links Notation\".\n146\t    if ledger::is_ledger_task(&task) {\n147\t        return Some(plan_ledger_step(messages, tool_names));\n148\t    }\n149\t    // The grounded self-explanation recipe: answers \"how does Formal AI work?\" from\n150\t    // real source/data/test artifacts. Checked alongside the other self-inspection\n151\t    // recipes and before formalization, since its request legitimately names \"Links\n152\t    // Notation\" as the output format its document is rendered in.\n153\t    if explain::is_explain_task(&task) {\n154\t        return Some(plan_explain_step(messages, tool_names));\n155\t    }\n156\t    // The user-initiated self-change recipe: turns a natural-language \"change Formal AI\n157\t    // itself\" request into a reviewable pull request through the same human-gated loop.\n158\t    // Checked alongside the other self-referential recipes and before formalization,\n159\t    // since its request legitimately names \"Links Notation\" as the output format.\n160\t    if change_request::is_change_request_task(&task) {\n161\t        return Some(plan_change_request_step(messages, tool_names));\n162\t    }\n163\t    // The general repair-classification recipe: given an arbitrary failure trace, decide\n164\t    // whether the repair is a solver method, a data record, or a test, and compose the\n165\t    // grounded, human-gated strategy for each class. Checked alongside the other\n166\t    // self-referential recipes and before formalization, since its request legitimately\n167\t    // names \"Links Notation\" as the output format its strategies are rendered in. Its\n168\t    // keywords are disjoint from the self-healing recipe's (\"repair case\"/\"repair loop\"),\n169\t    // so ordering only guards a request that somehow names both.\n170\t    if repair_strategy::is_repair_strategy_task(&task) {\n171\t        return Some(plan_repair_strategy_step(messages, tool_names));\n172\t    }\n173\t    // Rebuild-and-reattach recipe: once a change is accepted, recompile Formal AI and\n174\t    // reattach the improved WebAssembly worker to the UI (issue #558's `R558-06`).\n175\t    // Checked alongside the other self-referential recipes and before formalization,\n176\t    // since its request legitimately names \"Links Notation\" as the output format its plan\n177\t    // is rendered in. Its keywords key on \"reattach\" and are disjoint from the\n178\t    // source-graph recipe's \"recompile\", so ordering only guards a request that somehow\n179\t    // names both.\n180\t    if rebuild_plan::is_rebuild_task(&task) {\n181\t        return Some(plan_rebuild_step(messages, tool_names));\n182\t    }\n183\t    // The learning-frontier recipe (issues #498 + #558): route the trending prompts the\n184\t    // engine cannot yet resolve through the human-gated self-improvement loop. Checked\n185\t    // before the sibling catalog recipe because both legitimately name \"Google Trends\";\n186\t    // its keywords (\"learning frontier\", \"self-improvement loop\", \"cannot … resolve\") are\n187\t    // disjoint from the catalog recipe's (prompt/answer/catalog/test), so ordering only\n188\t    // guards a request that somehow names both.\n189\t    if google_trends_learning::is_google_trends_learning_task(&task) {\n190\t        return Some(plan_google_trends_learning_step(messages, tool_names));\n191\t    }\n192\t    if google_trends_catalog::is_google_trends_catalog_task(&task) {\n193\t        return Some(plan_google_trends_catalog_step(messages, tool_names));\n194\t    }\n195\t    // The question-catalog recipe (issue #527): enumerate every possible question\n196\t    // smallest-first, classify each grammatically and logically, and answer the\n197\t    // meaningful ones. Checked alongside the other self-referential recipes and before\n198\t    // formalization, since its request legitimately names \"Links Notation\" as the output\n199\t    // format its catalog is rendered in. Its keywords (\"question catalog\", \"all possible\n200\t    // questions\", …) are disjoint from the sibling recipes', so ordering only guards a\n201\t    // request that somehow names both.\n202\t    if question_catalog::is_question_catalog_task(&task) {\n203\t        return Some(plan_question_catalog_step(messages, tool_names));\n204\t    }\n205\t    if let Some(file_task) = file_read_task_for(&task) {\n206\t        return Some(plan_file_read_step(&file_task, messages, tool_names));\n207\t    }\n208\t    if let Some(command) = shell_command::shell_command_for_task(&task) {\n209\t        return Some(plan_shell_step(messages, tool_names, &command));\n210\t    }\n211\t    if is_formalization_task(&task) {\n212\t        return Some(plan_formalization_step(messages, tool_names));\n213\t    }\n214\t    if meaning_detail::is_meaning_detail_task(&task) {\n215\t        return Some(plan_meaning_detail_step(&task, messages, tool_names));\n216\t    }\n217\t    if diagram::is_diagram_task(&task) {\n218\t        return Some(plan_diagram_step(messages, tool_names));\n219\t    }\n220\t    compose_general_change_plan(&task)\n221\t        .map(|plan| plan_general_change_step(messages, tool_names, &plan))\n222\t}\n223\t\n224\tfn plan_general_change_step(\n225\t    messages: &[ChatMessage],\n226\t    tool_names: &[&str],\n227\t    plan: &GeneralChangePlan,\n228\t) -> AgenticPlan {\n229\t    let progress = Progress::scan(messages);\n230\t    let writes = progress.count(Capability::Write);\n231\t    if let Some(tool) = tool_for(tool_names, Capability::Write) {\n232\t        if writes == 0 {\n233\t            return plan_one(tool, write_arguments(PLAN_PATH, &plan.links_notation()));\n234\t        }\n235\t        if writes == 1 {\n236\t            return plan_one(tool, write_arguments(&plan.target, &plan.content));\n237\t        }\n238\t    }\n239\t    if let Some(tool) =\n240\t        tool_for(tool_names, Capability::Run).filter(|_| !progress.done(Capability::Run))\n241\t    {\n242\t        return plan_one(\n243\t            tool,\n244\t            json!({ \"command\": plan.verification_command }).to_string(),\n245\t        );\n246\t    }\n247\t    AgenticPlan::Final(format!(\n248\t        \"Completed the general change request for {} and verified it with `{}`.\\n\\nPlan event ({}):\\n\\n{}\",\n249\t        plan.target,\n250\t        plan.verification_command,\n251\t        PLAN_PATH,\n252\t        plan.links_notation().trim_end(),\n253\t    ))"
