n when the client advertises a shell tool for listing files.\"\n134:    if let Some(contents) = read_results_for_paths(records, &paths) {\n135:        return AgenticPlan::Final(file_read_final_answer(mode, &contents));\n139:        if let Some(tool) = read_tool {\n142:                .filter(|path| read_result_for_path(records, path).is_none())\n145:                    arguments: read_arguments(path),\n151:        if let Some(tool) = read_tool {\n152:            return plan_one(tool, read_arguments(path));\n160:            read_command_for(&paths[0], mode)\n163:            return AgenticPlan::Final(file_read_final_answer(\n172:        \"I can read the selected file after listing when the client advertises a read or shell tool.\"\n177:pub(super) fn file_read_task_for(prompt: &str) -> Option<FileReadTask> {\n181:        return Some(FileReadTask::Direct {\n183:            mode: FileReadMode::Full,\n188:    if asks_to_read_every_file(&lower) {\n189:        return Some(FileReadTask::ListThenRead {\n192:            mode: FileReadMode::Summary,\n196:    if asks_to_list_then_read(&lower) {\n197:        return Some(FileReadTask::ListThenRead {\n198:            directory: directory_for_list_read(prompt).unwrap_or_else(|| String::from(\".\")),\n204:    if asks_to_read_file_in_folder(&lower) {\n205:        return Some(FileReadTask::ListThenRead {\n206:            directory: directory_for_list_read(prompt).unwrap_or_else(|| String::from(\".\")),\n212:    if has_file_read_intent(&lower) {\n214:            return Some(FileReadTask::Direct {\n225:fn has_file_read_intent(lower: &str) -> bool {\n227:        \"read\",",
