2026-07-21T04:24:01.3266308Z [36;1m[0m
2026-07-21T04:24:01.3266647Z [36;1m# 2) Registry-mirror fallback. When Docker Hub's registry endpoint is[0m
2026-07-21T04:24:01.3267053Z [36;1m#    fully unreachable (issue #69: registry-1.docker.io timed out for[0m
2026-07-21T04:24:01.3267426Z [36;1m#    longer than a normal blip), the canonical pull above cannot recover[0m
2026-07-21T04:24:01.3267785Z [36;1m#    no matter how many times it retries. mirror.gcr.io is a[0m
2026-07-21T04:24:01.3268155Z [36;1m#    pull-through cache of Docker Hub on independent infrastructure, so[0m
2026-07-21T04:24:01.3268540Z [36;1m#    it usually still serves the image. We pull from there and re-tag to[0m
2026-07-21T04:24:01.3268924Z [36;1m#    the canonical reference so the docker-container driver boot finds it[0m
2026-07-21T04:24:01.3269391Z [36;1m#    locally and never touches the failing registry.[0m
2026-07-21T04:24:01.3269665Z [36;1mif [ -n "${REGISTRY_MIRROR}" ]; then[0m
2026-07-21T04:24:01.3269973Z [36;1m  mirror_ref="${REGISTRY_MIRROR}/${BUILDKIT_IMAGE}"[0m
2026-07-21T04:24:01.3270378Z [36;1m  echo "==> Canonical pull failed; trying registry mirror ${mirror_ref}"[0m
2026-07-21T04:24:01.3270707Z [36;1m  if pull_with_retries "${mirror_ref}"; then[0m
2026-07-21T04:24:01.3270997Z [36;1m    docker tag "${mirror_ref}" "${BUILDKIT_IMAGE}"[0m
2026-07-21T04:24:01.3271403Z [36;1m    echo "==> BuildKit image cached locally via mirror and tagged as ${BUILDKIT_IMAGE}; boot will reuse it"[0m
2026-07-21T04:24:01.3271775Z [36;1m    exit 0[0m
2026-07-21T04:24:01.3271945Z [36;1m  fi[0m
2026-07-21T04:24:01.3272169Z [36;1m  echo "==> Mirror pull from ${REGISTRY_MIRROR} also failed"[0m
2026-07-21T04:24:01.3272431Z [36;1mfi[0m
2026-07-21T04:24:01.3272587Z [36;1m[0m
2026-07-21T04:24:01.3272838Z [36;1m# Non-fatal: fall through to setup-buildx, which will attempt its own[0m
2026-07-21T04:24:01.3273228Z [36;1m# pull during boot. This preserves the previous behaviour in the worst[0m
