    inputs "Create file tests/issue_756.rs containing:\nuse std::ffi::OsStr;\nuse std::path::PathBuf;\nuse std::sync::{Mutex, OnceLock};\n\nuse formal_ai::{export_links_notation, resolve_memory_path_from, MemoryEvent, SyncStore};\n\nfn memory_env_lock() -> std::sync::MutexGuard<'static, ()> {\n    static LOCK: OnceLock<Mutex<()>> = OnceLock::new();\n    LOCK.get_or_init(|| Mutex::new(())).lock().unwrap()\n}\n\nfn event(id: &str, content: &str) -> MemoryEvent {\n    MemoryEvent {\n        id: id.to_owned(),\n        content: Some(content.to_owned()),\n        ..MemoryEvent::default()\n    }\n}\n\n#[test]\nfn shared_memory_path_honors_override_and_platform_defaults() {\n    assert_eq!(\n        resolve_memory_path_from(Some(OsStr::new(\"/custom/shared.lino\")), None, None, false),\n        PathBuf::from(\"/custom/shared.lino\")\n    );\n    assert_eq!(\n        resolve_memory_path_from(None, Some(OsStr::new(\"/users/alice\")), None, false),\n        PathBuf::from(\"/users/alice/.formal-ai/memory.lino\")\n    );\n    assert_eq!(\n        resolve_memory_path_from(None, None, Some(OsStr::new(\"/appdata/alice\")), true),\n        PathBuf::from(\"/appdata/alice/formal-ai/memory.lino\")\n    );\n    assert_eq!(\n        resolve_memory_path_from(Some(OsStr::new(\"  \")), Some(OsStr::new(\"/users/alice\")), None, false),\n        PathBuf::from(\"/users/alice/.formal-ai/memory.lino\")\n    );\n}\n\n#[test]\nfn fresh_default_store_is_created_securely_and_shared_between_surfaces() {\n    let _guard = memory_env_lock();\n    let root = std::env::temp_dir().join(format!(\"formal-ai-issue-756-{}\", std::process::id()));\n    let _ = std::fs::remove_dir_all(&root);\n    std::fs::create_dir_all(&root).expect(\"temp home\");\n\n    let previous_memory = std::env::var_os(\"FORMAL_AI_MEMORY_PATH\");\n    let previous_home = std::env::var_os(\"HOME\");\n    std::env::remove_var(\"FORMAL_AI_MEMORY_PATH\");\n    std::env::set_var(\"HOME\", &root);\n\n    let expected = root.join(\".formal-ai/memory.lino\");\n    let mut desktop_surface = SyncStore::open();\n    assert!(expected.is_file(), \"first open must create {}\", expected.display());\n\n    #[cfg(unix)]\n    {\n        use std::os::unix::fs::PermissionsExt;\n        let mode = std::fs::metadata(expected.parent().unwrap())\n            .expect(\"memory directory metadata\")\n            .permissions()\n            .mode()\n            & 0o777;\n        assert_eq!(mode, 0o700);\n    }\n\n    let lino = export_links_notation(&[event(\"shared-fact\", \"remember me everywhere\")]);\n    desktop_surface.import_links_notation(&lino).expect(\"desktop write\");\n    let vscode_surface = SyncStore::open();\n    assert_eq!(vscode_surface.events().len(), 1);\n    assert_eq!(vscode_surface.events()[0].id, \"shared-fact\");\n\n    match previous_memory {\n        Some(value) => std::env::set_var(\"FORMAL_AI_MEMORY_PATH\", value),\n        None => std::env::remove_var(\"FORMAL_AI_MEMORY_PATH\"),\n    }\n    match previous_home {\n        Some(value) => std::env::set_var(\"HOME\", value),\n        None => std::env::remove_var(\"HOME\"),\n    }\n    let _ = std::fs::remove_dir_all(&root);\n}"
    outputs "Completed the general change request for tests/issue_756.rs and verified it with `cat tests/issue_756.rs`.\n\nPlan event (.formal-ai/general-change-plan.lino):\n\ngeneral_change_plan\n  id \"general_change_plan_f806fb6ad6ebc8e5\"\n  goal \"Create file tests/issue_756.rs containing:\\nuse std::ffi::OsStr;\\nuse std::path::PathBuf;\\nuse std::sync::{Mutex, OnceLock};\\n\\nuse formal_ai::{export_links_notation, resolve_memory_path_from, MemoryEvent, SyncStore};\\n\\nfn memory_env_lock() -> std::sync::MutexGuard<'static, ()> {\\n    static LOCK: OnceLock<Mutex<()>> = OnceLock::new();\\n    LOCK.get_or_init(|| Mutex::new(())).lock().unwrap()\\n}\\n\\nfn event(id: &str, content: &str) -> MemoryEvent {\\n    MemoryEvent {\\n        id: id.to_owned(),\\n        content: Some(content.to_owned()),\\n        ..MemoryEvent::default()\\n    }\\n}\\n\\n#[test]\\nfn shared_memory_path_honors_override_and_platform_defaults() {\\n    assert_eq!(\\n        resolve_memory_path_from(Some(OsStr::new(\\\"/custom/shared.lino\\\")), None, None, false),\\n        PathBuf::from(\\\"/custom/shared.lino\\\")\\n    );\\n    assert_eq!(\\n        resolve_memory_path_from(None, Some(OsStr::new(\\\"/users/alice\\\")), None, false),\\n        PathBuf::from(\\\"/users/alice/.formal-ai/memory.lino\\\")\\n    );\\n    assert_eq!(\\n        resolve_memory_path_from(None, None, Some(OsStr::new(\\\"/appdata/alice\\\")), true),\\n        PathBuf::from(\\\"/appdata/alice/formal-ai/memory.lino\\\")\\n    );\\n    assert_eq!(\\n        resolve_memory_path_from(Some(OsStr::new(\\\"  \\\")), Some(OsStr::new(\\\"/users/alice\\\")), None, false),\\n        PathBuf::from(\\\"/users/alice/.formal-ai/memory.lino\\\")\\n    );\\n}\\n\\n#[test]\\nfn fresh_default_store_is_created_securely_and_shared_between_surfaces() {\\n    let _guard = memory_env_lock();\\n    let root = std::env::temp_dir().join(format!(\\\"formal-ai-issue-756-{}\\\", std::process::id()));\\n    let _ = std::fs::remove_dir_all(&root);\\n    std::fs::create_dir_all(&root).expect(\\\"temp home\\\");\\n\\n    let previous_memory = std::env::var_os(\\\"FORMAL_AI_MEMORY_PATH\\\");\\n    let previous_home = std::env::var_os(\\\"HOME\\\");\\n    std::env::remove_var(\\\"FORMAL_AI_MEMORY_PATH\\\");\\n    std::env::set_var(\\\"HOME\\\", &root);\\n\\n    let expected = root.join(\\\".formal-ai/memory.lino\\\");\\n    let mut desktop_surface = SyncStore::open();\\n    assert!(expected.is_file(), \\\"first open must create {}\\\", expected.display());\\n\\n    #[cfg(unix)]\\n    {\\n        use std::os::unix::fs::PermissionsExt;\\n        let mode = std::fs::metadata(expected.parent().unwrap())\\n            .expect(\\\"memory directory metadata\\\")\\n            .permissions()\\n            .mode()\\n            & 0o777;\\n        assert_eq!(mode, 0o700);\\n    }\\n\\n    let lino = export_links_notation(&[event(\\\"shared-fact\\\", \\\"remember me everywhere\\\")]);\\n    desktop_surface.import_links_notation(&lino).expect(\\\"desktop write\\\");\\n    let vscode_surface = SyncStore::open();\\n    assert_eq!(vscode_surface.events().len(), 1);\\n    assert_eq!(vscode_surface.events()[0].id, \\\"shared-fact\\\");\\n\\n    match previous_memory {\\n        Some(value) => std::env::set_var(\\\"FORMAL_AI_MEMORY_PATH\\\", value),\\n        None => std::env::remove_var(\\\"FORMAL_AI_MEMORY_PATH\\\"),\\n    }\\n    match previous_home {\\n        Some(value) => std::env::set_var(\\\"HOME\\\", value),\\n        None => std::env::remove_var(\\\"HOME\\\"),\\n    }\\n    let _ = std::fs::remove_dir_all(&root);\\n}\"\n  target \"tests/issue_756.rs\"\n  step 1\n    capability \"Write\"\n    action \"append the composed plan to .formal-ai/general-change-plan.lino\"\n    expected_evidence \"written plan event impulse_dae5840580857a9d\"\n  step 2\n    capability \"Write\"\n    action \"write the requested content to tests/issue_756.rs\"\n    expected_evidence \"workspace file tests/issue_756.rs\"\n  step 3\n    capabili