demo_memory
  event "chat_user_842203585c97d49e"
    kind "message"
    role "user"
    content "Write file desktop/lib/shared-memory.cjs with this content:\n\"use strict\";\n\nconst os = require(\"node:os\");\nconst path = require(\"node:path\");\n\nconst CONTAINER_MEMORY_DIRECTORY = \"/root/.formal-ai\";\nconst CONTAINER_MEMORY_PATH = `${CONTAINER_MEMORY_DIRECTORY}/memory.lino`;\n\nfunction resolveSharedMemoryPath(env = process.env, options = {}) {\n  const override = String(env.FORMAL_AI_MEMORY_PATH || \"\").trim();\n  if (override) {\n    return override;\n  }\n  const platform = options.platform || process.platform;\n  const pathImpl = options.pathImpl || path;\n  if (platform === \"win32\") {\n    const appData = String(options.appData || env.APPDATA || env.LOCALAPPDATA || \"\").trim();\n    const base = appData || String(options.homeDir || os.homedir() || \".\").trim() || \".\";\n    return pathImpl.join(base, \"formal-ai\", \"memory.lino\");\n  }\n  const home = String(options.homeDir || os.homedir() || \".\").trim() || \".\";\n  return pathImpl.join(home, \".formal-ai\", \"memory.lino\");\n}\n\nfunction sharedMemoryDirectory(env = process.env, options = {}) {\n  return (options.pathImpl || path).dirname(resolveSharedMemoryPath(env, options));\n}\n\nfunction dockerMemoryArgs(env = process.env, options = {}) {\n  return [\n    \"-v\",\n    `${sharedMemoryDirectory(env, options)}:${CONTAINER_MEMORY_DIRECTORY}`,\n    \"-e\",\n    `FORMAL_AI_MEMORY_PATH=${CONTAINER_MEMORY_PATH}`,\n  ];\n}\n\nmodule.exports = {\n  CONTAINER_MEMORY_DIRECTORY,\n  CONTAINER_MEMORY_PATH,\n  resolveSharedMemoryPath,\n  sharedMemoryDirectory,\n  dockerMemoryArgs,\n};"
    writeCount "1"
  event "chat_task_842203585c97d49e"
    kind "task"
    role "assistant"
    intent "solve"
    inputs "Write file desktop/lib/shared-memory.cjs with this content:\n\"use strict\";\n\nconst os = require(\"node:os\");\nconst path = require(\"node:path\");\n\nconst CONTAINER_MEMORY_DIRECTORY = \"/root/.formal-ai\";\nconst CONTAINER_MEMORY_PATH = `${CONTAINER_MEMORY_DIRECTORY}/memory.lino`;\n\nfunction resolveSharedMemoryPath(env = process.env, options = {}) {\n  const override = String(env.FORMAL_AI_MEMORY_PATH || \"\").trim();\n  if (override) {\n    return override;\n  }\n  const platform = options.platform || process.platform;\n  const pathImpl = options.pathImpl || path;\n  if (platform === \"win32\") {\n    const appData = String(options.appData || env.APPDATA || env.LOCALAPPDATA || \"\").trim();\n    const base = appData || String(options.homeDir || os.homedir() || \".\").trim() || \".\";\n    return pathImpl.join(base, \"formal-ai\", \"memory.lino\");\n  }\n  const home = String(options.homeDir || os.homedir() || \".\").trim() || \".\";\n  return pathImpl.join(home, \".formal-ai\", \"memory.lino\");\n}\n\nfunction sharedMemoryDirectory(env = process.env, options = {}) {\n  return (options.pathImpl || path).dirname(resolveSharedMemoryPath(env, options));\n}\n\nfunction dockerMemoryArgs(env = process.env, options = {}) {\n  return [\n    \"-v\",\n    `${sharedMemoryDirectory(env, options)}:${CONTAINER_MEMORY_DIRECTORY}`,\n    \"-e\",\n    `FORMAL_AI_MEMORY_PATH=${CONTAINER_MEMORY_PATH}`,\n  ];\n}\n\nmodule.exports = {\n  CONTAINER_MEMORY_DIRECTORY,\n  CONTAINER_MEMORY_PATH,\n  resolveSharedMemoryPath,\n  sharedMemoryDirectory,\n  dockerMemoryArgs,\n};"
    outputs "I can route `write_program(language, task)`, but I do not have a template for language `javascript` and task `missing`. Supported languages: rust, python, javascript, typescript, go, c, cpp, java, csharp, ruby. Supported tasks: hello_world, count_to_three, list_files, list_files_arg, list_files_reverse_sort, list_files_arg_reverse_sort, fizzbuzz, factorial, reverse_string, sum_to_ten, fibonacci."
