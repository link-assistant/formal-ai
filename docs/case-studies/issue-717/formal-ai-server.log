}}]},{"role":"tool","tool_call_id":"call_a80bb619d69525c2","content":"<file>\n00001| name: CI/CD Pipeline\n00002| \n00003| on:\n00004|   push:\n00005|     branches:\n00006|       - main\n00007|   pull_request:\n00008|     types: [opened, synchronize, reopened]\n00009|   workflow_dispatch:\n00010|     inputs:\n00011|       release_mode:\n00012|         description: 'Manual release mode'\n00013|         required: true\n00014|         type: choice\n00015|         default: 'instant'\n00016|         options:\n00017|           - instant\n00018|           - changelog-pr\n00019|       bump_type:\n00020|         description: 'Version bump type'\n00021|         required: true\n00022|         type: choice\n00023|         options:\n00024|           - patch\n00025|           - minor\n00026|           - major\n00027|       description:\n00028|         description: 'Release description (optional)'\n00029|         required: false\n00030|         type: string\n00031| \n00032| concurrency:\n00033|   group: ${{ github.workflow }}-${{ github.ref }}\n00034|   # Cancel superseded runs on PR branches to save CI minutes, but never cancel a\n00035|   # run on main: that branch drives the release pipeline (crates.io publish, tag\n00036|   # creation, desktop builds, Pages deploy), and cancelling it mid-flight can\n00037|   # leave a release half-published. desktop-release.yml uses cancel-in-progress:\n00038|   # false for the same reason (issue #479).\n00039|   cancel-in-progress: ${{ github.ref != 'refs/heads/main' }}\n00040| \n00041| env:\n00042|   GIT_CONFIG_COUNT: '1'\n00043|   GIT_CONFIG_KEY_0: init.defaultBranch\n00044|   GIT_CONFIG_VALUE_0: main\n00045|   CARGO_NET_RETRY: '10'\n00046|   CARGO_HTTP_MULTIPLEXING: 'false'\n00047|   CARGO_TERM_COLOR: always\n00048|   RUSTFLAGS: -Dwarnings\n00049|   # Support both CARGO_REGISTRY_TOKEN (cargo's native env var) and CARGO_TOKEN (for backwards compatibility)\n00050|   CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN || secrets.CARGO_TOKEN }}\n00051|   CARGO_TOKEN: ${{ secrets.CARGO_TOKEN }}\n00052|   # Default prepared Docker image published by releases for single-line bot startup.\n00053|   GHCR_IMAGE: ghcr.io/${{ github.repository }}\n00054|   # Optional: set repository variable DOCKERHUB_IMAGE to namespace/image to publish Docker Hub releases.\n00055|   DOCKERHUB_IMAGE: ${{ vars.DOCKERHUB_IMAGE }}\n00056| \n00057| jobs:\n00058|   # === DETECT CHANGES - determines which jobs should run ===\n00059|   detect-changes:\n00060|     name: Detect Changes\n00061|     runs-on: ubuntu-latest\n00062|     timeout-minutes: 5\n00063|     if: github.event_name != 'workflow_dispatch'\n00064|     outputs:\n00065|       rs-changed: ${{ steps.changes.outputs.rs-changed }}\n00066|       toml-changed: ${{ steps.changes.outputs.toml-changed }}\n00067|       docs-changed: ${{ steps.changes.outputs.docs-changed }}\n00068|       workflow-changed: ${{ steps.changes.outputs.workflow-changed }}\n00069|       any-code-changed: ${{ steps.changes.outputs.any-code-changed }}\n00070|     steps:\n00071|       - uses: actions/checkout@v6\n00072|         with:\n00073|           fetch-depth: 0\n00074| \n00075|       - name: Setup Rust\n00076|         uses: dtolnay/rust-toolchain@stable\n00077| \n00078|       - name: Install rust-script\n00079|         run: bash scripts/install-rust-script.sh\n00080| \n00081|       - name: Detect changes\n00082|         id: changes\n00083|         env:\n00084|           GITHUB_EVENT_NAME: ${{ github.event_name }}\n00085|         run: rust-script scripts/detect-code-changes.rs\n00086| \n00087|   # === CHANGELOG CHECK - only runs on PRs with code changes ===\n00088|   # Docs-only PRs (./docs folder, markdown files) don't require changelog fragments\n00089|   changelog:\n00090|     name: Changelog Fragment Check\n00091|     runs-on: ubuntu-latest\n00092|     timeout-minutes: 10\n00093|     needs: [detect-changes]\n00094|     if: github.event_name == 'pull_request' && needs.detect-changes.outputs.any-code-changed == 'true'\n00095|     steps:\n00096|       - uses: actions/checkout@v6\n00097|         with:\n00098|           fetch-depth: 0\n00099| \n00100|       - name: Setup Rust\n00101|         uses: dtolnay/rust-toolchain@stable\n00102| \n00103|       - name: Install rust-script\n00104|         run: bash scripts/install-rust-script.sh\n00105| \n00106|       - name: Check for changelog fragments\n00107|         env:\n00108|           GITHUB_BASE_REF: ${{ github.base_ref }}\n00109|         run: rust-script scripts/check-changelog-fragment.rs\n00110| \n00111|   # === VERSION CHECK - prevents manual version modification in PRs ===\n00112|   # This ensures versions are only modified by the automated release pipeline\n00113|   version-check:\n00114|     name: Version Modification Check\n00115|     runs-on: ubuntu-latest\n00116|     timeout-minutes: 5\n00117|     if: github.event_name == 'pull_request'\n00118|     steps:\n00119|       - uses: actions/checkout@v6\n00120|         with:\n00121|           fetch-depth: 0\n00122| \n00123|       - name: Setup Rust\n00124|         uses: dtolnay/rust-toolchain@stable\n00125| \n00126|       - name: Install rust-script\n00127|         run: bash scripts/install-rust-script.sh\n00128| \n00129|       - name: Check for manual version changes\n00130|         env:\n00131|           GITHUB_EVENT_NAME: ${{ github.event_name }}\n00132|           GITHUB_HEAD_REF: ${{ github.head_ref }}\n00133|           GITHUB_BASE_REF: ${{ github.base_ref }}\n00134|         run: rust-script scripts/check-version-modification.rs\n00135| \n00136|   # === LINT AND FORMAT CHECK ===\n00137|   # Lint runs independently of changelog check - it's a fast check that should always run\n00138|   # See: https://github.com/link-assistant/hive-mind/pull/1024 for why this dependency was removed\n00139|   lint:\n00140|     name: Lint and Format Check\n00141|     runs-on: ubuntu-latest\n00142|     timeout-minutes: 10\n00143|     needs: [detect-changes]\n00144|     # Note: always() is required because detect-changes is skipped on workflow_dispatch,\n00145|     # and without always(), this job would also be skipped even though its condition includes workflow_dispatch.\n00146|     # See: https://github.com/actions/runner/issues/491\n00147|     if: |\n00148|       always() && !cancelled() && (\n00149|         github.event_name == 'push' ||\n00150|         github.event_name == 'workflow_dispatch' ||\n00151|         needs.detect-changes.outputs.any-code-changed == 'true' ||\n00152|         needs.detect-changes.outputs.rs-changed == 'true' ||\n00153|         needs.detect-changes.outputs.toml-changed == 'true' ||\n00154|         needs.detect-changes.outputs.docs-changed == 'true' ||\n00155|         needs.detect-changes.outputs.workflow-changed == 'true'\n00156|       )\n00157|     steps:\n00158|       - uses: actions/checkout@v6\n00159|         with:\n00160|           fetch-depth: 0\n00161| \n00162|       - name: Setup Rust\n00163|         uses: dtolnay/rust-toolchain@stable\n00164|         with:\n00165|           components: rustfmt, clippy\n00166| \n00167|       - name: Setup Bun\n00168|         uses: oven-sh/setup-bun@v2\n00169|         with:\n00170|           bun-version-file: .bun-version\n00171| \n00172|       - name: Install rust-script\n00173|         run: bash scripts/install-rust-script.sh\n00174| \n00175|       - name: Cache cargo registry\n00176|         uses: actions/cache@v5\n00177|         with:\n00178|           path: |\n00179|             ~/.cargo/registry\n00180|             ~/.cargo/git\n00181|             target\n00182|           key: ${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}\n00183|           restore-keys: |\n00184|             ${{ runner.os }}-cargo-\n00185| \n00186|       - name: Check formatting\n00187|         run: cargo fmt --all -- --check\n00188| \n00189|       - name: Run Clippy\n00190|         run: cargo clippy --all-targets --all-features\n00191| \n00192|       - name: Check semantic grounding\n00193|         run: cargo test --test unit semantic_grounding -- --nocapture\n00194| \n00195|       - name: Check file size limit\n00196|         env:\n00197|           FILE_SIZE_WARNING_BASE: ${{ github.event.pull_request.base.sha || github.event.before }}\n00198|         run: rust-script scripts/check-file-size.rs\n00199| \n00200|       - name: Install web bundle dependencies\n00201|         run: bun install --frozen-lockfile\n00202| \n00203|       - name: Build web vendor bundle\n00204|         run: bun run build:web\n00205| \n00206|       - name: Check web bundles are current\n00207|         run: git diff --exit-code -- src/web/vendor.bundle.js src/web/ocr.bundle.js src/web/app.js\n00208| \n00209|       - name: Setup Node\n00210|         uses: actions/setup-node@v6\n00211|         with:\n00212|           node-version: 22\n00213|           cache: npm\n00214|           cache-dependency-path: tests/e2e/package-lock.json\n00215| \n00216|       - name: Install web test dependencies\n00217|         run: npm ci --prefix tests/e2e\n00218| \n00219|       - name: Check i18n catalog coverage\n00220|         run: npm run --prefix tests/e2e check:i18n\n00221| \n00222|       - name: Check language change parity\n00223|         env:\n00224|           GITHUB_BASE_REF: ${{ github.base_ref }}\n00225|         run: npm run --prefix tests/e2e check:language-parity\n00226| \n00227|       - name: Check language test coverage\n00228|         env:\n00229|           GITHUB_BASE_REF: ${{ github.base_ref }}\n00230|         run: npm run --prefix tests/e2e check:language-test-coverage\n00231| \n00232|       - name: Check multilingual intent coverage\n00233|         run: npm run --prefix tests/e2e check:intent-coverage\n00234| \n00235|       - name: Check web app for hook TDZ ordering bugs\n00236|         run: npm run --prefix tests/e2e check:web-tdz\n00237| \n00238|       # Issue #511/#514: fail the build if src/web/app.js renders hardcoded\n00239|       # user-facing prose instead of routing it through the i18n catalog (t()).\n00240|       # This stops the per-tool permission / Services regression class from\n00241|       # silently re-appearing.\n00242|       - name: Check web app for hardcoded user-facing strings\n00243|         run: npm run --prefix tests/e2e check:web-hardcoded-ui\n00244| \n00245|       # The terminal-command trigger vocabulary lives in\n00246|       # data/seed/terminal-commands.lino; the JS worker loads the generated\n00247|       # src/web/seed deployment mirror through seed_loader.js. This fails on\n00248|       # worker wiring regressions or stale present mirrors, so the worker can\n00249|       # never silently re-hardcode trigger phrases that have moved into seed data.\n00250|       - name: Check terminal vocabulary worker seed wiring\n00251|         run: node experiments/issue-513-sync-worker-terminal.mjs --check\n00252| \n00253|       # The VS Code extension host libraries (config/bridge/webview-html/\n00254|       # chat-view/server-process) and the manifest are pure JS exercised by\n00255|       # node's built-in test runner plus a static smoke check. They read only\n00256|       # committed source (never the git-ignored dist-web/vendor mirrors), so no\n00257|       # `npm ci` or prepare-resources step is required here.\n00258|       - name: Run VS Code extension node tests\n00259|         run: npm run vscode:test\n00260| \n00261|   # === TEST ===\n00262|   # Test runs independently of the changelog check and gates on the change\n00263|   # detector so it never burns runner time on non-code changes (issue #442).\n00264|   #\n00265|   # Previously this job ran whenever `changelog` was skipped. But `changelog`\n00266|   # is skipped precisely when there are NO code changes (docs-only / .gitkeep /\n00267|   # changelog-fragment-only commits), so `needs.changelog.result == 'skipped'`\n00268|   # turned \"no code changed\" into \"run the full test suite\" — the exact\n00269|   # opposite of what we want. Gate on the detect-changes outputs instead, the\n00270|   # same way `lint` and `coverage` already do.\n00271|   test:\n00272|     name: Test (${{ matrix.os }})\n00273|     runs-on: ${{ matrix.os }}\n00274|     timeout-minutes: 15\n00275|     needs: [detect-changes]\n00276|     # Note: always() is required because detect-changes is skipped on\n00277|     # workflow_dispatch; without it the skipped dependency would cascade and\n00278|     # skip this job despite the workflow_dispatch condition below.\n00279|     # See: https://github.com/actions/runner/issues/491\n00280|     if: |\n00281|       always() && !cancelled() && (\n00282|         github.event_name == 'push' ||\n00283|         github.event_name == 'workflow_dispatch' ||\n00284|         needs.detect-changes.outputs.any-code-changed == 'true' ||\n00285|         needs.detect-changes.outputs.rs-changed == 'true' ||\n00286|         needs.detect-changes.outputs.toml-changed == 'true' ||\n00287|         needs.detect-changes.outputs.workflow-changed == 'true'\n00288|       )\n00289|     strategy:\n00290|       fail-fast: false\n00291|       matrix:\n00292|         # Windows and macOS execution is dropped for now to speed up iteration;\n00293|         # the tests themselves are kept and still run on Linux.\n00294|         os: [ubuntu-latest]\n00295|     steps:\n00296|       - uses: actions/checkout@v6\n00297| \n00298|       - name: Setup Rust\n00299|         uses: dtolnay/rust-toolchain@stable\n00300| \n00301|       # Restore the cargo cache here, but leave cache writes to the lint/build\n00302|       # jobs. This test job runs close to its timeout after the full suite, and\n00303|       # saving a target-heavy cache in post-job cleanup can cancel an otherwise\n00304|       # successful run.\n00305|       - name: Restore cargo registry cache\n00306|         uses: actions/cache/restore@v5\n00307|         with:\n00308|           path: |\n00309|             ~/.cargo/registry\n00310|             ~/.cargo/git\n00311|             target\n00312|           key: ${{ runner.os }}-cargo-${{ hashFiles('**/Cargo.lock') }}\n00313|           restore-keys: |\n00314|             ${{ runner.os }}-cargo-\n00315| \n00316|       - name: Check LiNo data integrity\n00317|         run: cargo test --test unit data_files -- --nocapture\n00318| \n00319|       - name: Run tests\n00320|         run: cargo test --all-features --verbose\n00321| \n00322|       - name: Run doc tests\n00323|         run: cargo test --doc --verbose\n00324| \n00325|   # === CODE COVERAGE ===\n00326|   # Generate and upload code coverage using cargo-llvm-cov\n00327|   coverage:\n00328|     name: Code Coverage\n00329|     runs-on: ubuntu-latest\n00330|     timeout-minutes: 15\n00331|     needs: [detect-changes]\n00332|     if: |\n00333|       always() && !cancelled() && (\n00334|         github.event_name == 'push' ||\n00335|         github.event_name == 'workflow_dispatch' ||\n00336|         needs.detect-changes.outputs.rs-changed == 'true' ||\n00337|         needs.detect-changes.outputs.toml-changed == 'true'\n00338|       )\n00339|     steps:\n00340|       - uses: actions/checkout@v6\n00341| \n00342|       - name: Setup Rust\n00343|         uses: dtolnay/rust-toolchain@stable\n00344|         with:\n00345|           components: llvm-tools-preview\n00346| \n00347|       - name: Cache cargo registry\n00348|         uses: actions/cache@v5\n00349|         with:\n00350|           path: |\n00351|             ~/.cargo/registry\n00352|             ~/.cargo/git\n00353|             target\n00354|           key: ${{ runner.os }}-cargo-coverage-${{ hashFiles('**/Cargo.lock') }}\n00355|           restore-keys: |\n00356|             ${{ runner.os }}-cargo-coverage-\n00357| \n00358|       - name: Install cargo-llvm-cov\n00359|         uses: taiki-e/install-action@cargo-llvm-cov\n00360| \n00361|       - name: Generate code coverage\n00362|         run: cargo llvm-cov --all-features --lcov --output-path lcov.info\n00363| \n00364|       - name: Upload coverage to Codecov\n00365|         uses: codecov/codecov-action@v5\n00366|         with:\n00367|           files: lcov.info\n00368|           fail_ci_if_error: false\n00369| \n00370|   # === BUILD ===\n00371|   # Build package - only runs if lint and test pass\n00372|   build:\n00373|     name: Build Package\n00374|     runs-on: ubuntu-latest\n00375|     timeout-minutes: 10\n00376|     needs: [lint, test]\n00377|     if: always() && !cancelled() && needs.lint.result == 'success' && needs.test.result == 'success'\n00378|     steps:\n00379|       - uses: actions/checkout@v6\n00380| \n00381|       - name: Setup Rust\n00382|         uses: dtolnay/rust-toolchain@stable\n00383| \n00384|       - name: Install rust-script\n00385|         run: bash scripts/install-rust-script.sh\n00386| \n00387|       - name: Cache cargo registry\n00388|         uses: actions/cache@v5\n00389|         with:\n00390|           path: |\n00391|             ~/.cargo/registry\n00392|             ~/.cargo/git\n00393|             target\n00394|           key: ${{ runner.os }}-cargo-build-${{ hashFiles('**/Cargo.lock') }}\n00395|           restore-keys: |\n00396|             ${{ runner.os }}-cargo-build-\n00397| \n00398|       - name: Build release\n00399|         run: cargo build --release --verbose\n00400| \n00401|       - name: Check package\n00402|         run: cargo package --list --allow-dirty\n00403| \n00404|       - name: Check crate package size\n00405|         run: rust-script scripts/check-crate-package-size.rs\n00406| \n00407|   # === AUTO RELEASE ===\n00408|   # Automatic release on push to main using changelog fragments\n00409|   # This job automatically bumps version based on fragments in changelog.d/\n00410|   auto-release:\n00411|     name: Auto Release\n00412|     needs: [lint, test, build]\n00413|     # Note: always() ensures consistent behavior with other jobs that depend on jobs using always().\n00414|     if: |\n00415|       always() && !cancelled() &&\n00416|       github.event_name == 'push' &&\n00417|       github.ref == 'refs/heads/main' &&\n00418|       needs.build.result == 'success'\n00419|     runs-on: ubuntu-latest\n00420|     timeout-minutes: 30\n00421|     outputs:\n00422|       pages_sha: ${{ steps.release_pages_ref.outputs.sha }}\n00423|       pages_version: ${{ steps.release_pages_ref.outputs.version }}\n00424|     env:\n00425|       DOCKERHUB_USERNAME: ${{ vars.DOCKERHUB_USERNAME || secrets.DOCKERHUB_USERNAME }}\n00426|       DOCKERHUB_TOKEN: ${{ secrets.DOCKERHUB_TOKEN }}\n00427|     permissions:\n00428|       contents: write\n00429|       packages: write\n00430|     steps:\n00431|       - uses: actions/checkout@v6\n00432|         with:\n00433|           fetch-depth: 0\n00434|           token: ${{ secrets.GITHUB_TOKEN }}\n00435| \n00436|       - name: Setup Rust\n00437|         uses: dtolnay/rust-toolchain@stable\n00438| \n00439|       - name: Install rust-script\n00440|         run: bash scripts/install-rust-script.sh\n00441| \n00442|       - name: Configure git\n00443|         run: rust-script scripts/git-config.rs\n00444| \n00445|       - name: Determine bump type from changelog fragments\n00446|         id: bump_type\n00447|         run: rust-script scripts/get-bump-type.rs\n00448| \n00449|       - name: Check if version already released or no fragments\n00450|         id: check\n00451|         env:\n00452|           HAS_FRAGMENTS: ${{ steps.bump_type.outputs.has_fragments }}\n00453|           GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n00454|         run: rust-script scripts/check-release-needed.rs\n00455| \n00456|       - name: Collect changelog and bump version\n00457|         id: version\n00458|         if: steps.check.outputs.should_release == 'true' && steps.check.outputs.skip_bump != 'true'\n00459|         run: |\n00460|           rust-script scripts/version-and-commit.rs \\\n00461|             --bump-type \"${{ steps.bump_type.outputs.bump_type }}\"\n00462| \n00463|       - name: Get current version\n00464|         id: current_version\n00465|         if: steps.check.outputs.should_release == 'true'\n00466|         run: rust-script scripts/get-version.rs\n00467| \n00468|       - name: Build release\n00469|         if: steps.check.outputs.should_release == 'true'\n00470|         run: cargo build --release\n00471| \n00472|       - name: Publish to Crates.io\n00473|         if: steps.check.outputs.should_release == 'true' && steps.check.outputs.crate_published != 'true'\n00474|         id: publish-crate\n00475|         env:\n00476|           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN || secrets.CARGO_TOKEN }}\n00477|           CARGO_TOKEN: ${{ secrets.CARGO_TOKEN }}\n00478|         run: rust-script scripts/publish-crate.rs\n00479| \n00480|       - name: Wait for Crate availability on Crates.io\n00481|         if: |\n00482|           steps.check.outputs.should_release == 'true' && (\n00483|             steps.check.outputs.crate_published == 'true' ||\n00484|             steps.publish-crate.outputs.publish_result == 'success'\n00485|           )\n00486|         run: rust-script scripts/wait-for-crate.rs --release-version \"${{ steps.current_version.outputs.version }}\"\n00487| \n00488|       - name: Log in to GitHub Container Registry\n00489|         if: |\n00490|           steps.check.outputs.should_release == 'true' && (\n00491|             steps.check.outputs.crate_published == 'true' ||\n00492|             steps.publish-crate.outputs.publish_result == 'success'\n00493|           )\n00494|         uses: docker/login-action@v4\n00495|         with:\n00496|           registry: ghcr.io\n00497|           username: ${{ github.actor }}\n00498|           password: ${{ secrets.GITHUB_TOKEN }}\n00499| \n00500|       - name: Set up Docker Buildx\n00501|         if: |\n00502|           steps.check.outputs.should_release == 'true' && (\n00503|             steps.check.outputs.crate_published == 'true' ||\n00504|             steps.publish-crate.outputs.publish_result == 'success'\n00505|           )\n00506|         uses: docker/setup-buildx-action@v4\n00507| \n00508|       - name: Extract GHCR Docker metadata\n00509|         if: |\n00510|           steps.check.outputs.should_release == 'true' && (\n00511|             steps.check.outputs.crate_published == 'true' ||\n00512|             steps.publish-crate.outputs.publish_result == 'success'\n00513|           )\n00514|         id: ghcr-meta\n00515|         uses: docker/metadata-action@v6\n00516|         with:\n00517|           images: ${{ env.GHCR_IMAGE }}\n00518|           tags: |\n00519|             type=raw,value=latest\n00520|             type=raw,value=${{ steps.current_version.outputs.version }}\n00521|           labels: |\n00522|             org.opencontainers.image.version=${{ steps.current_version.outputs.version }}\n00523| \n00524|       - name: Publish Docker image to GHCR\n00525|         if: |\n00526|           steps.check.outputs.should_release == 'true' && (\n00527|             steps.check.outputs.crate_published == 'true' ||\n00528|             steps.publish-crate.outputs.publish_result == 'success'\n00529|           )\n00530|         uses: docker/build-push-action@v7\n00531|         with:\n00532|           context: .\n00533|           push: true\n00534|           tags: ${{ steps.ghcr-meta.outputs.tags }}\n00535|           labels: ${{ steps.ghcr-meta.outputs.labels }}\n00536| \n00537|       - name: Configure Docker Hub publishing\n00538|         if: |\n00539|           steps.check.outputs.should_release == 'true' && (\n00540|             steps.check.outputs.crate_published == 'true' ||\n00541|             steps.publish-crate.outputs.publish_result == 'success'\n00542|           )\n00543|         id: dockerhub\n00544|         run: |\n00545|           disable_dockerhub() {\n00546|             echo \"enabled=false\" >> \"$GITHUB_OUTPUT\"\n00547|             echo \"$1\"\n00548|           }\n00549| \n00550|           if [ -z \"$DOCKERHUB_IMAGE\" ]; then\n00551|             disable_dockerhub \"Docker 