on from Cargo.toml\"\n00632|             exit 1\n00633|           fi\n00634|           echo \"sha=${sha}\" >> \"$GITHUB_OUTPUT\"\n00635|           echo \"version=${version}\" >> \"$GITHUB_OUTPUT\"\n00636|           echo \"Pages deploy ref: ${sha} (formal-ai ${version})\"\n00637| \n00638|   # === MANUAL INSTANT RELEASE ===\n00639|   # Manual release via workflow_dispatch - only after CI passes\n00640|   manual-release:\n00641|     name: Instant Release\n00642|     needs: [lint, test, build]\n00643|     # Note: always() is required to evaluate the condition when dependencies use always().\n00644|     # The build job ensures lint and test passed before this job runs.\n00645|     if: |\n00646|       always() && !cancelled() &&\n00647|       github.event_name == 'workflow_dispatch' &&\n00648|       github.event.inputs.release_mode == 'instant' &&\n00649|       needs.build.result == 'success'\n00650|     runs-on: ubuntu-latest\n00651|     timeout-minutes: 30\n00652|     outputs:\n00653|       pages_sha: ${{ steps.release_pages_ref.outputs.sha }}\n00654|       pages_version: ${{ steps.release_pages_ref.outputs.version }}\n00655|     env:\n00656|       DOCKERHUB_USERNAME: ${{ vars.DOCKERHUB_USERNAME || secrets.DOCKERHUB_USERNAME }}\n00657|       DOCKERHUB_TOKEN: ${{ secrets.DOCKERHUB_TOKEN }}\n00658|     permissions:\n00659|       contents: write\n00660|       packages: write\n00661|     steps:\n00662|       - uses: actions/checkout@v6\n00663|         with:\n00664|           fetch-depth: 0\n00665|           token: ${{ secrets.GITHUB_TOKEN }}\n00666| \n00667|       - name: Setup Rust\n00668|         uses: dtolnay/rust-toolchain@stable\n00669| \n00670|       - name: Install rust-script\n00671|         run: bash scripts/install-rust-script.sh\n00672| \n00673|       - name: Configure git\n00674|         run: rust-script scripts/git-config.rs\n00675| \n00676|       - name: Collect changelog fragments\n00677|         run: rust-script scripts/collect-changelog.rs\n00678| \n00679| 