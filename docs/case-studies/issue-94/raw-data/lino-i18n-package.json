{
  "name": "lino-i18n",
  "version": "0.0.1",
  "description": "Universal i18n library that stores translations in Links Notation (.lino) instead of JSON.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "lino-i18n": "bin/lino-i18n.js"
  },
  "files": [
    "bin/",
    "src/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./converters": "./src/converters/index.js",
    "./loaders": "./src/loaders.js"
  },
  "scripts": {
    "test": "node --test --test-timeout=30000 tests/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:duplication": "jscpd .",
    "check": "npm run lint && npm run format:check && npm run check:duplication",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "links-notation",
    "lino",
    "localization"
  ],
  "author": "Link Foundation",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/link-foundation/lino-i18n.git"
  },
  "homepage": "https://github.com/link-foundation/lino-i18n#readme",
  "bugs": {
    "url": "https://github.com/link-foundation/lino-i18n/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "links-notation": "^0.13.0",
    "lino-arguments": "^0.3.0",
    "lino-objects-codec": "^0.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jscpd": "^4.2.2",
    "prettier": "^3.8.3",
    "test-anywhere": "^0.9.1"
  }
}
