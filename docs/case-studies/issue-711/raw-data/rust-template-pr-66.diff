+"#,
+        )
+        .unwrap();
+        fs::write(changelog_dir.join("README.md"), "Fragment instructions\n").unwrap();
+
+        let changelog = repo.join("CHANGELOG.md");
+        fs::write(
+            &changelog,
+            r#"# Changelog
+
+## [0.1.0] - 2026-01-01
+
+### Added
+- Initial release
+"#,
+        )
+        .unwrap();
+
+        collect_changelog_with_date(
